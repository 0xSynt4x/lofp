;-------------------
IFPREVERB LISTEN -1
  IFVAR ORG = 15
    CLEARVERB
    ECHO PLAYER You hear a faint murmur of greeting here.
    ECHO OTHERS %N smiles as %s listens to the sounds of nature here.
  ENDIF
ENDIF
IFENTRY
    IFVAR ALIGN <= -1
    	ECHO PLAYER The forces of nature align to throw you out of the sacred meadow.
	MOVE 564
	AFFECT 564
	ECHO OTHERS %N arrives.
	AFFECT 13
    ENDIF
ENDIF
