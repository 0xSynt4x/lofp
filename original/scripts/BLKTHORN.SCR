   ENDIF
   IFVAR DUMMY2 = 3
      ECHO PLAYER You gaze far off into the distance...
      ECHO OTHERS %N gazes far off into the distance.
      EQUAL ROUNDTIME 2
      SHOWROOM 1202
      ; Silent Shade
      AFFECT 1202
      ECHO ALL The sensation of being watched becomes almost tangible for a moment.
      AFFECT 1207
   ENDIF
   IFVAR DUMMY2 = 4
      ECHO PLAYER You gaze far off into the distance...
      ECHO OTHERS %N gazes far off into the distance.
      EQUAL ROUNDTIME 2
      SHOWROOM 1203
      ; Barrow Downs
      AFFECT 1203
      ECHO ALL The sensation of being watched becomes almost tangible for a moment.
      AFFECT 1207
   ENDIF
   IFVAR DUMMY2 = 5
      ECHO PLAYER You gaze far off into the distance...
      ECHO OTHERS %N gazes far off into the distance.
      EQUAL ROUNDTIME 2
      SHOWROOM 1204
      ; Deadly Vines
      AFFECT 1204
      ECHO ALL The sensation of being watched becomes almost tangible for a moment.
      AFFECT 1207
   ENDIF
   IFVAR DUMMY2 = 6
      ECHO PLAYER You gaze far off into the distance...
      ECHO OTHERS %N gazes far off into the distance.
      EQUAL ROUNDTIME 2
      SHOWROOM 1209
      ; Tule Fog
      AFFECT 1209
      ECHO ALL The sensation of being watched becomes almost tangible for a moment.
      AFFECT 1207
