   IFVAR WEALTH < 5000
      CLEARVERB
      ECHO PLAYER Korrvuz clacks his beak at you and squawks, "Not enough coins!"
      ECHO OTHERS Korrvuz clacks his beak at %N and squawks, "Not enough coins to use cauldron!"
   ENDIF
   IFVAR WEALTH > 4999
      SUB WEALTH 5000
      ECHO PLAYER The mysterious liquid churns and bubbles after you put %a in it.
