INUMBER 1127
NAME 695
ARTICLE a
MISC
WEIGHT 1000
SUBSTANCE INDESTRUCTABLE
VOLUME 9
CONTAINER ON
INTERIOR 10
HIDDEN
;
;

;

INUMBER 681
NAME 18
WEIGHT 20
VOLUME 10
SLASH_WEAPON
PARAMETER1 15

IFVERB LOOK -1
	IFVAR INTNUM3 = 1
		ECHO PLAYER Hey! This is a special battleaxe. Do not use!
	ENDIF
ENDIF

IFPREVERB SELL -1
	CLEARVERB
	ECHO PLAYER The battleaxe doesn't seem to want to be sold.
ENDIF

IFVAR AXEMOVE = 0
	RANDOM AXEMOVE 1 30 500
ENDIF

IFITEM -1 WIELDED
	IFVERB CONCENTRATE -1
		IFVAR TIM ! ITEMVAL1
			ECHO ALL The battleaxe glows softly for a moment.
			EQUAL FLAG3 33
			EQUAL ITEMVAL1 TIM
			ECHO PLAYER Aircleaver seems to twist in your grasp, seeking release.
		ENDIF
	ENDIF
	IFPREVERB TURN -1
		IFVAR FLAG3 = 33
			CLEARVERB
			ECHO ALL %A seems to dance with a life of its own, slashing in all directions!
			DAMAGEALL SLASH 20 %N is slashed by the blade!
			EQUAL FLAG3 0
		ENDIF
	ENDIF
	IFPREVERB WIELD -1
		CLEARVERB
		IFVAR FLAG3 = 33
			IFVAR REGION = 0
				IFVAR TERRAIN < 10
					ECHO PLAYER You swing Aircleaver through the air, opening a gate which you step through!
					ECHO OTHERS %N swings %a through the air, slicing a gate in the air!
					ECHO OTHGROUP %P steps through the gate, which closes.
					MOVEGROUP AXEMOVE
					AFFECT AXEMOVE
					ECHO OTHGROUP %P steps out of nothingness!
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDIF

IFPREVERB PUSH -1
		CLEARVERB
		ECHO ALL %A screams in limitless rage!
ENDIF

IFPREVERB WAVE -1
	CLEARVERB
	ECHO OTHERS %N waves %a, which screams!
	ECHO PLAYER You wave Aircleaver, which screams!
ENDIF

