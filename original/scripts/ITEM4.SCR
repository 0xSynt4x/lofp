;Pizza
INUMBER 1123
NAME 691
FOOD
PARAMETER1 6
WEIGHT 1
VOLUME 3
ARTICLE A
IFPREVERB EAT -1
   CLEARVERB
   SUB ITEMVAL2 1
   IFVAR ITEMVAL2 = 5
      ECHO PLAYER You sink your teeth into the hot slice of pizza, tasting the cheeses and herbs
      ECHO PLAYER with satisfaction.
      ECHO OTHERS You see %N get a satisfied look on %h face as %s bites into the slice of pizza.
   ENDIF
   IFVAR ITEMVAL2 = 4
      ECHO PLAYER You take another bite, stretching the cheese out as you pull the slice away
      ECHO PLAYER from your mouth.
      ECHO OTHERS You see %N take another bite of the pizza, stretching the cheese out as %s pulls it away from %h mouth.
   ENDIF
   IFVAR ITEMVAL2 = 3
      ECHO PLAYER You notice that your slice of pizza is halfway gone as you take another bite.
      ECHO OTHERS %N sure seems to be enjoying the slice of pizza.
   ENDIF
   IFVAR ITEMVAL2 = 2
      ECHO PLAYER You close your eyes as you savor the last few bites of crust, tomato sauce,
      ECHO PLAYER cheese and spices.
      ECHO OTHERS You see %N closing %h eyes as the pizza rapidly vanishes into %h mouth.
   ENDIF
   IFVAR ITEMVAL2 = 1
      ECHO PLAYER You notice with disappointment that the pizza is almost gone.
      ECHO OTHERS %N is almost finished with the slice of pizza.
   ENDIF
   IFVAR ITEMVAL2 = 0
      ECHO PLAYER You gobble down the crust and wipe the sauce off your face!
      ECHO OTHERS You see %N gobbling the last of the pizza and daintily wiping %h face.
      REMOVEITEM -1
   ENDIF
ENDIF
;
;
;bubblegum
INUMBER 1124
NAME 689
WEIGHT 1
VOLUME 1
FOOD
SUBSTANCE cloth
ARTICLE some
IFPREVERB eat -1
      CLEARVERB
   IFVAR ITEMVAL2 ! 1
      ADD ITEMVAL1 1
      IFVAR ITEMVAL1 = 1
         ECHO PLAYER A burst of fruity juices barrage your mouth as you begin chewing on the
         ECHO PLAYER bubblegum.
         ECHO OTHERS %n pops a piece of bubblegum into %h mouth and starts to chew like a horse.
      ENDIF
      IFVAR ITEMVAL1 = 2
         ECHO PLAYER You stick out your tongue, carefully balancing the bubblegum on the tip.
         ECHO OTHERS %n sticks out %h tongue with the bubblegum carefully balanced on its tip.
      ENDIF
      IFVAR ITEMVAL1 = 3
         ECHO PLAYER You concentrate intently on blowing the largest bubble you can, but it blows
         ECHO PLAYER up in your face!
         ECHO OTHERS You watch with glee as a bubblegum bubble explodes in %n's face!
         APPEAR %H face is covered with sticky bubblegum!
      ENDIF
      IFVAR ITEMVAL1 = 4
         ECHO PLAYER The bubblegum begins to lose its flavor as you continue chewing it.
         ECHO OTHERS A sour look passes over %n's face.
      ENDIF
      IFVAR ITEMVAL1 = 5
         ECHO PLAYER BLECH! You spit the tasteless wad of bubblegum out of your mouth.
         ECHO OTHERS %n spits out the gum, leaving a disgusting mess on the floor!
         REMOVEITEM -1
      ENDIF
   ENDIF
   IFVAR ITEMVAL2 = 1
      ECHO PLAYER The bubblegum is stuck in your hair!
   ENDIF
ENDIF

IFPREVERB wear -1
   ECHO PLAYER You work the bubblegum into a gooey mess and smear it into your hair.
   ECHO OTHERS %n works the gum into a gooey mess and smears it into %h hair! How disgusting!
   APPEAR %S has bubblegum stuck in %h hair!
   EQUAL ITEMVAL2 1
   CLEARVERB
ENDIF

IFPREVERB REMOVE -1
   CLEARVERB
   IFVAR ITEMVAL2 ! 1
      ECHO PLAYER Remove it from what?
   ENDIF
   IFVAR ITEMVAL2 = 1
      ECHO PLAYER You pull and pull on the bubblegum, trying to remove it from your hair. It
      ECHO PLAYER finally comes loose, taking a few hundred strands of hair with it. You pop it
      ECHO PLAYER back into your mouth.
      ECHO OTHERS %N pulls and pulls on the bubblegum, trying to remove it from %h hair. It finally comes loose, taking a few hundred strands of hair with it. %S pops it back into %h mouth!
      EQUAL ITEMVAL2 0
      APPEAR xxx
   ENDIF
ENDIF

IFPREVERB pull -1
   IFVAR ITEMVAL2 = 1
      ECHO PLAYER The bubblegum is still stuck in your hair!
   ENDIF
   IFVAR ITEMVAL2 ! 1
      ECHO PLAYER You stretch the bubblegum out from your mouth. When you release it, it snaps back, slapping you in the face!
      ECHO OTHERS %n stretches the bubblegum out from %h mouth. When %s releases it, it snaps back, slapping %i in the face!
      CLEARVERB
   ENDIF
ENDIF

IFPREVERB PUSH -1
   CLEARVERB
   IFVAR ITEMVAL2 = 1
      ECHO PLAYER The bubblegum is still stuck in your hair!
   ENDIF

   IFVAR ROUNDTIME > 0
      STRCVT 0 ROUNDTIME
      ECHO PLAYER [wait %0 seconds...]
   ENDIF
   IFVAR ROUNDTIME = 0
      IFVAR ITEMVAL2 ! 1
         EQUAL ROUNDTIME 8
         ECHO PLAYER You begin blowing a bubble with your bubblegum...
         ECHO OTHERS %N begins blowing a bubble with %h bubblegum...
         PLREVENT 1
         CONTPLREVENT
         ECHO PLAYER Your bubble grows larger and larger...
         ECHO OTHERS %N's bubble grows larger and larger...
         PLREVENT 1
         CONTPLREVENT
         ECHO PLAYER Just as you begin running out of breath...
         ECHO OTHERS Just as %N begins running out of breath...
         PLREVENT 1
         CONTPLREVENT
         ECHO ALL SPLAT!!
      ENDIF
   ENDIF
ENDIF
