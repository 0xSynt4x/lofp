; high-powerd rifle

INUMBER 33
NAME 166
WEIGHT 6
VOLUME 10
PARAMETER1 100
PARAMETER2 1065
BOW_WEAPON
WIELDABLE
SUBSTANCE HARDMETAL

IFPREVERB LOAD -1
  IFVAR ITEMBIT0 = 1
    IFVAR ITEMVAL5 = 1
      CLEARVERB
      ECHO PLAYER The rifle is loaded.
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You must pull back the bolt to load the rifle.
  ENDIF
ENDIF

IFVERB LOAD -1
  IFVAR ITEMVAL3 = 1
    IFVAR ITEMVAL5 = 0
      EQUAL ITEMVAL3 0
      EQUAL ITEMVAL5 1
    ENDIF
  ENDIF
ENDIF


IFPREVERB PULL -1
  IFVAR ITEMBIT0 = 0
    CLEARVERB
    EQUAL ROUNDTIME 10
    EQUAL ITEMVAL3 0
    EQUAL ITEMVAL5 0
    ECHO PLAYER You pull back the bolt of the rifle, and then down, opening the breech.
    ECHO OTHERS %n pulls back a metal bolt along the top of %a..
    ECHO ALL %cYou hear a sharp "clunk".
    EQUAL ITEMBIT0 1
    EQUAL ITEMVAL2 1
  ELSE
    CLEARVERB
    ECHO PLAYER The bolt is already pulled back.
  ENDIF
ENDIF

IFPREVERB PUSH -1
  IFVAR ITEMBIT0 = 1
    IFVAR ITEMVAL5 = 1
      CLEARVERB
      EQUAL ROUNDTIME 5
      EQUAL ITEMVAL3 1
      EQUAL ITEMVAL5 0
      ECHO PLAYER You push the bolt forward and lock it into place.
      ECHO OTHERS %n pushes the bolt into place along the top of %a.
      ECHO ALL %cYou hear a sharp "clunk".
      EQUAL ITEMBIT0 0
    ELSE
      CLEARVERB
      ECHO PLAYER You push the bolt forward and lock it into place.
      ECHO OTHERS %n pushes the bolt into place along the top of %a.
      ECHO ALL %cYou hear a sharp "clunk".
      EQUAL ITEMBIT0 0
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER The bolt is already locked into place.
  ENDIF
ENDIF

IFPREVERB GAZE -1
  IFVAR ITEMBIT0 = 0
    IFVAR ITEMVAL3 = 1
      IFVAR OUTDOOR = 0
        IFVAR DAY = 1
          CLEARVERB
          EQUAL ITEMVAL2 100
          ECHO PLAYER You look through the high-powered scope and center your target in the crosshairs.
          ECHO OTHERS You see a brief flash of light, as if sun of a piece of glass.
        ELSE
          CLEARVERB
          EQUAL ITEMVAL2 100
          ECHO PLAYER You look through the nightfinder scope and center your target in the crosshairs.
          ECHO OTHERS You catch a brief glimpse of an eery green illumination in the dark.
        ENDIF
      ELSE
        CLEARVERB
        EQUAL ITEMVAL2 100
        ECHO PLAYER You activate the laser targeting beam and line the little red dot on your target.
        ECHO OTHERS You catch a brief glimpse of a small red light and then it is gone.
      ENDIF
    ENDIF
  ENDIF
ENDIF


