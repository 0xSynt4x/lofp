;daisy
INUMBER 1044
NAME 745
MISC
WEIGHT 1
VOLUME 1
SUBSTANCE PAPER

IFVAR ITEMVAL2 = 0
   RANDOM ITEMVAL2 1 4 4
ENDIF

IFPREVERB SMELL -1
   CLEARVERB
   ECHO PLAYER You're reminded of summer as you sniff the daisy.
   ECHO OTHERS %N sniffs a daisy.
ENDIF

IFPREVERB RECALL -1
   CLEARVERB
   ECHO PLAYER You recall a game people play as they pluck the petals from a daisy.
   ECHO OTHERS %N recalls something about a daisy...
ENDIF

IFPREVERB EAT -1
   CLEARVERB
   ECHO PLAYER You stuff the daisy in your mouth.
   ECHO OTHERS %N stuffs a daisy in %h mouth.
   REMOVEITEM -1
ENDIF

IFPREVERB LOOK -1
   CLEARVERB
   ECHO PLAYER The daisy has many long white petals.
   IFVAR INTNUM3 = 1
      STRCVT 0 ITEMVAL2
      ECHO PLAYER $GM-SCRIPT There are %0 petals left.
   ENDIF
ENDIF

IFPREVERB PULL -1
   IFVAR ITEMVAL2 = 0
      RANDOM ITEMVAL2 1 4 4
   ENDIF
   CLEARVERB
   IFCARRY 1044 -1
      EQUAL ITEMVAL4 GEN
      IFVAR ITEMVAL4 = 0
         EQUAL GEN 1
      ENDIF
      IFVAR ITEMVAL4 = 1
         EQUAL GEN 0
      ENDIF
      IFVAR ITEMVAL3 = 0
         ECHO PLAYER You pluck a petal from the daisy and say, "%S loves me."
         ECHO OTHERS %N plucks a petal from the daisy and says, "%S loves me."
      ENDIF
      IFVAR ITEMVAL3 = 1
         ECHO PLAYER You pluck a petal from the daisy and say, "%S loves me not."
         ECHO OTHERS %N plucks a petal from the daisy and says, "%S loves me not."
      ENDIF
      EQUAL GEN ITEMVAL4
      EQUAL ITEMVAL5 ITEMVAL3
      IFVAR ITEMVAL5 = 0
         EQUAL ITEMVAL3 1
      ENDIF
      IFVAR ITEMVAL5 = 1
         EQUAL ITEMVAL3 0
      ENDIF
      SUB ITEMVAL2 1
      IFVAR ITEMVAL2 = 0
         ECHO ALL The daisy crumbles into dust.
         REMOVEITEM -1
      ENDIF
   ELSE
      ECHO PLAYER You must be holding the daisy.
   ENDIF
ENDIF

IFPREVERB PUSH -1
   IFVAR ITEMVAL2 = 0
      RANDOM ITEMVAL2 1 4 4
   ENDIF
   CLEARVERB
   IFCARRY 1044 -1
      IFVAR ITEMVAL3 = 0
         ECHO PLAYER You pluck a petal from the daisy and say, "%S loves me."
         ECHO OTHERS %N plucks a petal from the daisy and says, "%S loves me."
      ENDIF
      IFVAR ITEMVAL3 = 1
         ECHO PLAYER You pluck a petal from the daisy and say, "%S loves me not."
         ECHO OTHERS %N plucks a petal from the daisy and says, "%S loves me not."
      ENDIF
      EQUAL ITEMVAL5 ITEMVAL3
      IFVAR ITEMVAL5 = 0
         EQUAL ITEMVAL3 1
      ENDIF
      IFVAR ITEMVAL5 = 1
         EQUAL ITEMVAL3 0
      ENDIF
      SUB ITEMVAL2 1
      IFVAR ITEMVAL2 = 0
         ECHO ALL The daisy crumbles into dust.
         REMOVEITEM -1
      ENDIF
      EQUAL ITEMVAL5 0
   ELSE
      ECHO PLAYER You must be holding the daisy.
   ENDIF
ENDIF
