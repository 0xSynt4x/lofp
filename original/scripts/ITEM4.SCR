;
; These routines set up a RoomX routine which do some
; sophisticated stuff.
;
  IFPREVERB CAST -1
    IFVAR SPELLNUM = 412
      CLEARVERB
      ECHO PLAYER You gesture at %a.
      ECHO OTHERS %N gestures at %a.
      EQUAL ITEMVAL5 1
    ENDIF
    IFVAR SPELLNUM = 533
      IFVAR ITEMVAL5 = 1
        CLEARVERB
        ECHO PLAYER You gesture at %a.
        ECHO OTHERS %N gestures at %a.
        ECHO ALL It crumbles into dust.
        EQUAL CHASRITROOM RNUM
        EQUAL CHASRITPLAYER PLAYERNUM
        EQUAL BODYPOINTS 1
        EQUAL MANAPOINTS -10
        ECHO OTHERS %N doubles over in pain.
      ENDIF
    ENDIF
  ENDIF
