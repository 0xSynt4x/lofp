; CHARM
INUMBER 1096
NAME 1021
MISC
WEIGHT 1
VOLUME 1
SUBSTANCE HARDMETAL
IFPREVERB LOOK -1
  IFVAR ITEMVAL1 = 1
    clearverb
    IFVAR ITEMVAL3 = 1
      IFVAR ITEMVAL5 = 1
        ECHO PLAYER You look at the shimmering charm. Suddenly, you boil away into mist.
        ECHO OTHERS %N boils away into mist.
        SPELL 232 30
        REMOVEITEM -1
      ELSE
        ECHO PLAYER The charm shimmers a bit. You'll need to look at it again for it to activate.
        EQUAL ITEMVAL5 1
      ENDIF
    ENDIF
  ENDIF
ENDIF
