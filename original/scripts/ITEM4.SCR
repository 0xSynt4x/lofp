VARIABLE PATINJECT1
VARIABLE PATINJECT2
;
;INJECTOR
INUMBER 721
NAME 807
WEIGHT 2
VOLUME 2
FLIPABLE
SUBSTANCE INDESTRUCTABLE
PARAMETER1 10
TURNABLE
IFVERB LOOK -1
        IFVAR INTNUM3 = 1
        ECHO PLAYER Hi Ho. Unique item made by Gradrak. Uses global variables. Do not use please.
        ENDIF
ENDIF
IFPREVERB PUSH -1
        CLEARVERB
        ECHO PLAYER The light on top of the injector turns white.
        ECHO OTHERS %N fiddles with %h injector. The light on top of it turns white.
        ECHO ALL :::HEALTH INCREASE SETTING CONFIRMED:::
        EQUAL PATINJECT2 1
ENDIF
IFPREVERB PULL -1
        CLEARVERB
        ECHO PLAYER The light on top of the injector turns green.
        ECHO OTHERS %N fiddles with %h injector. The light on top of it turns green.
        ECHO ALL :::METABOLIC HYPERBOOST CONFIRMED:::
        EQUAL PATINJECT2 2
ENDIF
IFPREVERB TURN -1
        CLEARVERB
        ECHO PLAYER The light on top of the injector turns violet.
        ECHO OTHERS %N fiddles with %h injector. The light on top of it turns violet.
        ECHO ALL :::ANTI-CONTAGION CONFIRMED:::
        EQUAL PATINJECT2 3
ENDIF
IFPREVERB FLIP -1
        CLEARVERB
        ECHO PLAYER The light on top of the injector turns blue.
        ECHO OTHERS %N fiddles with %h injector. The light on top of it turns blue.
        ECHO ALL :::ANTI-TOXICITY CONFIRMED:::
        EQUAL PATINJECT2 4
ENDIF
IFPREVERB USE -1
        CLEARVERB
        IFVAR PATINJECT1 => 100
        ECHO PLAYER The injector is empty.
        ELSE
        IFVAR RAC > 6
        ECHO PLAYER Your race lacks the needed circulatory system to use the injector.
        ELSE
        ECHO PLAYER You push the injector up to a familiar part of your neck.
        ECHO PLAYER You feel a slight needle prick.
        ECHO OTHERS %N stiffens slightly as %h presses the injector against %h neck.
        EQUAL ROUNDTIME 6
        IFVAR PATINJECT2 = 1
                ADD PATINJECT1 2
        ENDIF
        IFVAR PATINJECT2 = 2
                ADD PATINJECT1 5
        ENDIF
        IFVAR PATINJECT2 = 3
                ADD PATINJECT1 1
        ENDIF
        IFVAR PATINJECT2 = 4
                ADD PATINJECT1 1
        ENDIF
                IFVAR PATINJECT2 = 1
                SPELL 318 50
                ENDIF
                IFVAR PATINJECT2 = 2
                SPELL 210 50
                ENDIF
                IFVAR PATINJECT2 = 3
                SPELL 319 50
                ENDIF
                IFVAR PATINJECT2 = 4
                SPELL 303 50
                ENDIF
        ENDIF
;
