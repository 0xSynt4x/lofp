; gun, automatic

INUMBER 893
NAME 102
WEIGHT 5
VOLUME 5
BOW_WEAPON
SUBSTANCE HARDMETAL
PARAMETER1 30
PARAMETER2 899

IFPREVERB WIELD -1
  EQUAL ITEMBIT2 0 ; cocked = 1 / not cocked = 0
ENDIF

IFPREVERB LOAD -1
  IFITEM -1 WIELDED
	  IFVAR ITEMVAL3 ! 0
	     CLEARVERB
	     ECHO PLAYER There is already a clip in the gun.
	  ELSE
	    ECHO PLAYER You finger the clip-release.%cA clip falls out and you slap in a new one.%c
	    ECHO OTHERS %n pulls out an empty clip from %a and slaps in a new one.
	    EQUAL ITEMBIT2 0
	  ENDIF
  ENDIF
ENDIF

IFVERB LOAD -1
	IFVAR ITEMVAL3 = 1
		EQUAL ITEMVAL3 30
    ENDIF
ENDIF

IFPREVERB CONCENTRATE -1
  IFVAR ITEMBIT2 = 0
    CLEARVERB
    ECHO OTHERS %n checks the firing pin on %a.
    ECHO PLAYER You notice that the weapon is not cocked.
  ELSE
    CLEARVERB
    ECHO OTHERS %n checks the firing pin on %a.
    ECHO PLAYER You notice the weapon is cocked.
  ENDIF
ENDIF

IFPREVERB LEAN -1
IFITEM -1 WIELDED
  CLEARVERB
  ECHO OTHERS %n levels %a in your direction.
  ECHO PLAYER %n you level out the gun.
ENDIF
ENDIF

IFPREVERB WAVE -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You hold the gun in a firm, one handed grasp, arm extended.
    ECHO OTHERS %n holds the gun holds the gun in a firm, one-handed grasp.
  ENDIF
ENDIF

IFPREVERB READ -1
  CLEARVERB
  EQUAL ITEMBIT2 0
  STRCVT 0 ITEMVAL3
  ECHO PLAYER You pull out the clip and see that there are %0 rounds remaining.
  ECHO PLAYER %cYou slap the clip back in place.
  ECHO OTHERS %n pull a clip out of %a for a moment, then slaps it back in place.
ENDIF

IFPREVERB LOOK -1
  CLEARVERB
  ECHO PLAYER This weapon is medium sized and easily held in one hand. It is rectangular in
  ECHO PLAYER shape with a single hand grip and a large metal clip extruding past the edge
  ECHO PLAYER where your hand would go.
ENDIF


IFPREVERB PULL -1
  IFITEM -1 WIELDED
    IFVAR ITEMBIT2 = 1
        SUB ITEMVAL3 1
        IFVAR ITEMVAL3 > 0
          CLEARVERB
          ECHO PLAYER %cYou cock the gun.
          ECHO OTHERS %n moves something along the top of %a.
          ECHO ALL You hear a double click and an unspent round flies from the breech as a new one is chambered.
        ELSE
          CLEARVERB
          ECHO PLAYER %cYou cock the gun.%cThe gun is empty.
          ECHO OTHERS %n moves something along the top of %a.
          ECHO ALL You hear a single click and the breech remains open indicating that all the rounds are spent.
          EQUAL ITEMVAL3 0
        ENDIF
    ELSE
      CLEARVERB
      ECHO PLAYER %cYou cock the gun.
      ECHO OTHERS %n moves something along the top of %a.
      ECHO ALL You hear a double click as a round is chambered.
      EQUAL ITEMBIT2 1
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You need to wield it first.
  ENDIF
ENDIF


