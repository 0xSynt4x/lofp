EXIT U 1458
ITEM 0 66 VAL1=200 VAL2=1460 CLOSED
IFVERB OPEN 0
	ECHO OTHERS %N tries to open the door.
	ECHO ALL A maniacal voice giggles, "The price to open it is 1000 shards. Pay up!"
ENDIF
IFPREVERB PAY -1
	IFVAR WEALTH4 < 1000
		ECHO OTHERS %N tries to pay the toll.
		ECHO ALL The voice giggles, "You don't have the money!  Hee hee!"
	ELSE
		ECHO OTHERS %N pays the toll.
		ECHO PLAYER You pay the toll.
		ECHO ALL The voice giggles, "Thank you!"
		ECHO PLAYER The money magically vanishes.
		SUB WEALTH4 1000
		ECHO ALL The cell door swings open.
		OPEN 0
		AFFECT 1460
		ECHO OTHERS The cell door swings open!
		OPEN 0
	ENDIF
	CLEARVERB
ENDIF
IFPREVERB GO 0
	IFITEM 0 OPEN
		ECHO PLAYER The door swings shut behind you!
		AFFECT 1459
		ECHO OTHERS %N goes through the cell door.%cThe door swings shut behind %n!
		CLOSE 0
		MOVE 1460
		AFFECT 1460
		ECHO OTHERS %N arrives through the cell door. The cell door slams shut!
		CLOSE 0
	ELSE
		ECHO PLAYER The door is closed.
	ENDIF
	CLEARVERB
ENDIF
