NUMBER 1176
NAME Sublevel 2, doorway
*DESCRIPTION_START
A huge steel door reinforced with welded plates blocks the entire passageway
to the south. Rectangular plastic panels set into the ceiling provide
uniform, diffuse illumination throughout the room. The corridor extends
to the north from here.
*DESCRIPTION_END
FIXED_LIGHT
INDOOR_FLOOR
MONSTER_GROUP 36
EXIT N 1183
;
; script for four-button lock
; item 1 is a latchable steel door
item 1 944 ADJ1=189 ADJ2=310 VAL2=1175 CLOSED LATCHED
*DESCRIPTION_START ITEM EXAM 1
A solid latch of bar steel is firmly bolted to the door, securing it
against unwarrented entry. Four buttons, colored gray, black, ochre, and
white, are recessed into the door's frame.
*DESCRIPTION_END
; items 2-5 are buttons to control the lock;
; grey button
item 2 247 ADJ1=150
; black button
item 3 247 ADJ1=25
; white button
item 4 247 ADJ1=347
; ochre button
item 5 247 ADJ1=219
;
; The variable mall_lock controls the status of the lock. When
; the first player enters the room, the variable is set to 0. When
; the correct sequence of buttons is bussed, then the variable progresses
; through its values 1,2,3, and 4. When the lock has been successfully operated,
; the value of mall_lock is 5, and the door can be unlatched and opened
; normally. Otherwise, any attempt to unlatch the door will result in an
; unpleasant shock for the player who was foolish enough to try.
;
; The correct sequence for this lock, by item #, is 3,5,4,3,2
;
variable mall_lock
;
ifpreverb unlatch 1
   ifvar mall_lock ! 5
      echo player As you reach for the door latch, a bolt of electricity arcs\
out from the door directly to your fingertips.
      echo others As %n reaches for the door latch, a bolt of electricity\
arcs out from the door directly to %h fingertips.
      damageplr electric 40 A potent electric charge courses through your body!
      echo others %n collapses to the ground an a heap.
      echo player You collapse to the ground as your strength leaves you.
      position lay
      clearverb
      equal mall_lock 0
   endif
endif
;
;
ifpreverb pick 1
   echo player You don't see any opening in the door to pick.
   clearverb
endif
;
ifverb close 1
   echo all You hear a mechanical click inside the door as the lock resets.
   equal mall_lock 0
endif
;
ifentry
  ifvar PLRSINROOM < 2
     equal mall_lock 0
  endif
endif
;
;
ifverb push 2
  ifvar mall_lock = 4
     echo all A solid mechanical thunk sounds from deep within the door.
     equal mall_lock 5
  else
     equal mall_lock 0
  endif
endif
;
ifverb push 3
  ifvar mall_lock = 0
     equal mall_lock 1
  else
    ifvar mall_lock = 3
       equal mall_lock 4
    else
       equal mall_lock 0
    endif
  endif
endif
;
ifverb push 4
   ifvar mall_lock = 2
      equal mall_lock 3
   else
      equal mall_lock 0
   endif
endif
;
ifverb push 5
   ifvar mall_lock = 1
      equal mall_lock 2
   else
      equal mall_lock 0
   endif
endif
;
;
