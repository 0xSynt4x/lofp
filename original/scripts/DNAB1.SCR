; Cloak
INUMBER 252
NAME 52
ARMOR
WORN_BACK
VOLUME 8
CRAFTABLE
WEIGHT 5
SUBSTANCE CLOTH
PARAMETER2 4
CONTAINER UNDER
IFVAR ITEMADJ2 = 825
        IFVAR ITEMVAL5 = 0
                SETITEMVAL -1 2 2
        ENDIF
ENDIF
INTERIOR 7
IFPREVERB WAVE -1
          IFITEM -1 WORN
                 CLEARVERB
                 ECHO PLAYER You ruffle the cloak.
                 ECHO OTHERS %N ruffles %a.
          ENDIF
ENDIF
IFPREVERB PULL -1
          IFITEM -1 WORN
                 CLEARVERB
                 ECHO PLAYER You pull your cloak more tightly about your body.
                 ECHO OTHERS %N pulls %a more tightly around %h body.
          ENDIF
ENDIF
IFPREVERB TURN -1
          IFITEM -1 WORN
                 CLEARVERB
                 ECHO PLAYER You turn around, your cloak swirling dramatically.
                 ECHO OTHERS %N turns around, %a flaring behind %i as %s does.
          ENDIF
ENDIF
IFPREVERB RUB -1
          IFITEM -1 WORN
                 CLEARVERB
                 ECHO PLAYER You rummage around underneath your cloak.
                 ECHO OTHERS %N rummages around under %a, looking for something.
                 IFITEM -1 CLOSED
                        OPEN -1
                 ENDIF
          ENDIF
ENDIF
IFVAR ITEMVAL5 = 666
        IFPREVERB WEAR -1
                TEMPNAME Spaedron
                ECHO PLAYER You feel the phantasmal mantle of Spaedron the Sorcerer descend upon you... but for how long?
        ENDIF
ENDIF
IFVAR ITEMVAL5 = 777
        IFPREVERB PULL -1
                CLEARVERB
                ECHO PLAYER ** You are now, "Marktos".
                TEMPNAME Marktos
        ENDIF
        IFPREVERB PUSH -1
                CLEARVERB
                ECHO PLAYER ** You are now, "Derlon".
                TEMPNAME Derlon
        ENDIF
        IFPREVERB TURN -1
                CLEARVERB
                ECHO PLAYER ** You are now, "Freddo".
                TEMPNAME Freddo
        ENDIF
        IFPREVERB TAP -1
                CLEARVERB
                ECHO PLAYER ** You are now, "Argo".
                TEMPNAME Argo
        ENDIF
ENDIF
