INUMBER 991
NAME 474
WORN_DON
IFPREVERB KISS -1
        CLEARVERB
        ECHO PLAYER You touch your lips to the spider, which twitches slightly.
        ECHO OTHERS %N kisses %a lightly.
        RANDOM DUMMY1 1 1000 0
        EQUAL INTNUM60 DUMMY1
        EQUAL ITEMVAL1 DUMMY1
ENDIF
IFPREVERB LOOK -1
        CLEARVERB
        ECHO PLAYER The spider is carved from gemstone material, perfect in every detail.
ENDIF
IFTOUCH -1
        IFVAR ITEMVAL1 ! INTNUM60
                IFVAR RAC < 7
                        IFVAR FLAG1 ! 111
                                EQUAL FLAG1 111
                                PLREVENT 1
                                CONTPLREVENT
                                GMMSG %N was just poisoned by the spider item. HAHAHAHAHA.
                                DAMAGEPLR POISON 30 You feel a little odd.
                                IFVAR UNDEAD = 1
                                        ECHO PLAYER Despite your undead nature, you seem to have been poisoned somehow!
                                ENDIF
                        ENDIF
                ENDIF
        ENDIF
ENDIF
WEIGHT 1
VOLUME 1

