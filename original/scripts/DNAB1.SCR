;
;
VARIABLE DANCRUMBS
;
; crumbs
INUMBER 1524
NAME 1222
WEIGHT 1
VOLUME 1
ARTICLE SOME
PLURAL
FOOD
HIDDEN
IFVAR ITEMVAL1 = 666
        IFPREVERB LOOK -1
                ECHO PLAYER The crumbs seem limitless in number, somehow. You think you might recall something about them...
                CLEARVERB
        ENDIF
        IFVERB RECALL -1
                ECHO PLAYER You think that you need merely sift out the white bread crumbs from the brown bread crumbs by slapping your hands against them.
        ENDIF
        IFPREVERB SLAP -1
                ECHO PLAYER You slap your hands together with the crumbs in them, sifting out the white bread crumbs, leaving the stale ones behind.
                CLEARVERB
                ADD DANCRUMBS 1
                IFVAR DANCRUMBS < 11
                        NEWITEM -1 1524 ADJ1=347 ADJ2=1029 VAL2=10
                ENDIF
                IFVAR DANCRUMBS > 10
                        ECHO PLAYER That seems to be all the fresh crumbs you can produce today.
                ENDIF
        ENDIF
        IFPREVERB EAT -1
                CLEARVERB
                ECHO PLAYER There are mostly hard, stale crumbs. Perhaps if you knew of a way to sort out the white, fresh crumbs.
        ENDIF
ENDIF

