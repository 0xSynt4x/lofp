IFPREVERB STOMP -1
   IFVAR INTNUM3 = 1
      ECHO PLAYER SET KMKINTNUM3 1 to activate reports of player INTNUM3's on entering room.
      STRCVT 0 KMKTELEPORT
      IFVAR KMKSILENT ! 1
         ECHO PLAYER KMKTELEPORT location set to room #%0 and is in visual mode.
      ELSE
         ECHO PLAYER KMKTELEPORT location set to room #%0 and is in silent mode.
      ENDIF
   ENDIF
   IFCARRY 136 643
      GENMON 78
