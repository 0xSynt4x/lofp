; Garnet Setting
ITEM 2 1678 ADJ3=139
; Pearl/Opal Setting
ITEM 3 1678 ADJ3=230
; Emerald Setting
ITEM 4 1678 ADJ3=111
; Ruby Setting
ITEM 5 1678 ADJ3=269
; Sapphire Setting
ITEM 6 1678 ADJ3=275
; Moonstone Setting
ITEM 7 1678 ADJ3=200
; Phase Diamond Setting
ITEM 8 1678 ADJ2=430 ADJ3=93
; Ucantsee
ITEM 9 693
;
IFTOUCH 0
  IFVAR ITEMVAL1 = 0
    ADD FLAG1 1
  ENDIF
ENDIF
IFTOUCH 1
  IFVAR ITEMVAL1 = 0
    ADD FLAG1 2
  ENDIF
ENDIF
IFTOUCH 2
  IFVAR ITEMVAL1 = 0
    ADD FLAG1 4
  ENDIF
ENDIF
IFTOUCH 3
  IFVAR ITEMVAL1 = 0
    ADD FLAG1 8
  ENDIF
ENDIF
IFTOUCH 4
  IFVAR ITEMVAL1 = 0
    ADD FLAG1 16
  ENDIF
ENDIF
IFTOUCH 5
  IFVAR ITEMVAL1 = 0
    ADD FLAG1 32
  ENDIF
ENDIF
IFTOUCH 6
  IFVAR ITEMVAL1 = 0
    ADD FLAG1 64
  ENDIF
ENDIF
IFTOUCH 7
  IFVAR ITEMVAL1 = 0
    ADD FLAG1 128
  ENDIF
ENDIF
IFTOUCH -1
  IFVAR ARCHNUM = 1678
    IFVAR ITEMADJ2 ! 430
      CLEARVERB
      IFVAR ITEMVAL1 = 0
        EQUAL ITEMVAL1 1
        ECHO PLAYER At your touch, the %a setting flickers and lights up.
      ELSE
        ECHO PLAYER You touch the %a setting, but it is already lit.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB LOOK -1
  IFVAR ARCHNUM = 1678
    CLEARVERB
    IFVAR ITEMVAL1 = 1
      ECHO PLAYER The %a is lit up brightly.
    ELSE
      ECHO PLAYER The %a pulsates normally.
    ENDIF
  ENDIF
ENDIF      
IFTOUCH 8
; Reset all items
  SETITEMVAL 0 1 0
  SETITEMVAL 1 1 0
  SETITEMVAL 2 1 0
  SETITEMVAL 3 1 0
  SETITEMVAL 4 1 0
  SETITEMVAL 5 1 0
  SETITEMVAL 6 1 0
  SETITEMVAL 7 1 0
; Perform effect based on selection
  IFVAR FLAG1 = 3
    EQUAL FLAG1 0
    SPELL 520 30
    SPELL 506 30
    SUB MANAPOINTS 4
    SUB PSIPOINTS 4
  ENDIF
  IFVAR FLAG1 = 25
    EQUAL FLAG1 0
    SPELL 245 30
    SPELL 535 30
    SUB MANAPOINTS 31
    SUB PSIPOINTS 31
  ENDIF
  IFVAR FLAG1 = 42
    EQUAL FLAG1 0
    SPELL 235 30
    SPELL 219 30
    SUB MANAPOINTS 29
    SUB PSIPOINTS 29
  ENDIF
  IFVAR FLAG1 = 85
    EQUAL FLAG1 0
    DIV PSIPOINTS 2
    ADD MANAPOINTS PSIPOINTS
    EQUAL PSIPOINTS 0
    RECALC
    ECHO PLAYER You feel lightheaded as your internal energies are altered.
  ENDIF
  IFVAR FLAG1 = 170
    EQUAL FLAG1 0
    DIV MANAPOINTS 2
    ADD PSIPOINTS MANAPOINTS
    EQUAL MANAPOINTS 0
    RECALC
    ECHO PLAYER You feel lightheaded as your internal energies are altered.
  ENDIF
  IFVAR FLAG1 = 255
    EQUAL FLAG1 0
    ECHO PLAYER The air above the pedestal shimmers and an amulet forms before you. You quickly grab it before it can crash to the pedestal surface, though you feel completely drained afterwards.
    NEWITEM -1 941 ADJ1=145 ADJ3=77 VAL2=0
    EQUAL MANAPOINTS 0
    EQUAL PSIPOINTS 0
  ENDIF
  IFVAR FLAG1 ! 0
    ECHO PLAYER You feel your energies drain away but nothing seems to happen.
    EQUAL FLAG1 0
    RANDOM FLAG3 1 50 0
    SUB MANAPOINTS FLAG3
    RANDOM FLAG3 1 50 0
    SUB PSIPOINTS FLAG3
  ELSE
    AFFECT 343
    ECHO ALL You see energies flare about %N.
    AFFECT 2501
  ENDIF
; Damage if stupid enough to have no mana or psi
  IFVAR MANAPOINTS < 0
    ADD BODYPOINTS MANAPOINTS
    ADD FATPOINTS MANAPOINTS
    EQUAL MANAPOINTS 0    
    ECHO PLAYER You double over in pain as you stretch your magical resources beyond their limits.
  ENDIF
  IFVAR PSIPOINTS < 0
    ADD BODYPOINTS PSIPOINTS
    ADD FATPOINTS PSIPOINTS
    EQUAL PSIPOINTS 0    
    ECHO PLAYER You double over in pain as you stretch your psionic resources beyond their limits.
  ENDIF
ENDIF
