        EQUAL ROUNDTIME 15
        ECHO PLAYER [Roundtime: 15 sec]
      ENDIF
      IFVAR INTNUM2 ! DATE
        RANDOM FLAG3 1 5 0
        EQUAL FLAG4 0
      ENDIF
    ENDIF
