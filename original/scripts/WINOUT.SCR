MACRO 4
RANDOM DARK 1 11 0
IFVAR DARK = 1
	ECHO ALL The screech of an owl penetrates the cold night air.
ENDIF
IFVAR DARK = 2
	ECHO ALL Something goes crunch in the ice.
ENDIF
IFVAR DARK = 3
	ECHO ALL Something disturbs the snow at your feet.
ENDIF
IFVAR DARK = 4
	ECHO ALL An icicle falls from a tree and shatters.
ENDIF
IFVAR DARK = 5
	ECHO ALL A small whirlwind of snow alights across your path.
ENDIF
IFVAR DARK = 6
	ECHO ALL You hear the sound of breaking ice in the distance.
ENDIF
IFVAR DARK = 7
	ECHO ALL You briefly see a pair of eyes glowing in the darkness.
ENDIF
IFVAR DARK = 8
	ECHO ALL A raccoon scrambles across your path.
ENDIF
IFVAR DARK = 9
	ECHO ALL You feel a dark presence behind you.
ENDIF
IFVAR DARK = 10
	ECHO ALL A howling wind whips around the leafless trees.
