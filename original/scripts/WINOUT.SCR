	ECHO ALL You notice a dorsal fin glide through the water and then vanish.
ENDIF
IFVAR HAPPENS = 7
	ECHO ALL Ice washes up on the shore.
ENDIF
IFVAR HAPPENS = 9
	ECHO ALL You catch the scent of kelp and seaweed in the breeze.
ENDIF
IFVAR HAPPENS = 10
	ECHO ALL On a nearby rock, a flock of gulls shivers in the wind.
ENDIF
