IFPREVERB TURN 4
  ECHO ALL A small slat in the wall slides open and a pair of deep green eyes look you up and down.
  IFVAR ORG = 13
    CLEARVERB
    PLREVENT 1
    CONTPLREVENT
    ECHO PLAYER Focused on you, the person behind the slat seems to nod.%cA section of the wall slides open, revealing a hole just large enough to squeeze through.
    NEWITEM 5 79 val2=630
    PLREVENT 1
    CONTPLREVENT
    ECHO OTHERS The eyes return to the slat focused on %n and seem to nod.%cA section of the wall slides open, revealling a hole just large enough to squeeze through.
  ELSE
    PLREVENT 1
    CONTPLREVENT
    ECHO ALL The eyes return to the slat and focus on the metal box.%cThe slat slides shut.
  ENDIF
ENDIF

IFPREVERB GO 5
  IFVAR ORG ! 13
    CLEARVERB
    ECHO ALL The hole snaps shut before you can enter.%cYou hear a voice behind the wall bellow "Traitor!"
    REMOVEITEM 5
    AFFECT 630
    ECHO ALL You hear the guard shout, "Traitor!"
  ELSE
    MOVE 630
    ECHO PLAYER You slip through the hole and it immediately shuts behind you.
    ECHO OTHERS %n slips through the hole and it immediately shuts behind %h. 
    REMOVEITEM 5
    AFFECT 630
    ECHO OTHERS %n arrives through the opening.
  ENDIF
ENDIF                                  

IFPREVERB PULL 6
  CLEARVERB
  ECHO OTHERS When %n tugs lightly on a silk cord tucked away in a dark corner, a fine dust showers from vents above you, coating everyone in the room.
  ECHO PLAYER When you tug lightly on the silken cord, a fine dust falls from vents in the ceiling, coating everyone in the room.
  IFVAR PLRSINROOM = 1
    ECHO ALL You are the only person present.
  ENDIF
    IFVAR PLRSINROOM = 2
      ECHO ALL The fine dust coats two figures.
    ENDIF
      IFVAR PLRSINROOM = 3
        ECHO ALL The fine dust coats three figures.
      ENDIF
        IFVAR PLRSINROOM = 4
          ECHO ALL The fine dust coats four figures.
        ENDIF
