ENDIF
IFPREVERB LEAN -1
  CLEARVERB
  IFVAR EXITB > 0
    IFVAR ITEMVAL3 ! 1
      ECHO PLAYER You aim the telescope downwards and peer through it.
      ECHO OTHERS %n aims the telescope downwards and peers through it.
      SHOWROOM EXITB
    ELSE
      ECHO PLAYER The telescope is collapsed.
    ENDIF
  ELSE
    IFVAR EXITD > 0
      ECHO PLAYER You aim the telescope downwards and peer through it.
      ECHO OTHERS %n aims the telescope downwards and peers through it.
      SHOWROOM EXITD
    ELSE
      ECHO PLAYER You never really looked at your feet this closely before.
      ECHO OTHERS %n aims the telescope downwards and gets a good close-up look of %h feet.
    ENDIF
  ENDIF
ENDIF
IFPREVERB RAISE -1
  CLEARVERB
  IFVAR EXITA > 0
    IFVAR ITEMVAL3 ! 1
      ECHO PLAYER You aim the telescope upwards and peer through it.
      ECHO OTHERS %n aims the telescope upwards and peers through it.
      SHOWROOM EXITA
    ELSE
      ECHO PLAYER The telescope is collapsed.
    ENDIF
  ELSE
    IFVAR EXITU > 0
      ECHO PLAYER You aim the telescope upwards and peer through it.
      ECHO OTHERS %n aims the telescope upwards and peers through it.
      SHOWROOM EXITU
    ELSE
      ECHO PLAYER There is nothing above you to see.
    ENDIF
  ENDIF
ENDIF
