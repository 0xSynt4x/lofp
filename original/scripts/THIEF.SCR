IFPREVERB2 UNLOCK -1
  CLEARVERB
  IFVAR SKILL22 = 0
    ECHO PLAYER You wouldn't know where to start.
  ENDIF
  IFVAR SKILL22 > 0
    IFVAR ITEMVAL5 = 1
      ECHO PLAYER The blank key has already been marked.
    ENDIF
    IFVAR ITEMVAL5 = 0
      IFVAR ARCHNUM >= 65
        IFVAR ARCHNUM <= 66        
          ECHO PLAYER You examine the lock with a studied eye and touch, memorizing every detail of the mechanism.
          ECHO OTHERS %N studies the lock mechanism intently, exploring its innards with a series of slender tools.                                        
          EQUAL ROUNDTIME 15
          EQUAL FLAG3 ITEMVAL1
          EQUAL FLAG4 ITEMVAL3
        ENDIF
      ENDIF        
      IFVAR ARCHNUM = 500
        ECHO PLAYER You examine the lock with a studied eye and touch, memorizing every detail of the mechanism.
        ECHO OTHERS %N studies the lock mechanism intently, exploring its innards with a series of slender tools.                                        
        EQUAL ROUNDTIME 15
        EQUAL FLAG3 ITEMVAL1
        EQUAL FLAG4 ITEMVAL3
      ENDIF
      IFVAR ARCHNUM = 943
        ECHO PLAYER You examine the lock with a studied eye and touch, memorizing every detail of the mechanism.
        ECHO OTHERS %N studies the lock mechanism intently, exploring its innards with a series of slender tools.                                        
        EQUAL ROUNDTIME 15
        EQUAL FLAG3 ITEMVAL1
        EQUAL FLAG4 ITEMVAL3
      ENDIF
      IFVAR ARCHNUM ! 65
        IFVAR ARCHNUM ! 66
          IFVAR ARCHNUM ! 500
            IFVAR ARCHNUM ! 943
              ECHO PLAYER This is not a lockable door.
            ENDIF
          ENDIF
        ENDIF
      ENDIF        
    ENDIF
  ENDIF
ENDIF

IFPREVERB WRITE -1
  CLEARVERB
  IFVAR SKILL22 = 0
    ECHO PLAYER You aren't a locksmith, and have no idea where to begin.
  ENDIF
  IFVAR SKILL22 > 0
    IFVAR ITEMVAL5 = 1
      ECHO PLAYER The blank key has already been marked.
    ELSE
      IFVAR FLAG4 ! 0
        EQUAL DUMMY1 5
        MULT DUMMY1 SKILL22
        EQUAL DUMMY2 PER
        DIV DUMMY2 10
        ADD DUMMY1 DUMMY2
        SUB DUMMY1 FLAG3
        IFVAR DUMMY1 < 0
          EQUAL DUMMY1 0
        ENDIF
        IFVAR DUMMY1 > 94
          EQUAL DUMMY1 95
        ENDIF
        RANDOM DUMMY3 1 100 0
        EQUAL ROUNDTIME 15
        EQUAL ITEMVAL5 1        
        STRCVT 0 DUMMY1
        STRCVT 1 DUMMY3
        STRCVT 2 ROUNDTIME
        IFVAR DUMMY3 <= DUMMY1
          EQUAL ITEMADJ1 925
          EQUAL ITEMVAL3 FLAG4
          ECHO PLAYER [Success: %0%, Roll: %1] Success!%cYou carefully mark the blank key with the information you will need to make a suitable mold!%c [Round: %2 sec]
          ECHO OTHERS %N carefully makes a series of marks on the blank key.
        ELSE
          EQUAL ITEMADJ1 692
          EQUAL ITEMVAL3 -1
          ECHO PLAYER [Success: %0%, Roll: %1] Failure.%cYou have mangled the blank key!%c [Round: %2 sec]
          ECHO OTHERS %N makes a series of marks on the blank key, but doesn't look too happy about the results.
        ENDIF
      ELSE
        ECHO PLAYER You need to study a lock mechanism first.
      ENDIF
    ENDIF                
  ENDIF
ENDIF
