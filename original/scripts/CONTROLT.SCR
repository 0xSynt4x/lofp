;
;
; TECH ROUTINES
;
IFVAR SETPLAYERTECH ! 0
  IFVAR PLAYERNUM = SETPLAYERTECH
    IFVAR ADDTECH > 3
      EQUAL ADDTECH 3
    ENDIF
    ADD INTNUM68 ADDTECH
    STRCVT 0 INTNUM68
    GMMSG ** %n's Tech Rating = %0.
    ECHO PLAYER You feel you have gained technological insight.
    EQUAL SETPLAYERTECH 0
  ENDIF
ENDIF


IFVAR TECHZERO ! 0
  IFVAR PLAYERNUM = TECHZERO
    IFVAR ORG ! 7
      EQUAL INTNUM68 0
      STRCVT 0 INTNUM68
      GMMSG ** %n's TECH RATING has been zeroed: %0.
      EQUAL TECHZERO 0
    ELSE
      GMMSG ** %n's a Tech, needs a tech rating.
    ENDIF
  ENDIF
ENDIF

IFVAR RANDOMTECH ! 0
  IFVAR PLAYERNUM = RANDOMTECH
    RANDOM INTNUM68 1 15 0
    STRCVT 0 INTNUM68
    GMMSG ** %N's INTNUM68 randomly set to %0.
    EQUAL RANDOMTECH 0
  ENDIF
ENDIF