ITEM 0 1327 ADJ1=189 ADJ2=1019 VAL2=201 UNLOCKED OPEN ; inner gate
ITEM 1 1327 ADJ1=189 ADJ2=1020 VAL2=501 UNLOCKED OPEN ; outer gate
ITEM 9 693 ADJ1=10
CALL 33
IFSAY Seal_the_outer_gate!
  IFITEM 0 OPEN
    IFITEM 1 CLOSED
      IFITEM 1 UNLOCKED
        IFVAR ORG = 6
          LOCK 1
          ECHO ALL A squad from the Crimson Band comes out with a pair of massive beams and barricades the inner gate.
          AFFECT 501
	  LOCK 0
	  AFFECT 3620
        ENDIF
        IFVAR ORG = 3
          LOCK 1
          ECHO ALL A squad from the Crimson Band comes out with a pair of massive beams and barricades the inner gate.
          AFFECT 501
	  LOCK 0
	  AFFECT 3620
      ENDIF
      ELSE
        ECHO PLAYER The gate is already locked.
      ENDIF
    ELSE
      ECHO PLAYER The gate is not closed yet.
    ENDIF
  ELSE
    ECHO PLAYER The guards can't get through the closed inner gate to seal the outer gate!
  ENDIF
ENDIF
IFSAY Open_the_outer_gate!
  IFITEM 0 OPEN
    IFITEM 1 CLOSED
      IFITEM 1 LOCKED
        IFVAR ORG = 6
          UNLOCK 1
          OPEN 1
          AFFECT 501
	  OPEN 0
          ECHO ALL With a thump, the massive outer gate opens.
          AFFECT 3620
          ECHO ALL A squad from the Crimson Band comes out and removes the two massive beams which barricades the inner gate.
        ENDIF
        IFVAR ORG = 3
          UNLOCK 1
          OPEN 1
          AFFECT 501
	  OPEN 0
          ECHO ALL With a thump, the massive outer gate opens.
          AFFECT 3620
          ECHO ALL A squad from the Crimson Band comes out and removes the two massive beams which barricades the inner gate.
        ENDIF
      ENDIF
    ELSE
      ECHO PLAYER The gate is already open.
    ENDIF
  ELSE
    ECHO PLAYER The guards can't get through the closed inner gate to open the outer gate!
  ENDIF
ENDIF
