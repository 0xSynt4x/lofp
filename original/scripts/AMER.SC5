        	ECHO ALL The drawbridge lowers with a clank of chains.
        	AFFECT 1653
        	ECHO ALL The drawbridge lowers with a clank of chains.
      ENDIF
      IFVAR ORG = 3
        	NEWITEM 6 653 ADJ1=997
        	AFFECT 1652
        	NEWITEM 6 653 ADJ1=997
        	ECHO ALL The drawbridge lowers with a clank of chains.
        	AFFECT 1653
        	ECHO ALL The drawbridge lowers with a clank of chains.
      ENDIF
      IFVAR INTNUM3 = 1
        	NEWITEM 6 653 ADJ1=997
        	AFFECT 1652
        	NEWITEM 6 653 ADJ1=997
        	ECHO ALL The drawbridge lowers with a clank of chains.
        	AFFECT 1653
        	ECHO ALL The drawbridge lowers with a clank of chains.
      ENDIF

   ELSE
      ECHO PLAYER The drawbridge is already down.
   ENDIF
ENDIF
IFSAY Raise_the_bridge!
   IFITEM 6
        IFVAR ORG = 6
        	REMOVEITEM 6
        	AFFECT 1652
        	REMOVEITEM 6
        	ECHO ALL The drawbridge raises with a clank of chains.
        	AFFECT 1653
        	ECHO ALL The drawbridge raises with a clank of chains.
      ENDIF
      IFVAR ORG = 3
        	REMOVEITEM 6
        	AFFECT 1652
        	REMOVEITEM 6
        	ECHO ALL The drawbridge raises with a clank of chains.
        	AFFECT 1653
        	ECHO ALL The drawbridge raises with a clank of chains.
      ENDIF
        IFVAR INTNUM3 = 1
        	REMOVEITEM 6
        	AFFECT 1652
        	REMOVEITEM 6
        	ECHO ALL The drawbridge raises with a clank of chains.
        	AFFECT 1653
        	ECHO ALL The drawbridge raises with a clank of chains.
      ENDIF

   ELSE
      ECHO PLAYER The drawbridge is already up.
   ENDIF
ENDIF
