    ifvar itembit6 = 0
      add dummy1 1
      echo player      an energy emitter
    endif
    ifvar dummy1 = 0
      echo player      <nothing>
    endif
  endif
  ifvar itemval5 = 0
    echo player The workbench lies open and ready to receive a master component to begin the construction process.
  endif
  strcvt 0 dummy1
  echo player %cInstructions:%c        PUT components on the workbench to prepare them.%c        TAP the workbench to lock them in place.%c        PULL the workbench when you have assembled the %0 components missing.
endif
