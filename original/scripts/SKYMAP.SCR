NUMBER 2192
AERIAL
NAME Sky over Inner Sea
*DESCRIPTION_START
The fathomless blue of the Inner Sea goes as far as the horizon in all directions.
*DESCRIPTION_END
DROPLOC 2077
DAY_LIGHT
EXIT N 2184
EXIT S 2192
EXIT E 2193
EXIT W 2191
EXIT NE 2185
EXIT NW 2183
EXIT SE 2192
EXIT SW 2191
ITEM 0 726 VAL2=2483
IFPREVERB GO 0
	DISBAND
	CLEARVERB
	EQUAL ROUNDTIME 30
	ECHO PLAYER You enter the clouds.%c [Round: 30 sec]
	ECHO OTHERS %P enters the clouds.
	MOVE 23
	AFFECT 23
	ECHO OTHERS %N comes through the mist.
ENDIF
;
NUMBER 23
NAME Inner cloud
*DESCRIPTION_START
You are in a huge cloud. Everywhere you look is white, so it hard to get your bearing. You can take a guess as to which way is north or south.
*DESCRIPTION_END
EXIT N 2192
EXIT S 2483
DROPLOC 2077
AERIAL
IFPREVERB NORTH -1
	DISBAND
	RANDOM DUMMY1 1 100 0
	IFVAR DUMMY1 > 75
		CLEARVERB
		ECHO PLAYER You become lost in the mist and exit the cloud in an unexpected place.
		ECHO OTHERS %N flies north.
		MOVE 2483
		AFFECT 2483
		ECHO OTHERS %N flies in.
	ENDIF
ENDIF
IFPREVERB SOUTH -1
	DISBAND
	RANDOM DUMMY1 1 100 0
	IFVAR DUMMY1 > 75
		CLEARVERB
		ECHO PLAYER You become lost in the mist and exit the cloud in an unexpected place.
		ECHO OTHERS %N flies south.
		MOVE 2192
		AFFECT 2192
		ECHO OTHERS %N flies in.
	ENDIF
ENDIF
;
