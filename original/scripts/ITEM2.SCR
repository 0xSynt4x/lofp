;
INUMBER 1568
NAME 1424
WEIGHT 1
VOLUME 1
SUBSTANCE PAPER
THROWN_WEAPON
PARAMETER1 1
*DESCRIPTION_START
It looks like a ball of snow.
*DESCRIPTION_END
IFPREVERB EAT -1
	CLEARVERB
	EQUAL ROUNDTIME 5
	ECHO PLAYER You gobble up %a.%c [Round: 5 sec]
	ECHO OTHERS %N gobbles up %a.
	REMOVEITEM -1
ENDIF
IFPREVERB PUSH -1
	CLEARVERB
	IFVAR FLAG4 ! 0
;		STRCVT 0 ROUNDTIME
;		ECHO PLAYER [Wait %0 seconds...]
		ECHO PLAYER You are already pushing the snowball.
	ENDIF
	IFVAR FLAG4 = 0
		IFVAR WILDERNESS = 1
			ECHO PLAYER Let me see if I understand you... you want to make a snowman indoors?
		ENDIF
		IFVAR WILDERNESS ! 1
			EQUAL ROUNDTIME 6
			EQUAL FLAG4 1
			ADD SNOWSIZE 1
			ECHO OTHERS %N rolls %a around in the snow, making it larger.
			ECHO PLAYER You roll %a around, making it larger.%c [Round: 6 sec]
			IFVAR SNOWSIZE > 1
				SETITEMADJ -1 1 178
			ENDIF
			IFVAR SNOWSIZE > 4
				SETITEMADJ -1 1 163
			ENDIF
			IFVAR SNOWSIZE > 7
				SETITEMADJ -1 1 189
			ENDIF
			IFVAR SNOWSIZE > 10
				SETITEMADJ -1 1 451
			ENDIF
			IFVAR SNOWSIZE > 13
				SETITEMADJ -1 1 717
			ENDIF
			IFVAR SNOWSIZE > 17
				IFITEM 9
					STOP
				ENDIF
				REMOVEITEM -1
				NEWITEM 9 1569
				ECHO PLAYER You shape the gigantic snowball into a snowman!
				ECHO OTHERS %N shapes the gigantic snowball into a snowman!
				EQUAL SNOWSIZE 0
			ENDIF
			PLREVENT 2
			CONTPLREVENT
			EQUAL FLAG4 0
		ENDIF
	ENDIF
ENDIF
IFTOUCH -1
        ifvar itembit1 ! 1
	IFVAR ITEMVAL5 ! TIM
		ECHO ALL %A melts away.
		REMOVEITEM -1
		EQUAL SNOWSIZE 0
	ENDIF
        endif
ENDIF
