PUNCTURE_WEAPON
SUBSTANCE WOOD
IFPREVERB UNWIELD -1
	IFITEM -1 WIELDED
		IFSEEK 933
			STOP
		ENDIF
		RANDOM DUMMY1 1 20 0
		SUB DUMMY1 10
		RANDOM DUMMY2 1 20 0
		SUB DUMMY2 10
		RANDOM DUMMY3 1 20 0
		SUB DUMMY3 10
		EQUAL DUMMY4 0
		ADD DUMMY4 DUMMY1
		ADD DUMMY4 DUMMY2
		ADD DUMMY4 DUMMY3
		EQUAL ITEMVAL2 DUMMY4
	ENDIF
ENDIF
