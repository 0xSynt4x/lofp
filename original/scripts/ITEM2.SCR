		REMOVEITEM -1
	ENDIF
ENDIF
;
;card
INUMBER 1422
NAME 681
MISC
WEIGHT 1
VOLUME 1
SUBSTANCE PAPER
ARTICLE A
IFPREVERB CONCENTRATE -1
  EQUAL DUMMY1 0
	IFVAR ITEMVAL5 > 100
	  EQUAL DUMMY1 ITEMVAL5
	ELSE
  	EQUAL DUMMY1 SKILL14
	ENDIF
	IFVAR DUMMY1 > 39
		IFVAR ITEMVAL1 > 1
	  	CLEARVERB
		  SUB MANAPOINTS 100
      ECHO PLAYER You concentrate on %a.%c The image on the card begins to form out of nothingness.
      ECHO OTHERS %n concentrates on %a.%c The image on the card begins to form out of nothingness.
    	IFVAR ITEMVAL5 >= 1000
    		ECHO PLAYER You will the person depicted on the card to appear.
    		ECHO OTHERS %N concentrates on %a with all %h being.
    		ADD ITEMVAL2 2
    		EQUAL TOMTRANS 9999
    		EQUAL ITEMVAL3 0
  		ENDIF
  		IFVAR INTNUM3 ! 0
	    	IFVAR ITEMVAL3 = INTNUM3
      		ECHO PLAYER You whisper the truename of the card maker.
      		ECHO OTHERS %N whispers the truename of the card maker.
      		ADD ITEMVAL2 2
      		EQUAL TOMTRANS 9999
  		ENDIF
		ENDIF
		EQUAL TOMMOVE ITEMVAL1
		EQUAL TOMMOVEROOM RNUM
		EQUAL TOMMOVEREGION REGION
		IFVAR TERRAIN > 7
			EQUAL TOMMOVEREGION 999
		ENDIF
		EQUAL TOMMOVECAST PLAYERNUM
		EQUAL TOMMOVECOUNT 0
		EQUAL ROUNDTIME 20
			ADD ITEMVAL2 1
			IFVAR ITEMVAL2 > 9
			ECHO ALL %A crumbles to dust.
			REMOVEITEM -1
			ENDIF
		ENDIF
	ENDIF
ENDIF
IFPREVERB CAST -1
	IFVAR SPELLNUM = 408
		IFVAR SKILL14 > 49
  		CLEARVERB
	    ECHO PLAYER You gesture at %a.%c You peer into the card and know the truename of its maker.
  		ECHO OTHERS %N gestures at %a.%c%N studies the card intently and smiles.
	  	EQUAL ITEMVAL3 INTNUM3
		  SUB MANAPOINTS 18
  		EQUAL SPELLNUM 0
  		EQUAL ROUNDTIME 60
		ELSE
  		ECHO PLAYER You gesture at %a.%cYou peer into the card and learn nothing.
  		ECHO OTHERS %N gestures at %a.%c%N stares blankly at %a.
  		EQUAL ROUNDTIME 60
		ENDIF
	ENDIF
	IFVAR SPELLNUM = 246
  	CLEARVERB
  	IFVAR TOMHEAL = 0
    	EQUAL SPELLNUM 0
    	ECHO PLAYER You gesture at %a.%cYou pour your life energy into the aether and collapse.
    	ECHO OTHERS %N  gestures at %a.%c%N seems to grow weaker and falls to the ground.
    	EQUAL TOMHEAL ITEMVAL1
    	EQUAL TOMHEALTIM TIM
    	ADD ITEMVAL2 1
			IFVAR ITEMVAL2 > 9
  			ECHO ALL %A crumbles to dust.
  			REMOVEITEM -1
			ENDIF
    	POSITION LAY
    	EQUAL MANAPOINTS 0
    	EQUAL PSIPOINTS 0
    	EQUAL BODYPOINTS 0
    	EQUAL ROUNDTIME 10
   	ELSE
    	ECHO PLAYER You gesture at %a.%cYou are unable to tap the aether at the moment.
    	ECHO OTHERS %N  gestures at %a.%c%N looks disconcerted.
    	SUB MANAPOINTS 29
    	EQUAL SPELLNUM 0
  	ENDIF
	ENDIF
	IFVAR SPELLNUM = 228
  	CLEARVERB
  	EQUAL DUMMY1 10
  	SUB DUMMY1 ITEMVAL2
  	STRCVT 0 DUMMY1
  	IFVAR DUMMY1 > 1
    	ECHO PLAYER You gesture at %a.%cYou sense %0 charges remain.
    	ECHO OTHERS %N  gestures at %a.
    	SUB MANAPOINTS 7
    	EQUAL SPELLNUM 0
  	ELSE
    	ECHO PLAYER You gesture at %a.%cYou sense %0 charge remains.
    	ECHO OTHERS %N  gestures at %a.
    	SUB MANAPOINTS 7
    	EQUAL SPELLNUM 0
  	ENDIF
	ENDIF
	IFVAR SPELLNUM = 244
  	SUB MANAPOINTS 31
		RANDOM DUMMY1 1 100 0
		IFVAR DUMMY1 < 96
    	CLEARVERB
    	ECHO PLAYER You gesture at %a.%cA card glows brightly for a moment.
    	ECHO OTHERS %N  gestures at %a.%cA card glows brightly for a moment.
    	EQUAL SPELLNUM 0
 			IFVAR ITEMVAL2 > 0
  			SUB ITEMVAL2 1
			ENDIF
		ELSE
    	CLEARVERB
    	ECHO PLAYER You gesture at %a.%cA card shatters!
    	ECHO OTHERS %N  gestures at %a.%cA card shatters!
    	EQUAL SPELLNUM 0
    	REMOVEITEM -1
  	ENDIF
	ENDIF
	IFVAR SPELLNUM = 412
		IFVAR SKILL14 > 39
			IFVAR ITEMVAL5 < 100
    		CLEARVERB
    		EQUAL SPELLNUM 0
        ECHO PLAYER You gesture at %a.%cYou feel the card absorbing your energy as you prepare it for use.
        ECHO OTHERS %N  gestures at %a.%cYou sense %N needs your strength for %h ritual.
       	EQUAL ITEMVAL4 INTNUM3
    		EQUAL ROUNDTIME 60
    		EQUAL TOMZAP TOMXSUM
    		EQUAL TOMZAPROOM RNUM
    		EQUAL TOMZAPEFFECT 4
    		EQUAL TOMCARDVAL 0
    		EQUAL TOMCARDMULT 0
			ELSE
    		CLEARVERB
    		EQUAL SPELLNUM 0
    		ECHO PLAYER You gesture at %a.%cThe card shimmers with luminous energy.
    		ECHO OTHERS %n gestures at %a.%cThe card shimmers with luminous energy.
			ENDIF
		ELSE
  		ECHO PLAYER You realize you lack the skill to properly prepare the card for use.
  		EQUAL SPELLNUM 0
		ENDIF
	ENDIF
ENDIF
IFPREVERB PUSH -1
  CLEARVERB
	IFVAR INTNUM3 > 1
		IFVAR ITEMVAL1 < 2
      ECHO PLAYER You press on %a and your image begins to form on its surface.
      ECHO OTHERS %n presses on %a and %h image begins to form on its surface.
      SPELL 408
      SETITEMVAL -1 1 INTNUM3
      STRCVT 0 INTNUM3
      GMMSG *** %N has imprinted a card with intnum3 = %0.
		ELSE
			IFVAR ITEMVAL1 = INTNUM3
    		ECHO PLAYER You press on %a and it crumbles to dust!
    		ECHO OTHERS %n presses on %a and it crumbles to dust!
    		REMOVEITEM -1
			ELSE
    		ECHO PLAYER You press on %a and fall to the ground.
    		ECHO OTHERS %n presses on %a and falls to the ground.
    		POSITION LAY
    		EQUAL BODYPOINTS 0
			ENDIF
		ENDIF
	ELSE
  	ECHO PLAYER You press on %a and it shatters!
  	ECHO OTHERS %n presses on %a and it shatters!
  	REMOVEITEM -1
	ENDIF
ENDIF
IFPREVERB RECALL -1
	IFVAR SKILL32 > 0
		IFVAR TERRAIN > 7
  		CLEARVERB
	  	ECHO PLAYER You doubt you could complete a summoning ritual here.
		ELSE
		  CLEARVERB
  		ECHO PLAYER You believe you could complete a summoning ritual here.
		ENDIF
	ENDIF
ENDIF
IFPREVERB TAP -1
	IFVAR ITEMVAL4 = 0
	  EQUAL ITEMVAL4 999
	ENDIF
	IFVAR ITEMVAL4 = INTNUM3
		IFVAR TOMCARDVAL > 0
	  	CLEARVERB
		  ECHO PLAYER You channel the energy you have absorbed into the card.
  		ECHO OTHERS %n taps %a and energy pours down %h arm into the card.
	  	MULT TOMCARDVAL TOMCARDMULT
  		STRCVT 0 TOMCARDVAL
	  	GMMSG ***Adding %0 to itemval5 of card.
		  ADD ITEMVAL5 TOMCARDVAL
			IFVAR ITEMADJ1 ! 287
			  IFVAR ITEMVAL5 > 100
    			SETITEMADJ -1 1 287
		      ECHO ALL A card pulses with brilliant white light and begins to shimmer.
      		GMMSG ***%N and others in %h room have completed the card preparation ritual.
      		GMMSG ***They deserve a bit of experience.
			  ENDIF
			ENDIF
  		EQUAL ROUNDTIME 10
		ENDIF
	ELSE
	;taps the card
	ENDIF
  EQUAL TOMCARDVAL 0
  EQUAL TOMCARDMULT 0
ENDIF
