IFVERB LOAD -1
	IFITEM -1 WIELDED
		IFVAR ITEMVAL3 = 1
			EQUAL ITEMVAL3 5
			ECHO PLAYER The blaster's energy readout rises to "full."
		ENDIF
	ENDIF
ENDIF
IFPREVERB READ -1
	CLEARVERB
	IFVAR ITEMVAL3 = 0
		ECHO PLAYER The blaster is uncharged.
	ENDIF
	IFVAR ITEMVAL3 > 0
		IFVAR ITEMVAL3 < 5
			ECHO PLAYER The blaster is partially charged.
		ENDIF
	ENDIF
	IFVAR ITEMVAL3 > 4
		ECHO PLAYER The blaster is fully charged
	ENDIF
ENDIF
;
; Magic Pouch
INUMBER 1758
NAME 835
WEIGHT 1
VOLUME 7
CONTAINER IN
SUBSTANCE INDESTRUCTABLE
OPENABLE
IFPREVERB CLOSE -1
	IFITEM -1 CLOSED
		CLEARVERB
		ECHO PLAYER There is no way to close it. It is already closed.
	ENDIF
ENDIF
IFVERB CLOSE -1
	RANDOM DUMMY1 1 1000 0
	EQUAL ITEMVAL1 DUMMY1
	EQUAL INTNUM10 DUMMY1
	ECHO PLAYER You feel a faint tingling in your fingertips.
	ECHO ALL The pouch seals itself.
ENDIF
IFPREVERB OPEN -1
	IFITEM -1 CLOSED
		IFVAR INTNUM10 = ITEMVAL1
			ECHO PLAYER A seam appears in the pouch as you reach for it.
			ECHO OTHERS A seam appears in the surface of %a as %n reaches for it.
		ENDIF
		IFVAR INTNUM10 ! ITEMVAL1
			CLEARVERB
			ECHO PLAYER The pouch doesn't seem to have a flap or seam to open.
			ECHO OTHERS %N turns %a this way and that, looking for an opening.
		ENDIF
	ENDIF
ENDIF
