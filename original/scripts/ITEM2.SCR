	IFVAR RNUM > 1899
		IFVAR RNUM < 2000
			EQUAL DANTEMP 1
		ENDIF
	ENDIF
	IFVAR DANTEMP = 0
		IFVAR ORG ! 7
			IFVAR RAC ! 7
				CLEARVERB
				ECHO PLAYER Huh?  How?
				ECHO OTHERS %N fiddles with %a, rattles it, and generally accomplishes nothing.
			ENDIF
		ENDIF
		IFVAR ORG = 7
			ECHO PLAYER You push the recessed switch set into the flashlight. Click!
			ECHO OTHERS %N pushes %h thumb along one part of %a.
			EQUAL FLAG1 1
		ENDIF
		IFVAR RAC = 7
			IFVAR FLAG1 = 0
				ECHO PLAYER You push the recessed switch set into the flashlight. Click!
				ECHO OTHERS %N pushes %h thumb along one part of %a.
			ENDIF
		ENDIF
	ENDIF
	EQUAL DANTEMP 0
ENDIF
