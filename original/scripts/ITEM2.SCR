IFPREVERB SNIFF -1
	IFVAR ITEMVAL5 = -1
		CLEARVERB
		ECHO PLAYER Nothing happens...which is expected since you got the amulet wet. Maybe you should have read the directions.
	ELSE
		IFVAR ITEMVAL5 ! 2
			CLEARVERB
			ECHO PLAYER The sadness of your current circumstance effects the amulets shade, turning it to blue.
			ECHO OTHERS %N's amulet turns a somber blue color.
			EQUAL ITEMVAL5 2
			EQUAL ITEMADJ1 29
		ELSE
			CLEARVERB
			ECHO PLAYER The amulet has already changed in response to your mood.
		ENDIF
	ENDIF
ENDIF
IFPREVERB THUMP -1
	IFVAR ITEMVAL5 = -1
		CLEARVERB
		ECHO PLAYER Nothing happens...which is expected since you got the amulet wet. Maybe you should have read the directions.
	ELSE
		IFVAR ITEMVAL5 ! 3
			CLEARVERB
			ECHO PLAYER The amulet turns red in reaction to your obviously foul mood.
			ECHO OTHERS %N's amulet abruptly turns to a nasty red color.
			EQUAL ITEMVAL5 3
			EQUAL ITEMADJ1 259
		ELSE
			CLEARVERB
			ECHO PLAYER Your nasty mood has already changed the helpless amulet.
		ENDIF
	ENDIF
ENDIF
IFPREVERB RUB -1
	IFVAR ITEMVAL5 = -1
		CLEARVERB
		ECHO PLAYER Nothing happens...which is expected since you got the amulet wet. Maybe you should have read the directions.
	ELSE
		IFVAR ITEMVAL5 ! 4
			CLEARVERB
			ECHO PLAYER Your greed and avarice turns the amulet to a sickly green.
			ECHO OTHERS %N's amulet slowly transforms to a sickly green color.
			EQUAL ITEMVAL5 4
			EQUAL ITEMADJ1 152
		ELSE
			CLEARVERB
			ECHO PLAYER Your greed has filtered nicely into the amulet, changing its shade prior to this.
		ENDIF
	ENDIF
ENDIF
IFPREVERB KISS -1
	IFVAR ITEMVAL5 = -1
		CLEARVERB
		ECHO PLAYER Nothing happens...which is expected since you got the amulet wet. Maybe you should have read the directions.
	ELSE
		IFVAR ITEMVAL5 ! 5
			CLEARVERB
			ECHO PLAYER The love in your heart takes form in the sweet pink color the amulet has become.
			ECHO OTHERS %N's amulet changes to a sweet pink color, heartening you at the sight.
			EQUAL ITEMVAL5 5
			EQUAL ITEMADJ1 464
		ELSE
			CLEARVERB
			ECHO PLAYER Your love is apparent to the amulet, and to others.
		ENDIF
	ENDIF
