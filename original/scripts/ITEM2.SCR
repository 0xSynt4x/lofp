ENDIF
IFPREVERB PUT -1
	ECHO PLAYER For some odd reason you can't seem to let go of %a!
	CLEARVERB
ENDIF
IFPREVERB DEPOSIT -1
	ECHO PLAYER For some odd reason you can't seem to let go of %a!
	CLEARVERB
ENDIF
