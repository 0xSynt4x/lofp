WEIGHT 1
CRAFTABLE
ARMOR
VOLUME 1
WORN_TORSO3
PARAMETER2 5
SUBSTANCE CLOTH
;
; Electric bo-stick
INUMBER 1193
NAME 29
WEIGHT 5
VOLUME 5
ARTICLE a
DRAKIN_CRUSH
PARAMETER1 10
TURNABLE
IFPREVERB TURN -1
	IFITEM -1 WIELDED
		EQUAL DUMMY1 0
		IFVAR ITEMADJ2 = -1
			ECHO OTHERS %n begins to twirl %a in a clockwise direction.
			ECHO PLAYEr You begin to twirl %a in a clockwise direction.
			EQUAL ITEMADJ2 1178
			EQUAL ITEMVAL3 4
			EQUAL ITEMVAL5 10
			CLEARVERB
			ADD DUMMY1 1
			PLREVENT 4
			CONTPLREVENT
			ECHO OTHERS As %n's bo-stick spins faster and faster it begins to crackle with electricity.
			ECHO PLAYER As your bo-stick spins faster and faster it begins to crackle with electricity.
			PLREVENT 4
			CONTPLREVENT
			ECHO OTHERS When %n stops twirling the bo-stick it crackles with energy.
			ECHO PLAYER When you stop twirling the bo-stick it crackles with energy.
		ENDIF
		IFVAR ITEMADJ2 = 1178
			IFVAR DUMMY1 = 0
				ECHO OTHERS %n begins spinning %a in a counter-clockwise direction.
				ECHO PLAYER You begin to spin %a in a counter-clockwise direction.
				EQUAL ITEMADJ2 -1
				EQUAL ITEMVAL3 0
				EQUAL ITEMVAL5 0
				CLEARVERB
				PLREVENT 4
				CONTPLREVENT
				SUB LIGHTME 1
				ECHO OTHERS As the bo-stick spins faster and faster it begins to throw off arcs of electricity.
				ECHO PLAYER As the bo-stick spins faster and faster it begins to throw off arcs of electricity.
				PLREVENT 4
				CONTPLREVENT
				ECHO ALL When the bo-stick stops spinning it is just a normal bo-stick again.
			ENDIF
		ENDIF
	ENDIF
ENDIF
IFPREVERB DROP -1
