;
; (Weaver Guild) distaff
INUMBER 1807
NAME 1108
MISC
WEIGHT 1
VOLUME 5
TURNABLE
IFPREVERB2 DESTROY -1
        CLEARVERB
        ECHO PLAYER You swing the distaff in a mighty blow, but slip and strike yourself instead!
        ECHO OTHERS %N swings %h distaff over %h head in a mighty blow, but slips and strikes %iself with it instead!
        TEMPNAME Weaver
ENDIF
IFPREVERB TURN -1
	CLEARVERB
	IFVAR SKILL15 > 0
		IFVAR ROUNDTIME > 0
			STRCVT 1 ROUNDTIME
			ECHO PLAYER [Wait %1 seconds...]
		ENDIF
		IFVAR ROUNDTIME = 0
			EQUAL ROUNDTIME 5
			ECHO PLAYER You turn %a.%c [Round 5 sec.]
			ECHO OTHERS %N turns %a.
			SKILLCHECK 15 -25 DUMMY1
			IFVAR DUMMY1 > 0
				ECHO PLAYER As you turn the distaff, fine threads of power weave a complex pattern above your head.
				ECHO OTHERS AS %N turns %i distaff, fine threads of power weave a complex pattern above %h head.
				ROUTINE 2
			ENDIF
		ENDIF
	ENDIF
	IFVAR SKILL15 = 0
		ECHO PLAYER You turn %a over and over in your hands, but with no knowledge in this area, you are at a loss to use it.
	ENDIF
ENDIF
