;
; Happy Fun ball
INUMBER 1761
NAME 546
WEIGHT 2
VOLUME 2
SUBSTANCE SOFTMETAL
IFPREVERB GET -1
	EQUAL ITEMVAL1 1
ENDIF
IFPREVERB DROP -1
	EQUAL ITEMVAL1 0
ENDIF
IFPREVERB LOOK -1
	CLEARVERB
	ECHO PLAYER Do not taunt Happy Fun Ball.
ENDIF
IFPREVERB TURN -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You turn %a over and over in your hands.
		ECHO OTHERS %N turns %a over and over in %h hands.
	ENDIF
ENDIF
IFPREVERB PUNCH -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You toss %a into the air and catch it.
		ECHO OTHERS %N tosses %a into the air and catches it.
	ENDIF
ENDIF
ARTICLE THE
IFVERB POKE -1
	ADD FLAG3 1
	IFVAR FLAG3 = 1
		ECHO PLAYER You seem to remember a warning not to taunt %a.
	ENDIF
	IFVAR FLAG3 = 2
		ECHO PLAYER %A growls menacingly at you.
		ECHO OTHERS %A growls menacingly at %n.
	ENDIF
	IFVAR FLAG3 = 3
		ECHO OTHERS %A throbs once. Suddenly a thin metallic spike thrusts out from its surface, impaling %n!
		ECHO PLAYER %A throbs once. Suddenly a thin metallic spike thrusts out from its surface, impaling you!
		KILL PLAYER
		POSITION LAY
		EQUAL FLAG3 0
	ENDIF
ENDIF
IFPREVERB EAT -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You balance %a on your nose for a moment.
		ECHO OTHERS %N balances %a on %h nose for a moment.
	ENDIF
ENDIF
IFPREVERB PUSH -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You drop %a.
		ECHO OTHERS %N drops %a.
		ECHO ALL ...%a bounces off the ground with a "BOING!" sound...
		ECHO PLAYER ...and you catch it!
		ECHO OTHERS ...and %N catches it!
	ENDIF
ENDIF
IFPREVERB HUG -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You squeeze %a as hard as you can, causing the strange space-chemicals within to glow for a moment.
		ECHO OTHERS %N squeezes %a as hard as %s can, causing the strange space-chemicals within to glow for a moment.
	ENDIF
ENDIF
IFPREVERB PULL -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		IFVAR RNUM = 206
			ECHO PLAYER You toss %a into the fountain, where it makes a big SPLASH!
			ECHO OTHERS %N tosses %a into the fountain, where it makes a big SPLASH!
			REMOVEITEM -1
			NEWPUT 0 1761 ADJ1=1198 ADJ2=1199
		ENDIF
		IFVAR RNUM = 212
			ECHO PLAYER You toss %a at the doorway, bouncing it off the forehead of someone just coming in.
			ECHO OTHERS %N tosses %a at the doorway, bouncing it off the forehead of a customer who's just coming in.
			GENMON 12
			ECHO ALL A commoner reels, confused, for a moment.
			REMOVEITEM -1
			NEWITEM 9 1761 ADJ1=1198 ADJ2=1199
		ENDIF
		IFVAR RNUM ! 206
			IFVAR RNUM ! 212
				ECHO PLAYER You look for something neat to do with %a here, and decide to ask Damnthing to put it in for you.
			ENDIF
		ENDIF
	ENDIF
ENDIF
IFPREVERB KISS -1
	CLEARVERB
	ECHO PLAYER You give %a a big, wet, sloppy kiss.
	ECHO OTHERS %N gives %a a big, wet, sloppy kiss.
	ECHO ALL %A croons contentedly.
	EQUAL FLAG3 0
ENDIF
IFPREVERB DRINK -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You bounce %a off your knee.
		ECHO OTHERS %N bounces %a off %h knee.
	ENDIF
ENDIF
IFPREVERB POINT -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You hold %a at arm's length, proudly presenting it to the world.
		ECHO OTHERS %N holds %a at arm's length, proudly presenting it to the world.
		EQUAL FLAG3 1
	ENDIF
ENDIF
IFPREVERB LEAN -1
	CLEARVERB
	IFVAR FLAG3 ! 1
		ECHO PLAYER You lean forward and fall flat on your face.
		ECHO OTHERS %N leans far forward, then falls flat on %h face.
		POSITION LAY
		ECHO ALL You'd almost swear you can hear %a snicker.
	ENDIF
	IFVAR FLAG3 = 1
		IFVAR ITEMVAL1 = 1
			ECHO PLAYER Still holding %a at arm's length, you lean forward, falling...
			ECHO OTHERS Still holding %a at arm's length, %n leans forward, falling...
			ECHO ALL ...until %a hits the ground, compressing and rebounding...
			ECHO PLAYER ...pushing you back up into a standing position!
			ECHO OTHERS ...pushing %i back up into a standing position!
			EQUAL FLAG3 0
		ENDIF
	ENDIF
ENDIF
IFPREVERB PLAY -1
	CLEARVERB
	ECHO PLAYER You tap %a three times in rapid succession, causing it to play a quick, catchy little tune.
	ECHO OTHERS %N taps %a three times in rapid succession, causing it to play a quick, catchy little tune.
ENDIF
IFVERB TAP -1
	ADD FLAG4 1
	IFVAR FLAG4 = 3
		ECHO PLAYER Not fast enough, sorry.
		EQUAL FLAG4 0
	ENDIF
ENDIF
IFPREVERB FLIP -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You flip %a a few inches into the air, spinning it as fast as you can...
		ECHO OTHERS %N flips %a a few inches into the air, putting spin on it...
		ECHO ALL ...%A hangs in the air for a moment...
		ECHO PLAYER ...then lands on the back of your waiting hand, rolling up your arm...
		ECHO OTHERS ...then lands on the back of %h waiting hand, rolling up %h arm...
		ECHO ALL ...from one shoulder to the other...
		ECHO PLAYER ...and down the other arm, into your open hand.
		ECHO OTHERS ...and down %h other arm, into %h open hand.
	ENDIF
ENDIF
IFPREVERB KICK -1
	IFVAR ITEMVAL1 = 1
		CLEARVERB
		ECHO PLAYER You drop-kick %a into the air, then catch it.
		ECHO OTHERS %N drop-kicks %a into the air, then catches it.
	ENDIF
	IFVAR ITEMVAL1 = 0
		IFVAR RNUM = 212
			CLEARVERB
			ECHO PLAYER You give %a a swift kick, sending it caroming out of the Cantina!
			ECHO OTHERS %N gives %a a swift kick, sending it caroming out of the Cantina!
			REMOVEITEM -1
			AFFECT 210
			ECHO ALL Suddenly the happy fun ball cruises through the hallway from east to west!
			AFFECT 211
			ECHO ALL Suddenly the happy fun ball comes sailing into the flop through the doorway, bouncing off several walls before coming to rest in the center of the room.
			NEWITEM 9 1761 ADJ1=1198 ADJ2=1199
		ENDIF
		IFVAR RNUM = 211
			CLEARVERB
			ECHO PLAYER You give %a a swift kick, sending it caroming out of the flop!
			ECHO OTHERS %N gives %a a swift kick, sending it caroming out of the flop!
			REMOVEITEM -1
			AFFECT 210
			ECHO ALL Suddenly the happy fun ball cruises through the hallway from west to east!
			AFFECT 212
			ECHO ALL Suddenly the happy fun ball comes sailing into the Cantina through the doorway, bounces off the bar, and rolls to a stop in the middle of the room.
			NEWITEM 9 1761 ADJ1=1198 ADJ2=1199
		ENDIF
	ENDIF
ENDIF
