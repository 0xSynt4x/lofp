;
;----------------------[  medallion  ]--------------------------------------
INUMBER 906
NAME 135
MISC
WORN_DON
ARMOR
WEIGHT 1
VOLUME 1
TURNABLE
FLIPABLE
SUBSTANCE INDESTRUCTABLE
*DESCRIPTION_START EXAMINE
Turning over the medallion, you see the back has been engraved with a likeness of the Silver Oak.
*DESCRIPTION_END
VARIABLE amerturn
VARIABLE amermove
;-------------------------gm message-------------------------
IFPREVERB EXAMINE -1
  IFVAR INTNUM3 = 1
     ECHO PLAYER If ADJ3 = 1182 (leaf) this is a forester's medallion. Talk to Amer before using.
     ECHO PLAYER ITEMVAL1 determines the forester's rank.
     ECHO PLAYER ITEMVAL5 is the INTNUM3 of the owner of the medallion. %c
  ENDIF
ENDIF
;----------------------------set medallion-------------------	
IFVAR ITEMADJ3 = 1182
    IFPREVERB CONCENTRATE -1
        CLEARVERB
        IFVAR ITEMVAL5 = 0
		IFVAR ORG = 15
       			ECHO PLAYER You concentrate on the medallion.%c The medallion flares a rich green.
			ECHO OTHERS %n concentrates on the medallion.%c The medallion flares a rich green.
			ECHO PLAYER The medallion says "You are my friend now, we belong together."
			SETITEMVAL -1 5 INTNUM3
		ELSE
			ECHO OTHERS %n concentrates on the medallion.%c The medallion flares an angry green and then disappears.
			ECHO PLAYER The medallion says "You are not a Forester."%c The medallion flares an angry green and then disappears. 			
			REMOVEITEM -1
		ENDIF
	ENDIF	
    ENDIF
ENDIF
;
;-------------------------- prevent taking medallion -------------------------
IFVAR ITEMADJ3 = 1182
    IFPREVERB TAKE -1
	IFVAR ITEMVAL5 ! INTNUM3
		CLEARVERB
		ECHO PLAYER The medallion jumps from your grasp and flares green before it disappears.
		ECHO OTHERS %N reaches for %a, but it flares green and vanishes.
		REMOVEITEM -1
	ENDIF
    ENDIF	
ENDIF
;------------------- prevent non owner from wearing it -----------------------
IFVAR ITEMADJ3 = 1182
    IFPREVERB WEAR -1
	IFVAR ITEMVAL5 ! INTNUM3
		CLEARVERB
		ECHO PLAYER The medallion struggles in your grasp and refuses to go around your neck, it flares green and disappears.
		ECHO OTHERS %N struggles to place %a over %h neck, but the medallion flares green and vanishes.
		REMOVEITEM -1
	ENDIF
    ENDIF
ENDIF
;
IFVAR ITEMADJ3 = 1182
    IFVERB WEAR -1
	ECHO ALL As %N places %a around %h neck it flares with a green light.	
    	IFVAR ITEMVAL1 = 11
;----------------BARK SKIN---------
		PARAMETER1 = 80
		EQUAL ITEMVAL2 20
;----------------------------------
	ENDIF
    ENDIF
ENDIF
;------------------------ prevent theft ----------------------
IFVAR ITEMADJ3 = 1182
    IFPREVERB STEAL -1
	IFVAR ITEMVAL5 ! INTNUM3
		CLEARVERB
		ECHO PLAYER The medallion jumps from your grasp and flares green before it disappears.
		ECHO OTHERS %N reaches for %a, but it flares green and vanishes.
		REMOVEITEM -1
	ENDIF
    ENDIF
ENDIF
;-------------------------Listen Medallion-------------------
IFVAR ITEMADJ3 = 1182
    IFITEM -1 WORN
    	IFPREVERB LISTEN -1
    		ECHO PLAYER For you and only for you I shall reveal the full extent of my powers.
    		IFVAR ITEMVAL1 = 1
			CLEARVERB
			ECHO PLAYER You are an Initiate in the Forester's Guild.		
		ENDIF
    		IFVAR ITEMVAL1 = 2
			CLEARVERB
			ECHO PLAYER You are an Journeyman in the Forester's Guild.%cTo heal thyself, polish me.		
		ENDIF
    		IFVAR ITEMVAL1 = 3
			CLEARVERB
			ECHO PLAYER You are an Woodsman in the Forester's Guild.%cTo heal thyself, polish me.		
		ENDIF
    		IFVAR ITEMVAL1 = 4
			CLEARVERB
			ECHO PLAYER You are an Tracker in the Forester's Guild.%cTo heal thyself, polish me.%cTo feel better, pinch me.		
		ENDIF
    		IFVAR ITEMVAL1 = 5
			CLEARVERB
			ECHO PLAYER You are an Scout in the Forester's Guild.%cTo heal thyself, polish me.%cTo feel better, pinch me.		
		ENDIF
    		IFVAR ITEMVAL1 = 6
			CLEARVERB
			ECHO PLAYER You are an Pathfinder in the Forester's Guild.%cTo heal thyself, polish me.%cTo feel better, pinch me.		
		ENDIF
    		IFVAR ITEMVAL1 = 7
			CLEARVERB
			ECHO PLAYER You are an Master Tracker in the Forester's Guild.%cTo heal thyself, polish me.%cTo feel better, pinch me.		
		ENDIF
    		IFVAR ITEMVAL1 = 8
			CLEARVERB
			ECHO PLAYER You are an Ranger in the Forester's Guild.%cTo heal thyself, polish me.%cTo feel better, pinch me.%cKiss me to fly on swift wings back to the Grove.		
		ENDIF
    		IFVAR ITEMVAL1 = 9
			CLEARVERB
			ECHO PLAYER You are on the Forest Council of the Forester's Guild.%cTo heal thyself, polish me.%cTo feel better, pinch me.%cKiss me to fly on swift wings back to the Grove.		
		ENDIF
    		IFVAR ITEMVAL1 = 10
			CLEARVERB
			ECHO PLAYER You are the High Forester of the Forester's Guild.%cTo heal thyself, polish me.%cTo feel better, pinch me.%cKiss me to fly on swift wings back to the Grove.		
		ENDIF
    		IFVAR ITEMVAL1 = 11
			CLEARVERB
			ECHO PLAYER You are a Forestal of the Forester's Guild.	
			ECHO PLAYER You have wielded so much earth power that your body has taken on some of the aspects of the mighty Oak.%cTo heal thyself, polish me.%cTo feel healthier, pinch me.%cKiss me to move back to the Grove.%cFlip me to become like the Oak.
		ENDIF
    		ECHO PLAYER If you ever need pierce the darkness, get my attention by tapping me.
    	ENDIF
;----------------Tap medallion---------------------
	IFPREVERB TAP -1
		CLEARVERB
    		ECHO PLAYER Your medallion flares with a brilliant green light.
   		ECHO OTHERS As %N taps %a it flares with a brilliant green light, and %h eyes flash.
  		SPELL 520 100
	ENDIF
;-------------------------Rub Medallion --------------------
	IFPREVERB RUB -1
		IFVAR ROUNDTIME ! 0
			CLEARVERB
			STRCVT 1 ROUNDTIME
			ECHO PLAYER [Wait %1 seconds...]
		ENDIF
		IFVAR ROUNDTIME = 0
			CLEARVERB
			EQUAL ROUNDTIME 3
    			ECHO PLAYER Your medallion flares with a brilliant green light as you polish it.%c[Round: 3 sec]		
  			ECHO OTHERS %N rubs the %a and it flares with a brilliant green light.
			IFVAR ITEMVAL1 = 2
  				SPELL 316 25	
			ENDIF
			IFVAR ITEMVAL1 = 3
  				SPELL 316 25	
			ENDIF
			IFVAR ITEMVAL1 = 4
  				SPELL 317 25	
			ENDIF
			IFVAR ITEMVAL1 = 5
  				SPELL 317 50
			ENDIF
			IFVAR ITEMVAL1 = 6
  				SPELL 317 100	
			ENDIF
			IFVAR ITEMVAL1 = 7
  				SPELL 318 50	
			ENDIF
			IFVAR ITEMVAL1 = 8
  				SPELL 318 50	
			ENDIF
			IFVAR ITEMVAL1 = 9
  				SPELL 318 75	
			ENDIF
			IFVAR ITEMVAL1 = 10
  				SPELL 318 100	
			ENDIF
			IFVAR ITEMVAL1 = 11
  				SPELL 318 100	
			ENDIF		
		ENDIF
	ENDIF
;------------------------Pinch Medallion-----------
	IFPREVERB PINCH -1
		IFVAR ROUNDTIME ! 0
			CLEARVERB
			STRCVT 1 ROUNDTIME
			ECHO PLAYER [Wait %1 seconds...]
		ENDIF
		IFVAR ROUNDTIME = 0
			CLEARVERB
			EQUAL ROUNDTIME 3
    			ECHO PLAYER Your medallion flares with a brilliant green light as you pinch it.		
  			ECHO OTHERS %N pinches %a and it flares with a brilliant green light.
			IFVAR ITEMVAL1 = 4
  				SPELL 334 25	
			ENDIF
			IFVAR ITEMVAL1 = 5
  				SPELL 334 50
			ENDIF
			IFVAR ITEMVAL1 = 6
  				SPELL 335 50	
			ENDIF
			IFVAR ITEMVAL1 = 7
  				SPELL 335 75	
			ENDIF
			IFVAR ITEMVAL1 = 8
  				SPELL 335 75	
			ENDIF
			IFVAR ITEMVAL1 = 9
  				SPELL 335 100	
			ENDIF
			IFVAR ITEMVAL1 = 10
  				SPELL 335 100	
			ENDIF
			IFVAR ITEMVAL1 = 11
      				ECHO PLAYER You extend your roots into the earth to absorb the earth power.%c[Round: 3 sec]		
  				ECHO OTHERS %N concentrates and small tendrils seem to sprout from %h ankles and enter the ground. A green glow soon rises up %h body.
				SPELL 335 100
  				SPELL 319 100
				SPELL 303 100
				SPELL 343 100
			ENDIF
		ENDIF
	ENDIF
;-------------------------Flip Medallion-------------
	IFPREVERB FLIP -1
		IFVAR ITEMVAL1 = 11
			IFVAR ROUNDTIME ! 0
				CLEARVERB
				STRCVT 1 ROUNDTIME
				ECHO PLAYER [Wait %1 seconds...]
			ENDIF
			IFVAR ROUNDTIME = 0
				CLEARVERB
	        		EQUAL ROUNDTIME 3
     				ECHO PLAYER You extend your roots into the earth to absorb the earth power.%c[Round: 3 sec]		
  				ECHO OTHERS %N concentrates and small tendrils seem to sprout from %h ankles and enter the ground. A green glow soon rises up %h body.
  				SPELL 511 100
				SPELL 209 100
				SPELL 510 100
				SPELL 521 100
			ENDIF
		ENDIF
	ENDIF		
;------------------------------Kiss medallion--------------
	IFVERB KISS -1
		IFVAR WILDERNESS ! 1
			IFVAR REGION = 0
    				IFVAR ITEMVAL1 = 8
					IFVAR RNUM ! 570
						DISBAND
  						ECHO OTHERS %N's form flares with a green glow and then slowly reforms into a swift hawk. The hawk leaps into the air and flys away!
						ECHO PLAYER You feel you body dissolve, and reshape into that of a hawk! You take wing, headed for the grove!
						PLREVENT 0
						CONTPLREVENT
						MOVE 2145
						AFFECT 2145
						ECHO PLAYER You soar through the air, flying over meadows and fields, headed for the grove!						
						ECHO OTHERS A swift hawk wings thru the air near you.
						SHOWROOM 2145
						PLREVENT 2
						CONTPLREVENT
						ECHO PLAYER You dive towards the grove!
						MOVE 570
						AFFECT 570
						ECHO OTHERS A swift hawk flies into the meadow and then glows a rich green. The hawk dissolves and turns into %N!
						ECHO PLAYER You feel your avian body dissolve, and reform into your normal shape.
						SHOWROOM 570
					ENDIF
				ENDIF
		    		IFVAR ITEMVAL1 = 9
					IFVAR RNUM ! 570
						DISBAND
						ECHO OTHERS %N's form flares with a green glow and then slowly reforms into a sleek falcon. The falcon leaps into the air and flys away!
						ECHO PLAYER You feel you body dissolve, and reshape into that of a falcon! You take wing, headed for the grove!
						PLREVENT 0
						CONTPLREVENT
						MOVE 2145
						AFFECT 2145
						ECHO PLAYER You soar through the air, flying over meadows and fields, headed for the grove!						
						ECHO OTHERS A sleek falcon wings thru the air near you.
						SHOWROOM 2145
						PLREVENT 2
						CONTPLREVENT
						ECHO PLAYER You dive towards the grove!
						MOVE 570
						AFFECT 570
						ECHO OTHERS A sleek falcon flies into the meadow and then glows a rich green. The falcon dissolves and turns into %N!
						ECHO PLAYER You feel your avian body dissolve, and reform into your normal shape.
						SHOWROOM 570
					ENDIF
				ENDIF
			ENDIF
	    		IFVAR ITEMVAL1 = 10
				IFVAR RNUM ! 570
					DISBAND
					ECHO OTHERS %N's form flares with a green glow and then slowly reforms into a noble eagle. The eagle leaps into the air and soars away!
					ECHO PLAYER You feel your body dissolve, and reshape into that of a powerful eagle! You take wing, headed for the grove!
					PLREVENT 0
					CONTPLREVENT
					MOVE 2145
					AFFECT 2145
					ECHO PLAYER You soar through the air, flying over meadows and fields, headed for the grove!						
					ECHO OTHERS A noble eagle wings thru the air near you.
					SHOWROOM 2145
					PLREVENT 2
					CONTPLREVENT
					ECHO PLAYER You dive towards the grove!
					MOVE 570
					AFFECT 570
					ECHO OTHERS A noble eagle flies into the meadow and then glows a rich green. The eagle dissolves and turns into %N!
					ECHO PLAYER You feel you body dissolve, and reform into your normal shape.
					SHOWROOM 570
				ENDIF
			ENDIF
		ENDIF
    		IFVAR ITEMVAL1 = 11
			IFVAR RNUM ! 570
				EQUAL amermove RNUM
				DISBAND
				ECHO OTHERS Mist gathers around %N until you can no longer see %i!
				ECHO PLAYER You feel your body dissolve as the Earth Power fills you. You are pulled through realms of Earth Power.
				PLREVENT 0
				CONTPLREVENT
				MOVE 570
				AFFECT 570
				ECHO OTHERS A mist appears on the ground before you. Suddenly it flares brightly and then %N is standing there!
				ECHO PLAYER You suddenly see that you are in the grove.
				SHOWROOM 570
			ELSE
				DISBAND
				ECHO OTHERS %N's form flares with a green glow that becomes brighter and brighter, until you can no longer see %i!
				ECHO PLAYER You feel your body dissolve as the Earth Power fills you. You are pulled through realms of Earth Power.
				PLREVENT 0
				CONTPLREVENT
				MOVE amermove
				AFFECT amermove
				ECHO OTHERS A thick mist appears on the ground before you. Suddenly it flares brightly and then %N is standing there!
				ECHO PLAYER You suddenly are in the natural world again.
				SHOWROOM amermove
				EQUAL amermove 0
			ENDIF
		ENDIF
	ENDIF
    ENDIF
ENDIF
;-----------------------------select medallion to craft ------------------
IFVAR ITEMADJ3 = 1182
    IFVAR ITEMVAL1 > 8
	IFITEM -1 WORN
		IFPREVERB TURN -1
			CLEARVERB
			Add amerturn 1
			IFVAR amerturn > 9
				Equal amerturn 1
			ENDIF
			IFVAR amerturn = 1
				ECHO PLAYER You prepare to make a Initiate Medallion (Lvl 1).
			ENDIF
			IFVAR amerturn = 2
				ECHO PLAYER You prepare to make a Journeyman Medallion (Lvl 2).
			ENDIF
			IFVAR amerturn = 3
				ECHO PLAYER You prepare to make a Woodsman Medallion (Lvl 3).
			ENDIF
			IFVAR amerturn = 4
				ECHO PLAYER You prepare to make a Tracker Medallion (Lvl 4).
			ENDIF
			IFVAR amerturn = 5
				ECHO PLAYER You prepare to make a Scout Medallion (Lvl 5).
			ENDIF
			IFVAR amerturn = 6
				ECHO PLAYER You prepare to make a Pathfinder Medallion (Lvl 6).
			ENDIF
			IFVAR amerturn = 7
				ECHO PLAYER You prepare to make a Master Tracker Medallion (Lvl 7).
			ENDIF
			IFVAR amerturn = 8
				ECHO PLAYER You prepare to make a Ranger Medallion (Lvl 8).
			ENDIF
			IFVAR amerturn = 9
				ECHO PLAYER You prepare to make a Forest Council Medallion (Lvl 9).
			ENDIF		
		endif
;-------------------------create medallions--------------------
		IFPREVERB POKE -1
			CLEARVERB
			ECHO OTHERS %N works with some simple tools to craft a small medallion.
			ECHO PLAYER You create a medallion with some small tools.
			IFVAR amerturn = 1
				NEWITEM -1 906 VAL1=1 ADJ1= ADJ2=1037 ADJ3=1182
			ENDIF
			IFVAR amerturn = 2
				NEWITEM -1 906 VAL1=2 ADJ1= ADJ2=895 ADJ3=1182
			ENDIF		
			IFVAR amerturn = 3
				NEWITEM -1 906 VAL1=3 ADJ1= ADJ2=196 ADJ3=1182
			ENDIF	
			IFVAR amerturn = 4
				NEWITEM -1 906 VAL1=4 ADJ1= ADJ2=577 ADJ3=1182
			ENDIF	
			IFVAR amerturn = 5
				NEWITEM -1 906 VAL1=5 ADJ1= ADJ2=528 ADJ3=1182
			ENDIF	
			IFVAR amerturn = 6
				NEWITEM -1 906 VAL1=6 ADJ1= ADJ2=366 ADJ3=1182
			ENDIF		
			IFVAR amerturn = 7
				NEWITEM -1 906 VAL1=7 ADJ1= ADJ2=400 ADJ3=1182
			ENDIF	
			IFVAR amerturn = 8
				NEWITEM -1 906 VAL1=8 ADJ1=259 ADJ2=216 ADJ3=1182
			ENDIF	
			IFVAR amerturn = 9
				NEWITEM -1 906 VAL1=9 ADJ1=347 ADJ2=216 ADJ3=1182
			ENDIF		
		ENDIF
	ENDIF
    ENDIF
ENDIF		
