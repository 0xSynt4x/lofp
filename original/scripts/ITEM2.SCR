;
;
VARIABLE OLDROOM
; evil circlet
INUMBER 1346
NAME 307
WORN_HEAD
ARMOR
PARAMETER1 1
WEIGHT 1
VOLUME 1
IFTOUCH -1
        IFVAR ALIGN > 0
                ECHO OTHERS %N reaches for the elkyri circlet, but suddenly goes stiff and collapses, dead.
		ECHO PLAYER As you reach for the circlet, you feel a diametrically opposed force within it rise up and smite you down!
		KILL PLAYER
		POSITION LAY
		CLEARVERB
	ENDIF
ENDIF
IFPREVERB WEAR -1
	IFITEM -1 WORN
		ECHO PLAYER You are already wearing it.
		CLEARVERB
	ELSE
		ECHO PLAYER An indeterminate force in the circlet grabs hold of you as you place it upon your head. You struggle against it for a moment, but it embraces you. After a moment, you relax, feeling the power course through your being.
	ENDIF
ENDIF
IFPREVERB REMOVE -1
	IFITEM -1 WORN
		ECHO PLAYER You can't seem to remove it.
                ECHO OTHERS %N struggles to remove the elkyri circlet, but fails.
		CLEARVERB
	ENDIF
ENDIF
IFVERB WEAR -1
	ECHO OTHERS %N seems to struggle with some unseen force, but then relaxes.
ENDIF
IFVERB CONCENTRATE -1
        EQUAL ROUNDTIME 1
        IFVAR ITEMVAL5 = TIM
                ECHO PLAYER A voice in your mind rasps, "You call when I am weak!"
        ENDIF
        IFVAR ITEMVAL5 ! TIM
                EQUAL ITEMVAL5 TIM
                SPELL 138
        ENDIF
ENDIF
IFPREVERB GAZE -1
        CLEARVERB
        ECHO PLAYER You gaze deep within yourself...
        EQUAL ROUNDTIME 18
        IFVAR ITEMVAL5 = TIM
                ECHO PLAYER A voice in your mind rasps, "You call when I am weak!"
        ELSE
                PLREVENT 1
                CONTPLREVENT
                ECHO PLAYER You feel energy flowing into you from the circlet.
                ADD BODYPOINTS 20
                PLREVENT 1
                CONTPLREVENT
                ADD BODYPOINTS 20
                PLREVENT 1
                CONTPLREVENT
                ADD BODYPOINTS 20
                PLREVENT 1
                CONTPLREVENT
                ECHO PLAYER You feel energy flowing into you from the circlet.
                ADD BODYPOINTS 20
                PLREVENT 1
                CONTPLREVENT
                ADD BODYPOINTS 20
                PLREVENT 1
                CONTPLREVENT
                ADD BODYPOINTS 20
                PLREVENT 1
                CONTPLREVENT
                ECHO PLAYER You feel energy flowing into you from the circlet.
                ADD BODYPOINTS 20
        ENDIF
ENDIF

;
; good circlet
INUMBER 1420
NAME 307
WORN_HEAD
ARMOR
PARAMETER1 1
WEIGHT 1
VOLUME 1
;
IFTOUCH -1
	IFVAR ALIGN < 0
		ECHO OTHERS %N reaches for the white elkyri circlet, but suddenly goes stiff and collapses, dead.
		ECHO PLAYER As you reach for the circlet, you feel a diametrically opposed force within it rise up and smite you down!
		KILL PLAYER
		POSITION LAY
		CLEARVERB
	ENDIF
ENDIF
IFPREVERB WEAR -1
	IFITEM -1 WORN
		ECHO PLAYER You are already wearing it.
		CLEARVERB
	ELSE
		ECHO PLAYER An indeterminate force in the circlet grabs hold of you as you place it upon your head. You struggle against it for a moment, but it embraces you. After a moment, you relax, feeling the power course through your being.
	ENDIF
ENDIF
IFPREVERB REMOVE -1
	IFITEM -1 WORN
		ECHO PLAYER You can't seem to remove it.
		ECHO OTHERS %N struggles to remove the white elkyri circlet, but fails.
		CLEARVERB
	ENDIF
ENDIF
IFVERB WEAR -1
	ECHO OTHERS %N seems to struggle with some unseen force, but then relaxes.
ENDIF
IFVERB CONCENTRATE -1
	IFITEM -1 WORN
		IFVAR GOODCIR ! TIM
			SPELL 133 10
			EQUAL GOODCIR TIM
			EQUAL OLDROOM RNUM
			IFSEEK 201
				IFITEM WORN -1
				RANDOM DUMMY1 1 3 0
				IFVAR DUMMY1 = 1
					ECHO PLAYER You feel a moment of unease as you sense the closeness of the white circlet's wielder.
				ENDIF
				IFVAR DUMMY1 = 2
					ECHO PLAYER You have a vision...
					SHOWROOM OLDROOM
				ENDIF
				IFVAR DUMMY1 = 3
					ECHO PLAYER A voice rasps in your mind, "'Ware!  Someone has invoked the power of the white circlet!"
				ENDIF
				ENDIF
			ENDIF
		ELSE
			ECHO PLAYER A voice whispers in your mind, "My power is limited at this time. Be patient and true."
		ENDIF
	ENDIF
ENDIF
;
CEVENT 39 60 50
IFSEEK 202
	IFITEM -1 WORN
		RANDOM DUMMY1 1 10 0
		IFVAR DUMMY1 = 1
			ECHO PLAYER A voice whispers in your mind, "Be true to the cause of goodness, my friend. A great evil has come to Andor, and you must be prepared to face it."
		ENDIF
		IFVAR DUMMY2 = 2
			ECHO PLAYER A voice whispers in your mind, "I shall provide for you and protect you, gentle friend. Be true in the face of Evil!"
		ENDIF
		IFVAR DUMMY3 = 3
			ECHO PLAYER A voice whispers in your mind, "You must prove yourself, savior of Andor. Know thy greatest enemy, for he wears a black elkyri circlet!"
		ENDIF
		IFVAR DUMMY4 = 4
			ECHO PLAYER A voice whispers in your mind, "In time, you shall learn to use my other powers. For now, be content. We shall sweep the forces of Evil from Andor!"
		ENDIF
		IFVAR DUMMY5 = 5
			ECHO PLAYER A voice whispers in your mind, "Seek the black elkyri circlet!  Until it can be destroyed, Evil will flourish!"
		ENDIF
	ENDIF
ENDIF
IFSEEK 201
	IFITEM -1 WORN
		RANDOM DUMMY1 1 10 0
		IFVAR DUMMY1 = 1
			ECHO PLAYER A voice rasps in your mind, "Power and riches shall be ours, my friend. Follow me, and in time you shall have that and more."
		ENDIF
		IFVAR DUMMY1 = 2
			ECHO PLAYER A voice rasps in your mind, "Soon, I shall teach you the full extent of my power. But first, you must destroy the white elkyri circlet."
		ENDIF
		IFVAR DUMMY1 = 3
			ECHO PLAYER A voice rasps in your mind, "Look around you!  Andor is filled with unwitting fools. Soon, they shall kneel at your feet, ready to serve you as the new Lord of Andor!"
		ENDIF
		IFVAR DUMMY1 = 4
			ECHO PLAYER A voice rasps in your mind, "Blood... I must have it!"
		ENDIF
		IFVAR DUMMY1 = 5
			ECHO PLAYER A voice rasps in your mind, "There is but one thing between us and ultimate power. Find the white elkyri circlet. It must be destroyed."
		ENDIF
	ENDIF
ENDIF
