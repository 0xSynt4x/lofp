;
;
; Belt
INUMBER 536
NAME 469
MISC
WORN_AROUND
ARMOR
VOLUME 2
WEIGHT 1
CRAFTABLE
SUBSTANCE CLOTH
PARAMETER2 2
IFPREVERB LOOK -1
        IFVAR INTNUM3 = 1
        ECHO PLAYER If itembit5 = 1 This is a belt which gived druidic powers.
        endif
ENDIF
IFPREVERB PULL -1
        IFVAR ITEMBIT5 = 1
        clearverb
        ECHO PLAYER  You pull your belt. The earth grants you a spell. The power of earthspike enters your mind.
        ECHO OTHERS  %N pulls %h belt.
        EQUAL SPELLNUM 523
        ENDIF
ENDIF
IFPREVERB TAP -1
        IFVAR ITEMBIT5 = 1
        CLEARVERB
                IFVAR SKILL17 < 7
                ECHO PLAYER You tap your belt.
                ECHO OTHERS %N taps %h belt.
                ENDIF
                IFVAR SKILL17 > 6
                ECHO PLAYER You tap your belt. The earth grants you a spell. The power of earthwave enters your mind.
                ECHO OTHERS %N taps %h belt.
                EQUAL SPELLNUM 524
                ENDIF
        ENDIF
ENDIF
IFPREVERB CONCENTRATE -1
        IFVAR ITEMBIT5 = 1
        clearverb
                IFVAR SKILL17 < 13
                ECHO PLAYER You concentrate intently on the belt.
                ECHO OTHERS %N concentrates intently on the belt.
                ENDIF
                IFVAR SKILL17 > 12
                        IFVAR ITEMVAL5 ! TIM
                        ECHO PLAYER You focus your thoughts on the belt. The earth rewards you with a servant.
                        ECHO OTHERS %N concentrates intently on the belt.
                        SPELL 123 30
                        EQUAL ITEMVAL5 TIM
                        ENDIF
                ENDIF
        ENDIF
ENDIF
IFPREVERB RUB -1
        IFVAR ITEMBIT5 = 1
        clearverb
                IFVAR SKILL17 < 19
                ECHO PLAYER You rub your belt.
                ECHO OTHERS %N rubs %h belt.
                ENDIF
                IFVAR SKILL17 > 18
                        IFVAR ITEMVAL3 ! TIM
                        ECHO PLAYER You rub your belt. Suddenly, the earth grants you the strength of the mountains.
                        ECHO OTHERS %N rubs %h belt.
                        SPELL 209 30
                        EQUAL ITEMVAL3 TIM
                        ENDIF
                ENDIF
        ENDIF
ENDIF

