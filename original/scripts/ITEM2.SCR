;
; phaser, rewritten
INUMBER 856
NAME 720
WEIGHT 1
VOLUME 2
BOW_WEAPON
PARAMETER1 35
PARAMETER2 1756
IFVAR ITEMBIT0 = 1
	IFVAR ITEMVAL2 ! 0
		ECHO ALL The dweaomer dissipates from %a.
		EQUAL ITEMADJ1 -1
		EQUAL ITEMVAL2 0
		EQUAL ITEMBIT0 0
	ENDIF
ENDIF
IFVAR ITEMVAL2 ! 0
	EQUAL ITEMBIT0 1
ENDIF
IFPREVERB WIELD -1
	IFVAR ORG = 15
		ECHO PLAYER Huh? How? This thing is nothing like a bow...
		CLEARVERB
		ECHO OTHERS %N grips %a tightly, turning it this way and that...
		IFVAR ITEMVAL3 > 0
			ECHO ALL You hear a loud "click."
			ECHO ALL %A suddenly shoots forth a burst of energy!
			ECHO OTHERS %N dances about wildly, trying %h best to turn %a off!
			ECHO PLAYER You dance about wildly, doing your best to turn %a off!
			ECHO OTHERS %A runs out of energy with one, final shot... but that final shot hits %n!
			DAMAGEPLR BODYONLY 50 %A runs out of energy with one, final shot... which hits you as your shaking hand twists wildly about!
			EQUAL ITEMVAL3 0
		ENDIF
	ENDIF
ENDIF
SUBSTANCE HARDMETAL
IFPREVERB LOAD -1
	IFVAR ITEMVAL3 ! 0
		ECHO PLAYER You can't load the phaser until it is uncharged.
		CLEARVERB
	ENDIF
ENDIF
IFVERB LOAD -1
	IFITEM -1 WIELDED
		IFVAR ITEMVAL3 = 1
			EQUAL ITEMVAL3 10
			ECHO PLAYER The phaser's energy readout rises to "full."
		ENDIF
	ENDIF
ENDIF
IFPREVERB READ -1
	CLEARVERB
	IFVAR ITEMVAL3 = 0
		ECHO PLAYER The phaser is uncharged.
	ENDIF
	IFVAR ITEMVAL3 > 0
		IFVAR ITEMVAL3 < 8
			ECHO PLAYER The phaser is partially charged.
		ENDIF
	ENDIF
	IFVAR ITEMVAL3 > 7
		IFVAR ITEMVAL3 < 10
			ECHO PLAYER The phaser is almost fully-charged.
		ENDIF
	ENDIF
	IFVAR ITEMVAL3 > 9
		ECHO PLAYER The phaser is fully-charged.
	ENDIF
ENDIF
