;
; defensive enhancing torc
INUMBER 723
NAME 308
WORN_NECK
ARMOR
WEIGHT 3
VOLUME 2
ifvar itembit0 = 1
        ifpreverb rub -1
                ifvar itemval5 > 0
                random dummy1 1 50 0
                        ifvar dummy1 ! 1
                        spell 210 30
                        sub itemval5 1
                        else
                        echo player Something goes wrong with the torc's spell matrix! Your surroundings fade away...
                        echo others %N fades away.
                        move 1365
                        affect 1365
                        showroom 1365
                        position lay
                        appear You reek of bat guano.
                        echo others %N fades in and lands with a splat!
                        endif
                else
                echo player Nothing observable happens.
                endif
        endif
        ifpreverb concentrate -1
                ifvar itemval5 > 0
                random dummy1 1 50 0
                        ifvar dummy1 ! 1
                        spell 230 30
                        sub itemval5 1
                        else
                        echo player Something goes wrong with the torc's spell matrix! Your surroundings fade away...
                        echo others %N fades away.
                        move 1365
                        affect 1365
                        showroom 1365
                        position lay
                        appear You reek of bat guano.
                        echo others %N fades in and lands with a splat!
                        endif
                else
                echo player Nothing observable happens.
                endif
        endif
endif
