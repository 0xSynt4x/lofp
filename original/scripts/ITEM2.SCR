			NEWPUT 9 1797 ADJ1=1317 ADJ2=1303 ADJ3=1308
		ENDIF
	ENDIF
ENDIF
IFPREVERB GO -1
	CLEARVERB
	IFVAR RNUM = 3176
		ECHO PLAYER You lead your group to the card table.
		ECHO OTHERS %N leads %h group to the card table.
		MOVEGROUP 2435
		EQUAL AMOUNT 0
		EQUAL STATE 0
		EQUAL CURCARDBET 0
	ENDIF
	IFVAR RNUM ! 3176
		ECHO PLAYER There doesn't seem to be a convienent table nearby.
	ENDIF
ENDIF
