;
; Hole in space time continum
INUMBER 731
NAME 108
WEIGHT 1
VOLUME 28
PORTAL
OPENABLE
VARIABLE turnme
IFVERB pull -1
	Add turnme 1
	IFVAR turnme > 5
		Equal turnme 0
	ENDIF
	IFVAR turnme = 0
		SETITEMVAL -1 2 314
	ENDIF
	IFVAR turnme = 1
		setitemval -1 2 206
	ENDIF
	IFVAR turnme = 2
		SETITEMVAL -1 2 601
	ENDIF
	IFVAR turnme = 3
		SETITEMVAL -1 2 503
	ENDIF
		IFVAR turnme = 4
		setitemval -1 2 150
	ENDIF
	IFVAR turnme = 5
		SETITEMVAL -1 2 628
	ENDIF
endif
IFVERB push -1
	sub turnme 1
	IFVAR turnme < 0
		Equal turnme 5
	ENDIF
	IFVAR turnme = 0
		SETITEMVAL -1 2 314
	ENDIF
	IFVAR turnme = 1
		setitemval -1 2 206
	ENDIF
	IFVAR turnme = 2
		SETITEMVAL -1 2 601
	ENDIF
	IFVAR turnme = 3
		SETITEMVAL -1 2 503
	ENDIF
	IFVAR turnme = 4
		setitemval -1 2 150
	ENDIF
	IFVAR turnme = 5
		SETITEMVAL -1 2 628
	ENDIF
ENDIF
