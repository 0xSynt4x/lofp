VOLUME 2
IFpreVERB EXAM -1
clearverb
	ECHO OTHERS %N gazes deep into %a.
	ECHO PLAYER You gaze deep into %a.
	RANDOM DUMMY1 1 100 0
	ADD DUMMY1 300
        ifvar dummy1 = 25
        equal dummy2 1
        endif
        ifvar dummy1 = 330
        equal dummy2 1
        endif
        ifvar dummy1 = 354
        equal dummy2 1
        endif
        ifvar dummy1 = 78
        equal dummy2 1
        endif
        ifvar dummy1 = 84
        equal dummy2 1
        endif
        ifvar dummy2 = 1
        echo player The ball floods with inky shadows...%cYou hear a voice in your mind rasp, "There are some things that are not meant to be seen...See this instead!"
        echo others %N gasps in horror!
        echo player You are treated to an image of your loved ones being eaten alive by ghouls.%c%c%c
        echo player Shadows flow out of the ball and make a blade to slash you!
        echo others %N gets pummeled by huge blades of solid shadow!
        damageplr slash 100 You get struck by a huge shadow blade!!
        position lay
        else
	SHOWROOM DUMMY1
        endif
ENDIF
IFVERB RUB -1
	ECHO PLAYER It sparkles as you polish it.
ENDIF
SUBSTANCE BRITTLE
;
; lawkeeper badge
INUMBER 652
NAME 552
MISC
WEIGHT 1
VOLUME 1
WORN_DON
IFTOUCH -1
  IFVAR ORG ! 3
    ECHO PLAYER Some unseen force prevents you from touching the badge.
    CLEARVERB
  ENDIF
ENDIF
*DESCRIPTION_START EXAM
It is a simple badge crafted into the shape of a shield. There is an inscription on it.
*DESCRIPTION_END
*DESCRIPTION_START READ
"Sworn under the authority of King Fredrick III,
 To preserve and protect the citizens of Fayd and enforce her laws."
*DESCRIPTION_END
IFPREVERB TAP -1
  ECHO PLAYER Rock on Shadow!
ENDIF

IFPREVERB CONC -1
  IFVAR ORG = 3
    CLEARVERB
    SPELL 250 50
    ECHO PLAYER You concentrate, calling upon the magic in the badge.
    ECHO OTHERS %A glows with a soft silver light.
    ROUTINE 1
  ENDIF
ENDIF
IFPREVERB LOOK -1
   IFVAR INTNUM3 = 1
     CLEARVERB
     ECHO PLAYER  This is the badge of the lawkeepers.%c It's a special item and not for use by anyone else.%c Look = unstun, Concentrate = Revelation & poke will summon help.
   ELSE
   IFVAR ORG = 3
     CLEARVERB
     SPELL 338 50
     ECHO PLAYER Saved by the badge!
     GMMSG It's possible %N just got unstunned by %h lawkeeper badge - is %s hunting? If so, please @get %h badge and let Shadow know.
   ENDIF
ENDIF

IFPREVERB POKE -1
  CLEARVERB
    IFVAR RNUM > 200
      IFVAR RNUM < 400
        ADD FLAG3 1
        EQUAL DANTEMP1 1
        IFVAR FLAG3 > 5
          ECHO PLAYER You may only call so many times per location.
        ENDIF
        IFVAR FLAG3 = 1
          ECHO OTHERS %N calls for reinforcements.
        ENDIF
        IFVAR FLAG3 < 6
          ECHO PLAYER You call for reinforcements, expecting them in about a minute.
          PLREVENT 20
          CONTPLREVENT
          ECHO ALL A lawkeeper arrives.
          GENMON 18
        ENDIF
      ENDIF
    ENDIF
    IFVAR DANTEMP1 ! 1
      ECHO PLAYER You call for reinforcements, knowing they will not show up here, but hey, it may scare people.
      ECHO OTHERS %N calls for reinforcements.
    ENDIF
    EQUAL DANTEMP1 0
ENDIF

; Bracers, and bracers for MA users.
INUMBER 647
NAME 547
ARMOR
WEIGHT 3
VOLUME 1
WORN_WRIST
SUBSTANCE hardmetal
PLURAL
ARTICLE SOME

IFPREVERB LOOK -1
  IFVAR SKILL24 > 40
    ECHO PLAYER Always remember you must NOT have any strength spells cast on you before you wear these, STR spells MUST be cast after wearing them. If you think there is a problem with your strength just remove them and exit and enter the game. If this fails e-mail shadow@lofp.com
  ENDIF
ENDIF
  
IFVERB WEAR -1
  IFVAR ITEMBIT0 = 1
    IFVAR SKILL24 > 40
      IFVAR ITEMVAL5 = 0 
        EQUAL ITEMVAL5 STR
        ECHO PLAYER You place the bracers on and cross them over your chest and begin to focus your energy into them.
        ECHO OTHERS %N dons some bracers and crosses them over %h chest and closes %h eyes, a blue light flows out of the bracers and covers %i.
        PLREVENT 1
        CONTPLREVENT
        ECHO PLAYER You feel a rush of power, your power.
        ECHO OTHERS As %n opens %h eyes the light is absorbed into %h skin.
        ADD STR 125
      ENDIF
    ENDIF
  Endif
ENDIF   
  
IFPREVERB REMOVE -1
  IFVAR ITEMBIT0 = 1
    IFVAR SKILL24 > 30
      IFITEM -1 WORN
        EQUAL STR ITEMVAL5      
        EQUAL ITEMVAL5 0
        ECHO PLAYER As you remove the bracers you lose the focus on your inner power.
      ENDIF
    ENDIF
  ENDIF
ENDIF
