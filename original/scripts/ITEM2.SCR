	IFITEM -1 WORN
		IFVAR ITEMBIT5 = 1
			CLEARVERB
			EQUAL ITEMBIT5 0
			IFVAR WILDERNESS = 1
				ECHO OTHERS %N clicks %h heels together.
				ECHO PLAYER You click your heels together.%cNothing happens.
			ENDIF
			IFVAR REGION ! 0
				ECHO OTHERS %N clicks %h heels together.
				ECHO PLAYER You click your heels together.%cNothing happens.
			ENDIF
			IFVAR REGION = 0
				IFVAR WILDERNESS ! 1
					ECHO OTHERS %N clicks %h heels together and quietly vanishes.
					ECHO PLAYER You slip through space and time, arriving at Rosie's.
