			IFVAR DUMMY2 = 5
				ECHO ALL "...Vengance of the Lord, Rorin's Fire!  Repent, sinners!  Repent!  The com..."
			ENDIF
			IFVAR DUMMY2 = 6
				ECHO ALL "...an emergency situation, repeat, this is an emerg..."
			ENDIF
			IFVAR DUMMY2 = 7
				ECHO ALL "...if you're feeling sad and blue, tomatoes end it *squaaarrrk!* This is an emergency interruption... comet Ar...
			ENDIF
			IFVAR DUMMY2 = 8
				ECHO ALL "...dead they're all dead they... ...ead... ...all dead... ...ey're all dea..."
			ENDIF
			IFVAR DUMMY2 = 9
				ECHO ALL "...tions are jammed, too man.... ...off, too much skytraffic to op..."
			ENDIF
			IFVAR DUMMY2 = 10
				ECHO ALL "...sands are finishing themse... ...met can do it to... ...ood running in the streets..."
			ENDIF
		ENDIF
	ENDIF
	IFVAR DUMMY1 > 10
		IFVAR DUMMY1 < 15
			ECHO ALL %A emits a sudden burst of static.
		ENDIF
	ENDIF
	IFVAR DUMMY1 > 14
		IFVAR DUMMY1 < 18
			ECHO ALL A random babble of voices suddenly spouts from %a.
			RANDOM DUMMY2 1 5 0
			IFVAR DUMMY2 = 1
				ECHO ALL "...not expected to stri... ...undred clicks of Fayd..."
			ENDIF
			IFVAR DUMMY2 = 2
				ECHO ALL "...rin's Fury will smite the sinners and the just!  Repent!  Save your..."
			ENDIF
			IFVAR DUMMY2 = 3
				ECHO ALL "...is Leader Five, come in, Bandit Seven, come... ...terceptor attack has fai... ...repeat, failed comple..."
			ENDIF
			IFVAR DUMMY2 = 4
				ECHO ALL "...low Faydians, we must ban... ...risis... ...evil times ahead..."
			ENDIF
			IFVAR DUMMY2 = 5
				ECHO ALL "...have siezed control of this sta... ...mit or we... ...neural wav... ...ightbringers..."
			ENDIF
		ENDIF
	ENDIF
	IFVAR DUMMY1 > 17
		IFVAR DUMMY1 < 21
			RANDOM DUMMY2 1 6 0
			IFVAR DUMMY2 = 1
