; Rod
INUMBER 1176
NAME 170
WEIGHT 1
VOLUME 3
SUBSTANCE INDESTRUCTABLE
MISC
VARIABLE DENNIS
IFVERB WAVE -1
	IFVAR ITEMVAL5 ! TIM
		RANDOM DENNIS 1 55 0
		IFVAR DENNIS = 1
			ECHO ALL As soon as %n waves the rod an inverted black vortex appears and a so-ut destroyer flashes into being!
			GENMON 143
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 2
			ECHO ALL The rod glows brightly as %n waves it.
			SPELL 324
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 3
			ECHO ALL As %n waves the rod an energy maelstrom takes form lashing out at everyone present.
			SPELL 138 50
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 4
			ECHO ALL %N waves the rod and dark clouds boil into the area.
			SPELL 501
			SPELL 501
			SPELL 501
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 5
			ECHO ALL %n waves the rod and drops dead in a smoldering heap as a massive bolt of lightning strikes %i.
			DAMAGEPLR ELECTRIC 900 Hmmm.. seems the rod did not want to work for you that time.
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 6
			ECHO ALL The rod glows briefly as %n waves it.
			SPELL 133 10
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 7
			ECHO ALL The rod glows briefly.
			SPELL 510 30
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 8
			ECHO ALL The rod glows brielfy as %n waves it.
			SPELL 212
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 9
			IFVAR REGION = 0
				ECHO ALL As %n waves the rod a rip in the air appears and sucks %h in.
				MOVE 206
				AFFECT 206
				ECHO OTHERS %N is forcefully expelled from a sudden rip in the air.
				EQUAL ITEMVAL5 TIM
			ENDIF
			IFVAR REGION ! 0
				ECHO PLAYER Nothing happens.
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS = 10
			ECHO ALL A bright flash of light emenates from the rod.
			SPELL 318
			EQUAL ITEMVAL5 TIM
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 11
			IFVAR DENNIS <= 15
				ECHO ALL The rod pulses with dark energy.
				SPELL 314
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 16
			IFVAR DENNIS <= 20
				ECHO ALL The rod Flashes brilliantly for a moment.
				SPELL 234 10
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 21
			IFVAR DENNIS <= 25
				ECHO ALL The rod glows with a brilliant red light.
				SPELL 230
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 26
			IFVAR DENNIS <= 30
				ECHO ALL A ghostly light emenates from the rod and circles %n briefly.
				SPELL 218
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 31
			IFVAR DENNIS <= 35
				ECHO PLAYER Dark energy pulses from the rod.
				SPELL 118
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 36
			IFVAR DENNIS <= 40
				ECHO OTHERS A fetid stench emenates from the rod.
				ECHO PLAYER Ghostly shapes swirl from the rod and solidify into a small horde of undead.
				GENMON 131
				GENMON 130
				GENMON 183
				GENMON 184
				GENMON 182
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 41
			IFVAR DENNIS <= 45
				ECHO PLAYER The rod glows with a soothing blue glow.
				SPELL 317
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 46
			IFVAR DENNIS <= 50
				SPELL 225
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DENNIS >= 51
			IFVAR DENNIS <= 55
				ECHO ALL The rod grows momentarily translucent.
				SPELL 232
				EQUAL ITEMVAL5 TIM
			ENDIF
		ENDIF
	ENDIF
ENDIF
;
; Statue
INUMBER 1618
NAME 196
WEIGHT 5
VOLUME 5
SUBSTANCE INDESTRUCTABLE
MISC
*DESCRIPTION_START ITEM EXAM -1
The statue is sculpted in the likeness of a woman of alien yet overwhelming beauty. She stands shrouded in a toga like garment.
*DESCRIPTION_END
IFVERB CONCENTRATE -1
	IFVAR ITEMVAL5 ! TIM
		RANDOM DUMMY3 1 90 0
		IFVAR DUMMY3 <= 30
			ECHO PLAYER The statue speak in your mind, "You must provide the power for me to help you."
			ECHO OTHERS %N looks severely drained!
			IFVAR ITEMBIT1 ! 1
  			DAMAGEPLR BODYONLY 50 You feel your life force drained from you!
	  		SPELL 109 50
	    ENDIF
			IFVAR ITEMBIT1 = 1
  			DAMAGEPLR BODYONLY 80 You feel your life force drained from you!
	  		SPELL 210 80
	    ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DUMMY3 > 30
			IFVAR DUMMY3 <= 60
				ECHO PLAYER The statue whispers in your mind, "I shall do as you bid master, but as always, there is a price."
				ECHO OTHERS %N looks severely drained!
				IFVAR ITEMBIT1 ! 1
  				DAMAGEPLR BODYONLY 50 You feel your life force drained from you!
	  			SPELL 232 50
	  	  ENDIF
	  	  IFVAR ITEMBIT1 = 1
    			DAMAGEPLR BODYONLY 50 You feel your life force drained from you!
	    		SPELL 133 150
	      ENDIF
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 ! TIM
		IFVAR DUMMY3 > 60
			ECHO PLAYER The statue says, "As you wish, but the cost for this service is great indeed."
      IFVAR ITEMBIT1 ! 1
  			ECHO OTHERS %N looks on the verge of passing out!
	  		SPELL 133 100
	    ENDIF
	   	IFVAR ITEMBIT1 = 1
  			DAMAGEPLR BODYONLY 200 You feel most of your life force drain into the statue!
	  		SPELL 144 200
	    ENDIF
		ENDIF
	ENDIF
