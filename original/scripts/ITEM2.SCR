;
; Lobster
INUMBER 1389
NAME 1230
WEIGHT 1
VOLUME 1
FOOD
PARAMETER1 5
IFPREVERB EAT -1
	CLEARVERB
	IFVAR RAC < 7
		EQUAL ROUNDTIME 5
		SUBITEMVAL -1 2 1
		IFVAR ITEMVAL2 = 0
			REMOVEITEM -1
			ECHO PLAYER You gobble up the last bit of lobster meat, licking your fingers whan you are done.
			ECHO OTHERS %N licks %h fingers.
			STOP
		ENDIF
		IFVAR ITEMVAL2 = 4
			ECHO PLAYER You crack your way through the lobster's tough shell and bite into its succulent meat.
			ECHO OTHERS %N makes an absolute mess as %s rips into the lobster.
		ELSE
			ECHO PLAYER You continue to indulge in your lobster.
			ECHO OTHERS %N continues to demolish %h lobster.
		ENDIF
	ENDIF
ENDIF
