; Guide
INUMBER 950
NAME 422
WEIGHT 1
VOLUME 1
THROWN_WEAPON
PARAMETER1 1
SUBSTANCE PAPER
*DESCRIPTION_START READ
Since you can't judge a book by its cover, perhaps you should open it.
*DESCRIPTION_END
IFPREVERB OPEN -1
	EQUAL ROUNDTIME 5
	CLEARVERB
	ECHO OTHERS %N flips through the pages of %h %a.
	ECHO PLAYER You flip through the pages of the guide and read the following:%c%
	IFVAR RNUM = 1615
		ECHO PLAYER "Ask yourself for HELP when you can't COMMAND the world at your will."%c%c     - Drex Nabius
	ENDIF
	IFVAR RNUM = 1608
		ECHO PLAYER "Sometimes things are not as they appear."%c%c     - The Great Universal They
	ENDIF
	IFVAR RNUM ! 1608
		IFVAR RNUM ! 1615
			RANDOM DUMMY4 1 21 0
			IFVAR DUMMY4 = 14
				ECHO PLAYER "An adventurer never whines, especially to the gods."%c%c     - Selene Morgause
			ENDIF
			IFVAR DUMMY4 = 2
				ECHO PLAYER "It is generally important to search every nook and cranny... ...never leave a stone unturned"%c%c     The Great Universal They
			ENDIF
			IFVAR DUMMY4 = 3
				ECHO PLAYER "Things are not always as they seem, when you are stuck, try to look at the problem in every way you can."%c%c     - Magnifico the Magnific
			ENDIF
			IFVAR DUMMY4 = 4
				ECHO PLAYER "1. Keep a firm grasp on your weapon;%c 2. Keep one eye on your back; and%c 3. Always pay your death insurance."%c%c     - Drex Nabius
			ENDIF
			IFVAR DUMMY4 = 5
				ECHO PLAYER "When you are sure you have done everything, do it all again a different way."%c%c     - Drex Nabius
			ENDIF
			IFVAR DUMMY4 = 6
				ECHO PLAYER "Never assume you know how something works just because you got one result one time."%c%c     - Drex Nabius
			ENDIF
			IFVAR DUMMY4 = 7
				ECHO PLAYER "In a magical world, empirical analysis is often invalid."%c%c     - Tarinth Lintaranz
			ENDIF
			IFVAR DUMMY4 = 8
				ECHO PLAYER "There is no pleasure without pain."%c%c      - Book of Shaltos
			ENDIF
			IFVAR DUMMY4 = 9
				ECHO PLAYER "To do nothing, is in every man's power."%c%c     - Samual Johnson
			ENDIF
			IFVAR DUMMY4 = 10
				ECHO PLAYER "To attempt an adventure without adequate roots, berries, lockpicks, torches and potions is a good way to insure disaster."%c%c     - Drex Nabius
			ENDIF
			IFVAR DUMMY4 = 11
				ECHO PLAYER "The best way to attract treasure and wealth into your life is to have some room in your pack to carry it."%c%c     - Fernil Stonehand
			ENDIF
			IFVAR DUMMY4 = 12
				ECHO PLAYER "One can always hope for the best advice when consulting a Scholar of Fayd."%c%c     - Phelan Kell
			ENDIF
			IFVAR DUMMY4 = 13
				ECHO PLAYER "If you don't read the room descriptions you will probably die as well you should."%c%c     - Selene Morgause
			ENDIF
			IFVAR DUMMY4 = 1
				ECHO PLAYER "It is always best to do some advance recon of an area before charging into it headfirst.%c%c     - Zerek Von Slek, aelfen scout
			ENDIF
			IFVAR DUMMY4 = 15
				ECHO PLAYER "If at first you don't succeed, try, try again."%c%c     - The Great Universal They
			ENDIF
			IFVAR DUMMY4 = 16
				ECHO PLAYER "It is always amazing what people will just throw away, and amazing how fortunate I am at finding it."%c%c     - Fernil Stonehand
			ENDIF
			IFVAR DUMMY4 = 17
				ECHO PLAYER "Be a friend to your white necromancers: carry a little mandrake root at all times."%c%c     - Yshtarin
			ENDIF
			IFVAR DUMMY4 = 18
				ECHO PLAYER "Nothing beats a warhammer for sheer destruction."%c%c - Drex Nabius
			ENDIF
			IFVAR DUMMY4 = 19
				ECHO PLAYER "If one does not parse, one is an arse."%c%c - Selene Morgause
			ENDIF
			IFVAR DUMMY4 = 20
				ECHO PLAYER "Ask yourself for HELP when you can't COMMAND the world at your will."%c%c     - Drex Nabius
			ENDIF
			IFVAR DUMMY4 = 21
				ECHO PLAYER "Sometimes things are not as they appear."%c%c     - The Great Universal They
			ENDIF
		ENDIF
	ENDIF
	ECHO PLAYER %c[Round: 5 sec]
ENDIF
IFVERB WIELD -1
	ECHO OTHERS %N prepares to enlighten you...
ENDIF
;
; Orb that requires sun power
INUMBER 1779
NAME 151
WEIGHT 1
VOLUME 1
IFPREVERB WIELD -1
	CLEARVERB
	IFVAR DAY ! 1
		ECHO PLAYER You hoist %a over your head in the darkness of the night. As you feel some of the orb's energy drawn away, you quickly lower it.
		IFVAR ITEMVAL2 > 0
			SUB ITEMVAL2 1
			IFVAR ITEMVAL2 = 0
				SETITEMADJ -1 1 -1
			ENDIF
		ENDIF
	ENDIF
	IFVAR DAY = 1
		IFVAR ITEMVAL5 = TIM
			ECHO PLAYER You hoist %a over your head, but you can tell nothing is happening, so you stop.
		ENDIF
		IFVAR ITEMVAL5 ! TIM
			IFVAR WEA >= 2
				ECHO PLAYER You hoist %a over your head, but you quickly gather that there are too many clouds blocking the sun, and you stop.
			ENDIF
			IFVAR WEA < 2
				IFVAR WILDERNESS = 1
					ECHO PLAYER You hoist %a over your head, but it does not absorb anything from the ceiling.
				ENDIF
				IFVAR WILDERNESS ! 1
					EQUAL ROUNDTIME 60
					ECHO PLAYER You hoist %a over your head in the light of the sun. As you hold it aloft, it begins to soak up solar energy which you can feel slowly reenergizing the power locked within.%c [Round 60 sec]
					ECHO OTHERS %N hoists %a over %h head in the light of the sun.
					SETITEMVAL -1 5 TIM
					RANDOM DUMMY1 1 9 0
					IFVAR DUMMY1 > 6
						ADD ITEMVAL2 1
						SETITEMADJ -1 1 145
						PLREVENT 20
						CONTPLREVENT
						ECHO PLAYER You sense the orb has gained another charge.
						ECHO ALL The orb brightens a bit.
					ENDIF
					IFVAR DUMMY1 < 7
						PLREVENT 20
						CONTPLREVENT
						ECHO PLAYER The orb absorbs some power but not enough to add a charge.
						ECHO OTHERS %N lowers the orb with a disappointed look on %h face.
					ENDIF
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDIF
IFVERB CONCENTRATE -1
	ROUTINE 2
	IFVAR ITEMVAL2 = 0
		SETITEMADJ -1 1 -1
	ENDIF
ENDIF
IFVERB RUB -1
	ROUTINE 1
	IFVAR ITEMVAL2 = 0
		SETITEMADJ -1 1 -1
	ENDIF
ENDIF
IFTOUCH -1
	IFVAR UNDEAD = 1
		IFVAR ITEMVAL2 > 0
			CLEARVERB
			ECHO ALL %N reaches out and touches %a.%c>%c%N is vaporized as the stored up power of the sun annihilates %h putrid flesh!
			KILL PLAYER
			POSITION LAY
			SETITEMVAL -1 2 0
			SETITEMADJ -1 1 -1
		ENDIF
	ENDIF
ENDIF
IFVERB TAP -1
	IFVAR UNDEAD = 1
		IFVAR ITEMVAL2 > 0
			CLEARVERB
			ECHO ALL %N reaches out and touches %a.%c>%c%N is vaporized as the stored up power of the sun annihilates %h putrid flesh!
			KILL PLAYER
			POSITION LAY
			SETITEMVAL -1 2 0
			SETITEMADJ -1 1 -1
		ENDIF
	ENDIF
ENDIF
