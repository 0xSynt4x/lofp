INUMBER 924
NAME 552
VOLUME 1
WEIGHT 1
ARTICLE A
WORN_DON
IFTOUCH -1
  IFVAR ITEMBIT0 = 1
    IFVAR INTNUM3 = 1
      ECHO PLAYER This item is a rough prototype of the Rorinite Badge.  A non-GM who
      ECHO PLAYER touches it and is a member will have ORGRANK put into VAL5 which the RoomY script will
      ECHO PLAYER translate when they type STAT.
    ENDIF
    IFVAR INTNUM3 ! 1
      IFVAR ORG = 11
        SETITEMVAL -1 5 ORGRANK
      ENDIF
    ENDIF
  ENDIF
ENDIF
