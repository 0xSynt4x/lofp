NUMBER 49
NAME Evil City Echo Chamber!
ASTRAL
REGION 5
ECHOCHAN 148
*DESCRIPTION_START
Hey, everyone in the evil city can see you!!!!! Don't move! This is where the big cevent lives.
*DESCRIPTION_END
;-----------ucantsee-----------
ITEM 9 693
CALL 33
;------------------------------
IFENTRY -1
 IFVAR INTNUM3 ! 1
  MOVE 57
 ELSE
  ECHO PLAYER You realize, of course, that anything you do can be seen all over the Evil City?
 ENDIF
ENDIF
;--------------------------CEVENT--------------------------------
;Set the cevent to run every 15 seconds
CEVENT 147 5 49
;
;Put the timers in action
;
ADD ILZARMIN 1
;
;Define the 1 Minute events
;
IFVAR ILZARMIN > 3
;
;Tell time in the temples for sacrifices
;
	IFVAR TIM = 0
		AFFECT 71
		ECHO ALL Bells in the Cathedral Tower toll that it is the hour of Midnight.	
		AFFECT 72
		ECHO ALL Bells in the Cathedral Tower toll that it is the hour of Midnight.
		AFFECT 73
		ECHO ALL Bells in the Cathedral Tower toll that it is the hour of Midnight.
		AFFECT 76
		ECHO ALL The Chorus sings a Mass to the Dark Lord, celebrating His hour of Midnight.
		AFFECT 77
		ECHO ALL Bells in the Cathedral Tower toll that it is the hour of Midnight.				
	ENDIF
	IFVAR TIM = 12
		AFFECT 66
		ECHO ALL A shaft of bright sunlight comes through a crystal in the ceiling, illuminating the altar with the fire of the noon sun.
	ENDIF
;
;Indoor
;
	RANDOM ILZARINDOOR 1 10 0
 	IFVAR ILZARINDOOR = 1
		AFFECT 66
		ECHO ALL The light from the butter lamps flicker on the tapestries. 	
		AFFECT 74
		ECHO ALL A scribe re-rolls and ties a scroll and places it in a scoll tube.
	ENDIF
 	IFVAR ILZARINDOOR = 2
		AFFECT 66
		ECHO ALL A priest chants in prayer before the altar. 	
		AFFECT 74
		ECHO ALL Shadows dance upon the wall from a candle.
	ENDIF
 	IFVAR ILZARINDOOR = 3
		AFFECT 66
		ECHO ALL The light from the butter lamps glint off the ruby eyes of Shin-Jah's image. 	
		AFFECT 74
		ECHO ALL A pair of scribes discuss a new book.
	ENDIF
 	IFVAR ILZARINDOOR = 4
		AFFECT 66
		ECHO ALL The smell of opium drifts across the room from smoking braziers. 	
		AFFECT 74
		ECHO ALL You hear a skittering from the darkness of a shadow.
	ENDIF
 	IFVAR ILZARINDOOR = 5
		AFFECT 66
		ECHO ALL Some acoyltes clean up after a sacrifice. 	
		AFFECT 74
		ECHO ALL An elderly scholar pours over a dusty tome.
	ENDIF		
;
;Sell sacrifices event once per minute
;
	AFFECT 67
	IFVAR ILZARTIMER = 0
		ECHO ALL The auctioneer drags a human slave up onto the block. He cries, "10,000 darktars for this fine specimen."
		EQUAL ILZARAUCTION 139
		EQUAL ILZARPRICE 10000
	ENDIF
	IFVAR ILZARTIMER = 1
		ECHO ALL The auctioneer leads a tethered sheep to the block. He cries, "2,000 darktars for this animal."
		EQUAL ILZARAUCTION 200
		EQUAL ILZARPRICE 2000
	ENDIF
	IFVAR ILZARTIMER = 2
		ECHO ALL The auctioneer drags a terrified commoner to the block. He cries, "20,000 darktars for this prisoner from Fayd!"
		EQUAL ILZARAUCTION 12
		EQUAL ILZARPRICE 20000
	ENDIF
	IFVAR ILZARTIMER = 3
		ECHO ALL The auctioneer pulls an angry boar to the block. He cries, "4,000 darktars for this magnificent creature."
		EQUAL ILZARAUCTION 39
		EQUAL ILZARPRICE 4000
	ENDIF
	IFVAR ILZARTIMER = 4
		ECHO ALL The auctioneer coaxes a befuddled hill giant towards the block. He cries, "17,000 darktars for this massive fellow!"
		EQUAL ILZARAUCTION 80
		EQUAL ILZARPRICE 17000
	ENDIF
	IFVAR ILZARTIMER = 5
		ECHO ALL The auctioneer lifts a large eagle from a box. He cries, "7,000 darktars for this magnificent creature."
		EQUAL ILZARAUCTION 96
		EQUAL ILZARPRICE 7000
	ENDIF

	IFVAR ILZARTIMER < 5
		ADD ILZARTIMER 1
	ELSE
		EQUAL ILZARTIMER 0
	ENDIF
;
;reset sacrifice timer
;
	EQUAL ILZARMIN 0
ENDIF
;----------MACRO 89--------------------------------------------
MACRO 89
IFPREVERB SLAP -1
 CLEARVERB
 ECHO PLAYER You strike a slave sharply across the face.
 ECHO OTHERS %n strikes a slave sharply across the face.
 PLREVENT 0
 CONTPLREVENT
 ECHO PLAYER A slave cowers away from you.
 ECHO OTHERS A slave cowers away from %n.
ENDIF
IFPREVERB KICK -1
 CLEARVERB
 ECHO PLAYER You kick a slave out of your path.
 ECHO OTHERS %n kicks a slave out of %h path.
ENDIF
IFPREVERB CARESS -1
 CLEARVERB
 ECHO PLAYER You reach out and caress a slave.
 ECHO OTHERS %n reaches out and caresses a slave.
 PLREVENT 0
 CONTPLREVENT
 ECHO ALL A slave suffers the caress stoically.
ENDIF
IFPREVERB LEAN -1
 CLEARVERB
 ECHO PLAYER You lean on a slave for support.
 ECHO OTHERS %n leans on a slave for support.
ENDIF
IFPREVERB RAISE -1
 PLREVENT 0
 CONTPLREVENT
 ECHO ALL A slave casts his eyes down under the scrutiny.
ENDIF
IFPREVERB THUMP -1
 CLEARVERB
 ECHO PLAYER You strike a slave about the head and shoulders.
 ECHO OTHERS %n strikes a slave about the head and shoulders.
 PLREVENT 0
 CONTPLREVENT
 ECHO ALL A slave cringes under the blows.
ENDIF
