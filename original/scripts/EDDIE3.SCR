;----------------- gate ---------------
ITEM 0 1327 ADJ1=189 VAL1=999 VAL2=56 VAL3=66 UNLOCKED OPEN
;-------------- door into bailey -------------
ITEM 1 943 ADJ1=355 VAL1=999 VAL2=86 VAL3=66 UNLOCKED
;-----------ucantsee-----------
ITEM 9 693 ADJ1=50
CALL 33
;------------------------------
IFSAY Seal_the_gate!
	IFITEM 0 OPEN
		IFITEM 0 UNLOCKED
			IFVAR ORG = 23
			        CLOSE 0
				LOCK 0
				AFFECT 56
				ECHO ALL The massive gate swings shut and you hear the sounds of heavy timbers moving behind it.
				CLOSE 0
				LOCK 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out with a pair of massive beams and barricades the massive gate.
			ENDIF
			IFVAR ORG = 1
			        CLOSE 0
				LOCK 0
				AFFECT 56
				ECHO ALL The massive gate swings shut and you hear the sounds of heavy timbers moving behind it.
				CLOSE 0
				LOCK 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out with a pair of massive beams and barricades the inner gate.
			ENDIF
			IFVAR ORG = 14
			        CLOSE 0
				LOCK 0
				AFFECT 56
				ECHO ALL The massive gate swings shut and you hear the sounds of heavy timbers moving behind it.
				CLOSE 0
				LOCK 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out with a pair of massive beams and barricades the inner gate.
			ENDIF			
		ELSE
			ECHO PLAYER The gate is already locked.
		ENDIF
	ELSE
		IFITEM 0 UNLOCKED
			IFVAR ORG = 23
			        LOCK 0
				AFFECT 56
				ECHO ALL You hear the sounds of heavy timbers moving behind the gate.
				LOCK 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out with a pair of massive beams and barricades the inner gate.
			ENDIF
			IFVAR ORG = 1
			        LOCK 0
				AFFECT 56
				ECHO ALL You hear the sounds of heavy timbers moving behind the gate.
				LOCK 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out with a pair of massive beams and barricades the inner gate.
			ENDIF
			IFVAR ORG = 14
			        LOCK 0
				AFFECT 56
				ECHO ALL You hear the sounds of heavy timbers moving behind the gate.
				LOCK 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out with a pair of massive beams and barricades the inner gate.
			ENDIF			
		ELSE
			ECHO PLAYER The gate is already locked.
		ENDIF		
	ENDIF
ENDIF		
IFSAY Open_the_gate!
	IFITEM 0 CLOSED
		IFITEM 0 LOCKED
			IFVAR ORG = 23
				UNLOCK 0
				OPEN 0
				AFFECT 56
				ECHO ALL You hear timbers being moved and the massive gate swings open.
				UNLOCK 0
				OPEN 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out and removes the two massive beams which barricades the gate.
			ENDIF
			IFVAR ORG = 1
				UNLOCK 0
				OPEN 0
				AFFECT 56
				ECHO ALL You hear timbers being moved and the massive gate swings open.
				UNLOCK 0
				OPEN 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out and removes the two massive beams which barricades the gate.
			ENDIF
			IFVAR ORG = 14
				UNLOCK 0
				OPEN 0
				AFFECT 56
				ECHO ALL You hear timbers being moved and the massive gate swings open.
				UNLOCK 0
				OPEN 0
				AFFECT 85
				ECHO ALL A squad from the Dark Guard comes out and removes the two massive beams which barricades the gate.
			ENDIF			
		ENDIF
	ELSE
		ECHO PLAYER The gate is already open.
	ENDIF
ENDIF
