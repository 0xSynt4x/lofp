ENDIF
IFPREVERB PULL -1
  CLEARVERB
  IFVAR ITEMVAL3 = PLANTORIFIC
    ECHO PLAYER There doesn't seem to be any ripe fruit on the plant.
  ELSE
    EQUAL ITEMVAL3 PLANTORIFIC
    ECHO PLAYER You pluck a fruit from the plant.
    ECHO OTHERS %N plucks a fruit from %h plant.
    IFVAR ITEMVAL1 = 1
      NEWITEM -1 1886 ADJ1=327 ADJ2=40 VAL2=15 VAL3=209
    ENDIF
    IFVAR ITEMVAL1 = 2
      NEWITEM -1 1886 ADJ1=311 ADJ2=40 VAL2=152 VAL3=105
    ENDIF
    IFVAR ITEMVAL1 = 3
      NEWITEM -1 1886 ADJ1=566 ADJ2=259 VAL2=56 VAL3=102
    ENDIF
    IFVAR ITEMVAL1 = 4
      NEWITEM -1 1886 ADJ1=327 ADJ2=347 VAL2=6 VAL3=332
    ENDIF
    IFVAR ITEMVAL1 = 5
      NEWITEM -1 1886 ADJ1=738 VAL2=15 VAL3=225
    ENDIF
    IFVAR ITEMVAL1 = 6
      NEWITEM -1 1886 ADJ1=839 VAL2=23 VAL3=138
    ENDIF
    IFVAR ITEMVAL1 = 7
      NEWITEM -1 1886 ADJ1=468 ADJ2=40 VAL2=56 VAL3=144
    ENDIF
    IFVAR ITEMVAL1 = 8
      NEWITEM -1 1886 ADJ1=163 ADJ2=1132 ADJ3=152 VAL2=25 VAL3=248
    ENDIF
    IFVAR ITEMVAL1 = 9
      NEWITEM -1 1886 ADJ1=294 ADJ2=150 VAL2=9 VAL3=250
    ENDIF
    IFVAR ITEMVAL1 = 10
      NEWITEM -1 1886 ADJ1=297 ADJ2=248 VAL2=16 VAL1=1
    ENDIF
    IFVAR ITEMVAL1 = 11
      NEWITEM -1 1886 ADJ1=297 ADJ2=40 VAL2=16 VAL1=2
