    echo all A voice intones, "Unable to obtain a lock on that destination."
  else
    equal IDCto plrmark10
    echo all A voice intones, "Confirmed."
  endif
endif
ifsay COMPUTER,_ENERGIZE.
    ifvar flag1 = 449
  ifvar IDCto = 0
    equal IDCto 206
    echo all A voice intones, "Unable to query the previous location. Restoring default parameters."
  else
    echo all A voice intones, "Commencing transport now."
  endif
  plrevent 2
  contplrevent
  echo all The ceiling panels dim slightly.
  plrevent 1
  contplrevent
  echo all You hear a low-pitched, modulated tone off in the distance.
  plrevent 1
  contplrevent
  echo group You are bathed in a flash of white light! Your vision begins to fade.
  echo othgroup %P vanishes!
  affect IDCto
  equal dummy1 1
  ifvar terrain ! 7
  ifvar terrain ! 1
  ifvar terrain ! 5
    equal dummy1 0
  endif
  endif
  endif
  ifvar region ! 0
    equal dummy1 0
  endif
  ifvar dummy1 ! 1
    affect 3530
    echo all The room goes dark. A voice intones, "Destination unreachable."
  else
    echo group Your surroundings shift.
    affect 3530
    movegroup IDCto
    affect IDCto
    echo othgroup %P appears before you in a flash of bright light!
  endif
    else
  echo all A voice intones, "Please position yourself on the platform before commencing transport."
    endif
endif
ifsay COMPUTER,_SECURITY_AUTHORIZATION_CYRANO.
   ifvar IDCokay = 0
  ifvar intnum3 = 219
    echo all A voice intones, "Voice verification is confirmed. Welcome. Deactivating the security measures, please wait."
    plrevent 2
    contplrevent
    echo all The doorway shimmers for a moment.
    equal IDCokay 1
  else
    echo all A voice intones, "Only User Cyrano DeBergerac has the authority to activate this function."
  endif
   else
  echo all A voice intones, "The security systems are already deactivated."
   endif
endif
ifsay COMPUTER,_ACTIVATE_SECURITY_NET.
   ifvar IDCokay = 1
  ifvar intnum3 = 219
    echo all A voice intones, "Voice verification is confirmed. Activating the security measures. Please wait."
    plrevent 2
    contplrevent
    echo all The doorway shimmers for a moment.
    equal IDCokay 0
  else
    echo all A voice intones, "Only User Cyrano DeBergerac has the authority to activate this function."
  endif
   else
  echo all A voice intones, "The security systems are already in place."
   endif
endif
;
number 3533
astral
channel 1315
name Shuttle, Airlock
*description_start
The airlock is small and lined with reinforced metal. Though a shimmering
doorway, you can make out the bridge. Though a window to your right, you can
make out the vastness of deep space. A large, unmarked red button lies to
the side.
*description_end
item 1 1341 val2=3532
item 2 247 adj1=451 adj2=259
ifpreverb go 1
  echo player Your skin tingles as you pass through the doorway.
endif
ifverb push 2
  echo all You are sucked out of the shuttle through the hull!
  moveall 3534
endif
;
number 3534
astral
name Floating In Deep Space
channel 1315
*description_start
You hover in space, unable to breathe, suffering from the effects of deep-
space radiation. Below is Andor, a beautiful bluish-green dotted with gray-
brown continents.
*description_end
ifentry -1
ifvar intnum3 ! 1
  plrevent 5
  contplrevent
  kill player
  echo player You succumb to the effects of the radiation!
endif
endif
ifpreverb psi -1
  clearverb
  echo player You are unable to do that in your current position.
endif

ifpreverb invoke -1
  clearverb
  echo player You are unable to do that in your current position.
endif

iftouch -1
  clearverb
  echo player You are unable to do that in your current position.
endif

ifvar dummy1 ! 6969
ifvar intnum3 ! 1
  position lay
  plrevent 10
  contplrevent
  kill player
  echo player You succumb to the effects of the radiation! Within moments, you fall to Andor!
  move 206
  affect 206
  appear %S has been burnt to a crisp.
  echo others %N comes crashing down to the ground in flames!
endif
endif
;
number 3532
astral
channel 1315
name Shuttle, Bridge
*description_start
The hemispherical bridge bears an immense viewing surface that takes up most
of the far end of the room. To either side of the screen are control arrays
and seating for four crew members. Two doorways lead out.
*description_end
item 1 1597
item 2 86
item 3 86
item 4 86
item 5 86
item 6 1341 val2=3530
extend 6 leading to the transporter room
item 7 1341 val2=3533
extend 7 leading to the airlock
ifpreverb go 6
  echo player Your skin tingles as you pass through the doorway.
endif
ifpreverb go 7
  echo player Your skin tingles as you pass through the doorway.
endif
ifpreverb look 1
  clearverb
  echo player The viewing surface is filled with static.
endif
ifsay Computer,_status.
  echo all A voice intones, "Listing current operating parameters."
  plrevent 2
  contplrevent
  echo player The screen briefly flashes gray-on-white lettering:
  echo player
  echo player Primary power at one hundredth of one percent.
  echo player Backup power is nominal.
  echo player Life support is nominal.
  echo player Shields are offline.
  echo player Radiation shielding is nominal.
  echo player Weapons array is offline.
  echo player Navigation is offline.
  echo player Communications array is online.
endif
ifsay Computer,_how_are_you?
  echo all A voice intones, "The computer is functioning at 88% efficiency."
endif
ifsay computer,_raise_shields.
  echo all A voice intones, "Shields are up at .001% efficiency."
endif
ifsay computer,_lower_shields.
  echo all A voice intones, "Shields are down."
endif
ifsay computer,_fire_phasers.
  echo all A voice intones, "Insufficient power to comply with your order."
endif
ifsay Computer,_battle_stations.
  ifvar IDCalert = 1
    echo all A voice intones, "We are already at battle stations."
  else
    echo all The viewing surface flashes red briefly, and a klaxon sounds.
    equal idcalert 1
  endif
endif
ifsay Computer,_cancel_red_alert
  ifvar IDCalert = 0
    echo all A voice intones, "We are already standing down."
  else
    echo all The viewing surface goes blank. A voice intones, "Red alert cancelled."
    equal idcalert 0
  endif
endif
ifsay Computer,_descend.
  echo all A voice intones, "Navigational functions are offline."
endif
ifsay Computer,_open_communications.
  echo all A voice intones, "Communications are opened."
  affect 206
  echo all You briefly see %N's face flicker before you.
endif
ifsay Computer,_close_communications.
  echo all A voice intones, "Communications are closed."
endif
ifsay Computer,_what_is_your_favorite_color?
   echo all A voice intones, "Lime green."
endif
;
INUMBER 1887
NAME 381
VOLUME 8
WEIGHT 4
;
ifvar itemval1 = 1
  IFPREVERB LOOK -1
    CLEARVERB
    ECHO PLAYER The device is cone-shaped, and looks as though it were made of plaster. Its
    ECHO PLAYER base is tapered, with thin black lines extending radially out from its center.
    ECHO PLAYER Other than that, there is nothing remarkable about it.
  ENDIF
  IFPREVERB TAP -1
    IFVAR ITEMVAL2 = 0
      CLEARVERB
      ECHO OTHERS %N taps %a, and it begins to make a series of distinct clicking noises.
      ECHO PLAYER As you tap the device, it clicks and seems to become heavier.
      EQUAL ITEMVAL2 1
    ELSE
      CLEARVERB
      ECHO OTHERS %N taps %a, and it becomes quiet.
      ECHO PLAYER You tap the device, and it becomes quiet.
      EQUAL ITEMVAL2 0
    ENDIF
  ENDIF
  IFPREVERB TAKE -1
    ECHO ALL %A begins to glow with the light of a thousand suns!
    DAMAGEALL BURN 8000 %N is burned by %a!
    ECHO ALL %A crumbles.
    GMMSG %N set off Talizar's device. It's gone forever, keptain.
    REMOVEITEM -1
  ENDIF
  IFPREVERB TURN -1
    CLEARVERB
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER As you turn the device, you feel heavier.
      PLREVENT 2
      CONTPLREVENT
      EQUAL DUMMY1 1
      IFVAR RNUM > 200
  IFVAR RNUM < 400
    AFFECT RNUM
    ECHO ALL Suddenly, your surroundings are enveloped in a flash of white light!
    ECHO OTHGROUP %N vanishes!
    ECHO GROUP When the light dims, you find yourself elsewhere...
    EQUAL DUMMY1 2
    MOVEGROUP 1681
    AFFECT 1681
    ECHO OTHGROUP A bright light flashes before your eyes!
  ENDIF
      ENDIF
      IFVAR DUMMY1 = 1
  ECHO PLAYER Nothing happens.
      ENDIF
    ELSE
      ECHO PLAYER You turn it over in your hands.
    ENDIF
  ENDIF
endif
ifvar itemval1 = 2
  ifpreverb look -1
    clearverb
    echo player It's a small silvery pin bearing odd gold markings on the surface.
  endif
  ifverb push -1
    echo player You hear a small clicking noise from within the device.
    ifvar region = 0
      equal dummy1 0
      ifvar terrain = 5
  equal dummy1 1
      endif
      ifvar terrain = 7
  equal dummy1 1
      endif
      ifvar terrain = 1
  equal dummy1 1
      endif
      ifvar dummy1 = 1
  ifvar idcnoport = 0
    echo all A brilliant flash of white light surrounds you!
    movegroup 3530
    affect 3530
    echo othgroup A brilliant flash of white light engulfs you!
    random dummy1 1 15 0
    ifvar dummy1 = 1
      equal idcnoport 1
      echo player A voice intones, "Warning. Insufficient energy for further uplink."
    endif
  endif
      endif
    endif
  endif
endif
