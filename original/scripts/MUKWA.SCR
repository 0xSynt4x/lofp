VARIABLE VROEPOTION
;
NUMBER 3535
NAME Room of Vroe
*DESCRIPTION_START
All around you is the Vroe. Lots of people might say that you are completely
and utterly hopeless if you are here, but what the heck would the Vroe Room
be if you weren't? There is a room description here, but you are much too far
away to read it with your damn eyes, captain. STOMP your feet for
instructions.
*DESCRIPTION_END
;
; Fruit
INUMBER 1886
WEIGHT 5
VOLUME 2
NAME 92
FOOD
IFPREVERB EAT -1
  IFVAR ITEMVAL1 = 1
    ECHO PLAYER A burning sensation runs through your stomach for a moment.
    random dummy1 1 10 0
    ADD MANAPOINTS dummy1
    SUB BODYPOINTS dummy1
  ENDIF
  IFVAR ITEMVAL1 = 2
    ECHO PLAYER Your head throbs for a moment.
    EQUAL DUMMY1 ITEMVAL2
    MULT DUMMY1 2
    ADD DUMMY1 10
    ADD PSIPOINTS DUMMY1
    div dummy1 5
    sub bodypoints dummy1
  ENDIF
  IFVAR ITEMVAL1 = 3
    SPELL 102
    SPELL 105
    SPELL 109
    SPELL 209
    SPELL 225
  ENDIF
  IFVAR ITEMVAL1 = 4
    SPELL 230
  ENDIF
  IFVAR ITEMVAL1 = 5
    SPELL 533
  ENDIF
  IFVAR ITEMVAL1 = 6
    SPELL 536
    SPELL 535
  ENDIF
  IFVAR ITEMVAL1 = 7
    SPELL 351
  ENDIF
  IFVAR ITEMVAL1 = 8
    SPELL 251
    SPELL 248
  ENDIF
  random dummy1 1 100 0
  ifvar dummy1 = 1
    plrevent 2
    contplrevent
    echo player You fall to your knees!
    echo others %N falls to %h knees!
    equal roundtime 10
  endif
ENDIF
