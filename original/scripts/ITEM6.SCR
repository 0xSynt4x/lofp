;		ENDIF
;	ENDIF
;ENDIF
IFVAR ITEMBIT0 = 1
	IFPREVERB EXAMINE -1
        	IFVAR ITEMBIT18 = 1
          		ECHO PLAYER You see a triple-edged dagger, called a "Phurba", whose pommel bears intricate traceries of carving, in patterns reminiscent of grinning demonic faces. %c
          	ENDIF
        	IFVAR ITEMBIT19 = 1
          		ECHO PLAYER You see a slim black dagger with glowing silvery runes that spell out "DAHKAHN". %c
          	ENDIF	
		IFVAR INTNUM3 = 1
		;-------------------------gm message-------------------------
     			ECHO PLAYER **It's a Dahkahn/Shin-jah dagger... when they concentrate on it, it sets to them. Talk to Amer before messing with.**
     			ECHO PLAYER ITEMVAL1 is the INTNUM3 of the owner of the dagger.
     			ECHO PLAYER ITEMVAL5 determines the member's rank.
     			ECHO PLAYER ITEMBIT0 indicates it is a special Dahkahn/Shin-jah dagger.
     			ECHO PLAYER ITEMBIT18 indicates the dagger is for Shin-jah.
     			ECHO PLAYER ITEMBIT19 indicates the dagger is for Dahkahn.     			     			     			
		ENDIF
	ENDIF
	;----------------------------set dagger-------------------	
	IFPREVERB CONCENTRATE -1
		IFVAR ITEMVAL1 = 0
    			IFVAR POSITION ! 3
      				CLEARVERB
				ECHO PLAYER You must adopt a kneeling posture of respect to bond with the dagger.
			ENDIF
    			IFVAR POSITION = 3    
				IFVAR RNUM = 66
      				ECHO PLAYER You say, "I offer my life to you, Shin-jah, Mistress of Death."
       				ECHO OTHERS %n says, "I offer my life to you, Shin-jah, Mistress of Death."      				
		       		ECHO PLAYER You concentrate on the dagger.%c The dagger flares with hot orange flames.
					ECHO OTHERS %n concentrates on the dagger.%c The dagger flares with hot orange flames.
					ECHO PLAYER The dagger says "You and I are one now, we belong together."
       				SETITEMVAL -1  1 INTNUM3
					SETITEMVAL -1 3 0
					SETITEMVAL -1 4 0      
				ENDIF        			
				IFVAR RNUM = 76
			        	ECHO PLAYER You say, "I offer my life and my soul to you, Great Dahkahn, Dread Lord of the All Seeing Eye."
       				ECHO OTHERS %n says, "I offer my life and my soul to you, Great Dahkahn, Dread Lord of the All Seeing Eye."
		       		ECHO PLAYER You concentrate on the dagger.%c The dagger flares with cold black fire.
					ECHO OTHERS %n concentrate on the dagger.%c The dagger flares with cold black fire.
					ECHO PLAYER The dagger says "You and I are one now, we belong together."
       				SETITEMVAL -1  1 INTNUM3
					SETITEMVAL -1 3 0
					SETITEMVAL -1 4 0      
				ENDIF        			
    			ENDIF
    	    	ENDIF
		IFVAR ITEMVAL1 = INTNUM3
			IFVAR ITEMVAL5 < 21
          			ECHO PLAYER You have attained the rank of Neophyte.%c          To heal thyself, polish me.
          			ECHO OTHERS %n's dagger displays the symbol for a Neophyte.
        		ENDIF
        		IFVAR ITEMVAL5 > 20
          			IFVAR ITEMVAL5 < 41
            				ECHO PLAYER You have attained the rank of Acolyte.%c          To heal thyself, polish me.
            				ECHO OTHERS %n's dagger displays the symbol for an Acolyte.
          			ENDIF
        		ENDIF
        		IFVAR ITEMVAL5 > 40
          			IFVAR ITEMVAL5 < 61
        				IFVAR ITEMBIT18 = 1
          					ECHO PLAYER You have attained the rank of Slayer.%c          To heal thyself, polish me.%c          For protection, pinch me. 
            				ECHO OTHERS %n's dagger displays the symbol for a Slayer.
          				ENDIF
        				IFVAR ITEMBIT19 = 1
          					ECHO PLAYER You have attained the rank of Student.%c          To heal thyself, polish me.%c          For protection, pinch me.
            				ECHO OTHERS %n's dagger displays the symbol for a Student.
          				ENDIF             			
          			ENDIF
        		ENDIF
        		IFVAR ITEMVAL5 > 60
          			IFVAR ITEMVAL5 < 81
        				IFVAR ITEMBIT18 = 1
          					ECHO PLAYER You have attained the rank of a Master Slayer.%c          To heal thyself, polish me.%c          For protection, pinch me.
            				ECHO OTHERS %n's dagger displays the symbol for a Black Ngagspa.
          				ENDIF
        				IFVAR ITEMBIT19 = 1
          					ECHO PLAYER You have attained the rank of Scholar.%c          To heal thyself, polish me.%c          For protection, pinch me.
            				ECHO OTHERS %n's dagger displays the symbol for a Scholar.
          				ENDIF           			
          			ENDIF
        		ENDIF
        		IFVAR ITEMVAL5 > 80
          			IFVAR ITEMVAL5 < 101
        				IFVAR ITEMBIT18 = 1
          					ECHO PLAYER You have attained the rank of Deathstrike.%c          To heal thyself, polish me.%c          For protection, pinch me.%c          To quickly travel to the Temple, Kiss me.
            				ECHO OTHERS %n's dagger displays the symbol for a Deathstrike.
          				ENDIF
        				IFVAR ITEMBIT19 = 1
          					ECHO PLAYER You have attained the rank of Philosopher.%c          To heal thyself, polish me.%c          For protection, pinch me.%c          To quickly travel to the Temple, Kiss me.
            				ECHO OTHERS %n's dagger displays the symbol for a Philospher.
          				ENDIF           			
          			ENDIF
        		ENDIF
        		IFVAR ITEMVAL5 > 100
        			ECHO PLAYER You have attained the rank of High Priest.%c          To heal thyself, polish me.%c          For protection, pinch me.%c          To quickly travel to the Temple, Kiss me.
         			ECHO OTHERS %n's dagger displays the symbol for a High Priest.
        		ENDIF
		ENDIF    	    		    		
  	ENDIF
	;-------------------keeps it from being dropped or deposited
	IFPREVERB DROP -1
  		CLEARVERB
		ECHO PLAYER The dagger refuses to budge.
	ENDIF
	IFPREVERB DEPOSIT -1
		CLEARVERB
		ECHO PLAYER The dagger refuses to budge.
	ENDIF
	;-------------------------- prevent taking dagger thats not yours -------------------------
	IFPREVERB TAKE -1
		IFVAR ITEMVAL1 ! INTNUM3
			CLEARVERB
			DAMAGEPLR ELECTRIC 170 The dagger jumps from your grasp and flares darkly, zapping you.
			ECHO OTHERS %N reaches for %a, but it flares with a black snap.
			GMMSG **%n just tried to take a Dahkahn/Shin-jah dagger.
		ENDIF
    	ENDIF
	;------------------------ prevent theft ----------------------
	IFPREVERB STEAL -1
		IFVAR ITEMVAL1 ! INTNUM3
			CLEARVERB
			DAMAGEPLR ELECTRIC 170 The dagger jumps from your grasp and flares darkly, zapping you.
			ECHO OTHERS %N reaches for %a, but it flares with a black snap.
			GMMSG **%n just tried to steal a Dahkahn/Shin-jah dagger.
		ENDIF
    	ENDIF
	;---------------------craft a dagger ------------------
	IFPREVERB POKE -1
		IFVAR ITEMVAL5 > 100
			IFVAR RNUM = 66
				CLEARVERB
				ECHO OTHERS %N chants arcane words and a small dagger starts to form upon the floor near the altar.
				ECHO PLAYER You create a dagger upon the floor near the altar.
				NEWITEM 8 1892 VAL5=1
			ENDIF
			IFVAR RNUM = 76
				CLEARVERB
				ECHO OTHERS %N chants arcane words and a small dagger starts to form upon the floor near the altar.
				ECHO PLAYER You create a dagger upon the floor near the altar.
				NEWITEM 8 1892 VAL5=1
			ENDIF
		ENDIF
	ENDIF    	
	;--------------------Listen to Dagger---------------------
	IFPREVERB LISTEN -1
		CLEARVERB
		IFVAR ITEMVAL1 = INTNUM3
			IFVAR ITEMVAL5 < 21
          			ECHO PLAYER You have attained the rank of Neophyte.%c          To heal thyself, polish me.
        		ENDIF
        		IFVAR ITEMVAL5 > 20
          			IFVAR ITEMVAL5 < 41
            				ECHO PLAYER You have attained the rank of Acolyte.%c          To heal thyself, polish me.
          			ENDIF
        		ENDIF
        		IFVAR ITEMVAL5 > 40
          			IFVAR ITEMVAL5 < 61
        				IFVAR ITEMBIT18 = 1
          					ECHO PLAYER You have attained the rank of Slayer.%c          To heal thyself, polish me.%c          For protection, pinch me. 
          				ENDIF
        				IFVAR ITEMBIT19 = 1
          					ECHO PLAYER You have attained the rank of Student.%c          To heal thyself, polish me.%c          For protection, pinch me.
          				ENDIF             			
          			ENDIF
        		ENDIF
        		IFVAR ITEMVAL5 > 60
          			IFVAR ITEMVAL5 < 81
        				IFVAR ITEMBIT18 = 1
          					ECHO PLAYER You have attained the rank of a Master Slayer.%c          To heal thyself, polish me.%c          For protection, pinch me.
          				ENDIF
        				IFVAR ITEMBIT19 = 1
          					ECHO PLAYER You have attained the rank of Scholar.%c          To heal thyself, polish me.%c          For protection, pinch me.
          				ENDIF           			
          			ENDIF
        		ENDIF
        		IFVAR ITEMVAL5 > 80
          			IFVAR ITEMVAL5 < 101
        				IFVAR ITEMBIT18 = 1
          					ECHO PLAYER You have attained the rank of Deathstrike.%c          To heal thyself, polish me.%c          For protection, pinch me.%c          To quickly travel to the Temple, Kiss me.
          				ENDIF
        				IFVAR ITEMBIT19 = 1
          					ECHO PLAYER You have attained the rank of Philosopher.%c          To heal thyself, polish me.%c          For protection, pinch me.%c          To quickly travel to the Temple, Kiss me.
          				ENDIF           			
          			ENDIF
        		ENDIF
        		IFVAR ITEMVAL5 > 100
        			ECHO PLAYER You have attained the rank of High Priest.%c          To heal thyself, polish me.%c          For protection, pinch me.%c          To quickly travel to the Temple, Kiss me.
        		ENDIF
         		ECHO OTHERS %n's dagger glows.
		ENDIF
	ENDIF
	;--------------------Rub dagger --------------------
	IFPREVERB RUB -1
		IFVAR ROUNDTIME ! 0
			CLEARVERB
			STRCVT 1 ROUNDTIME
			ECHO PLAYER [Wait %1 seconds...]
		ENDIF
		IFVAR ROUNDTIME = 0
			CLEARVERB
			EQUAL ROUNDTIME 3
        		IFVAR ITEMBIT18 = 1
    				ECHO PLAYER Your dagger flares with a strong dark gold light as you prick your wrist with it.%c[Round: 3 sec]		
  				ECHO OTHERS %N pricks %h wrist with %a and it flares with a strong dark gold light.
          		ENDIF
        		IFVAR ITEMBIT19 = 1
    				ECHO PLAYER Your dagger flares with a strong dark silvery light as you slash your palm with it.%c[Round: 3 sec]		
  				ECHO OTHERS %N slashes %h palm with %a and it flares with a strong dark silvery light.
          		ENDIF 			
			IFVAR UNDEAD = 0
				IFVAR ITEMVAL5 < 21
  					SPELL 316 100	
				ENDIF
        			IFVAR ITEMVAL5 > 20
          				IFVAR ITEMVAL5 < 41
  						SPELL 317 100
  					ENDIF	
				ENDIF
        			IFVAR ITEMVAL5 > 40
          				IFVAR ITEMVAL5 < 61
  						SPELL 318 100	
					ENDIF
				ENDIF
        			IFVAR ITEMVAL5 > 60
          				IFVAR ITEMVAL5 < 81
						SPELL 303 100
						SPELL 318 100
					ENDIF
				ENDIF
        			IFVAR ITEMVAL5 > 80
          				IFVAR ITEMVAL5 < 101
						SPELL 303 100
						SPELL 319 100
  						SPELL 318 100
  					ENDIF	
				ENDIF
				IFVAR ITEMVAL5 > 100
					SPELL 303 100
					SPELL 319 100
  					SPELL 318 100
  					SPELL 318 100
					SPELL 343 100
				ENDIF
			ENDIF
			IFVAR UNDEAD = 1
				IFVAR ITEMVAL5 < 21
  					SPELL 337 100	
				ENDIF
        			IFVAR ITEMVAL5 > 20
          				IFVAR ITEMVAL5 < 41
  						SPELL 337 100	
						SPELL 337 100
					ENDIF
				ENDIF
        			IFVAR ITEMVAL5 > 40
          				IFVAR ITEMVAL5 < 61
  						SPELL 337 100	
						SPELL 337 100
						SPELL 337 100
					ENDIF
				ENDIF
        			IFVAR ITEMVAL5 > 60
          				IFVAR ITEMVAL5 < 81
						SPELL 337 100
						SPELL 337 100
						SPELL 337 100
						SPELL 337 100
					ENDIF
				ENDIF
        			IFVAR ITEMVAL5 > 80
          				IFVAR ITEMVAL5 < 101
						SPELL 337 100
						SPELL 337 100
  						SPELL 337 100	
						SPELL 337 100
  						SPELL 337 100
  					ENDIF
				ENDIF
				IFVAR ITEMVAL5 > 100
					SPELL 337 100
					SPELL 337 100
  					SPELL 337 100
					SPELL 337 100
					SPELL 337 100
				ENDIF
			ENDIF
		ENDIF
	ENDIF
	;--------------------Pinch dagger --------------------
	IFPREVERB PINCH -1
		IFVAR ROUNDTIME ! 0
			CLEARVERB
			STRCVT 1 ROUNDTIME
			ECHO PLAYER [Wait %1 seconds...]
		ENDIF
		IFVAR ROUNDTIME = 0
			CLEARVERB
			IFVAR ITEMVAL5 > 40
				EQUAL ROUNDTIME 3
        			IFVAR ITEMBIT18 = 1
     					ECHO PLAYER Your dagger flys around you forming shields of protection.%c[Round: 3 sec]		
  					ECHO OTHERS %N releases %a and it flys around %i forming shields of protection.
          			ENDIF
        			IFVAR ITEMBIT19 = 1
    					ECHO PLAYER As you raise the dagger above your head black waves of cold fire form shields of protection.%c[Round: 3 sec]		
  					ECHO OTHERS %N raises %a above %h head and black waves of cold fire form shields of protection around %i.
          			ENDIF 		
        			IFVAR ITEMVAL5 > 40
          				IFVAR ITEMVAL5 < 61
  						SPELL 326 100
  					ENDIF	
				ENDIF
        			IFVAR ITEMVAL5 > 60
          				IFVAR ITEMVAL5 < 81
						SPELL 326 100
						SPELL 102 100
					ENDIF
				ENDIF
        			IFVAR ITEMVAL5 > 80
          				IFVAR ITEMVAL5 < 101
						SPELL 326 100
						SPELL 102 100
  						SPELL 105 100
  					ENDIF	
				ENDIF
				IFVAR ITEMVAL5 > 100
					SPELL 326 100
					SPELL 102 100
  					SPELL 133 100
				ENDIF
			ENDIF	
		ENDIF
	ENDIF		
	;---------------------teleport ------------------
	IFPREVERB KISS -1
		IFVAR ITEMVAL5 > 80
			IFVAR ITEMBIT18 = 1
				CLEARVERB
				IFVAR RNUM ! 66
					DISBAND
					ECHO OTHERS %N holds the dagger out in front of %i, pointing it into the distance.%cSuddenly %N leaps into the air!
					ECHO PLAYER You point the dagger toward the Temple, somehow you feel the correct direction. It pulls you into the air.
					PLREVENT 0
					CONTPLREVENT
					MOVE 2145
					AFFECT 2145
					ECHO PLAYER You soar through the air, the dagger pulling you along!						
					ECHO OTHERS %N soars by, a glowing dagger in %h hand.
					SHOWROOM 2145
					PLREVENT 2
					CONTPLREVENT
					ECHO PLAYER You dive towards the Temple!
					MOVE 66
					AFFECT 66
					ECHO OTHERS %N flys into the room!
					ECHO PLAYER You arrive at the heart of Shin-jah.
					SHOWROOM 66
				ENDIF			    	
			ENDIF
			IFVAR ITEMBIT19 = 1
				CLEARVERB
				IFVAR RNUM ! 76
					DISBAND
					ECHO OTHERS %N holds the dagger out in front of %i, pointing it into the distance.
					ECHO PLAYER You point the dagger toward the Dark Cathedral, somehow you feel the correct direction.
					PLREVENT 0
					CONTPLREVENT
					ECHO PLAYER You slash a hole in the fabric of reality with the rune dagger!						
					ECHO OTHERS %N slashes at the air with a glowing rune dagger, and a hole appaears.
					PLREVENT 2
					CONTPLREVENT
					ECHO PLAYER You step into the hole and it closes behind you!						
					ECHO OTHERS %N steps into the hole and it closes behind %i.
					MOVE 76
					AFFECT 76
					ECHO OTHERS %N appears in the room!
					ECHO PLAYER You arrive in Dahkahn's Dark Cathedral.
					SHOWROOM 76
				ENDIF		
			ENDIF
		ENDIF
	ENDIF
ENDIF
