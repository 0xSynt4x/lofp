variable patgrim
;
; wight dust urn
INUMBER 75
NAME 218
WEIGHT 8
VOLUME 3
CONTAINER IN
INTERIOR 10
MISC
SUBSTANCE INDESTRUCTABLE
IFPREVERB2 PUT -1
clearverb
        IFVAR ARCHNUM = 505
                IFVAR ITEMADJ2 = 547
                ECHO PLAYER You place the claw into the urn. Suddenly you hear a rumbling noise as the claw is ground into dust.
                ECHO OTHERS %N puts a wight claw into %h urn. Suddenly, you hear a rumbling sound as the claw it ground into dust.
                REMOVEITEM -1
                NEWITEM 9 512 ADJ2=547
                ENDIF
        endif
        IFVAR ARCHNUM = 510
                IFVAR ITEMADJ2 = 547
                ECHO PLAYER You place the tooth into the urn. Suddenly you hear a rumbling noise as the tooth is ground into dust.
                ECHO OTHERS %N puts a wight tooth into %h urn. Suddenly, you hear a rumbling sound as the tooth it ground into dust.
                REMOVEITEM -1
                NEWITEM 9 512 ADJ2=547
                ENDIF
        ENDIF
ENDIF

; Mirror (container)
INUMBER 428
NAME 137
MISC
WEIGHT 1
PARAMETER2 11
VOLUME 8
SUBSTANCE INDESTRUCTABLE
CONTAINER IN
INTERIOR 500
IFPREVERB RUB -1
        CLEARVERB
        IFVAR ITEMBIT5 = 1
                IFVAR ITEMVAL5 = INTNUM3
                ECHO PLAYER You rub the glass of the mirror. It slowly becomes more pliable until you can reach your hand into it.
                ECHO OTHERS %N rubs the glass surface of %h mirror.
                OPEN -1
                ELSE
                ECHO PLAYER You rub a mirror.
                ECHO OTHERS %N rubs a mirror
                ENDIF
        ENDIF
ENDIF
IFPREVERB LOOK -1
        IFVAR ITEMBIT5 ! 1
        ECHO PLAYER you see your reflection.
        ENDIF
ENDIF
IFPREVERB GAZE -1
        CLEARVERB
        IFVAR ITEMBIT5 ! 1
        ECHO PLAYER You see your reflection.
        ENDIF
        IFVAR ITEMBIT5 = 1
                IFVAR ITEMVAL5 = 0
                        IFVAR INTNUM3 ! 1
                        ECHO PLAYER The mirror starts off showing your reflection, but slowly clouds over. You feel soft probes analyze your mind. You get the feeling you are bound to this mirror somehow.
                        EQUAL ITEMVAL5 INTNUM3
                        ELSE
                        ECHO PLAYER You see your reflection.
                        ENDIF
                ENDIF
        ENDIF
ENDIF
IFPREVERB TOUCH -1
        CLEARVERB
        IFVAR ITEMBIT5 = 1
                IFVAR ITEMVAL5 = INTNUM3
                ECHO PLAYER Your fingers touch on some familiar pressure points on the mirror's frame. Slowly, the glass becomes more rigid, until you can no longer reach your hand into it.
                ECHO OTHERS %N touches the frame of %h mirror in a quick, odd fashion.
                CLOSE -1
                ELSE
                ECHO PLAYER You touch a mirror.
                ECHO OTHERS %N touches a mirror.
                ENDIF
        ENDIF
ENDIF
IFPREVERB2 GET -1
        CLEARVERB
        IFVAR ITEMBIT5 = 1
                IFVAR ITEMVAL5 ! INTNUM3
                ECHO PLAYER You cannot reach your hand into the mirror. You keep banging your knuckles into the glass.
                ECHO OTHERS %N seems to be trying to punch a mirror.
                ELSE
                ECHO PLAYER You reach your hand into the mirror. It disappears from view.
                ECHO OTHERS %N reaches %h hand into a mirror. %h hand disappears from view.
                ENDIF
        ENDIF
ENDIF

; Bracelet
INUMBER 330
NAME 33
MISC
WEIGHT 1
PARAMETER2 2
VOLUME 3
WORN_WRIST
SUBSTANCE INDESTRUCTABLE
CONTAINER ON
INTERIOR 10
IFPREVERB LOOK -1
        IFVAR INTNUM3 = 1
        ECHO PLAYER This is a charm bracelet which gives mist form.
        endif
ENDIF
IFPREVERB RUB -1
        CLEARVERB
        IFITEM -1 WORN
        ECHO PLAYER You rub your bracelet. Your hand begins to tingle. Suddenly, you boil away into mist.
        ECHO OTHERS %N rubs %h bracelet. Suddenly, %i boils away into mist.
        SPELL 232 30
        ENDIF
ENDIF
IFPREVERB2 PUT -1
        IFVAR ARCHNUM = 1096
                IFVAR ITEMADJ3 = 93
                EQUAL ITEMVAL3 1
                ECHO PLAYER You put the diamond charm on the charm bracelet.
                ECHO OTHERS %N puts a diamond charm on the charm bracelet.
                ELSE
                CLEARVERB
                ECHO PLAYER You can't put that there.
                endif
        ENDIF
ENDIF
IFPREVERB CAST -1
        IFVAR SPELLNUM = 204
        clearverb
        ECHO PLAYER You gesture at the bracelet. The power of your spell bounces off the bracelet and coaleces into a diamond charm.
        ECHO OTHERS %N gestutes at the bracelet. The power of %h spell bounces off the bracelet and coaleses into a diamond charm.
        NEWITEM 9 1096 ADJ2=93 VAL1=1
        ENDIF
ENDIF

