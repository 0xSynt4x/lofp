variable idscarab
VARIABLE BPIPEROOM

MACRO 5

ifpreverb open -1
  ifitem -1 open
    ifitem -1 locked
      close -1
    endif
  endif
endif
iftouch -1
  ifitem -1 open
    ifitem -1 locked
      close -1
    endif
  endif
endif
ifpreverb dump -1
  ifvar rac =  8
    ifvar lev > 9
      ifitem -1 locked
        ifvar roundtime ! 0
          clearverb
          strcvt 0 roundtime
          echo player [Round: %0 Sec]
          stop
        endif
        ifvar lev > agi
          equal dummy1 agi
        endif
        ifvar lev <= agi
          equal dummy1 lev
        endif
        ifvar dummy1 < itemval1
          random dummy2 1 20 0
          ifvar dummy2 ! 1
            clearverb
            echo player You reach into the chest and try to pull out its contents, but you are unsuccessful.
            echo others %N reaches %h hands right into the chest and rummages around.
            equal roundtime 6
            echo player [Round: 6 Sec]
          else
            echo player You reach into the chest and successfully pull out its contents.
            echo others %N reaches %h hands right into the chest!
            open -1
            equal roundtime 20
            echo player [Round: 20 Sec]
          endif
          ifvar dummy1 = 18
            echo player Part of your hand becomes solid while still in the chest!
            echo others %N grimaces in pain.
            damageplr crush 12 Wow! That really stings.
          endif
        else
          random dummy2 1 4 0
          ifvar dummy2 ! 1
            clearverb
            echo player You reach into the chest and try to pull out its contents, but you are unsuccessful.
            echo others %N reaches %h hands right into the chest and rummages around.
            equal roundtime 6
            echo player [Round: 6 Sec]
          else
            echo player You reach into the chest and successfully pull out its contents.
            echo others %N reaches %h hands right into the chest!
            open -1
            equal roundtime 20
            echo player [Round: 20 Sec]
          endif
        endif
      endif
    endif
  endif
endif
ifpreverb look -1
  ifitem -1 locked
    ifvar rac ! 8
      close -1
    else
      ifvar disguised = 1
        ifvar roundtime ! 0
          clearverb
          strcvt 0 roundtime
          echo player [Round: %0 Sec]
          stop
        else
          echo player You secretly attempt to take a peek in the locked chest.
          skillcheck 33 -100 dummy1
          ifvar dummy1 >= 0
            echo player You did it!
            equal roundtime 15
            echo player [Round: 15 Sec]
            open -1
          endif
          ifvar dummy1 < 0
            echo player You fail to get a peek in the chest.
            equal roundtime 5
            echo player [Round: 5 Sec]
          endif
          ifvar dummy1 < -80
            echo player Oh no! You solidify part of your body in the chest!
            echo others You hear something hiss in pain.
            spell 250 50
            damageplr crush 50 You don't remember anything being quite this painful.
          endif
        endif
      endif
    endif
  endif
endif
ifpreverb gaze -1
  ifvar rac = 8
    ifitem -1 open
      ifitem -1 locked
        clearverb
        echo player You smile to yourself as you look at the locked chest you just looted.
        close -1
      endif
    endif
  endif
endif
