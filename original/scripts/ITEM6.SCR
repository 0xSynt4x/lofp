;
;staff(creod)
INUMBER 1302
NAME 194
WEIGHT 1
VOLUME 5
SUBSTANCE BRITTLE
MISC
IFVAR ITEMBIT1 ! 1
  EQUAL ITEMBIT1 1
  EQUAL ITEMVAL4 ITEMVAL2
  EQUAL ITEMVAL2 ITEMVAL1
  EQUAL ITEMVAL1 ITEMVAL4
  EQUAL ITEMVAL4 0
ENDIF
IFPREVERB PUT -1
  CLEARVERB
  ECHO PLAYER It won't fit.
ENDIF
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER GM Note : This is a special mage's staff. Don't use unless you actually want a special mage's staff.%c---%c
  ENDIF
  ECHO PLAYER You see a very light and delicate staff. It seems to be hollow.
ENDIF
IFPREVERB CAST -1
  CLEARVERB
  IFVAR ITEMBIT0 = 0
    ECHO PLAYER You can feel the staff lock onto your energy. From now on, only you may tap it.
    EQUAL ITEMBIT0 1
    EQUAL ITEMBIT1 1
    EQUAL ITEMVAL1 INTNUM3
  ENDIF
  IFVAR SPELLNUM = 412
    IFVAR ITEMVAL3 > 5
      ECHO PLAYER The staff cannot be charged while it still has power.
    ELSE
      IFVAR ITEMVAL5 = TIM
        ECHO PLAYER The staff will not absorb your energy.
        ECHO OTHERS Bright lights flash all around %N!
      ELSE
        EQUAL ITEMVAL3 0
        ECHO PLAYER You channel your power into the staff. It is exhausting.
        ECHO OTHERS %N gestures at a staff. A wave of power floods into it. %N looks exhausted.
        DIV MANAPOINTS 5
        EQUAL ITEMVAL2 MANAPOINTS
        EQUAL dummy1 LEV
        MULT DUMMY1 5
        IFVAR ITEMVAL2 > DUMMY1
          EQUAL ITEMVAL2 DUMMY1
        ENDIF
        EQUAL MANAPOINTS 0
        DIV FATPOINTS 2
        DIV PSIPOINTS 2
        EQUAL ITEMVAL3 10
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB CONCENTRATE -1
  CLEARVERB
  IFVAR INTNUM3 ! ITEMVAL1
    EQUAL DUMMY2 1
  ENDIF
  IFVAR ITEMVAL3 = 0
    EQUAL DUMMY2 1
  ENDIF
  IFVAR DUMMY2 = 1
    ECHO PLAYER You concentrate over a staff.
    ECHO OTHERS %N focuses at a staff.
  ELSE
    EQUAL ROUNDTIME 6
    ECHO PLAYER You tap into a power pocket in your creod staff.
    ECHO OTHERS %N concentrates on a staff. Sparks shoot out of the staff and into %N!
    ADD MANAPOINTS ITEMVAL2
    SUB ITEMVAL3 1
    EQUAL DUMMY1 LEV
    MULT DUMMY1 5
    IFVAR MANAPOINTS > DUMMY1
      EQUAL MANAPOINTS DUMMY1
    ENDIF
  ENDIF
ENDIF
IFPREVERB TAP -1
  CLEARVERB
  ECHO PLAYER You rap your staff on the ground.
  ECHO OTHERS %N taps the butt of %h staff on the ground.
  IFVAR INTNUM3 = ITEMVAL1
    IFVAR ORG = 2
      IFVAR WIELDED = 0
        IFVAR ITEMVAL5 ! TIM
          SPELL 113 30
          EQUAL ITEMVAL5 TIM
        ENDIF
      ELSE  
        ECHO PLAYER Your hands must be empty to use the staff that way.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB RUB -1
  CLEARVERB
  ECHO PLAYER You rub your hand along the staff.
  ECHO OTHERS %N rubs %h hand along the staff.
  IFVAR INTNUM3 = ITEMVAL1
    IFVAR ORG = 2
      IFVAR WIELDED = 0
        IFVAR ITEMVAL5 ! TIM
          IFVAR ORGRANK > 49
            SPELL 406
            EQUAL ITEMVAL5 TIM
          ENDIF
        ENDIF
      ELSE  
        ECHO PLAYER Your hands must be empty to use the staff that way.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB PUSH -1
  CLEARVERB
  ECHO PLAYER You hold the staff up over your head.
  ECHO OTHERS %N holds %h staff over %h head.
  IFVAR INTNUM3 = ITEMVAL1
    IFVAR ORG = 2
      IFVAR WIELDED = 0
        IFVAR ITEMVAL5 ! TIM
          IFVAR ORGRANK > 99
            SPELL 107
            EQUAL ITEMVAL5 TIM
          ENDIF
        ENDIF
      ELSE  
        ECHO PLAYER Your hands must be empty to use the staff that way.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB PULL -1
  CLEARVERB
  ECHO PLAYER You swing your staff around in a whiplike motion.
  ECHO OTHERS %N swings %h staff around in a whiplike motion.
  IFVAR INTNUM3 = ITEMVAL1
    IFVAR ORG = 2
      IFVAR WIELDED = 0
        IFVAR ITEMVAL5 ! TIM
          IFVAR ORGRANK > 199
            SPELL 109
            EQUAL ITEMVAL5 TIM
          ENDIF
        ENDIF
      ELSE  
        ECHO PLAYER Your hands must be empty to use the staff that way.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB LEAN -1
  CLEARVERB
  ECHO PLAYER You lean on your staff.
  ECHO OTHERS %N leans on %h staff.
  IFVAR INTNUM3 = ITEMVAL1
    EQUAL ROUNDTIME 5
    RANDOM DUMMY1 1 10 0
    IFVAR DUMMY1 = 1
      SPELL 113 30
    ENDIF
    IFVAR DUMMY1 = 2
      SPELL 224 30
    ENDIF
    IFVAR DUMMY1 = 3
      SPELL 127 30
    ENDIF
    IFVAR DUMMY1 = 4
      SPELL 521 30
    ENDIF
    IFVAR DUMMY1 = 5
      SPELL 315 30
    ENDIF
    IFVAR DUMMY1 = 6
      SPELL 335
    ENDIF
    IFVAR DUMMY1 = 7
      SPELL 318
    ENDIF
    IFVAR DUMMY1 = 8
      SPELL 105
    ENDIF
    IFVAR DUMMY1 = 9
      SPELL 231 30
    ENDIF
    IFVAR DUMMY1 = 10
      SPELL 230 30
    ENDIF
  ENDIF
ENDIF
;
;Jakana (Pet)
INUMBER 1301
NAME 12
WEIGHT 1
VOLUME 1
MISC
TURNABLE
FLIPABLE
WORN_DON
IFPREVERB LOOK -1
  CLEARVERB
  ECHO PLAYER You gaze into the amphibous eyes of a jakana from the jungle island. The jakana vary in color, but their eyes are always black and their suctioned toes are always long.
ENDIF
IFPREVERB RUB -1
  CLEARVERB
  ECHO PLAYER You rub your finger along the jakana's spine. It is very slimey.
  ECHO OTHERS %N rubs %h fingers along the back of the jakana, then looks at %h fingers.
ENDIF
IFPREVERB WEAR -1
  CLEARVERB
  ECHO PLAYER The jakana scampers up to the top of your head to look around. It grabs onto either side of your face with its long toes.
  ECHO OTHERS A jakana climbs onto the top of %N's head to have a look around.
ENDIF
IFPREVERB TAP -1
  CLEARVERB
  ECHO PLAYER You lightly tap your jakana. It flicks its tail.
  ECHO OTHERS %N lightly taps %h jakana. It flicks its tail.
ENDIF
IFPREVERB HUG -1
  CLEARVERB
  ECHO PLAYER You attempt to hug your jakana, but it squirms out of your grasp.
  ECHO OTHERS %N attemmpts to hug %h jakana, but it squirms out of %h grasp.
ENDIF
IFPREVERB KISS -1
  CLEARVERB
  ECHO PLAYER You go to kiss your jakana. Its sticky tongue slaps you in the nose.
  ECHO OTHERS %N puckers up towards %h jakana. It licks %h nose with its sticky tongue.
ENDIF
IFPREVERB LICK -1
  CLEARVERB
  ECHO PLAYER As much as you like it, you can't bring yourself to lick it.
  ECHO OTHERS %N looks at %h jakana, then flinches.
ENDIF
IFPREVERB KICK -1
  CLEARVERB
  ECHO PLAYER You go to kick the jakana and it clings on to your foot!
  ECHO OTHERS %N goes to kick %h jakana, but it clings on to his foot.
ENDIF
IFPREVERB POKE -1
  CLEARVERB
  ECHO PLAYER You poke your jakana in the belly.
  ECHO PLAYER It goes "Buuurp!"
  ECHO OTHERS %N pokes %h jakana in the belly.
  ECHO OTHERS It goes "Buuurp!"
ENDIF
IFPREVERB PULL -1
  CLEARVERB
  ECHO PLAYER You hold your jakana up by the tail. It wriggles around and finally latches onto your wrist.
  ECHO OTHERS %N holds %h jakana up by the tail. It wriggles around and finally latches onto %h wrist.
ENDIF
IFPREVERB REMOVE -1
  CLEARVERB
  ECHO PLAYER You carefully remove your pet jakana from where it has attached to you.
  ECHO OTHERS %N carefully removes %h jakana from where it has attached itself to %i.
ENDIF
