INUMBER 1003
NAME 435
FOOD
PARAMETER1 5
ARTICLE SOME

iftouch -1
  ifvar itemadj3 = 430
    equal itemadj2 430
    equal itemadj3 -1
  endif
endif

IFVAR ITEMADJ2 = 671
  IFPREVERB LOOK -1
    CLEARVERB
    ECHO PLAYER The root looks particularly vile, bearing thick, black marks along its length, and dripping some kind of saplike substance.
  ENDIF
  IFVERB LISTEN -1
    ECHO PLAYER It's a root; what were you expecting to hear?
  ENDIF
  IFVERB EAT -1
    IFVAR INTNUM90 > 0
      ECHO PLAYER You feel something terrible happening within your stomach.
      PLREVENT 2
      CONTPLREVENT
      ECHO PLAYER You keel over, dead.
      ECHO OTHERS %N smiles, then keels over, dead.
      KILL PLAYER
      GMMSG %N overdoses on darkened root.
    ELSE
      EQUAL INTNUM90 1
      EQUAL INTNUM89 1
    ENDIF
  ENDIF
ENDIF
IFVAR ITEMADJ2 = 375
  IFPREVERB LOOK -1
    ECHO PLAYER The root resembles pure white ginger in size and texture.
    CLEARVERB
  ENDIF
  IFVERB SMELL -1
    ECHO PLAYER The blizzardroot gives off a pleasant odour.
  ENDIF
  IFVERB EAT -1
    IFVAR INTNUM90 = 0
      EQUAL INTNUM90 2
      EQUAL INTNUM89 1
      GMMSG %N ate some blizzard root.
    ELSE
      PLREVENT 1
      CONTPLREVENT
      ECHO PLAYER You feel slightly sick for a moment.
      ECHO OTHERS %N pales.
      GMMSG %N is trying to overdose on blizzard root.
    ENDIF
  ENDIF
ENDIF
ifvar itemadj2 = 430
  ifpreverb look -1
    clearverb
    echo player The root bears resemblance to a small yam, but bears a tough skin and deeper orange flesh.
  endif
  ifverb eat -1
    IFVAR INTNUM90 = 0
      random dummy1 1 500 0
      ifvar dummy1 < itemval1
        EQUAL INTNUM90 5
        echo player Your entire body tingles.
      else
        EQUAL INTNUM90 4
        echo player Your throat tingles.
      endif
      EQUAL INTNUM89 1
      GMMSG %N ate some phase root.
    ELSE
      PLREVENT 1
      CONTPLREVENT
      ECHO PLAYER You feel slightly ill for a moment.
      ECHO OTHERS %N pales.
      GMMSG %N is trying to overdose on phase root.
    ENDIF
  endif
  ifpreverb cast -1
    ifvar spellnum > 0
      clearverb
      echo player You channel some mana into the root.
      echo others %N gestures at some phase root.
      equal spellnum 0
      random dummy1 1 20 0
      sub manapoints dummy1
      add itemval1 dummy1
      ifvar manapoints < 0
        damageplr bodyonly 23 You keel over in pain!
        echo others %N keels over in pain!
        position kneel
      endif
      ifvar itemval1 > 700
        echo all The glowing phase root solidifies and shatters, releasing its contained mana!
        damageall slash 30 %N is hit by the shards!
        removeitem -1
      endif
    endif
  endif
endif
