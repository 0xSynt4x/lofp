    EQUAL IDDEVNE 0
    EQUAL IDDEVNW 0
    EQUAL IDDEVS 0
    EQUAL IDDEVSE 0
    EQUAL IDDEVSW 0
    EQUAL IDDEVE 0
    EQUAL IDDEVW 0
    EQUAL IDDEVX 0
    IFVAR EXITN > -1
      AFFECT EXITN
      ADD IDDEVN PLRSINROOM
      ADD IDDEVN MONINROOM
    ENDIF
    IFVAR EXITNE > -1
      AFFECT EXITNE
      ADD IDDEVNE PLRSINROOM
      ADD IDDEVNE MONINROOM
    ENDIF
    IFVAR EXITNW > -1
      AFFECT EXITNW
      ADD IDDEVNW PLRSINROOM
      ADD IDDEVNW MONINROOM
    ENDIF
    IFVAR EXITSE > -1
      AFFECT EXITSE
      ADD IDDEVSE PLRSINROOM
      ADD IDDEVSE MONINROOM
    ENDIF
    IFVAR EXITSW > -1
      AFFECT EXITSW
      ADD IDDEVSW PLRSINROOM
      ADD IDDEVSW MONINROOM
    ENDIF
    IFVAR EXITS > -1
      AFFECT EXITS
      ADD IDDEVS PLRSINROOM
      ADD IDDEVS MONINROOM
    ENDIF
    IFVAR EXITE > -1
      AFFECT EXITE
      ADD IDDEVE PLRSINROOM
      ADD IDDEVE MONINROOM
    ENDIF
    IFVAR EXITW > -1
      AFFECT EXITW
      ADD IDDEVW PLRSINROOM
      ADD IDDEVW MONINROOM
