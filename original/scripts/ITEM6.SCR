ARTICLE SOME
FOOD
PARAMETER1 1
IFVERB TAP -1
	IFVAR SKILL23 = 100
		ECHO ALL The seeds have now been blessed.
		EQUAL ITEMBIT1 1
	ENDIF
ENDIF
IFPREVERB DROP -1
	IFVAR ITEMBIT1 = 1
		CLEARVERB
		EQUAL DUMMY4 0
		IFVAR MONTH > 1
			IFVAR MONTH < 6
				EQUAL DUMMY4 1
			ENDIF
		ENDIF
		ECHO OTHERS %N drops %a.
		ECHO PLAYER You drop %a.
		IFVAR WILDERNESS = 0
			IFVAR WEA < 3
				IFVAR DAY = 1
					IFVAR DUMMY4 = 0
						IFITEM 9
							ECHO PLAYER Nothing happens. There is not enough room to grow something here.
						ENDIF
						IFNOITEM 9
							EQUAL ROUNDTIME 60
							ECHO PLAYER You watch in amazement as a miracle occurs...%c [Round: 60 sec]
							ECHO ALL The seeds disappear into the ground.
							REMOVEITEM -1
							PLREVENT 3
							CONTPLREVENT
							ECHO ALL You see movement under the soil.
							PLREVENT 3
							CONTPLREVENT
							ECHO ALL A tiny seedling sprouts from the earth.
							PLREVENT 3
							CONTPLREVENT
							ECHO ALL You watch the seedling mature into a bush before your eyes.
							NEWITEM 9 1232
							PLREVENT 3
							CONTPLREVENT
							ECHO ALL The bush buds out then flowers with bright pink blossoms.
							PLREVENT 3
							CONTPLREVENT
							ECHO ALL The blossoms fade as fast as they formed, and you notice that fruit has been set.
							PLREVENT 3
							CONTPLREVENT
							ECHO ALL The fruit ripens and the bush is filled with a crop of rowik berries.
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
							NEWPUT 9 493 ADJ3=530 VAL1=1000 VAL2=1 VAL3=303
						ENDIF
					ENDIF
					IFVAR DUMMY4 = 1
						ECHO PLAYER Nothing happens. Winter is not a growing season.
					ENDIF
				ENDIF
				IFVAR DAY = 0
					ECHO PLAYER Nothing happens. Plants need sunshine to live.
				ENDIF
			ENDIF
			IFVAR WEA > 2
				ECHO PLAYER Nothing happens. The weather is too severe for planting.
			ENDIF
		ENDIF
		IFVAR WILDERNESS = 1
			ECHO PLAYER Nothing happens. You cannot grow things in here.
		ENDIF
	ENDIF
ENDIF
