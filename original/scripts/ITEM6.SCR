; regular alley
IFVAR ITEMVAL5 = 0
  IFTOUCH -1
    CLEARVERB
    ECHO PLAYER Huh? How can you do that to a space between buildings?
  ENDIF
  IFPREVERB GO -1
    CLEARVERB
    ECHO PLAYER You walk right into the alley without bothering to hide. Better hope no one saw that.
    ECHO OTHERS %N ducks into an opening between the buildings.
    DISBAND
    MOVE ITEMVAL2
    AFFECT ITEMVAL2
    ECHO OTHERS %N appears through an opening between buildings.
  ENDIF
  IFPREVERB STEAL -1
    CLEARVERB
    SKILLCHECK 33 0 DUMMY1
    IFVAR DUMMY1 >= 0
      ECHO PLAYER You slink into the alley unnoticed.
      DISBAND
      MOVE ITEMVAL2
    ENDIF
    IFVAR DUMMY1 < 0
      IFVAR DUMMY1 >= -45
        ECHO PLAYER You don't see an opportune moment to sneak into the alley.
      ENDIF
      IFVAR DUMMY1 < -45
      SKILLCHECK 33 0 DUMMY3
        IFVAR DUMMY3 > 0
               ECHO PLAYER You don't see an opportune moment to sneak into the alley.
        ELSE
          ECHO PLAYER You stumble over your feet, botching your attempt to sneak into the alley.
          ECHO OTHERS %N ducks into an opening between buildings.
          DISBAND
          MOVE ITEMVAL2
          AFFECT ITEMVAL2
          ECHO OTHERS %N appears through an opening between buildings.
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
