;
; Cookie
INUMBER 790
NAME 647
FOOD
WEIGHT 1
VOLUME 2
PARAMETER1 6
SUBSTANCE wood
IFPREVERB EAT -1
  ifvar itemadj3 = 685
    echo player You break open the fortune cookie, eat it and read the fortune inside:
    echo others %N breaks open a fortune cookie, eats it and reads the fortune inside.
    removeitem -1
    random dummy1 1 44 0
    ifvar dummy1 = 1
      echo player "It is better to have loved and lost than never to have loved before."
      GMMSG %N's fortune is, "It is better to have loved and lost than never to have loved before."
    endif
    ifvar dummy1 = 2
      echo player "Your winsome smile is the only protection."
      GMMSG %N's fortune is, "Your winsome smile is the only protection."
    endif
    ifvar dummy1 = 3
      echo player "The city will be attacked by a band of demons in the near future."
      GMMSG %N's fortune is, "The city will be attacked by a band of demons in the near future."
    endif
    ifvar dummy1 = 4
      echo player "The city will be assaulted by hordes of undead."
      GMMSG %N's fortune is, "The city will be assaulted by hoardes of undead."
    endif
    ifvar dummy1 = 5
      echo player "You are the Chosen One."
      GMMSG %N's fortune is, "You are the Chosen One."
    endif
    ifvar dummy1 = 6
      echo player "Shemri is watching you."
      GMMSG %N's fortune is, "Shemri is watching you."
    endif
    ifvar dummy1 = 7
      echo player "Amilor is watching you."
      GMMSG %N's fortune is, "Amilor is watching you."
    endif
    ifvar dummy1 = 8
      echo player "Rorin is watching you."
      GMMSG %N's fortune is, "Rorin is watching you."
    endif
    ifvar dummy1 = 9
      echo player "The Dark One vies for your soul."
      GMMSG %N's fortune is, "The Dark One vies for your soul."
    endif
    ifvar dummy1 = 10
      echo player "Whatever happened to Ordanin?"
      GMMSG %N's fortune is, "Whatever happened to Ordanin?"
    endif
    ifvar dummy1 = 11
      echo player "You are about to come into a vast sum of money."
      GMMSG %N's fortune is, "You are about to come into a vast sum of money."
    endif
    ifvar dummy1 = 12
      echo player "Andor's orbit will someday intersect a cometary cloud."
      GMMSG %N's fortune is, "Andor's orbit will someday intersect a cometary cloud."
    endif
    ifvar dummy1 = 13
      echo player "Be kind and good things will happen."
      GMMSG %N's fortune is, "Be kind and good things will happen."
    endif
    ifvar dummy1 = 14
      echo player "Believe in yourself, or no one else will."
