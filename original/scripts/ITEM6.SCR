INUMBER 1662
NAME 1103
EQUAL ITEMADJ3 977
TWOHAND_WEAPON
WEIGHT 50
VOLUME 8
SUBSTANCE HARDMETAL
ARTICLE THE
PARAMETER1 5
;
IFPREVERB WIELD -1
  CLEARVERB
  IFVAR ITEMADJ1 ! 374
    IFVAR RNUM = 2713
      IFVAR ITEMVAL5 = 1
        ECHO PLAYER You unfurl the Standard and mount it in its stand for all to see.
        ECHO OTHERS %N unfurls ths Standard, mounting it in its stand for all to see.
        IFVAR ORG = 6
          IFVAR CBSTANDMAGIC <= 32
            SPELL 130 100
            ADD CBSTANDMAGIC 4
          ENDIF
        ENDIF
        REMOVEITEM -1
        NEWITEM 8 1662 ADJ1=976 ADJ3=977 VAL5=1
      ENDIF
      IFVAR ITEMVAL5 = 2
        ECHO PLAYER As you unfurl the Initiate Standard and place it in its stand, an unfelt breeze stirs a faint whisper of silk.
        ECHO OTHERS As %N unfurls the Initiate Standard and places it in its stand, an unfelt breeze stirs a faint whisper of silk.
        REMOVEITEM -1
        NEWITEM 9 1662 ADJ1=976 ADJ2=989 ADJ3=977 VAL5=2
      ENDIF
    ELSE
      IFVAR TERRAIN >= 3
        IFNOITEM 8
          ECHO PLAYER You unfurl the Standard and plant it firmly into the ground for all to see.
          ECHO OTHERS %N unfurls the Standard, planting it firmly into the ground for all to see.
          IFVAR ITEMVAL5 = 1
            IFVAR ORG = 6
              IFVAR CBSTANDMAGIC <= 32
                SPELL 130
                ADD CBSTANDMAGIC 4
              ENDIF
            ENDIF
            REMOVEITEM -1
            NEWITEM 8 1662 ADJ1=976 ADJ3=977 VAL5=1
          ENDIF
          IFVAR ITEMVAL5 = 2
            REMOVEITEM -1
            NEWITEM 8 1662 ADJ1=976 ADJ2=989 ADJ3=977 VAL5=2
          ENDIF
          IFVAR ITEMVAL5 = 0
            REMOVEITEM -1
            NEWITEM 8 1662 ADJ1=976 ADJ3=977
          ENDIF
        ELSE
          IFNOITEM 9
            ECHO PLAYER You unfurl the Standard and plant it firmly into the ground for all to see.
            ECHO OTHERS %N unfurls the Standard, planting it firmly into the ground for all to see.
            IFVAR ITEMVAL5 = 1
              IFVAR ORG = 6
                IFVAR CBSTANDMAGIC <= 32
                  SPELL 130
                  ADD CBSTANDMAGIC 4
                ENDIF
              ENDIF
              REMOVEITEM -1
              NEWITEM 9 1662 ADJ1=976 ADJ3=977 VAL5=1
            ENDIF
            IFVAR ITEMVAL5 = 2
              REMOVEITEM -1
              NEWITEM 9 1662 ADJ1=976 ADJ2=989 ADJ3=977 VAL5=2
            ENDIF
            IFVAR ITEMVAL5 = 0
              REMOVEITEM -1
              NEWITEM 9 1662 ADJ1=976 ADJ3=977
            ENDIF
          ELSE
            ECHO PLAYER There is no place to raise the standard here.
          ENDIF
        ENDIF
      ELSE
        ECHO PLAYER You cannot plant the standard indoors.
      ENDIF
    ENDIF
  ELSE
    ECHO PLAYER The Standard has been broken and cannot be raised.
  ENDIF
ENDIF
IFPREVERB GET -1
  IFVAR ITEMVAL5 = 1
    IFCARRY 1662 -1
      CLEARVERB
      ECHO PLAYER You already have the Standard.
    ELSE
      IFVAR ITEMADJ1 ! 374
        IFVAR ITEMADJ1 ! 975
          IFVAR ORG ! 6
            ECHO OTHERS %N has seized the Standard!
            EQUAL ITEMADJ1 -1
          ENDIF
          IFVAR ORG = 6
            ECHO PLAYER You pull the Standard from the ground and furl it.
            ECHO OTHERS %N pulls the Standard from the ground and furls it.
            EQUAL ITEMADJ1 -1
          ENDIF
        ELSE
          IFVAR ORG ! 6
            ECHO OTHERS %N has seized the Standard!
            EQUAL ITEMADJ1 -1
          ENDIF
          IFVAR ORG = 6
            ECHO PLAYER You retrieve the fallen Standard.
            ECHO OTHERS %N retrieves the fallen Standard.
            EQUAL ITEMADJ1 -1
          ENDIF
        ENDIF
      ELSE
        IFVAR ORG ! 6
          ECHO OTHERS %N has seized the broken Standard!
        ENDIF
        IFVAR ORG = 6
          ECHO PLAYER You retrieve the broken Standard.
          ECHO OTHERS %N retrieves the broken Standard.
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
;non CB GET
IFPREVERB GET -1
  IFVAR ITEMVAL5 ! 1
    IFCARRY 1662 -1
      CLEARVERB
      ECHO PLAYER You already have the Standard.
    ELSE
      IFVAR ITEMADJ1 ! 374
        IFVAR ITEMADJ1 ! 975
          ECHO PLAYER You pull the Standard from the ground and furl it.
          ECHO OTHERS %N pulls the Standard from the ground and furls it.
          EQUAL ITEMADJ1 -1
        ELSE
          ECHO PLAYER You retrieve the fallen Standard.
          ECHO OTHERS %N retrieves the fallen Standard.
          EQUAL ITEMADJ1 -1
        ENDIF
      ELSE
        ECHO PLAYER You retrieve the broken Standard.
        ECHO OTHERS %N retrieves the broken Standard.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB DROP -1
  IFVAR ITEMADJ1 ! 374
    IFCARRY 1662 -1
      ECHO PLAYER You have dropped the Standard to the ground!
      ECHO OTHERS %N has dropped the Standard to the ground!
      EQUAL ITEMADJ1 975
    ELSE
      CLEARVERB
      ECHO PLAYER You are not holding the Standard.
    ENDIF
  ELSE
    ECHO PLAYER You have dropped the Standard to the ground!
    ECHO OTHERS %N has dropped the Standard to the ground!
  ENDIF
ENDIF
IFPREVERB BREAK -1
  CLEARVERB
  IFVAR ITEMADJ1 ! 374
    RANDOM DUMMY1 1 100 0
    ADD DUMMY1 STR
    IFVAR DUMMY1 < 160
      ECHO PLAYER You strike the Standard with all your might, but it does not break!
      ECHO OTHERS %N strikes the Standard with all %h might, but it does not break!
      EQUAL ROUNDTIME 5
    ELSE
      IFVAR DUMMY1 < 240
        IFVAR ITEMADJ1 ! 975
          ECHO PLAYER You strike the Standard with all your might, knocking it to the ground!
          ECHO OTHERS %N strikes the Standard with all %h might, knocking it to the ground!
          EQUAL ITEMADJ1 975
          IFVAR ITEMVAL5 = 1
            EQUAL JANUSCBSTAND 1
          ENDIF
          EQUAL ROUNDTIME 10
        ELSE
          ECHO PLAYER You strike the Standard with all your might, but it does not break!
          ECHO OTHERS %N strikes the Standard with all %h might, but it does not break!
          EQUAL ROUNDTIME 5
        ENDIF
      ELSE
        ECHO PLAYER With a thunderous crack, the Standard is broken asunder by your blow!
        ECHO OTHERS With a thunderous crack, the Standard is broken asunder by %N's mighty blow!
        EQUAL ITEMADJ1 374
        IFVAR ITEMVAL5 = 1
          EQUAL JANUSCBSTAND 2
          SPELL 230
          PLREVENT 4
          CONTPLREVENT
          SPELL 138
          ECHO PLAYER A wave of energy pours forth from the broken Standard, knocking everything down in its path.
          POSITION LAY
        ENDIF
        EQUAL ROUNDTIME 10
      ENDIF
    ENDIF
  ELSE
    ECHO PLAYER The Standard is already broken.
  ENDIF
ENDIF
IFPREVERB SALUTE -1
  CLEARVERB
  IFVAR ITEMADJ1 = 976
    ECHO PLAYER You come to attention and salute the Standard smartly.
    ECHO OTHERS %N comes to attention and salutes the Standard smartly.
  ELSE
    ECHO PLAYER The Standard is not raised.
  ENDIF
ENDIF
IFPREVERB CONCENTRATE -1
  IFVAR ITEMVAL5 = 1
    IFVAR ORG = 6
      IFVAR ITEMADJ1 = 976
        CLEARVERB
        IFVAR CBSTANDMAGIC <= 32
          ECHO PLAYER The Standard glows for a moment as you concentrate on it.
          SPELL 318
          ADD CBSTANDMAGIC 2
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB GAZE -1
  IFVAR ITEMVAL5 = 1
    IFVAR ORG = 6
      IFVAR ITEMADJ1 = 976
        CLEARVERB
        IFVAR CBSTANDMAGIC < 33
          ECHO PLAYER As you gaze proudly upon the Standard, you are filled with renewed strength!
          SPELL 209
          ADD CBSTANDMAGIC 2
        ENDIF
      ENDIF
    ENDIF
  ENDIF
  IFVAR ITEMVAL5 = 2
    IFVAR ITEMADJ1 = 976
      IFCARRY 131 989
        IFVAR INITMAGIC < 12
          CLEARVERB
          ECHO PLAYER As you gaze upon the Standard, you are filled with a sense of pride and courage.
          SPELL 347 100
          ADD INITMAGIC 2
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB LOOK -1
  CLEARVERB
  IFVAR ITEMVAL5 = 1
    ECHO PLAYER Mounted on an ivory-tipped rod of uquart, the Standard of the Crimson Band flutters in the slightest breeze. Emblazoned on the ancient silk standard is a fierce eagle, wings spread, grasping a brilliant star ruby in its talons.
  ENDIF
  IFVAR ITEMVAL5 = 2
    ECHO PLAYER A brilliant crimson banner flies from a bright white pole tipped with a flaming blade.
  ENDIF
  IFVAR ITEMVAL5 = 0
    ECHO PLAYER You see nothing extraordinary.
  ENDIF
ENDIF
IFPREVERB FILCH -1
  CLEARVERB
  ECHO PLAYER Yeah right, maybe it'll fit in your pocket.
ENDIF
