;
; ** Alley
;
INUMBER 692
NAME 852
WEIGHT 1000
VOLUME 500
EQUAL ITEMADJ1 87
ARTICLE A
HIDDEN
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    CLEARVERB
    ECHO PLAYER If ITEMVAL5 = 2, alley is usable by only a Master thief.
    ECHO PLAYER If ITEMVAL5 = 1, alley is usable only by a thief.
    ECHO PLAYER Alley uses ITEMVAL2 as if it were a portal.
  ENDIF
ENDIF
; regular alley
IFVAR ITEMVAL5 = 0
  IFTOUCH -1
    CLEARVERB
    ECHO PLAYER Huh? How can you do that to a space between buildings?
  ENDIF
  IFPREVERB GO -1
    CLEARVERB
    ECHO PLAYER You walk directly into the alley.
    ECHO OTHERS %N ducks into an opening between the buildings.
    DISBAND
    MOVE ITEMVAL2
    AFFECT ITEMVAL2
    ECHO OTHERS %N appears through an opening between buildings.
  ENDIF
  IFPREVERB STEAL -1
    CLEARVERB
    SKILLCHECK 33 0 DUMMY1
    IFVAR DUMMY1 >= 0
      ECHO PLAYER You slink into the alley unnoticed.
      DISBAND
      MOVE ITEMVAL2
    ENDIF
    IFVAR DUMMY1 < 0
      IFVAR DUMMY1 >= -45
        ECHO PLAYER You don't see an opportune moment to sneak into the alley.
      ENDIF
      IFVAR DUMMY1 < -45
      SKILLCHECK 33 0 DUMMY3
        IFVAR DUMMY3 > 0
               ECHO PLAYER You don't see an opportune moment to sneak into the alley.
        ELSE
          ECHO PLAYER You stumble over your feet, botching your attempt to sneak into the alley.
          ECHO OTHERS %N ducks into an opening between buildings.
          DISBAND
          MOVE ITEMVAL2
          AFFECT ITEMVAL2
          ECHO OTHERS %N appears through an opening between buildings.
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
; Master Thief-only version
IFVAR ITEMVAL5 = 2
IFVAR ORG ! 13
  CLEARVERB
  ECHO PLAYER What are you referring to?  Please be more specific.
ELSE
  IFVAR ORGRANK < 100
    CLEARVERB
    ECHO PLAYER What are you referring to?  Please be more specific.
  ELSE
    IFTOUCH -1
      CLEARVERB
      ECHO PLAYER Huh? How can you do that to a space between buildings?
    ENDIF
    IFPREVERB GO -1
      CLEARVERB
      ECHO PLAYER You walk right into the alley without bothering to hide. Better hope no one saw that.
      ECHO OTHERS %N ducks into an opening between the buildings.
      DISBAND
      MOVE ITEMVAL2
      AFFECT ITEMVAL2
      ECHO OTHERS %N appears through an opening between buildings.
    ENDIF
    IFPREVERB STEAL -1
      CLEARVERB
      SKILLCHECK 33 0 DUMMY1
      IFVAR DUMMY1 >= 0
        ECHO PLAYER You slink into the alley unnoticed.
        DISBAND
        MOVE ITEMVAL2
      ENDIF
      IFVAR DUMMY1 < 0
        IFVAR DUMMY1 >= -45
          ECHO PLAYER You don't see an opportune moment to sneak into the alley.
        ENDIF
        IFVAR DUMMY1 < -45
          SKILLCHECK 33 0 DUMMY3
          IFVAR DUMMY3 > 0
            ECHO PLAYER You don't see an opportune moment to sneak into the alley.
          ELSE
            ECHO PLAYER You stumble over your feet, botching your attempt to sneak into the alley.
            ECHO OTHERS %N ducks into an alleyway.
            DISBAND
            MOVE ITEMVAL2
            AFFECT ITEMVAL2
            ECHO OTHERS %N appears through an alleyway.
          ENDIF
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
ENDIF
; Thief only version
IFVAR ITEMVAL5 = 1
IFVAR ORG ! 13
  CLEARVERB
  ECHO PLAYER What are you referring to?  Please be more specific.
ELSE
    IFTOUCH -1
      CLEARVERB
      ECHO PLAYER Huh? How can you do that to a space between buildings?
    ENDIF
    IFPREVERB GO -1
      CLEARVERB
      ECHO PLAYER You walk right into the alley without bothering to hide. Better hope no one saw that.
      ECHO OTHERS %N ducks into an opening between the buildings.
      DISBAND
      MOVE ITEMVAL2
      AFFECT ITEMVAL2
      ECHO OTHERS %N appears through an opening between buildings.
    ENDIF
    IFPREVERB STEAL -1
      CLEARVERB
      SKILLCHECK 33 0 DUMMY1
      IFVAR DUMMY1 >= 0
        ECHO PLAYER You slink into the alley unnoticed.
        DISBAND
        MOVE ITEMVAL2
      ENDIF
      IFVAR DUMMY1 < 0
        IFVAR DUMMY1 >= -45
          ECHO PLAYER You don't see an opportune moment to sneak into the alley.
        ENDIF
        IFVAR DUMMY1 < -45
          SKILLCHECK 33 0 DUMMY3
          IFVAR DUMMY3 > 0
            ECHO PLAYER You don't see an opportune moment to sneak into the alley.
          ELSE
            ECHO PLAYER You stumble over your feet, botching your attempt to sneak into the alley.
            ECHO OTHERS %N ducks into an alleyway.
            DISBAND
            MOVE ITEMVAL2
            AFFECT ITEMVAL2
            ECHO OTHERS %N appears through an alleyway.
          ENDIF
        ENDIF
      ENDIF
    ENDIF
ENDIF
ENDIF
;
INUMBER 1644
NAME 55
WEIGHT 12
VOLUME 3
WORN_NECK
SUBSTANCE INDESTRUCTABLE
IFPREVERB CONCENTRATE -1
  IFITEM -1 WORN
  CLEARVERB
    IFVAR intnum97 = 6
      ECHO PLAYER You clear your mind and project your mental energy into the collar.
      ECHO PLAYER You slide your conciousness along pathways of psychic circuitry. You switch the energy draw nodes one by one over to draw from your psionic power reserves.
      echo player Your collar beeps.
      equal roundtime 60
      echo player [Round: 60 sec]
      ECHO OTHERS %N closes %h eyes in concentation. You hear a beep.
      EQUAL intnum97 5
      stop
    endif
    ifvar intnum97 = 5
      ECHO PLAYER You clear your mind and project your mental energy into the collar.
      ECHO PLAYER You slide your conciousness along pathways of psychic circuitry. You switch the energy draw nodes one by one over to draw from your magical power reserves.
      echo player Your collar beeps.
      equal roundtime 60
      echo player [Round: 60 sec]
      ECHO OTHERS %N closes %h eyes in concentation. You hear a beep.
      EQUAL intnum97 6
      stop
    ENDIF
  ENDIF
ENDIF
IFPREVERB FLIP -1
  CLEARVERB
  IFITEM -1 WORN
    IFVAR FATPOINTS > 20
      ECHO PLAYER You rapidly flip a few switches on %a.
      ECHO OTHERS %N rapidly flips a few switches on %a.
      SPELL 342 30
      SUB manapoints 10
      sub psipoints 10
      echo player You feel drained.
      echo others %S looks tired.
    ELSE
      ECHO PLAYER You rapidly flip a few switches on %a.%cYou feel the collar try to draw on your body's energy for power, but nothing seems to happen.
      ECHO OTHERS %N rapidly flips a few switches on %a.
    ENDIF
  ELSE
    ECHO PLAYER You seem to remember that the collar can only work when you are wearing it.
  ENDIF
ENDIF
IFPREVERB TAP -1
  CLEARVERB
  IFITEM -1 WORN
    IFVAR FATPOINTS > 20
      ECHO PLAYER You tap a recessed switch on the side of %a.
      ECHO OTHERS %N presses something on the side of %a.
      SPELL 343 10
      SUB manapoints 10
      sub psipoints 10
      echo player You feel drained.
      echo player %S looks tired.
    ELSE
      ECHO PLAYER You tap a recessed switch on the side of %a.%cYou feel the collar try to draw on your body's energy for power, but nothing seems to happen.
      ECHO OTHERS %N presses something on the side of %a.
    ENDIF
  ELSE
    ECHO PLAYER You seem to recall that the collar remains inert when it is not worn.
  ENDIF
ENDIF
IFVERB WEAR -1
  echo player You feel tickles all over your body as micro-filiment sensors deploy all over your body.
  echo others %N squirms around and stifles a giggle.
  equal intnum97 5
endif
ifpreverb remove -1
  echo player Micro-filiment sensors retract from all over your body, causing you to shiver.
  echo others %N shivers and squirms.
  equal intnum97 0
endif
ifpreverb rub -1
  ifitem -1 worn
  clearverb
  echo player Your collar flashes red and beeps rapidly, warning you that you are over exerting yourself.
  echo others %N's collar flashes red and beeps rapidly.
  endif
endif
ifpreverb poke -1
  ifitem -1 worn
  clearverb
  echo player Your collar whirrs as is performs a routine diagnostic on your functions.
  echo others %N's collar whirrs.
  endif
endif
iftouch -1
  ifvar intnum3 = 1
  echo player Gradrak bleats, "This is a special auto-doc collar, which currently uses global variables. Do not use please."
  endif
endif
ifpreverb pull -1
  ifitem -1 worn
  clearverb
  echo player You pull up a small antenna on the back of %a and activate the activate the corpse fetcher robot.
  echo others %N pulls up a small antenna on the back of %a.
  equal patcollar3 1
  endif
endif
ifpreverb push -1
  ifitem -1 worn
  clearverb
  echo player You push a hidden stud and feel the vibrations of activation.
  echo player A digital readout flashes onto your retna... It reads...
  echo player "Auto-med function level set to just below current health."
  echo others %N fiddles with %a.
  equal patcollaron 1
  equal patcollarbody bodypoints
  sub patcollarbody 20
  endif
endif
;
; white oak
;
INUMBER 1985
NAME 1575
MATERIAL
WEIGHT 2
VOLUME 2
SUBSTANCE wood
ARTICLE SOME
PARAMETER1 216
PARAMETER2 18
*DESCRIPTION_START
This wood is hard and strong, well suited to either construction or tool-making.
*DESCRIPTION_END
IFTOUCH -1
  IFVAR ITEMVAL2 ! 0
    IFVAR RAC ! 2
      CLEARVERB
      ECHO PLAYER You reach out to some white oak.
      ECHO OTHERS %n reaches out to some white oak.
      EQUAL ITEMVAL2 0
      EQUAL ITEMADJ3  87
      PLREVENT 0
      CONTPLREVENT
      ECHO PLAYER The wood writhes uneasily under your touch, rapidly darkening to brown color.
      ECHO OTHERS The wood seems to darken as %n touches it.
    ELSE
     PLREVENT 1
     CONTPLREVENT
     ECHO PLAYER The living wood grows comfortably warm under your touch.
    ENDIF
  ENDIF
ENDIF
IFVERB RECALL -1
  IFVAR ITEMVAL2 ! 0
    IFVAR RAC = 2
       PLREVENT 0
       CONTPLREVENT
       ECHO PLAYER You recognize the rare and valuable white oak wood, which can be used by skilled aelfen artisans to make exceptional weapons.
    ENDIF
  ENDIF
ENDIF
IFPREVERB LISTEN -1
  IFVAR ITEMVAL2 ! 0
    IFVAR RAC = 2
      CLEARVERB
      ECHO PLAYER You place your ear to the wood and hear a soft whispering as of wind through tall trees.
      ECHO OTHERS %n places an ear to %a and listens intently.
   ENDIF
  ENDIF
ENDIF
;
; Drakin Egg
;
INUMBER 803
NAME 1057
WEIGHT 1
VOLUME 1
*DESCRIPTION_START
This long, slender egg is a coated in a hardened yellowish shell. The smooth
texture is free of any cracks or blemishes and it is warm to the touch.
Unlike the egg of a bird, this egg is of even diameter with two matched ends.
*DESCRIPTION_END
IFTOUCH -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER **This is the infamous Drakin Egg archtype. The first time a player touches it, it begins timing the 7 month cycle, with echoes changing game-monthly.
    ECHO PLAYER **YOU MUST HAVE PERMISSION FROM ABOVE TO GIVE THIS OUT**
  ELSE
    IFVAR ITEMVAL1 = 0
      SETITEMVAL -1 1 MONTH
      SETITEMADJ -1 2 100
    ENDIF
  ENDIF
ENDIF
IFPREVERB RUB -1
  CLEARVERB
  SETITEMVAL -1 2 MONTH
  IFVAR ITEMVAL2 < ITEMVAL1
    ADD ITEMVAL2 13
  ENDIF
  EQUAL ITEMVAL3 ITEMVAL2
  SUB ITEMVAL3 ITEMVAL1
  IFVAR ITEMVAL3 < 2
    ECHO PLAYER You carefully stroke the egg, warming it with your touch.
    ECHO OTHERS %n carefully caresses %h egg, warming it with %h touch.
  ENDIF
  IFVAR ITEMVAL3 = 2
    ECHO PLAYER As you caress %a, warming it with your touch, you almost swear you felt movement within.
    ECHO OTHERS As %n caresses %a you can swear you see it move in %h grasp.
  ENDIF
  IFVAR ITEMVAL3 = 3
    ECHO OTHERS %A twitches slightly as %n warms it with %h hands.
    ECHO PLAYER As you warm %a with your hands, it seem to twitch slightly.
  ENDIF
  IFVAR ITEMVAL3 = 4
    ECHO OTHERS %A twitches slightly as %n warms it with %h hands.
    ECHO PLAYER As you warm %a with your hands, it seem to twitch slightly.
  ENDIF
  IFVAR ITEMVAL3 = 5
    ECHO PLAYER You rub the egg gently, feeling the contents stir within.
    ECHO OTHERS %n rubs %a gently and the contents stir beneath the warmth of %h hand.
  ENDIF
  IFVAR ITEMVAL3 = 6
    ECHO PLAYER As you warm %a with your hands it rocks gently from side to side.
    ECHO OTHERS %A rocks slightly from side to side as %n rubs it gently, warming it.
  ENDIF
  IFVAR ITEMVAL3 = 7
    ECHO PLAYER %A jumps sharply when you warm it as the infant Drakin within snaps its forming tail back and forth.
    ECHO OTHERS %A jumps sharply in %n's grasp as the infant Drakin within snaps its forming tail back and forth under the weight of %h hands.
  ENDIF
  IFVAR ITEMVAL3 > 7
    ECHO PLAYER You rub %a warmly feeling a sporadic tapping from within.
    ECHO OTHERS %n rubs %a warmly, feeling a sporadic tapping from within.
    GMMSG ** %n's Drakin egg is ready for hatching if you wanna take care of it.
    PLREVENT 1
    CONTPLREVENT
    ECHO ALL A tiny, triangular flap of eggshell lifts up to reveal the protruding tip of an infant Drakin's dewclaw.
  ENDIF
ENDIF
IFPREVERB TURN -1
  CLEARVERB
  ECHO PLAYER You turn %a this way and that within your grasp, warming it lovingly.
  ECHO OTHERS %n turns %a this way and that within %h grasp, warming it lovingly.
ENDIF
IFPREVERB NUZZLE -1
  CLEARVERB
  ECHO PLAYER You rub your cheek against %a lovingly.
  ECHO OTHERS %n rubs %h cheek against %a lovingly.
ENDIF
IFPREVERB KISS -1
  CLEARVERB
  IFVAR RAC ! 6
    ECHO PLAYER You plant a gentle kiss on the egg.
    ECHO OTHERS %n plants a gentle kiss on %a.
  ELSE
    ECHO PLAYER You flick your forked tongue over the smooth surface of the egg, kissing it.
    ECHO OTHERS %n flicks %h forked tongue over %a, kissing it.
  ENDIF
ENDIF
IFPREVERB FLIP -1
  CLEARVERB
  ECHO PLAYER You decide against it.
ENDIF
IFPREVERB BREAK -1
  CLEARVERB
  ECHO PLAYER You smash %a spilling fluid and the infant Drakin within onto the ground!
  ECHO OTHERS %n smashes %a spilling fluid and the infant Drakin within onto the ground!
  REMOVEITEM -1
  STRCVT 1 PLAYERNUM
  STRCVT 0 RNUM
  GMMSG ** %n, player #%1 just totally smashed an infant Drakin egg, better take care of it.. (sigh) ROOM #%0
  NEWITEM 9 511 ADJ1=358
ENDIF
IFPREVERB HUG -1
  CLEARVERB
  ECHO PLAYER You gently cradle %a in your arms.
  ECHO OTHERS %n cradles %a in %h arms gently.
ENDIF
IFPREVERB LISTEN -1
  CLEARVERB
  IFVAR ITEMVAL3 > 4
    ECHO PLAYER You hear the gentle scraping of a tiny life within the egg.
    ECHO OTHERS %n rests %h ear against %a.
  ELSE
    ECHO PLAYER You hear nothing but the egg is warm against your head.
    ECHO OTHERS %n rests %h ear against %a.
  ENDIF
ENDIF
IFPREVERB TAP -1
  IFVAR ITEMVAL3 > 5
    CLEARVERB
    ECHO PLAYER You tap softly against the eggshell.%c>%cTap Tap.
    ECHO OTHERS %n taps softly against the eggshell.%c>%cTap Tap.
    PLREVENT 1
    CONTPLREVENT
    ECHO ALL A soft sound from within the egg echoes...%c>%cTap Tap.
  ENDIF
ENDIF
;
INUMBER 957
NAME 363
WEIGHT 3
VOLUME 2
MISC
SUBSTANCE WOOD
*DESCRIPTION_START
You see an ornately carved wooden box with a lid of thin white wood, so highly polished that you can see right through it. A cleverly carved latch secures the lid for carrying. A pair of bone pointers lay in the center of the box, where they can be easily pulled out and turned in the hand to be tossed back into the box. A small hollow at either end holds scoring stones for the players. Surrounding the hollow, ten small pictures of woodland beasts are covered by tiny slivers of bark. A central pouch holds scoring stones for the players. [Please tap to have a GM activate the box (temporary)]
*DESCRIPTION_END
IFVERB TAP -1
 ECHO PLAYER Our operators are all busy at the moment, please be patient. Your call is important to us.
 GMMSG **%n has requested that the Aelfen Game be activated, please compile JACKGAME.SCR, thank you.
ENDIF
;
INUMBER 1259
NAME 1533
MISC
WEIGHT 3
VOLUME 6
SUBSTANCE WOOD
DYEABLE
ARTICLE SOME
TURNABLE
*DESCRIPTION_START
This peculiar instrument is comprised of a large, cloth-covered bladder with several wooden pipes extending outwards from it. Slightly separate from the others, a single pipe obviously acts as a mouthpiece. The pipes can be turned slightly to adjust their pitch and tuning.
*DESCRIPTION_END
IFVERB LOOK -1
 IFVAR INTNUM3 = 1
  ECHO PLAYER ** If you're giving these to someone, make sure you reset the itemval1 to 0 if you've touched them.
 ENDIF
ENDIF
;scripts
IFTOUCH -1
 IFVAR ITEMVAL1 ! INTNUM3
  IFVAR ITEMVAL1 = 0
   SETITEMVAL -1 1 INTNUM3
  ELSE
   CLEARVERB
   ECHO PLAYER Your fumbling creates a hideous braying noise.
   ECHO OTHERS %n fumbles with some bagpipes, creating a hideous braying noise.
  ENDIF
 ENDIF
ENDIF
IFPREVERB TURN -1
 CLEARVERB
 ECHO PLAYER You adjust the tuning of the pipes.
 ECHO OTHERS %n adjusts the tuning of %h bagpipes.
 EQUAL BPIPEROOM 0
 ADD ITEMVAL2 1
 IFVAR ITEMVAL2 = 3
  SETITEMVAL -1 2 0
 ENDIF
 IFVAR ITEMVAL2 = 0
  ECHO PLAYER The bagpipes are now tuned for a martial piece.
 ENDIF
 IFVAR ITEMVAL2 = 1
  ECHO PLAYER The bagpipes are now tuned for a festive reel.
 ENDIF
 IFVAR ITEMVAL2 = 2
  ECHO PLAYER The bagpipes are now tuned for a mournful dirge.
 ENDIF
ENDIF
IFPREVERB WEAR -1
 CLEARVERB
 ECHO PLAYER You tuck the pipes under your arm, and breath steadily into the mouthpiece, ready to play.
 ECHO OTHERS %n tucks %a under %h arm, and breathes steadily into their mouthpiece, preparing to play.
ENDIF
IFPREVERB REMOVE -1
 CLEARVERB
 ECHO PLAYER You lower the bagpipes, allowing them to slowly deflate.
 ECHO OTHERS %n lowers %a, allowing them to deflate with a feeble wheezing sound.
ENDIF
IFPREVERB PUSH -1
 CLEARVERB
 ECHO PLAYER You give the bagpipes a squeeze, making them utter an unearthly wail!
 ECHO ALL A loud unearthly wailing noise erupts from %a!
 IFVAR BPIPEROOM = 0
  EQUAL BPIPEROOM RNUM
  AFFECT EXITN
  ECHO ALL A loud unearthly wailing noise fills the area!
  AFFECT BPIPEROOM
  AFFECT EXITNE
  ECHO ALL A loud unearthly wailing noise fills the area!
  AFFECT BPIPEROOM
  AFFECT EXITNW
  ECHO ALL A loud unearthly wailing noise fills the area!
  AFFECT BPIPEROOM
  AFFECT EXITW
  ECHO ALL A loud unearthly wailing noise fills the area!
  AFFECT BPIPEROOM
  AFFECT EXITE
  ECHO ALL A loud unearthly wailing noise fills the area!
  AFFECT BPIPEROOM
  AFFECT EXITSE
  ECHO ALL A loud unearthly wailing noise fills the area!
  AFFECT BPIPEROOM
  AFFECT EXITSW
  ECHO ALL A loud unearthly wailing noise fills the area!
  AFFECT BPIPEROOM
  AFFECT EXITS
  ECHO ALL A loud unearthly wailing noise fills the area!
  EQUAL BPIPEROOM 0
 ENDIF
ENDIF
IFPREVERB PULL -1
 CLEARVERB
 ECHO PLAYER You fidget with the pipes and tassels radiating from the back of your pipes.
 ECHO OTHERS %n fidgets with the pipes and tassels radiating from the back of %a.
ENDIF
IFPREVERB PLAY -1
 CLEARVERB
 IFVAR ITEMVAL1 = INTNUM3
  IFVAR BPIPEROOM = 0
   EQUAL BPIPEROOM RNUM
   EQUAL ROUNDTIME 40
   IFVAR ITEMVAL2 = 0
;march
    ECHO PLAYER You start with a steady harmonic tone, rising eerily from the bagpipes.
    ECHO OTHERS %n starts with a steady harmonic tone, rising eerily from the bagpipes.
    PLREVENT 3
    CONTPLREVENT
    ECHO PLAYER You add a strident martial tune to the air, causing hearts to race in time to the aggressive beat.
    ECHO OTHERS %n adds a strident martial tune to the air, causing hearts to race in time to the aggressive beat.
    PLREVENT 3
    CONTPLREVENT
    ECHO ALL The wailing music of the bagpipes rises to a fierce crescendo. You seem to see faint images of a great army marching to the fray!
    PLREVENT 3
    CONTPLREVENT
    ECHO PLAYER You coax an even fiercer rhythm from the screaming bagpipes, conjuring up visions of glory and mighty deeds in battle!
    ECHO OTHERS %n coaxes an even fiercer rhythm from the screaming bagpipes, conjuring up visions of glory and mighty deeds in battle!
    PLREVENT 3
    CONTPLREVENT
    EQUAL BPIPEROOM 0
    ECHO PLAYER You finish with a final dwindling skirl of the pipes, like the last trail of sound from an vanishing army.
    ECHO OTHERS %n finishes with a dwindling skirl of the pipes, like the last trail of sound from a vanishing army.
   ENDIF
   IFVAR ITEMVAL2 = 1
 ;reel
    ECHO PLAYER You begin with a lively harmonic tone from the pipes.
    ECHO OTHERS %n begins with a lively harmonic tone from the pipes.
    PLREVENT 3
    CONTPLREVENT
    ECHO PLAYER You start the actual melody, a whirling skirling reel that brings a smile to everyone's faces.
    ECHO OTHERS %n starts the melody, a whirling skirling reel that brings a smile to your face.
    PLREVENT 3
    CONTPLREVENT
    ECHO PLAYER You swing into a lively jig which sets toes to tapping and hands to clapping along with the beat.
    ECHO OTHERS %n swings into a lively jig which sets your toes to tapping and your hands to clapping along with the beat.
    PLREVENT 3
    CONTPLREVENT
    ECHO PLAYER You play faster and faster, until the bagpipes create a whirlwind of sound, catching everyone up in the lively stomping rhythm.
    ECHO OTHERS %n plays faster and faster, until the bagpipes create a whirlwind of sound, catching everyone up in the lively stomping rhythm.
    PLREVENT 3
    CONTPLREVENT
    EQUAL BPIPEROOM 0
    ECHO PLAYER With a final flourish of rising notes, you finish the tune with a breathless grin.
    ECHO OTHERS With a final flourish of rising notes, %n finishes the tune with a breathless grin.
   ENDIF
   IFVAR ITEMVAL2 = 2
 ; dirge
    ECHO PLAYER You allow the pipes to slowly build a low, mournful harmonic, which rises up in the air like a tide of sorrow.
    ECHO OTHERS %n allows the pipes to slowly build a low, mournful harmonic, which rises up in the air like a tide of sorrow.
    PLREVENT 3
    CONTPLREVENT
    ECHO PLAYER Slowly you begin a stately hymn to the loss of something precious, something indefinable yet ultimately priceless.
    ECHO OTHERS Slowly %n begins a stately hymn to the loss of something precious, something indefinable yet ultimately priceless.
    PLREVENT 3
    CONTPLREVENT
    ECHO ALL The dirge from the pipes rises to an achingly beautiful paean to the belief that something better awaits beyond the final veil of death.
    PLREVENT 3
    CONTPLREVENT
    ECHO PLAYER You slowly descend in tone to a pulsing wail of outflowing grief, which washes through everyone, allowing their feelings of grief expression and release.
    ECHO OTHERS %n slowly descends in tone to a pulsing wail of outflowing grief, which washes through you, allowing your feelings of grief expression and release.
    PLREVENT 3
    CONTPLREVENT
    EQUAL BPIPEROOM 0
    ECHO PLAYER Ever so slowly, you let the dirge fade away, leaving only a lingering harmonic tone gently reverberating through everyone like a comforting embrace.
    ECHO OTHERS Ever so slowly, %n lets the dirge fade away, leaving only a lingering harmonic tone gently reverberating through your body like a comforting embrace.
   ENDIF
  ELSE
 ;someone else already playing
   IFVAR BPIPEROOM = RNUM
    ECHO PLAYER You play along with the tune, adding depth and richness to the melody.
    ECHO OTHERS %n plays along with the tune, adding depth and richness to the melody.
   ELSE
    ECHO PLAYER The bagpipes give a slightly out of tune note, causing you to consider tuning them.
    ECHO OTHERS %n gives a tentative, out of tune bleat of the bagpipes.
   ENDIF
  ENDIF
 ELSE
  ECHO PLAYER Your fumbling creates a hideous braying noise.
  ECHO OTHERS %n fumbles with some bagpipes, creating a hideous braying noise.
 ENDIF
ENDIF
