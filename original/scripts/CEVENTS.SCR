CEVENT 7 60 315
;GMMSG Morthain's script running in room 315
RANDOM dummy4 1 9 0
IFVAR DUMMY4 = 1
  AFFECT 315
  ECHO ALL The whisper of many settles running through the looms fills your ears.
ENDIF
IFVAR DUMMY4 = 2
  AFFECT 315
  ECHO ALL A group of apprentice weavers sweep the floor and clean residue out of the cauldron.
ENDIF
IFVAR DUMMY4 = 3
  AFFECT 315
  ECHO ALL One of the senior journeymen continues a lesson in advanced weaving techniques to a pair of young apprentices.
ENDIF
IFVAR DUMMY4 = 4
  AFFECT 316
  ECHO ALL The cauldron bubbles and spurts for a few moments before settling back down.
ENDIF
IFVAR DUMMY4 = 5
  AFFECT 316
  ECHO ALL A craftsman alchemist works at one of the workbenches, refining liquids and sorting out powders.
ENDIF
IFVAR DUMMY4 = 6
  AFFECT 316
  ECHO ALL Without warning yet another alchemical experiment goes awry, exploding and sending out a large clous of noxious smoke.
ENDIF
IFVAR DUMMY4 = 7
  AFFECT 317
  ECHO ALL Working cautiously, an aelfen jewler creates fine pieces of flatware, spending hours on each piece.
ENDIF
IFVAR DUMMY4 = 8
  AFFECT 317
  ECHO ALL Each of the crafters turn and nod slightly to one of the Masters as she strides into the room.
ENDIF
IFVAR DUMMY4 = 9
  AFFECT 317
  ECHO ALL A journeyman bowyer works at the small forge, making fine arrowheads from various metals.
ENDIF
;
; Cantina
;
CEVENT 5 80 212
RANDOM DUMMY4 1 18 0
IFVAR DUMMY4 = 1
	ECHO ALL There is laughter across the bar as the loser in a drinking contest passes out.
ENDIF
IFVAR DUMMY4 = 2
	ECHO ALL Silence is cast across the room momentarily as a particularly dangerous looking individual steps in. After a tense moment everyone resumes their revelry.
ENDIF
IFVAR DUMMY4 = 3
  ECHO ALL You notice two murgs at a table, belting out a fighting song.
ENDIF
IFVAR DUMMY4 = 4
	ECHO ALL A drakin laborer comes through and picks up the tables.
ENDIF
IFVAR DUMMY4 = 5
	ECHO ALL A brawl breaks out between two highlanders, one of whom appears to be defending the honor of his sister.
ENDIF
IFVAR DUMMY4 = 6
	ECHO ALL You notice a commoner strolling the empty tables, drinking up dregs.
ENDIF
IFVAR DUMMY4 = 7
	ECHO ALL Two aelfen women flirt with a lawkeeper at the bar.
ENDIF
IFVAR DUMMY4 = 8
	ECHO ALL A large fly buzzes about the room.
ENDIF
IFVAR DUMMY4 = 9
	ECHO ALL The bartender whips up a frappe. The serving wench delivers it to a wolfling seated in the corner.
ENDIF
IFVAR DUMMY4 = 10
	ECHO ALL A highlander leans too far back in his chair and topples over.
ENDIF
IFVAR DUMMY4 = 11
	ECHO ALL A voluptuous woman stashes some coins in the cavity between her breasts.
ENDIF
IFVAR DUMMY4 = 12
	ECHO ALL In a quiet moment the bartender twirls his mustache.
ENDIF
IFVAR DUMMY4 = 13
	ECHO ALL The serving wench returns a drink to the bartender. Apparently there is a fly in it.
ENDIF
IFVAR DUMMY4 = 14
	ECHO ALL A drunken man yells, "Bring out yer dead," for no apparent reason.
ENDIF
IFVAR DUMMY4 = 15
	ECHO ALL You catch the serving wench giving the bartender the eye.
ENDIF
