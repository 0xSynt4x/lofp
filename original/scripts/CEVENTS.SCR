;
; Swamp mud....append this to something else
;
CEVENT 10 20 141
ECHO ALL You continue to sink into the mud.
;
;
;       Garin's sword VARs
;
VARIABLE JANGARSWORD
VARIABLE JANSWORDRNUM
VARIABLE JANEVILINROOM
VARIABLE JANEVILINROOM2
VARIABLE janevildif
VARIABLE JANCOUNTER
;
CEVENT 94 0 44
;
;       *** GARIN's SWORD CEVENT
;
; difference between last count and present count
EQUAL janevildif 0
ADD janevildif JANEVILINROOM2
SUB janevildif JANEVILINROOM
; sets last count for next cycle
EQUAL JANEVILINROOM2 JANEVILINROOM
EQUAL JANEVILINROOM 0
IFSEEK 362
  EQUAL JANSWORDRNUM RNUM
  IFVAR janevildif < -7
    ECHO PLAYER Lightbringer begins to glow with a bright white light.
    ECHO OTHERS %N's sword begins to glow with a bright white light.
    EQUAL ITEMVAL2 45
  ELSE
    IFVAR janevildif < -2
      IFVAR JANEVILINROOM2 >= 7
        ECHO PLAYER Lightbringer begins to glow with a bright white light.
        ECHO OTHERS %N's sword begins to glow with a bright white light.
        EQUAL ITEMVAL2 45
      ENDIF
      IFVAR JANEVILINROOM2 < 7
        ECHO PLAYER Lightbringer begins to glow softly with a white light.
        ECHO OTHERS %N's sword begins to glow softly with a white light.
        EQUAL ITEMVAL2 40
      ENDIF
    ELSE
      IFVAR janevildif < 0
        IFVAR JANEVILINROOM2 >= 7
          ECHO PLAYER Lightbringer begins to glow with a bright white light.
          ECHO OTHERS %N's sword begins to glow with a bright white light.
          EQUAL ITEMVAL2 45
        ENDIF
        IFVAR JANEVILINROOM2 < 7
          ECHO PLAYER Lightbringer vibrates with a nearly inaudible hum.
          EQUAL ITEMVAL2 30
        ENDIF
      ENDIF
    ENDIF
  ENDIF
  IFVAR janevildif > 0
    IFVAR JANEVILINROOM2 < 7
      ECHO PLAYER Lightbringer's glow fades to a soft white light.
      ECHO OTHERS The glow from %N's sword fades to a soft white light.
      EQUAL ITEMVAL2 40
    ELSE
      IFVAR JANEVILINROOM2 < 1
        ECHO PLAYER Lightbringer's glow fades altogether.
        ECHO OTHERS The glow from %N's sword fades altogether.
        EQUAL ITEMVAL2 25
      ENDIF
    ENDIF
  ENDIF
ENDIF
;
MACRO 47
;
; MACRO ROUTINE for Garin's Sword
;
  IFVAR RNUM = JANSWORDRNUM
    IFVAR ALIGN < -5
      ADD JANEVILINROOM 2
    ELSE
      IFVAR ALIGN < 0
        ADD JANEVILINROOM 1
      ENDIF
    ENDIF
  ENDIF
;
VARIABLE DEMONZAP
;
MACRO 88
IFVAR PLAYERNUM = DEMONZAP
  EQUAL SPELLNUM 139
  GMMSG ***Gonna zap %N***
  ECHO PLAYER You are surrounded by a black glow!
  ECHO OTHERS %N is surrounded by a black glow.
  EQUAL DEMONZAP 0
ENDIF
IFVAR PLAYERNUM = PATHOSER
  IFVAR RNUM = 206
    ECHO PLAYER The fountain glows with a strange red light, shifts a fraction and douses you with a stream of water!
    ECHO OTHERS The fountain glows red for a second and then douses %N with a stream of water!
    APPEAR %N is sopping wet!
    EQUAL PATHOSER 0
  ENDIF
ENDIF
IFVAR RNUM = GRADPAIN
  IFVAR PLAYERNUM ! GRADPAINSKIP
    IFVAR TERRAIN < 13
      ECHO PLAYER Something green springs out at you!
      ECHO OTHERS Something green springs out at %N!
      SPELL 526 100
      ADD GRADPAINCOUNT 1
      IFVAR GRADPAINCOUNT > 15
        EQUAL GRADPAIN 0
        EQUAL GRADPAINSKIP 0
        EQUAL GRADPAINCOUNT 0
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFVAR SPELLNUM = 139
  RANDOM DUMMY1 1 25 0
  IFVAR DUMMY1 = 1
    RANDOM DUMMY2 1 5 0
    IFVAR DUMMY2 = 1
      ECHO PLAYER An enormous demon hand appears in the air in front of you, grabs you and pulls to into hell!
      ECHO OTHERS An enormous demon hand grabs %N and takes %i away!
      POSITION LAY
      DAMAGEPLR CRUSH 40 You hit the floor hard!
      MOVE 1454
      AFFECT 1454
      ECHO OTHERS %N APPEARS FROM OUT OF NOWHERE AND HITS THE FLOOR HARD.
      EQUAL SPELLNUM 0
    ENDIF
    IFVAR DUMMY2 = 2
      EQUAL SPELLNUM 0
      IFVAR RAC < 7
        ECHO PLAYER The dark magics you are playing with make your heart stop beating. You keel over, dead.
        ECHO OTHERS %N keels over, dead.
        EQUAL DEAD 1
      ELSE
        ECHO PLAYER A black cloud descends upon you and renders you lifeless.
        ECHO OTHERS A black cloud descends upon %N and renders %i lifeless!
        EQUAL DEAD 1
      ENDIF
    ENDIF
    IFVAR DUMMY2 = 3
      EQUAL SPELLNUM 0
      ECHO PLAYER You get a lump in the pit of your stomach.
      ECHO PLAYER Your surroundings shift.
      ECHO OTHERS %N vanishes.
      MOVE 3260
      AFFECT 3260
      ECHO OTHERS %N appears.
      GENMON 299
      GENMON 298
      GENMON 297
      GENMON 296
      GENMON 295
    ENDIF
    IFVAR DUMMY2 = 4
      EQUAL SPELLNUM 0
      ECHO PLAYER Your body writhes in agony... You backout....
      ECHO OTHERS %N's body writhes in agony...
      ECHO OTHERS %N vanishes.
      MOVE 2225
      AFFECT 2225
      ECHO OTHERS %N appears in a moaning heap.
    ENDIF
    IFVAR DUMMY2 = 5
      EQUAL SPELLNUM 0
      ECHO PLAYER You feel that you have someone's attention...
      ECHO PLAYER Forces of dark magic lash out at you!
      ECHO OTHERS Forces of dark magic lash out at %N!
      SPELL 351 30
      SPELL 351 30
      SPELL 351 30
      SPELL 351 30
      SPELL 351 30
      SPELL 351 30
      SPELL 231 30
    ENDIF
  ENDIF
ENDIF
IFVAR SPELLNUM = 140
  RANDOM DUMMY1 1 50 0
  IFVAR DUMMY1 = 1
    RANDOM DUMMY2 1 5 0
    IFVAR DUMMY2 = 1
      ECHO PLAYER An enormous demon hand appears in the air in front of you, grabs you and pulls to into hell!
      ECHO OTHERS An enormous demon hand grabs %N and takes %i away!
      POSITION LAY
      DAMAGEPLR CRUSH 40 YOU HIT THE FLOOR HARD!
      MOVE 1454
      AFFECT 1454
      ECHO OTHERS %N appears from out of nowhere and hits the floor hard.
      EQUAL SPELLNUM 0
    ENDIF
    IFVAR DUMMY2 = 2
      IFVAR RAC > 7
        ECHO PLAYER The dark magics you are playing with make your heart stop beating. You keel over, dead.
        ECHO OTHERS %N keels over, dead.
        EQUAL DEAD 1
      ELSE
        ECHO PLAYER A black cloud descends upon you and renders you lifeless.
        ECHO OTHERS A black cloud descends upon %N and renders %i lifeless!
        EQUAL DEAD 1
      ENDIF
    ENDIF
    IFVAR DUMMY2 = 3
      ECHO PLAYER You get a lump in the pit of your stomach.
      ECHO PLAYER Your surroundings shift.
      ECHO OTHERS %N vanishes.
      EQUAL PBACKFLOW RNUM
      MOVE 3260
      AFFECT 3260
      ECHO OTHERS %N appears.
      GENMON 299
      GENMON 298
      GENMON 297
      GENMON 296
      GENMON 295
    ENDIF
    IFVAR DUMMY2 = 4
      ECHO PLAYER Your body writhes in agony... You backout....
      ECHO OTHERS %N's body writhes in agony...
      ECHO OTHERS %N vanishes.
      EQUAL PAGONY RNUM
      MOVE 2225
      AFFECT 2225
      ECHO OTHERS %N appears in a moaning heap.
    ENDIF
    IFVAR DUMMY2 = 5
      ECHO PLAYER You feel that you have someone's attention...
      ECHO PLAYER Forces of dark magic lash out at you!
      ECHO OTHERS Forces of dark magic lash out at %N!
      SPELL 351
      SPELL 351
      SPELL 351
      SPELL 351
      SPELL 351
      SPELL 351
      SPELL 231
    ENDIF
  ENDIF
ENDIF
IFVAR PPOISON1 > 0
  IFVAR INTNUM3 = PPOISON1
    RANDOM DUMMY1 1 3 0
    IFVAR DUMMY1 = 1
      ECHO PLAYER Your temples throb.
      ECHO OTHERS %N's temples throb ominously.
    ENDIF
    ADD PSIPOINTS 5
    SUB MANAPOINTS 10
    SUB FATPOINTS 1
    IFVAR MANAPOINTS < 0
      EQUAL PPOISON1 0
      ECHO PLAYER Your head stops throbbing.
    ENDIF
    IFVAR FATPOINTS < 0
      EQUAL PPOISON1 0
      ECHO PLAYER Your head stops throbbing.
    ENDIF
  ENDIF
ENDIF
IFVAR PPOISON2 > 0
  IFVAR INTNUM3 = PPOISON2
    RANDOM DUMMY1 1 3 0
    IFVAR DUMMY1 = 1
      ECHO PLAYEr Your temples throb.
      ECHO OTHERS %N's temples throb ominously.
    ENDIF
    ADD PSIPOINTS 5
    SUB MANAPOINTS 10
    SUB FATPOINTS 1
    IFVAR MANAPOINTS < 0
      EQUAL PPOISON2 0
      ECHO PLAYER Your head stops throbbing.
    ENDIF
    IFVAR FATPOINTS < 0
      EQUAL PPOISON2 0
      ECHO PLAYER Your head stops throbbing.
    ENDIF
  ENDIF
ENDIF
IFVAR PPOISON3 > 0
  IFVAR INTNUM3 = PPOISON3
    RANDOM DUMMY1 1 3 0
    IFVAR DUMMY1 = 1
      ECHO PLAYER Your temples throb.
      ECHO OTHERS %N's temples throb ominously.
    ENDIF
    ADD PSIPOINTS 5
    SUB MANAPOINTS 10
    SUB FATPOINTS 1
    IFVAR MANAPOINTS < 0
      EQUAL PPOISON3 0
      ECHO PLAYER Your head stops throbbing.
    ENDIF
    IFVAR FATPOINTS < 0
      EQUAL PPOISON3 0
      ECHO PLAYER YOUR HEAD STOPS THROBBING.
    ENDIF
  ENDIF
ENDIF
IFVAR INTNUM3 = 165
  IFVAR WARRANT = 6
    EQUAL WARRANT 0
  ENDIF
ENDIF
;IFVAR INTNUM3 = 255
;  IFVAR DISGUISED ! 1
;  EQUAL WARRANT 9
;  ENDIF
;ENDIF
;IFVAR INTNUM3 = 400
;  IFVAR DISGUISED ! 1
;  EQUAL WARRANT 9
;  ENDIF
;ENDIF
;IFVAR INTNUM3 = 230
;  IFVAR DISGUISED ! 1
;  EQUAL WARRANT 9
;  ENDIF
;ENDIF
IFVAR PATCOLLARON = 1
  IFVAR INTNUM97 = 5
    IFVAR DEAD ! 1
      RANDOM DUMMY1 1 2 0
      IFVAR DUMMY1 = 1
        SUB PSIPOINTS 1
      ENDIF
      IFVAR BODYPOINTS < PATCOLLARBODY
        ADD PATCOUNTER 1
        IFVAR PATCOUNTER = 40
        ECHO PLAYER Your collar emits a high pitched beep.
        ECHO OTHERS Something on %N emits a high pitched beep.
        ECHO PLAYER Purple and blue lights flash around you.
        ADD BODYPOINTS 30
        SPELL 303 50
        SPELL 319 50
        EQUAL PATCOUNTER 0
        ENDIF
      ENDIF
    ELSE
      IFVAR PATCOLLAR3 > 0
        IFVAR PATCOLLARUSED = 0
          IFVAR REGION = 0
            ECHO PLAYER Three large robots phase in next to you, grab your corpse and phase out...
            ECHO OTHERS Three large robots phase in, grab %N's body and phase out with it.
            EQUAL PATCOLLARUSED 1
            MOVE 96
            AFFECT 96
            ECHO OTHERS Three large robots phase in carrying %N's dead body.
            POSITION LAY
            PLREVENT 3
            CONTPLREVENT
            ECHO PLAYER THE ROBOTS EFFICIENTLY MOVE AROUND AND TRY TO BRING YOU BACK TO LIFE.
            ECHO OTHERS The robots seem to be trying to bring %N back to life.
            PLREVENT 3
            CONTPLREVENT
            ECHO PLAYER The robots successfully bring you back from the dead.
            ECHO OTHERS %N takes a breath and you realize that %s is alive.
            ECHO PLAYER One of the robots whispers to you, "We cannot help you any more today."
            ECHO ALL The robots all touch a panel on their chests and phase out in unison.
            EQUAL ROUNDTIME 90
            ECHO PLAYER [Round: 90 Sec]
            EQUAL DEAD 0
            ECHO PLAYER Your collar clicks off to charge a bit.
            EQUAL PATCOLLARON 0
            EQUAL MANAPOINTS 0
            EQUAL PSIPOINTS 0
            EQUAL FATPOINTS 0
          ENDIF
        ENDIF
      ENDIF
    ENDIF
  ENDIF
  IFVAR INTNUM97 = 6
    IFVAR DEAD ! 1
      RANDOM DUMMY1 1 2 0
      IFVAR DUMMY1 = 1
        SUB MANAPOINTS 1
      ENDIF
      IFVAR BODYPOINTS < PATCOLLARBODY
        ADD PATCOUNTER 1
        IFVAR PATCOUNTER = 40
          ECHO PLAYER Your collar emits a high pitched beep.
          ECHO OTHERS Something on %N emits a high pitched beep.
          ECHO PLAYER Purple and blue lights flash around you. You feel a little better
          ADD BODYPOINTS 30
          SPELL 303 50
          SPELL 319 50
          EQUAL PATCOUNTER 0
        ENDIF
      ENDIF
    ELSE
      IFVAR PATCOLLAR3 > 0
        IFVAR PATCOLLARUSED = 0
          IFVAR REGION = 0
            ECHO PLAYER Three large robots phase in next to you, grab your corpse and phase out...
            ECHO OTHERS Three large robots phase in, grab %N's body and phase out with it.
            EQUAL PATCOLLARUSED 1
            MOVE 96
            AFFECT 96
            ECHO OTHERS Three large robots phase in carrying %N's dead body.
            POSITION LAY
            PLREVENT 3
            CONTPLREVENT
            ECHO PLAYER The robots efficiently move around and try to bring you back to life.
            ECHO OTHERS The robots seem to be trying to bring %N back to life.
            PLREVENT 3
            CONTPLREVENT
            ECHO PLAYER The robots successfully bring you back from the dead.
            ECHO OTHERS %N takes a breath and you realize that %s is alive.
            ECHO PLAYER One of the robots whispers to you, "We cannot help you any more today."
            ECHO ALL The robots all touch a panel on their chests and phase out in unison.
            EQUAL ROUNDTIME 90
            ECHO PLAYER [Round: 90 Sec]
            EQUAL DEAD 0
            ECHO PLAYER Your collar clicks off to charge a bit.
            EQUAL PATCOLLARON 0
            EQUAL MANAPOINTS 0
            EQUAL PSIPOINTS 0
            EQUAL FATPOINTS 0
          ENDIF
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF


