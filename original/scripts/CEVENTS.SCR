;
;Ichiro's Cevents
;
CEVENT 74 0 482

IFSEEK 74
  IFVAR RAC ! 111
    IFVAR WIELDED = 1886
      IFVAR DEAD = 1
        ECHO OTHERS %N's pogo stick bounces around with %h corpse.
        ECHO PLAYER The pogo stick bounces your corpse around.
      ENDIF
      IFVAR MOVEABLE ! 0
        IFVAR ITEMVAL1 = 0 // N
          IFVAR EXITN ! -1
            ECHO OTHERS %N's pogo stick bounces %i north!
            ECHO PLAYER Your pogo stick bounces you north!
            MOVE EXITN
            SHOWROOM EXITN
            AFFECT RNUM
            ECHO OTHERS %N's pogo stick bounces %i in!
          ELSE
            ECHO OTHERS %N's pogo stick bounces %i north, bashing %i into a wall.
            ECHO PLAYER Your pogo stick tries to bounce you north, but you end up hitting a wall.
          ENDIF
        ENDIF
        IFVAR ITEMVAL1 = 1 // NE
          IFVAR EXITNE ! -1
            ECHO OTHERS %N's pogo stick bounces %i northeast!
            ECHO PLAYER Your pogo stick bounces you northeast!
            MOVE EXITNE
            SHOWROOM EXITNE
            AFFECT RNUM
            ECHO OTHERS %N's pogo stick bounces %i in!
          ELSE
            ECHO OTHERS %N's pogo stick bounces %i northeast, bashing %i into a wall.
            ECHO PLAYER Your pogo stick tries to bounce you northeast, but you end up hitting a wall.
          ENDIF
        ENDIF
        IFVAR ITEMVAL1 = 2 // E
          IFVAR EXITE ! -1
            ECHO OTHERS %N's pogo stick bounces %i east!
            ECHO PLAYER Your pogo stick bounces you east!
            MOVE EXITE
            SHOWROOM EXITE
            AFFECT RNUM
            ECHO OTHERS %N's pogo stick bounces %i in!
          ELSE
            ECHO OTHERS %N's pogo stick bounces %i east, bashing %i into a wall.
            ECHO PLAYER Your pogo stick tries to bounce you east, but you end up hitting a wall.
          ENDIF
        ENDIF
        IFVAR ITEMVAL1 = 3 // SE
          IFVAR EXITSE ! -1
            ECHO OTHERS %N's pogo stick bounces %i southeast!
            ECHO PLAYER Your pogo stick bounces you southeast!
            MOVE EXITSE
            SHOWROOM EXITSE
            AFFECT RNUM
            ECHO OTHERS %N's pogo stick bounces %i in!
          ELSE
            ECHO OTHERS %N's pogo stick bounces %i southeast, bashing %i into a wall.
            ECHO PLAYER Your pogo stick tries to bounce you southeast, but you end up hitting a wall.
          ENDIF
        ENDIF
        IFVAR ITEMVAL1 = 4 // S
          IFVAR EXITS ! -1
            ECHO OTHERS %N's pogo stick bounces %i south!
            ECHO PLAYER Your pogo stick bounces you south!
            MOVE EXITS
            SHOWROOM EXITS
            AFFECT RNUM
            ECHO OTHERS %N's pogo stick bounces %i in!
          ELSE
            ECHO OTHERS %N's pogo stick bounces %i south, bashing %i into a wall.
            ECHO PLAYER Your pogo stick tries to bounce you south, but you end up hitting a wall.
          ENDIF
        ENDIF
        IFVAR ITEMVAL1 = 5 // SW
          IFVAR EXITSW ! -1
            ECHO OTHERS %N's pogo stick bounces %i southwest!
            ECHO PLAYER Your pogo stick bounces you southwest!
            MOVE EXITN
            SHOWROOM EXITN
            AFFECT RNUM
            ECHO OTHERS %N's pogo stick bounces %i in!
          ELSE
            ECHO OTHERS %N's pogo stick bounces %i north, bashing %i into a wall.
            ECHO PLAYER Your pogo stick tries to bounce you north, but you end up hitting a wall.
          ENDIF
        ENDIF
        IFVAR ITEMVAL1 = 6 // W
          IFVAR EXITW ! -1
            ECHO OTHERS %N's pogo stick bounces %i west!
            ECHO PLAYER Your pogo stick bounces you west!
            MOVE EXITW
            SHOWROOM EXITW
            AFFECT RNUM
            ECHO OTHERS %N's pogo stick bounces %i in!
          ELSE
            ECHO OTHERS %N's pogo stick bounces %i west, bashing %i into a wall.
            ECHO PLAYER Your pogo stick tries to bounce you west, but you end up hitting a wall.
          ENDIF
        ENDIF
        IFVAR ITEMVAL1 = 7 // NW
          IFVAR EXITNW ! -1
            ECHO OTHERS %N's pogo stick bounces %i northwest!
            ECHO PLAYER Your pogo stick bounces you northwest!
            MOVE EXITNW
            SHOWROOM EXITNW
            AFFECT RNUM
            ECHO OTHERS %N's pogo stick bounces %i in!
          ELSE
            ECHO OTHERS %N's pogo stick bounces %i northwest, bashing %i into a wall.
            ECHO PLAYER Your pogo stick tries to bounce you northwest, but you end up hitting a wall.
          ENDIF
        ENDIF
      ELSE
        ECHO PLAYER Your pogo stick tries to bounce you away, but to no avail.
        ECHO OTHERS %N's pogo stick bounces up and down, but is unable to break %i free.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFVAR CBLCAULDRON > 0
  AFFECT 2707
  ADD CBLCAULDRON -1
  IFVAR CBLCAULDRON = 0
    ECHO ALL The guards step away from the cauldron of boiling oil.
  ENDIF
  IFVAR CBLCAULDRON = 2
    ECHO ALL A guard pours more oil into the cauldron.
  ENDIF
ENDIF
IFVAR CBRCAULDRON > 0
  AFFECT 2711
  ADD CBRCAULDRON -1
  IFVAR CBRCAULDRON = 0
    ECHO ALL The guards step away from the cauldron of boiling oil.
  ENDIF
  IFVAR CBRCAULDRON = 2
    ECHO ALL A guard pours more oil into the cauldron.
  ENDIF
ENDIF
AFFECT 2722
; CB Arena:
IFVAR CBAPPLAUSE > 0
  EQUAL CBAVERAGE CBAPPLAUSE

  IFVAR CBLASTAVERAGE = 0
    IFVAR CBAVERAGE > 0
    ENDIF
  ENDIF

  IFVAR CBAVERAGE = 0
    IFVAR CBLASTAVERAGE > CBAVERAGE
      ECHO ALL The applause dies down.
    ENDIF
  ELSE
    IFVAR CBAVERAGE = CBLASTAVERAGE
      ECHO ALL The audience continues to applaud.
    ENDIF
  ENDIF
  IFVAR CBAVERAGE = 3
    IFVAR CBLASTAVERAGE > CBAVERAGE
      ECHO ALL The applause dies down to almost nothing.
    ENDIF
  ENDIF
  IFVAR CBAVERAGE > 10
    IFVAR CBLASTAVERAGE < CBAVERAGE
      RANDOM DUMMY1 1 5 0
      IFVAR DUMMY1 = 1
        ECHO ALL The crowd goes wild!
      ENDIF
      IFVAR DUMMY1 = 2
        ECHO ALL The crowd roars its approval!
      ENDIF
      IFVAR DUMMY1 = 3
        ECHO ALL The audience has gone mad with bloodlust!
      ENDIF
      IFVAR DUMMY1 = 4
        ECHO ALL The audience cheers you on!
      ENDIF
      IFVAR DUMMY1 = 5
        ECHO ALL The guards in the balcony crowd towards the edge to get a glimpse of the action.
      ENDIF
    ENDIF
  ENDIF

  EQUAL CBLASTAVERAGE CBAVERAGE
  EQUAL CBAPPLAUSE 0
ENDIF

