 ELSE
  ECHO PLAYER Your a GM! Of course you can pick it up.
 ENDIF
ENDIF
IFTOUCH -1
 IFVAR ORG ! 27
    ECHO PLAYER %a was not meant for you.
    ECHO OTHERS %n can not figure out what %a is about.
    CLEARVERB
  ENDIF
ENDIF
