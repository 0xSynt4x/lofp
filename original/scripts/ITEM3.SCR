		ENDIF
		IFVAR DUMMY1 < 50
			ECHO ALL A doll fires at %n with its bow.%c      [To hit: 50 Roll: %0. Miss.]
		ENDIF
	ENDIF
	IFVAR ITEMVAL1 = 2
		ECHO ALL %A incants a spell.
		ECHO ALL A doll gestures at %n.
		SPELL 315
	ENDIF
