IFPREVERB THUMP -1
	CLEARVERB
	IFVAR ITEMVAL1 = 1
		ECHO PLAYER You thump the doll upside the head!
		ECHO OTHERS %N thumps %a upside the head!
	ENDIF
	IFVAR ITEMVAL1 = 2
		ECHO PLAYER You try to thump the doll upside the head, but it nimbly avoids your strike!
		ECHO OTHERS %N tries to thump %a upside the head, but it nimbly avoids %h strike!
	ENDIF
ENDIF
IFPREVERB PUSH -1
	CLEARVERB
	ECHO PLAYER You squeeze the doll.
	ECHO OTHERS %N squeezes %a.
	IFVAR ITEMVAL1 = 1
		ECHO ALL The doll's eyes light up.
	ENDIF
	IFVAR ITEMVAL1 = 2
		ECHO ALL The doll exclaims, "Soon we will rule all of Andor!"
	ENDIF
ENDIF
IFPREVERB PULL -1
	CLEARVERB
	ECHO OTHERS %N pulls the string on the back of %a, which slowly retracts...
	ECHO PLAYER You pull out the string on the back of the doll, which slowly retracts...
	IFVAR ITEMVAL1 = 1
		RANDOM DUMMY1 1 10 0
		IFVAR DUMMY1 = 1
			ECHO ALL The doll exclaims, "Hello! I'm Dopey Druid!"
		ENDIF
		IFVAR DUMMY1 = 2
			ECHO ALL The doll asks, "Will you hunt with me?"
		ENDIF
		IFVAR DUMMY1 = 3
			ECHO ALL The doll says, "The forest is my home and the trees are my best friends."
		ENDIF
		IFVAR DUMMY1 = 4
			ECHO ALL The doll says, "I am flame-retardent and completely child-safe."
		ENDIF
		IFVAR DUMMY1 = 5
			ECHO ALL The doll says, "Give a hoot! Don't litter!"
		ENDIF
		IFVAR DUMMY1 = 6
			ECHO ALL The doll asks, "All right, kids, what time is it?"
			PLREVENT 1
			CONTPLREVENT
			ECHO ALL The doll exclaims, "That's right, kids, it's time to go camping!"
		ENDIF
		IFVAR DUMMY1 = 7
			ECHO ALL The doll says, "Weather is not a toy."
		ENDIF
		IFVAR DUMMY1 = 8
			ECHO ALL The doll says, "Fun safety tip: If you feed the ursines, be sure to give them meat. They hate peanuts!"
		ENDIF
		IFVAR DUMMY1 = 9
			ECHO ALL The doll sings, "Over the river and through the woods, to Forester's Grove we go..."
		ENDIF
		IFVAR DUMMY1 = 10
			IFVAR PLRSINROOM > 3
				ECHO OTHERS The doll murmurs something softly to %n.
				ECHO PLAYER You can barely make out as the doll says, "We... are not alone."
			ENDIF
			IFVAR PLRSINROOM < 4
				ECHO OTHERS The doll murmurs something softly to %n.
				ECHO PLAYER You can barely make out as the doll exclaims, "Help! I'm trapped in a toy factory and I can't get out!"
			ENDIF
		ENDIF
	ENDIF
	IFVAR ITEMVAL1 = 2
		RANDOM DUMMY1 1 10 0
		IFVAR DUMMY1 = 1
			ECHO ALL The doll exclaims, "Soon we will rule all of Andor!"
		ENDIF
		IFVAR DUMMY1 = 2
			ECHO ALL The doll says, "Trust me. I am not evil."
		ENDIF
		IFVAR DUMMY1 = 3
			ECHO ALL The doll exclaims, "Dahkahn, Dahkahn, Dahkahn! Ha ha, you can't arrest a doll!"
		ENDIF
		IFVAR DUMMY1 = 4
			ECHO ALL The doll asks, "Hey, anybody want to go hunt commoners with me?"
		ENDIF
		IFVAR DUMMY1 = 5
			ECHO ALL The doll exclaims, "Join the F.S.A!"
		ENDIF
		IFVAR DUMMY1 = 6
			ECHO ALL The doll says, "New here, eh? Well, come with me and I'll get you some equipment."
		ENDIF
		IFVAR DUMMY1 = 7
			ECHO ALL The doll rasps, "Evil?"
			PLREVENT 1
			CONTPLREVENT
			ECHO ALL The doll clears its tiny throat.
			PLREVENT 1
			CONTPLREVENT
			ECHO ALL The doll says, "No, I'm not evil."
		ENDIF
		IFVAR DUMMY1 = 8
			ECHO ALL The doll says, "Blood... I must have blood..."
		ENDIF
		IFVAR DUMMY1 = 9
			IFVAR DAY = 1
				IFVAR WILDERNESS = 1
					ECHO ALL The doll says, "Hey, keep me out of the sun."
				ENDIF
				IFVAR WILDERNESS = 0
					ECHO ALL The doll says, "Don't forget to keep me out of the sun."
				ENDIF
			ENDIF
			IFVAR DAY = 0
				ECHO ALL The doll says, "Ah... I love the night."
			ENDIF
		ENDIF
		IFVAR DUMMY1 = 10
			ECHO ALL The doll says, "Try some mandrake root. It's really good. Trust me."
		ENDIF
	ENDIF
ENDIF
IFVERB KICK -1
	IFVAR ITEMVAL1 = 1
		ECHO OTHERS You'd swear you see the doll point its little bow at %n.
		PLREVENT 2
		CONTPLREVENT
		ECHO ALL A doll loads the bow with a broad-bladed little plastic arrow.
		RANDOM DUMMY1 1 100 0
		STRCVT 0 DUMMY1
		IFVAR DUMMY1 > 49
			ECHO OTHERS A doll fires at %n with its bow.%c      [To hit: 50 Roll: %0. Hit!]
