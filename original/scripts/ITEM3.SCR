;
; Candy
INUMBER 1319
NAME 910
WEIGHT 1
VOLUME 1
FOOD
SUBSTANCE CLOTH
PARAMETER1 1
IFPREVERB EAT -1
	IFVAR RAC < 7
		CLEARVERB
		ECHO PLAYER You pop %a into your mouth.
		EQUAL ROUNDTIME 5
		ROUTINE 1
		IFVAR ITEMADJ1 = 347
			ECHO PLAYER You taste cool mint. You get the sensation of racing down an powdery white ski slope, the winter wind whipping through your hair...
		ENDIF
		IFVAR ITEMADJ1 = 54
			ECHO PLAYER The creamy milk chocolate melts into a delicious silk sensation in your mouth.
		ENDIF
		IFVAR ITEMADJ1 = 152
			ECHO PLAYER You taste sour apple. Your lips pucker up. Despite the candy's yumminess, the inside of your mouth seems to be shrinking.
		ENDIF
		IFVAR ITEMADJ1 = 259
			ECHO PLAYER The taste of freshly picked juicy cherries fills your mouth.
		ENDIF
		REMOVEITEM -1
	ENDIF
ENDIF
;
; Lotion
INUMBER 1801
NAME 351
WEIGHT 1
VOLUME 1
ARTICLE SOME
IFPREVERB PULL -1
	ECHO OTHERS %N pulls one hand slowly across the other, covering %h palms with %a.
	ECHO PLAYER You pull one hand slowly across the other, covering your palms with %a.
	CLEARVERB
ENDIF
IFPREVERB PUSH -1
	CLEARVERB
	ECHO OTHERS %N pushes %h hands together, little driblets of %a squeezing out from between them and falling to the floor.
	ECHO PLAYER You push your hands together, little driblets of the squeezing out and falling to the floor.
ENDIF
IFPREVERB RUB -1
	EQUAL ROUNDTIME 10
	CLEARVERB
	IFVAR RNUM > 1899
		IFVAR RNUM < 2000
			SUB ITEMVAL2 1
			IFVAR PLRSINROOM ! 2
				ECHO PLAYER You rub %a onto your arms, legs, face... everywhere.
			ENDIF
			IFVAR PLRSINROOM = 2
				IFVAR FLAG4 >= 2
					ECHO PLAYER You continue to apply %a, rubbing it into your partner's back.
					ECHO OTHERS %N continues to rub %a slowly into your back.
					ADD FLAG4 1
				ENDIF
				IFVAR FLAG4 = 1
					ECHO PLAYER You begin to gently massage your partner's back and shoulders with %a using a deep circular strokes.
					ECHO OTHERS %N begins to gently massage your back  and shoulders with %a using a deep circular strokes.
					ADD FLAG4 1
				ENDIF
				IFVAR FLAG4 = 0
					ECHO PLAYER You begin to apply%a, rubbing it into your partner's back.
					ECHO OTHERS %N begins to rub %a into your back.
					ADD FLAG4 1
				ENDIF
			ENDIF
			IFVAR ITEMVAL2 = 0
				ECHO PLAYER That was the last of it.
				REMOVEITEM -1
			ENDIF
		ENDIF
	ENDIF
ENDIF
