;
; Box (teleporting)
INUMBER 574
NAME 363
WEIGHT 2
VOLUME 1
OPENABLE
CONTAINER IN
IFPREVERB GO -1
	CLEARVERB
	IFVAR REGION ! 0
		ECHO PLAYER For some reason you can't seem to fit through the box right now.
	ENDIF
	IFVAR REGION = 0
		IFVAR QUESTISON = 0
			IFITEM -1 CLOSED
				ECHO PLAYER The box is closed.
			ENDIF
			IFITEM -1 OPEN
				EQUAL DANLEFT RNUM
				CLOSE -1
				ECHO PLAYER You step into the tiny box, calmly violating the laws of physics.
				ECHO OTHERS %N calmly violates the laws of physics by stepping into %a.
				ECHO OTHERS The box closes, then vanishes.
				IFVAR DANBOX1 > 0
					MOVE DANBOX1
					AFFECT DANBOX1
					ECHO OTHERS %N steps out of nowhere.
					AFFECT DANLEFT
					EQUAL DANBOX1 DANLEFT
				ENDIF
				IFVAR DANBOX1 = 0
					MOVE 530
					AFFECT 530
					ECHO OTHERS %N steps out of nowhere.
					AFFECT DANLEFT
					EQUAL DANBOX1 DANLEFT
				ENDIF
			ENDIF
		ENDIF
		IFVAR QUESTISON ! 0
			ECHO PLAYER For some reason you can't seem to fit through the box right now.
		ENDIF
	ENDIF
ENDIF
IFPREVERB PUSH -1
	CLEARVERB
	IFVAR REGION ! 0
		ECHO PLAYER For some reason you can't seem to push in the side of the box right now.
	ENDIF
	IFVAR REGION = 0
		IFVAR QUESTISON = 0
			IFITEM -1 CLOSED
				ECHO PLAYER You gently push one side of the box in, causing it to produce a "click!" sound.
				ECHO OTHERS %N gently pushes one side of %a in, causing it to produce a "click!" sound.
				EQUAL DANBOX1 RNUM
			ENDIF
			IFITEM -1 OPEN
				ECHO PLAYER You gently push one side of the box in, causing it to produce a "click!" sound.
				ECHO OTHERS %N gently pushes one side of %a in, causing it to produce a "click!" sound.
				EQUAL DANBOX2 RNUM
			ENDIF
		ENDIF
		IFVAR QUESTISON ! 0
			ECHO PLAYER For some reason you can't seem to push in the side of the box right now.
		ENDIF
	ENDIF
ENDIF
IFPREVERB TURN -1
	CLEARVERB
	IFITEM -1 OPEN
		ECHO PLAYER The box is open.
	ENDIF
	IFITEM -1 CLOSED
		IFVAR REGION ! 0
			ECHO PLAYER For some reason the two halves of the box don't seem to want to turn right now.
		ENDIF
		IFVAR REGION = 0
			IFVAR QUESTISON = 1
				ECHO PLAYER For some reason the two halves of the box don't seem to want to turn right now.
			ENDIF
			IFVAR QUESTISON = 0
				ECHO OTHERS %N turns the halves of %a in opposite directions until it is once again a perfect cube and quietly vanishes.
				ECHO PLAYER You turn the two halves of the box in opposite directions until it is once again a perfect cube.
				EQUAL DUMMY1 RNUM
				IFVAR DANBOX2 = 0
					EQUAL DANBOX2 1385
				ENDIF
				MOVE DANBOX2
				AFFECT DANBOX2
				ECHO OTHERS You notice %n standing in the shadows.
				AFFECT DUMMY1
			ENDIF
		ENDIF
	ENDIF
ENDIF
