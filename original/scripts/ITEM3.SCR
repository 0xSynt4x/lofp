	IFVAR ITEMVAL1 = 1
		IFVAR ORG ! 7
			ECHO PLAYER You try to hug the doll, but it holds you back!
			ECHO OTHERS %N tries to hug %a, but it holds %h back!
			ECHO ALL The doll exclaims, "I only hug trees!"
		ENDIF
		IFVAR ORG = 7
			ECHO PLAYER You hug the doll.
			ECHO OTHERS %N hugs %a.
		ENDIF
	ENDIF
	IFVAR ITEMVAL1 = 2
		ECHO PLAYER You hug the doll.
		ECHO OTHERS %N hugs %a.
		ECHO OTHERS You notice the doll pulling a dagger from a concealed sheath... suddenly it stabs %n!
		PLREVENT 1
		CONTPLREVENT
		DAMAGEPLR SLASH 10 The doll suddenly slashes at you with a tiny dagger!
	ENDIF
