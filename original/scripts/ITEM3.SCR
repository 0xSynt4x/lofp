  IFPREVERB PULL -1
  CLEARVERB
ECHO ALL %N gives %a a good push to get it going then dives through it, does a double flip and lands on %h feet.
  ENDIF
  IFVERB HUG -1
  CLEARVERB
ECHO ALL %N slips %a over %h head down to %h waist %N bumps and grinds %i hips causing the wheel to spin around and around %iself.
  ENDIF
  IFVERB MASSAGE -1
  CLEARVERB
ECHO ALL %N tosses %a into the air, dives through it doing a backflip and lands on %h toes, catching it with one hand before it hits the ground.
  ENDIF
  IFVERB CARESS -1
  CLEARVERB
ECHO ALL %N balances %a on one fingertip, spins it and keeps it whirling at a frantic speed until %s tosses it up into the air and catches it on the tip of %h foot.
  ENDIF
