IFPREVERB TURN -1
	IFVAR REGION = 0
		CLEARVERB
		IFVAR ITEMVAL2 = 0
			ECHO PLAYER Nothing seems to happen.
			ECHO OTHERS %N twists %h ring.
		ENDIF
		IFVAR ITEMVAL2 = 1
			ECHO PLAYER You twist the ring, and feel strange forces at work.
			ECHO OTHERS %N twists %h ring, and you feel something evil in the air.
			GENMON 295
			MOVE 206
			AFFECT 206
			ECHO OTHERS %N appears, through a rift in reality!
			EQUAL ITEMVAL2 0
		ENDIF
		IFVAR ITEMVAL2 > 1
			ECHO PLAYER You twist the ring, and feel strange forces at work.
			ECHO OTHERS %N twists %h ring, and you feel something evil in the air.
			GENMON 299
			MOVE 206
			AFFECT 206
			ECHO OTHERS %N appears, through a rift in reality!
			SUB ITEMVAL2 1
		ENDIF
	ENDIF
ENDIF
