IFPREVERB TWIST -1
	CLEARVERB
	ECHO PLAYER You shake up %a
	ECHO OTHERS %N shakes %a
	RANDOM DUMMY1 1 21 0
	RANDOM DUMMY2 1 21 0
	RANDOM DUMMY3 1 21 0
	IFVAR DUMMY2 = DUMMY1
		ADD DUMMY2 2
	ENDIF
	IFVAR DUMMY3 = DUMMY2
		ADD DUMMY3 5
	ENDIF
	IFVAR DUMMY3 = DUMMY1
		ADD DUMMY3 1
	ENDIF
	MOD DUMMY1 22
	MOD DUMMY2 22
	MOD DUMMY3 22
	EQUAL ITEMVAL1 DUMMY1
	EQUAL ITEMVAL2 DUMMY2
	EQUAL ITEMVAL3 DUMMY3
	EQUAL CHASTEMP2 DUMMY2
ENDIF
