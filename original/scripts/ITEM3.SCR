	SETITEMADJ -1 1 266
	SETITEMADJ -1 2 1111
	SETITEMADJ -1 3 40
ENDIF
IFVERB TOUCH -1
	ECHO PLAYER The egg is soft and leathery to the touch.
ENDIF
IFVERB LISTEN -1
	ECHO PLAYER You hear movement inside the egg.
ENDIF
IFPREVERB RUB -1
	CLEARVERB
	IFVAR ITEMADJ1 ! 266
		REMOVEITEM -1
		ECHO PLAYER You rub the surface of the egg. The heat caused by the friction of your hand triggers a reaction. Something suddenly bursts forth from within!
		ECHO OTHERS %N rubs the surface of a leathery brown egg. The heat caused by the friction of %h hand triggers a reaction. Something suddenly bursts forth from within!
		GENMON 288
	ENDIF
	IFVAR ITEMADJ1 = 266
		REMOVEITEM -1
		ECHO PLAYER You rub the surface of the egg. The shell breaks open and an icky greeen goo spills out.
		ECHO OTHERS %N rubs the surface of the egg. The shell breaks open and an icky greeen goo spills out.
	ENDIF
ENDIF
IFPREVERB EAT -1
	CLEARVERB
	ECHO PLAYER After a moment's thought, you realize that these aren't like the ones mom used to whip up.
ENDIF
