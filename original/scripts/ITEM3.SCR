; (manango) fruit
INUMBER 473
NAME 92
FOOD
WEIGHT 1
VOLUME 1
SUBSTANCE INSUBSTANTIAL
EQUAL ITEMVAL3 335
PARAMETER1 4
IFVERB EAT -1
        ECHO PLAYER You savor the tart, tangy juice of the fruit.
        SUB ITEMVAL2 1
        ROUTINE 1
        CLEARVERB
        IFVAR ITEMVAL2 = 0
                IFITEM 9
                ECHO PLAYER Funny, there was no pit in that one.
                EQUAL ALPO 1
                ENDIF
                IFVAR ALPO = 0
                ECHO PLAYER You finish the fruit and spit out the hard pit.
                REMOVEITEM -1
                NEWITEM 9 1680 ADJ1=1236 VAL5=10
                ENDIF
                EQUAL ALPO 0
                endif
        endif
endif
;
; myrkberry
INUMBER 472
NAME 1388
DYE
FOOD
WEIGHT 1
VOLUME 1
SUBSTANCE INSUBSTANTIAL
PARAMETER1 1
PARAMETER3 1243
EQUAL ITEMVAL3 209
IFPREVERB EAT -1
	EQUAL DUMMY1 0
	ECHO PLAYER You eat a sugary myrkberry and immediately feel revitalized.
	ECHO OTHERS %N eats a myrkberry.
	ROUTINE 1
	REMOVEITEM -1
	IFVAR INTNUM82 = TIM
		ADD INTNUM14 1
	ENDIF
	EQUAL INNUM82 TIM
	IFVAR INTNUM14 > 4
		EQUAL DUMMY1 1
		IFVAR INTNUM14 > 9
			EQUAL DUMMY1 2
			IFVAR INTNUM14 > 14
				EQUAL DUMMY1 3
				IFVAR INTNUM14 > 19
					EQUAL DUMMY1 4
					IFVAR INTNUM14 > 24
						EQUAL DUMMY1 5
						IFVAR INTNUM14 > 29
							EQUAL DUMMY1 6
						ENDIF
					ENDIF
				ENDIF
			ENDIF
		ENDIF
	ENDIF
	IFVAR dummy1 = 1
		DAMAGEPLR BODYONLY 5 You feel a pang in your stomach.
	ENDIF
	IFVAR dummy1 = 2
		DAMAGEPLR BODYONLY 10 You feel a sharp pang in your stomach.
	ENDIF
	IFVAR dummy1 = 3
		DAMAGEPLR BODYONLY 20 Your stomach cramps in a few painful spasms.
	ENDIF
	IFVAR dummy1 = 4
		DAMAGEPLR BODYONLY 40 Your stomach knots into almost unbearable cramps.
	ENDIF
	IFVAR dummy1 = 5
		DAMAGEPLR BODYONLY 80 Your stomach flares in viscious spasms.
	ENDIF
	IFVAR dummy1 = 6
		DAMAGEPLR BODYONLY 160 Horrible spasms wrack your body with agony.
	ENDIF
	CLEARVERB
ENDIF
