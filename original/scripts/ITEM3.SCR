	ECHO PLAYER Hah! Bet you didn't expect to get something by RECALLing this!
ENDIF
IFPREVERB LICK -1
	CLEARVERB
	ECHO PLAYER You lick the frosting off the top of %a.
	ECHO OTHERS %N licks the frosting off the top of %a.
ENDIF
IFPREVERB KISS -1
	CLEARVERB
	ECHO PLAYER You kiss %a deeply.
	ECHO OTHERS %N kisses %a deeply.
ENDIF
IFVERB EAT -1
	IFVAR ITEMVAL2 = 3
	ECHO PLAYER The top of the cupcake is delicious, a little firmer than the rest.
	ENDIF
	IFVAR ITEMVAL2 = 2
	ECHO PLAYER The soft inside of the cupcake is still warm.
	ENDIF
	IFVAR ITEMVAL2 = 1
	ECHO PLAYER The bottom of the cupcake is rich and chocolatey.
	ENDIF
	IFVAR ITEMVAL2 = 0
	ECHO PLAYER That was the best cupcake you've ever had!
	ENDIF
ENDIF
IFVERB SMELL -1
	ECHO PLAYER The cupcake is still fresh and warm, and oh so chocolatey.
ENDIF
IFVERB LISTEN -1
	ECHO PLAYER What are you, a nut?
ENDIF
;
;
INUMBER 1390
NAME 648
WEIGHT 1
VOLUME 1
IFPREVERB LOOK -1
	CLEARVERB
	ECHO PLAYER You see a thin tube of silvery metal.
	IFVAR ORG = 7
		ECHO PLAYER As a technologist, you recognize its mechanism. All you have to do is give it a sharp slap to activate it.
	ENDIF
ENDIF
IFPREVERB SLAP -1
	CLEARVERB
	ECHO PLAYER You pass your palm over the raised part of the tube with just the right amount of pressure.
	ECHO OTHERS %N fiddles with %a.
	ECHO ALL The tube goes, "ping!"
	EQUAL ITEMVAL1 10
ENDIF
IFPREVERB PULL -1
	IFVAR ITEMVAL1 = 10
		CLEARVERB
		ECHO PLAYER You pull the two ends of the tube apart until it is as tall as you are.
		ECHO OTHERS %N pulls the two ends of %a apart until it is as tall as %s is.
		EQUAL ITEMVAL1 20
	ENDIF
ENDIF
IFPREVERB TURN -1
	IFVAR ITEMVAL1 = 20
		CLEARVERB
		ECHO PLAYER You turn the elongated tube over and over in your hands, spinning it in a circle.
		ECHO OTHERS %N turns %a over and over in %h hands, spinning it in a circle.
		EQUAL FLAG3 49
	ENDIF
ENDIF
IFPREVERB PULL -1
	IFVAR ITEMVAL1 = 20
		IFVAR FLAG3 = 49
			CLEARVERB
			ECHO OTHERS %N rises a few inches off the ground as %h raises the spinning tube above %h head.
			ECHO PLAYER You raise the spinning tube above your head and it lifts you a few inches above the ground!
			EQUAL FLAG3 59
		ENDIF
	ENDIF
ENDIF
IFPREVERB GO -1
	IFITEM 7
		EQUAL DANTEMP 3
	ENDIF
ENDIF
IFPREVERB GO -1
	IFVAR DANTEMP ! 3
		IFVAR ITEMVAL1 = 20
			IFVAR FLAG3 = 59
				CLEARVERB
				REMOVEITEM -1
				ECHO OTHERS %N suddenly pulls the tube down in front of %iself... and is gone!
				ECHO PLAYER You do a funny little twist of the wrist with the tube... and you're gone!
				REMOVEITEM 7
				NEWITEM 7 1390 ADJ1=81 ADJ2=192
				ECHO OTHERS The tube falls to the ground, retracting to its former size.
				MOVE 3175
				EQUAL LEFTFROM RNUM
				EQUAL INTNUM75 RNUM
				AFFECT 3175
				ECHO OTHERS %N fades into view.
				AFFECT LEFTFROM
			ENDIF
		ENDIF
	ENDIF
	EQUAL DANTEMP 0
ENDIF
IFPREVERB PUSH -1
	IFVAR ITEMVAL1 = 20
		CLEARVERB
		ECHO PLAYER You push the ends of the tube closer together.
		ECHO OTHERS %N pushes on the ends of %a, causing it to retract to a much smaller size.
		EQUAL ITEMVAL1 0
	ENDIF
	IFVAR ITEMVAL1 = 10
		CLEARVERB
		ECHO PLAYER You push the raised bit of the tube back in.
		ECHO OTHERS %N passes %h palm over %a.
		EQUAL ITEMVAL1 0
	ENDIF
ENDIF
