;   FIREARMS

; handgun, revolver, normal sized, 6 shots

INUMBER 19
NAME 105
WEIGHT 4
VOLUME 4
BOW_WEAPON
PARAMETER1 20
PARAMETER2 1065
*DESCRIPTION_START
A lightweight metal firearm made up of a 6 inch barrel, cylinder
and handle, plus hammer and double-action firing mechanism.
*DESCRIPTION_END

IFPREVERB TAP -1
  IFVAR ITEMBIT5 = 1
    IFVAR ITEMBIT4 = 1
      CLEARVERB
      ECHO PLAYER You thumb the laser targetting sight and the tiny red beam turns off.
      ECHO OTHERS %n touches a small cylinder mounted atop %a and a tiny read beam disappears.
      EQUAL ITEMBIT4 0
      EQUAL ITEMVAL2 1
    ELSE
      CLEARVERB
      ECHO PLAYER You thumb the laser targetting sight and a tiny red beam projects straight out ahead of you.
      ECHO OTHERS %n thumbs a small cylinder mounted atop %a and a tiny red beam projects straight ahead.
      EQUAL ITEMBIT4 1
      EQUAL ITEMVAL2 21
    ENDIF
  ENDIF
ENDIF

IFPREVERB LOAD -1
  IFVAR ITEMBIT1 = 1
    IFVAR ITEMBIT2 = 0
      IFVAR ITEMVAL5 > 5
        CLEARVERB
        ECHO PLAYER There are already 6 bullets in the cylinder.
      ENDIF
      IFVAR ITEMVAL5 < 6
        ECHO PLAYER You turn the cylinder to the next empty chamber.%c
        ECHO OTHERS %n turns the cylinder on the revolver.%c
      ENDIF
    ELSE
      IFVAR ITEMVAL5 > 5
        CLEARVERB
        ECHO PLAYER There are already 6 bullets in the cylinder.
      ENDIF
      IFVAR ITEMVAL5 < 6
        ECHO PLAYER You turn the cylinder and pull an empty casing from a chamber.%c
        ECHO OTHERS %n turns the cylinder on the revolver and removes an empty casing from one of the chambers..%c
      ENDIF
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You have to open the cylinder first.
  ENDIF
ENDIF

IFVERB LOAD -1
  IFVAR ITEMVAL3 = 1
      ADD ITEMVAL5 1
      EQUAL ITEMVAL3 0
      IFVAR ITEMVAL5 > 0
        EQUAL ITEMBIT2 1
    ENDIF
  ENDIF
ENDIF

IFPREVERB TURN -1
  IFVAR ITEMBIT1 = 1
    CLEARVERB
    EQUAL ITEMBIT2 0
    ECHO PLAYER You spin the cylinder and dump the casings on the ground.
    ECHO OTHERS %n spins the cylinder of the revolver and holds the gun up.
    ECHO ALL You can hear the tiny "Clinks" as the metal casings hit the floor.
    EQUAL ITEMVAL5 0
    EQUAL FLAG3 0
  ELSE
    CLEARVERB
    ECHO OTHERS %n spins the cylinder of the revolver.
    ECHO PLAYER You spin the cylinder on the revolver.
    EQUAL FLAG3 0
    IFVAR ITEMVAL3 = 1
        RANDOM ITEMVAL5 1 6 0
        EQUAL ITEMVAL4 1
        IFVAR ITEMVAL4 ! ITEMVAL5
          STRCVT 0 ITEMVAL5
          GMMSG **  %n will blow %h head off in %0 shot(s).
          EQUAL ITEMBIT3 0
        ELSE
          GMMSG **  Next shot blows %n's head off.
          EQUAL ITEMBIT3 1
        ENDIF
    ENDIF
    IFVAR ITEMVAL3 = 2
        RANDOM ITEMVAL5 1 5 0
        EQUAL ITEMVAL4 1
        IFVAR ITEMVAL4 ! ITEMVAL5
          STRCVT 0 ITEMVAL5
          GMMSG **  %n will blow %h head off in %0 shot(s).
          EQUAL ITEMBIT3 0
        ELSE
          GMMSG **  Next shot blows %n's head off.
          EQUAL ITEMBIT3 1
        ENDIF
    ENDIF
    IFVAR ITEMVAL3 = 3
        RANDOM ITEMVAL5 1 4 0
        EQUAL ITEMVAL4 1
        IFVAR ITEMVAL4 ! ITEMVAL5
          STRCVT 0 ITEMVAL5
          GMMSG **  %n will blow %h head off in %0 shot(s).
          EQUAL ITEMBIT3 0
        ELSE
          GMMSG **  Next shot blows %n's head off.
          EQUAL ITEMBIT3 1
        ENDIF
    ENDIF
    IFVAR ITEMVAL3 = 4
        RANDOM ITEMVAL5 1 3 0
        EQUAL ITEMVAL4 1
        IFVAR ITEMVAL4 ! ITEMVAL5
          STRCVT 0 ITEMVAL5
          GMMSG **  %n will blow %h head off in %0 shot(s).
          EQUAL ITEMBIT3 0
        ELSE
          GMMSG **  Next shot blows %n's head off.
          EQUAL ITEMBIT3 1
        ENDIF
    ENDIF
    IFVAR ITEMVAL3 = 5
        RANDOM ITEMVAL5 1 2 0
        EQUAL ITEMVAL4 1
        IFVAR ITEMVAL4 ! ITEMVAL5
          STRCVT 0 ITEMVAL5
          GMMSG **  %n will blow %h head off in %0 shot(s).
          EQUAL ITEMBIT3 0
        ELSE
          GMMSG **  Next shot blows %n's head off.
          EQUAL ITEMBIT3 1
        ENDIF
    ENDIF
    IFVAR ITEMVAL3 = 6
          GMMSG **  Next shot blows %n's head off.
          EQUAL ITEMBIT3 1
    ENDIF
  ENDIF
ENDIF

IFVERB LOOK -1
 IFVAR INTNUM3 = 1
   ECHO PLAYER %c **  To add a laser sight (+21 ToHit), set ITEMBIT5 to 1. **%c
 ENDIF
  IFVAR ITEMBIT1 = 1
    STRCVT 0 ITEMVAL5
    ECHO PLAYER %cYou see %0 live rounds remaining.
  ELSE
    CLEARVERB
    ECHO PLAYER %cThe cylinder is closed.
  ENDIF
ENDIF

IFPREVERB OPEN -1
  IFVAR ITEMBIT1 = 1
    CLEARVERB
    ECHO PLAYER The cylinder is already open.
  ELSE
    CLEARVERB
    EQUAL ITEMBIT1 1
    EQUAL ITEMVAL5 ITEMVAL3
    EQUAL ITEMVAL3 0
    ECHO PLAYER You open the cylinder of the gun with a flick of your wrist.
    ECHO OTHERS %n opens the cylinder of %h gun with the flick of %h wrist.
  ENDIF
ENDIF

IFPREVERB CLOSE -1
  IFVAR ITEMBIT1 = 0
    CLEARVERB
    ECHO PLAYER The cylinder is already closed.
  ELSE
    CLEARVERB
    EQUAL ITEMBIT1 0
    EQUAL ITEMVAL3 ITEMVAL5
    EQUAL ITEMVAL5 0
    ECHO PLAYER You close the cylinder of the gun with a flick of your wrist.
    ECHO OTHERS %n closes the cylinder of %h gun with the flick of %h wrist.
  ENDIF
ENDIF

IFPREVERB LEAN -1
  CLEARVERB
  ECHO PLAYER You put the barrel of the gun to your temple.
  ECHO OTHERS You see %n put the barrel of %h revolver to %h temple.
  EQUAL FLAG3 1
ENDIF

IFPREVERB SLAP -1
  CLEARVERB
  ECHO PLAYER You pull back the hammer until it locks into place with a "Click".
  ECHO OTHERS %n pulls back the hammer on the revolver and it locks into place with a "Click".
  EQUAL FLAG3 2
ENDIF

IFPREVERB PULL -1
 IFVAR FLAG3 = 2
  IFVAR ITEMBIT3 = 1
    CLEARVERB
    ECHO OTHERS %n pulls the trigger and blows %h brains out the other side of %h head.
    DAMAGE BODYONLY 2000 You pull the trigger and blow your brains out.
    POSITION LAY
    GMMSG **  %n just blew %h brains out playing Russian Roulette.
    SUB ITEMVAL3 1
    EQUAL ITEMBIT3 0
    EQUAL ITEMVAL4 1
    EQUAL FLAG3 0
  ELSE
    CLEARVERB
    EQUAL FLAG3 1
    ECHO PLAYER You pull the trigger and hear a "Click".
    ECHO OTHERS %n pulls the trigger and you hear a "Click".
    GMMSG **  %n managed not to blow %h brains out playing Russian Roulette.
    SUB ITEMVAL5 1
    IFVAR ITEMVAL4 ! ITEMVAL5
      STRCVT 0 ITEMVAL5
      GMMSG **  %n will blow %h head off in %0 shot(s).
      EQUAL ITEMBIT3 0
    ELSE
      GMMSG **  Next shot blows %n's head off.
      EQUAL ITEMBIT3 1
    ENDIF
  ENDIF
 ELSE
  IFVAR FLAG3 = 1
    CLEARVERB
    ECHO PLAYER You must cock the handgun first. [SLAP HANDGUN]
  ELSE
    IFVAR FLAG3 = 0
      CLEARVERB
      ECHO PLAYER You must put it to your head first. [LEAN HANDGUN]
    ENDIF
  ENDIF
 ENDIF
ENDIF

IFPREVERB WAVE -1
  CLEARVERB
  ECHO PLAYER You wave %a around menacingly.
  ECHO OTHERS Duck! %n waves around a %a!
  IFVAR ITEMBIT4 = 1
    ECHO PLAYER %cYou see a tiny red dot play across things around you as you wave the handgun around.
    ECHO OTHERS %cYou see a narrow red beam form a tiny read dot on your forehead.
  ENDIF
ENDIF

IFPREVERB UNWIELD -1
  EQUAL FLAG3 0
ENDIF

IFVERB RECALL -1
  IFVAR INTNUM68 > 5
    ECHO PLAYER %cIt is quite apparent to you that this particular type of handgun is known as a revolver,
    ECHO PLAYER deriving it's name from the action the small cylinder performs with each pull of the trigger.
  ELSE
    IFVAR INTNUM68 > 10
      ECHO PLAYER %cYou can tell from the standard 6 inch barrel that the firepower of this particular firearm is likely not much more than a conventional bow of the present.
    ELSE
      ECHO PLAYER %cYou lack the expertise to understand this firearm.
    ENDIF
  ENDIF
ENDIF
;

; handgun, revolver, snub-nosed, 6 shots

INUMBER 572
NAME 105
WEIGHT 3
VOLUME 4
BOW_WEAPON
PARAMETER1 25
PARAMETER2 1065

IFPREVERB LOAD -1
	IFVAR ITEMVAL3 > 5
		CLEARVERB
		ECHO PLAYER There are already six bullets in the gun.
	ENDIF
	IFVAR ITEMVAL3 < 6
		EQUAL DANTEMP ITEMVAL3
		EQUAL ITEMVAL3 0
	ENDIF
ENDIF

IFVERB LOAD -1
	IFVAR ITEMVAL3 = 1
		IFVAR DANTEMP > 0
			ADD DANTEMP 1
			EQUAL ITEMVAL3 DANTEMP
			EQUAL DANTEMP 0
		ENDIF
	ENDIF
ENDIF

IFPREVERB LOOK -1
	CLEARVERB
 IFVAR INTNUM3 = 1
   ECHO PLAYER %c **  To add a laser sight (+21 ToHit), set ITEMBIT5 to 1. **%c
 ENDIF
	ECHO PLAYER The gun has a hammer-shaped piece of metal set just above the point where the handle meets the cylindrical main body.
	IFVAR ORG = 7
		ECHO PLAYER As a technologist, you recognize this type of pistol. It is called a snub-nosed revolver, and it can be loaded with up to six bullets at a time.
	ENDIF
ENDIF

IFPREVERB PULL -1
	IFITEM -1 WIELDED
		CLEARVERB
		ECHO PLAYER You spin the gun backwards on your index finger by the trigger guard.
		ECHO OTHERS %N spins %a backwards by its trigger guard.
	ENDIF
ENDIF

IFPREVERB PUSH -1
	IFITEM -1 WIELDED
		CLEARVERB
		ECHO PLAYER You spin the gun forward, shifting your grip.
		ECHO OTHERS %N spins %a forward, shifting %h grip to the handle.
	ENDIF
ENDIF

IFPREVERB PLAY -1
	IFITEM -1 WIELDED
		CLEARVERB
		ECHO PLAYER You blow the smoke from the barrel of the gun.
		ECHO OTHERS %N blows the plume of smoke from the barrel of %a.
	ENDIF
ENDIF

IFPREVERB FLIP -1
	CLEARVERB
	ECHO PLAYER You toss the gun into the air, flipping it over, and catch it.
	ECHO OTHERS %N tosses %a into the air, then catches it by the handle.
ENDIF

IFPREVERB TAP -1
  IFVAR ITEMBIT5 = 1
    IFVAR ITEMBIT4 = 1
      CLEARVERB
      ECHO PLAYER You thumb the laser targetting sight and the tiny red beam turns off.
      ECHO OTHERS %n touches a small cylinder mounted atop %a and a tiny read beam disappears.
      EQUAL ITEMBIT4 0
      EQUAL ITEMVAL2 1
    ELSE
      CLEARVERB
      ECHO PLAYER You thumb the laser targetting sight and a tiny red beam projects straight out ahead of you.
      ECHO OTHERS %n thumbs a small cylinder mounted atop %a and a tiny red beam projects straight ahead.
      EQUAL ITEMBIT4 1
      EQUAL ITEMVAL2 21
    ENDIF
  ENDIF
ENDIF

IFPREVERB WAVE -1
  CLEARVERB
  ECHO PLAYER You wave %a around menacingly.
  ECHO OTHERS Duck! %n waves around a %a!
  IFVAR ITEMBIT4 = 1
    ECHO PLAYER %cYou see a tiny red dot play across things around you as you wave the handgun around.
    ECHO OTHERS %cYou see a narrow red beam form a tiny read dot on your forehead.
  ENDIF
ENDIF

; handgun, automatic, normal sized, 1 clip = 7 shots.

INUMBER 888
NAME 105
WEIGHT 5
BOW_WEAPON
VOLUME 4
PARAMETER1 15
WIELDABLE
SUBSTANCE HARDMETAL
PARAMETER2 891

IFPREVERB WIELD -1
  EQUAL ITEMBIT2 0 ; cocked = 1 / not cocked = 0
ENDIF

IFPREVERB TAP -1
  IFVAR ITEMBIT5 = 1
    IFVAR ITEMBIT4 = 1
      CLEARVERB
      ECHO PLAYER You thumb the laser targetting sight and the tiny red beam turns off.
      ECHO OTHERS %n touches a small cylinder mounted atop %a and a tiny read beam disappears.
      EQUAL ITEMBIT4 0
      EQUAL ITEMVAL2 1
    ELSE
      CLEARVERB
      ECHO PLAYER You thumb the laser targetting sight and a tiny red beam projects straight out ahead of you.
      ECHO OTHERS %n thumbs a small cylinder mounted atop %a and a tiny red beam projects straight ahead.
      EQUAL ITEMBIT4 1
      EQUAL ITEMVAL2 21
    ENDIF
  ENDIF
ENDIF

IFPREVERB LOAD -1
  IFITEM -1 WIELDED
	IFVAR ITEMVAL3 ! 0
		CLEARVERB
		ECHO PLAYER There is already a clip in the gun.
	ELSE
	  ECHO PLAYER You finger the clip-release.%cA clip falls out and you slap in a new one.%c
	  ECHO OTHERS %n pulls out an empty clip from %a and slaps in a new one.
	  EQUAL ITEMBIT2 0
	ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You need to wield it first.
  ENDIF
ENDIF

IFVERB LOAD -1
	IFVAR ITEMVAL3 = 1
		EQUAL ITEMVAL3 7
    ENDIF
ENDIF

IFPREVERB CONCENTRATE -1
  IFVAR ITEMBIT2 = 0
    CLEARVERB
    ECHO OTHERS %n checks the firing pin on %a.
    ECHO PLAYER You notice that the weapon is not cocked.
  ELSE
    CLEARVERB
    ECHO OTHERS %n checks the firing pin on %a.
    ECHO PLAYER You notice the weapon is cocked.
  ENDIF
ENDIF

IFPREVERB READ -1
  CLEARVERB
  EQUAL ITEMBIT2 0
  STRCVT 0 ITEMVAL3
  ECHO PLAYER You pull out the clip and see that there are %0 rounds remaining.
  ECHO PLAYER %cYou slap the clip back in place.
  ECHO OTHERS %n pull a clip out of %a for a moment, then slaps it back in place.
ENDIF

IFPREVERB LOOK -1
  CLEARVERB
 IFVAR INTNUM3 = 1
   ECHO PLAYER %c **  To add a laser sight (+21 ToHit), set ITEMBIT5 to 1. **%c
 ENDIF
  ECHO PLAYER This weapon has a small profile and is light-weight. It is has a rounded
  ECHO PLAYER barrel enclosed in a somewhat rectangular piece of metal. The grip is
  ECHO PLAYER small, room for only one hand. The clip itself fits snugly in the recessed
  ECHO PLAYER portion of the small grip.
  IFVAR INTNUM68 > 6
    ECHO PLAYER %cYour strong background in technology provides you with the knoweldge that
    ECHO PLAYER this particular firearm is an automatic with a capacity of seven rounds in each clip.
  ENDIF
ENDIF

IFPREVERB PULL -1
  IFITEM -1 WIELDED
    IFVAR ITEMBIT2 = 1
        SUB ITEMVAL3 1
        IFVAR ITEMVAL3 > 0
          CLEARVERB
          ECHO PLAYER %cYou cock the gun.
          ECHO OTHERS %n moves something along the top of %a.
          ECHO ALL You hear a double click and an unspent round flies from the breech as a new one is chambered.
        ELSE
          CLEARVERB
          ECHO PLAYER %cYou cock the gun.%cThe gun is empty.
          ECHO OTHERS %n moves something along the top of %a.
          ECHO ALL You hear a single click and the breech remains open indicating that all the rounds are spent.
          EQUAL ITEMVAL3 0
        ENDIF
    ELSE
      CLEARVERB
      ECHO PLAYER %cYou cock the gun.
      ECHO OTHERS %n moves something along the top of %a.
      ECHO ALL You hear a double click as a round is chambered.
      EQUAL ITEMBIT2 1
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You need to wield it first.
  ENDIF
ENDIF


IFPREVERB WAVE -1
  CLEARVERB
  ECHO PLAYER You wave %a around menacingly.
  ECHO OTHERS Duck! %n waves around a %a!
  IFVAR ITEMBIT4 = 1
    ECHO PLAYER %cYou see a tiny red dot play across things around you as you wave the handgun around.
    ECHO OTHERS %cYou see a narrow red beam form a tiny read dot on your forehead.
  ENDIF
ENDIF
;
