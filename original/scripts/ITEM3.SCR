                GMMSG %N just tried to do something to %a. %N is not a GM or assistant GM.
        ENDIF
ENDIF
IFPREVERB LOOK -1
        IFVAR INTNUM3 = -1
                CLEARVERB
                ECHO PLAYER You see a list of the commands for 'Delving Deep'.
                ECHO PLAYER TURN UTILITATOR ---- Changes the room to which it will take you.
                ECHO PLAYER GAZE UTILITATOR ---- Lets you scan the room it is set to.
                ECHO PLAYER GO UTILITATOR ------ Takes you to that room.
                ECHO PLAYER FLIP UTILITATOR ---- Turns on and off the DELVE variable.
                ECHO PLAYER HUG UTILITATOR ---- Creates the correct undead for the room.
                ECHO PLAYER CONC UTILITATOR ---- Turns you invisible. NOTE this is JUST THE SPELL.
                ECHO PLAYER ...
                ECHO PLAYER ...
        ENDIF
ENDIF
IFPREVERB TURN -1
	IFVAR INTNUM3 = -1
                CLEARVERB
                IFVAR ITEMVAL2 = 1699
                        EQUAL ITEMVAL2 1600
                ENDIF
                IFVAR ITEMVAL2 < 1699
                        ADD ITEMVAL2 1
                ENDIF
                IFVAR ITEMVAL2 > 1617
                        EQUAL ITEMVAL2 1699
                ENDIF
                STRCVT 0 ITEMVAL2
                ECHO PLAYER You change the setting on the utilitator to room # %0.
        ENDIF
ENDIF
IFPREVERB GAZE -1
        IFVAR INTNUM3 = -1
                CLEARVERB
                SHOWROOM ITEMVAL2
	ENDIF
ENDIF
IFPREVERB GO -1
        IFVAR INTNUM3 = -1
                CLEARVERB
                MOVE ITEMVAL2
        ENDIF
ENDIF
IFPREVERB HUG -1
        IFVAR INTNUM3 = -1
                CLEARVERB
                IFVAR RNUM = 1602
                        ECHO PLAYER Generating a skeleton.
                        GENMON 1
                        ECHO ALL A skeleton clatters into the room.
                ENDIF
                IFVAR RNUM = 1608
                        ECHO PLAYER Generating a zombie.
                        GENMON 2
			ECHO ALL A zombie shuffles into the room.
                ENDIF
                IFVAR RNUM = 1614
                        ECHO PLAYER Generating a banshee.
                        ECHO PLAYER Remember, even if invisible you're seen when they scream.
                        GENMON 34
                        ECHO ALL A banshee billows into the room.
                ENDIF
        ENDIF
ENDIF
IFPREVERB FLIP -1
        IFVAR INTNUM3 = -1
                CLEARVERB
                IFVAR DELVE = 1
                        ECHO PLAYER Delve now equals 0.
                        EQUAL DELVE 0
                        EQUAL DUMMY1 848
                ENDIF
                IFVAR DELVE = 0
			IFVAR DUMMY1 ! 848
                                ECHO PLAYER Delve now equals 1.
                                EQUAL DELVE 1
                        ENDIF
                ENDIF
        ENDIF
ENDIF
IFPREVERB CONCENTRATE -1
        IFVAR INTNUM3 = -1
                CLEARVERB
                ECHO PLAYER Invisibility coming right up. Just the spell, though.
                SPELL 225 50
        ENDIF
ENDIF
