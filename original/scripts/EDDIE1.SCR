IFVAR INTNUM98 ! 0
 IFVAR INTNUM57 = 22
  RANDOM TANNWERE 1 58 0
  IFVAR TANNWERE = 47
   IFVAR INTNUM98 < 95
    ADD INTNUM57 1
    ADD INTNUM98 1
    STRCVT 0 INTNUM98
    GMMSG ** %n just gained a generation of lycanthropy Keptain. %S is now %0 percent werewolf.
    SUB ALIGN 1
   ENDIF
  ENDIF
 ENDIF
ENDIF
;werewolf creation


IFVAR RNUM = 2250
 IFVAR PLRSINROOM > 2
  IFVAR DEAD = 1
   IFVAR DUMMY4 = 47
    IFVAR INTNUM98 < 1
     EQUAL INTNUM98 1
     ECHO PLAYER You feel a stirring rush of strange, bestial force at play in your corpse.
     ECHO OTHERS %n's corpse glows with a faint reddish hue for a moment.
    ELSE
     ECHO PLAYER You feel the energy of the pentacle in which you lay suffusing your body with newfound life!
     ECHO OTHERS %n's body suddenly is bombarded with energies from all points of the pentacle!
     SPELL 305 99
    ENDIF
   ENDIF
  ENDIF
 ENDIF
ENDIF
