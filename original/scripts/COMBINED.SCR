NAME 299
WEIGHT 1
VOLUME 1
WORN_NECK
VARIABLE dontinterupt
;
IFPREVERB read -1
 CLEARVERB
 ECHO PLAYER On the back of the locket is a delicate inscription reading,\
"Love always, Joqain."
ENDIF
;
IFVERB close -1
 IFITEM -1 open
  CLEARVERB
  ECHO PLAYER The locket refuses to close until the song is over.
 ENDIF
ENDIF
;
IFpreVERB open -1
 IFITEM -1 WORN
 OPEN -1
 EQUAL dontinterupt 1
 CLEARVERB
 ECHO ALL As %n opens %h locket, it begins to play a slow, romantic song,\
melting your heart with its beauty and melody.
 CONTEVENT 40
 SETEVENT 40 5
 ECHO ALL %n's magical locket continues to play a lovely, romantic song.
 CONTEVENT 40
 SETEVENT 40 5
 ECHO ALL The locket worn by %n continues to play a magic melody, striking\
pure and true feelings into your heart.
 CONTEVENT 40
 SETEVENT 40 5
 ECHO ALL The magic melody played by %n's locket comes to a close, leaving\
everyone listening with a smile on their face. The locket snaps itself shut.
 ENDIF
 CLOSE -1
ENDIF
;
INUMBER 1110
NAME 690
WEIGHT 1
VOLUME 10
PARAMETER1 15
WIELDABLE
TWOHAND_WEAPON
VARIABLE pickme
VARIABLE wheee
IFpreVERB WIELD -1
 ECHO ALL %n's blade phases into existance for a brief moment.
 ECHO ALL The phase blade disappears out of sight.
 ECHO PLAYER You feel the blade still in your hand, but can't see it anywhere!
ENDIF
;
IFTOUCH -1
 IFVERB get -1
  ECHO PLAYER The blade flickers as you reach for it.
 ELSE
  CLEARVERB
  ECHO OTHERS %N makes an obscure gesture.
  ECHO PLAYER You can't see the phase blade, but you reach out and touch it.
 ENDIF
ENDIF
;
SUBSTANCE INDESTRUCTABLE
CEVENT 72 15 699
IFSEEK 72
 RANDOM wheee 1 7 0
 IFITEM -1 WIELDED
  IFVAR wheee = 1
   ECHO ALL %n's phase blade shimmers into existence for a moment.
  ENDIF
  IFVAR wheee = 2
   ECHO ALL %n's phase blade pulses with light.
  ENDIF
  IFvar wheee = 3
   ECHO ALL Shimmering streaks of lightning flicker up %n's phase blade.
  ENDIF
  IFVAR wheee = 4
   ECHO ALL %n tightly grasps something, but you can't see anything in %h hand.
  ENDIF
  IFVAR wheee = 5
   ECHO ALL Streaks of grey light trail behind %n's phase blade.
  ENDIF
  IFVAR wheee = 6
   ECHO ALL A piece of %n's phase blade becomes substantial for a moment\
looking like a strange piece of steel hanging in mid air, before shimmering\
out of existance.
  ENDIF
  IFVAR wheee = 7
   ECHO ALL The tip of %n's phase blade becomes substantial for a moment\
looking like a strange piece of steel hanging in mid air, before shimmering\
out of existance.
  ENDIF
 ENDIF
ENDIF
;
;
; The blade of Siryx
INUMBER 1104
NAME 201
WEIGHT 1
VOLUME 5
ARTICLE THE
SUBSTANCE INDESTRUCTABLE
PARAMETER1 2
SLASH_WEAPON
VARIABLE NEWCRIT
IFITEM -1 WIELDED
 IFVERB CONCENTRATE -1
  ADD NEWCRIT 1
  IFVAR NEWCRIT = 0
   ECHO ALL The electricity flowing over %n's blade disperses.
   EQUAL ITEMADJ1 526
   EQUAL ITEMVAL3 2
   SETEVENT 41 2
   CONTEVENT 41
   ECHO PLAYER Your blade suddenly becomes a towering inferno!
   DAMAGEPLR BURN 50 The blade burns you!
   ECHO OTHERS %n's blade suddenly becomes a towering inferno of fire!
   ECHO OTHERS %n flinches in pain.
  ENDIF
  IFVAR NEWCRIT = 1
   ECHO ALL %n's blade cools down to a more normal temperature.
   EQUAL ITEMADJ1 375
   EQUAL ITEMVAL3 3
   SETEVENT 41 2
   CONTEVENT 41
   ECHO PLAYER Ice suddenly forms over the blade, chilling you to the bone!
   ECHO OTHERS Huge lays of ice crystalize over %n's blade!
   ECHO OTHERS %n flinches in pain!
   DAMAGEPLR COLD 50 The blade freezes you!
  ENDIF
  IFVAR NEWCRIT = 2
   ECHO ALL %n's blade heats up to a more normal temperature.
   EQUAL ITEMADJ1 376
   EQUAL ITEMVAL3 4
   SETEVENT 41 2
   CONTEVENT 41
   ECHO PLAYER Electricity suddenly crackles over your blade!
   ECHO OTHERS Huge sheets of electricity crackle over %n's blade!
   ECHO OTHERS %N flinches in pain!
   DAMAGEPLR BURN 50 The blade burns you!
  ENDIF
   IFVAR NEWCRIT = 2
   SUB NEWCRIT 3
  ENDIF
 ENDIF
ENDIF
