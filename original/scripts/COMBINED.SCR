INUMBER 594
NAME 66
WEIGHT 3
VOLUME 2
SUBSTANCE INDESTRUCTABLE
PUNCTURE_WEAPON
VARIABLE yowsers
VARIABLE oneyowsers
VARIABLE thiswillhurt
IFVAR oneyowsers = 0
 EQUAL yowsers 250
 EQUAL oneyowsers 1
ENDIF
PARAMETER1 8
;
IFpreVERB exa -1
CLEARVERB
ECHO PLAYER This clear dagger seems to be hollow... Hmmm...
ENDIF
;
IFPREVERB push -1
 CLEARVERB
  ECHO OTHERS %n is fiddling with %h dagger.
  IFVAR yowsers > 0
  EQUAL thiswillhurt ITEMVAL4
  SUB thiswillhurt 50
   IFVAR ITEMVAL4 = 0
    EQUAL ITEMVAL4 50
   ENDIF
   IFVAR ITEMVAL4 < 60
    ECHO PLAYER You give the dagger a little squeeze on the hilt, and a tiny trickle\
 of venom drips onto the blade.
    ADD ITEMVAL4 1
    SUB yowsers 1
    DAMAGEPLR COLD THISWILLHURT The poison stings!
    ECHO OTHERS %n winces in pain.
   ENDIf
   IFVAR ITEMVAL4 > 59
    IFVAR ITEMVAL4 < 80
     ECHO PLAYER You give the dagger a bigger squeeze, and venom coats the surface of the blade.
     ADD ITEMVAL4 3
     SUB yowsers 3
     DAMAGEPLR COLD THISWILLHURT The poison stings!
     ECHO OTHERS %n lets out a tiny yowl of pain.
    ENDIF
   ENDIF
   IFVAR ITEMVAL4 > 79
    ECHO PLAYER You can't put any more poison on the blade.
   ENDIF
  ELSE
   ECHO PLAYER It looks like the dagger is out of venom, perhaps you should wait a day.
  ENDIF
 ENDIF
