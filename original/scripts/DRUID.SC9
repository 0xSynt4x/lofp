  ENDIF
  IFVAR RAC = 6
    CLEARVERB
    ECHO PLAYER You bare your teeth warningly.
    ECHO OTHERS %N bares %h teeth menancingly.
  ENDIF
  IFVAR UNDEAD = 1
    IFVAR TIM > 5
      CLEARVERB
      ECHO PLAYER You recoil in the sunlight.
      ECHO OTHERS %n recoils from the sun's glare.
    ENDIF
    IFVAR TIM < 12
      CLEARVERB
      ECHO PLAYER You recoil in the sunlight.
      ECHO OTHERS %n recoils from the sun's glare.
    ENDIF
  ENDIF
ENDIF

