IFPREVERB GESTURE -1
     CLEARVERB
     IFVAR RNUM = 206
    ECHO PLAYER You gaze at your reflection in the fountain.
    ECHO OTHERS %n gazes at %h reflection in the fountain.
     ENDIF
     IFVAR RNUM = 201
    ECHO PLAYER You peer through the gates.
    ECHO OTHERS %n peers through the gates.
    SHOWROOM 501
     ENDIF
     IFVAR RNUM = 501
    ECHO PLAYER You peer into the city.
    ECHO OTHERS %n peers through the gates.
    SHOWROOM 201
     ENDIF
     IFVAR RNUM > 213
    IFVAR RNUM < 220
         IFVAR RNUM ! 216
        CLEARVERB
        ECHO PLAYER You moan loudly.
        ECHO OTHERS %n moans loudly.
         ENDIF
    ENDIF
     ENDIF
ENDIF

