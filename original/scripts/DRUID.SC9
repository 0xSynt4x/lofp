IFPREVERB LOOK -1
     CLEARVERB
     IFVAR INTNUM3 = 120
  ECHO OTHERS %N aims, %h body taunt with concentration, the black-feathered shaft drawn close to his cheek.
  ECHO PLAYER You aim, pulling the black-feathered shaft close to your cheek.
     ENDIF
     IFVAR INTNUM3 = 8
    ADD FLAG4 1
    IFVAR FLAG4 = 1
         ECHO OTHERS %n produces a well worn skinning knife.
         ECHO PLAYER You produce your trusty skinning knife.
    ELSE
         EQUAL FLAG4 0
         ECHO OTHERS %n puts away a skinning knife with a flourish.
         ECHO PLAYER You put away your skinning knife with a flourish.
    ENDIF
     ENDIF
ENDIF

IFPREVERB CAST -1
     CLEARVERB

     IFVAR INTNUM3 = 123
  ECHO OTHERS %n draws a black shroud over %h face leaving only his eyes exposed and falls into an aggressive fighting stance.
  ECHO PLAYER You draw the shroud over your face and assume a fighting stance.
     ENDIF
     IFVAR INTNUM3 = 71
  ECHO OTHERS %N glances around with a hunted expression.
  ECHO PLAYER You glance around with a hunted expression.
     ENDIF
     IFVAR INTNUM3 = 87
  ECHO OTHERS %N grins devilishly, giving you the impression that %h tongue is as sharp as %h blade.
  ECHO PLAYER You grin devilishly, knowing that your tongue is every bit as sharp as your blade.
     ENDIF
     IFVAR INTNUM3 = 85
  ECHO PLAYER You tie your hair back in a ponytail indicating that play-time is over.
  ECHO OTHERS %N ties %h hair back in a ponytail indicating that play-time is over.
     ENDIF
     IFVAR INTNUM3 = 84
     	ECHO PLAYER You blow everyone a kiss.
  ECHO OTHERS %N blows you a kiss.
     ENDIF
     IFVAR INTNUM3 = 8
    ECHO PLAYER You flip through a spellbook secretly deciding what to hit yourself with next.
    ECHO OTHERS %n flips through a spellbook, stroking %h chin thoughtfully.
     ENDIF
     IFVAR INTNUM3 = 34
    IFVAR ITEMVAL3 = 0
         ECHO OTHERS %N reaches into a pouch and pulls out some shredded leaves and a small square of paper.
         ECHO PLAYER You reach into a pouch and pull out some tabac and a small square of paper.
         EQUAL ITEMVAL3 1
    ENDIF
    IFVAR ITEMVAL3 = 1
         ECHO OTHERS %N rolls up a cigarette and puts it to her lips, lighting it with a small spark that leaps from her fingertips.
         ECHO PLAYER You roll up a cigarette and put it to your lips, lighting it with a small spark that leaps from your fingertips.
         EQUAL ITEMVAL3 0
    ENDIF
     ENDIF
     IFVAR INTNUM3 = 81
    IFVAR ZEREKPAINT = 0
         ECHO OTHERS %N carefully applies camoflage facepaint to %h exposed skin.
         ECHO PLAYER You carefully apply camoflage facepaint to your exposed skin.
         APPEAR %S seems to blend into his surroundings.
         EQUAL ZEREKPAINT 1
    ELSE
         ECHO OTHERS %N begins to remove his camoflage facepaint with a damp cloth.
         ECHO PLAYER You remove your camoflage facepaint with a damp cloth.
         APPEAR XXX
         EQUAL ZEREKPAINT 0
    ENDIF
     ENDIF
     IFVAR INTNUM3 = 79
    ECHO OTHERS %n rummages through %h satchel and produces a roll of gauze, some salves and a small, sharp knife.
    ECHO PLAYER You rummage through your satchel and produce various innocent-looking instruments.
     ENDIF
     IFVAR INTNUM3 = 21
    ECHO OTHERS %n looks incredulous.
    ECHO PLAYER HUMP WOLF
     ENDIF
     IFVAR INTNUM3 = 58
    ECHO OTHERS %n yawns and stretches, %h claws appear and dig into the ground before %i.
    ECHO PLAYER You yawn and stretch, sticking your claws out and digging them into the ground before you.
     ENDIF
     IFVAR INTNUM3 = 78
    ADD CAMMIESTAGE 1
    IFVAR CAMMIESTAGE = 1
         ECHO ALL %n shudders. Suddenly, the snow-white hairs that cover her body begin to grow thicker.
    ENDIF
    IFVAR CAMMIESTAGE = 2
         ECHO ALL %n's clothes fall gently away as her spine crackles and lengthens.
    ENDIF
    IFVAR CAMMIESTAGE = 3
         ECHO ALL %n slowly bends her powerful limbs back and forth, unsheathing finely honed claws.
    ENDIF
    IFVAR CAMMIESTAGE = 4
         ECHO ALL %n's face becomes lupine; %h jaw begins to extend outwards as she emits a gutteral moan of pleasure.
         ECHO PLAYER You feel your muscles twitching abnormally.
    GMMSG *** Camorra is transforming to wolfform.
    ENDIF
     ENDIF
     IFVAR INTNUM3 = 86
  ADD RASTAGANJA 1
  IFVAR RASTAGANJA = 1
    ECHO OTHERS %N spins a fat joint of ganja and fires it up.
    ECHO PLAYER You spin a fat joint of ganja and fire it up.
  ENDIF
  IFVAR RASTAGANJA > 1
    IFVAR RASTAGANJA < 5
      ECHO OTHERS As %n takes a massive puff of %n funky cigarette, his eyes become more bloodshot.
      DAMAGEPLR BODYONLY 1 You take a massive puff of your funky cigarette.
    ENDIF
  ENDIF
  IFVAR RASTAGANJA > 4
    ECHO OTHERS To your amazement, %n pops the burning butt of %h cigarette into %h mouth and swallows it.
    DAMAGEPLR BODYONLY 2 You swallow the still burning butt!
    EQUAL RASTAGANJA 0
  ENDIF
     ENDIF
     IFVAR INTNUM3 = 118
     	ECHO OTHERS %N polishes some round, wire-framed glasses on %h t-shirt. It seems to help, a little.
		ECHO PLAYER You polish your glasses. What a difference!
     ENDIF
     IFVAR INTNUM3 = 89
  ECHO PLAYER You touch your fist to your heart, then extend your hand out from your body.
  ECHO OTHERS %N touches %h fist to %h heart, then extends %h hand out from %h body.
     ENDIF
     IFVAR INTNUM3 = 122
  ECHO PLAYER You beat your wings absent-midedly.
  ECHO OTHERS %N beats %h wings absent-mindedly, lost in thought.
     ENDIF
     IFVAR INTNUM3 = 124
  ECHO PLAYER You take out a whetstone and begin to sharpen the blade of your naginata.
  ECHO OTHERS %N takes out a whetstone and begins to sharpen the blade of %h naginata.
     ENDIF
     IFVAR INTNUM3 = 126
  ECHO PLAYER You twitch your ear quickly, producing a jingle from your earring.
  ECHO OTHERS You hear a jingle from %N's earring as %h twitches %h ear.
     ENDIF
     IFVAR INTNUM3 = 127
  ECHO PLAYER You tap your shin, causing it to emit a loud ping.
  ECHO OTHERS %N taps %h shin, creating a loud PING!
     ENDIF
     IFVAR INTNUM3 = 128
  ECHO PLAYER You lay down, cross your feet, fold your arms and assume a fighting position.
  ECHO OTHERS %N lays down, crossing %h feet and folding %h arms, assuming a fighting position.
  POSITION LAY
     ENDIF
; Slarba
ENDIF

IFPREVERB UNUSE -1
     CLEARVERB
     ECHO PLAYER You rub your temples.
     ECHO OTHERS %N rubs %h temples with %h fingertips.
     IFVAR INTNUM3 = 78
    ECHO PLAYER You sense yourself becoming nearly human.
    EQUAL CAMMIESTAGE 0
     ENDIF
ENDIF

