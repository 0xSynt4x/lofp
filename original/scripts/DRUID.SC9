IFPREVERB USE -1
     IFVAR ORG = 22
    CLEARVERB
    ECHO PLAYER You drop to your knees.
    ECHO OTHERS %N drops to %h knees as a shadow passes over %h face.
    POSITION KNEEL
     ENDIF
     IFVAR ORG = 2
    CLEARVERB
    ECHO PLAYER You flip through a spellbook secretly deciding what to hit yourself with next.
    ECHO OTHERS %n flips through a spellbook, stroking %h chin thoughtfully.
     ENDIF
     IFVAR ORG = 3
    CLEARVERB
    ECHO PLAYER You turn your badge to catch the light.
    ECHO OTHERS %n turns %h badge to catch the light.
     ENDIF
     IFVAR ORG = 5
    CLEARVERB
    ECHO PLAYER You produce some antiseptic gauze.
    ECHO OTHERS %n produces a roll of gauze.
     ENDIF
     IFVAR ORG = 8
    CLEARVERB
    ECHO PLAYER You grin mischevously.
    ECHO OTHERS %n grins mischevously.
     ENDIF
     IFVAR ORG = 9
    CLEARVERB
    ECHO PLAYER You trace a tiny symbol over your heart.
    ECHO OTHERS %N traces a tiny symbol over %h heart.
     ENDIF
     IFVAR ORG = 15
    CLEARVERB
    ECHO PLAYER You catch sight of an especially beautiful tree and begin hugging it.
    ECHO OTHERS %n walks over to an especially beautiful tree and hugs it gently.
     ENDIF
ENDIF

