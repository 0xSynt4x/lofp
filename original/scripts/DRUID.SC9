IFPREVERB STEAL -1
  CLEARVERB
  IFVAR ITEMVAL3 = 111
    IFVAR FLAG1 = 111
      IFVAR PLRSINROOM = 2
        EQUAL FLAG1 0
        GMMSG  ** %N just used the object to knock all the net-dead people off in %h room.
        ECHO OTHERS %N disconnects everyone in the room................................
        strcpy 0 "****[Legends_is_disconnecting_you_now_due_to_net_inactivity]****
        echo player %0%c%0%c%0%c%0%c%0%c%0%c%0%c%0%0%c%0%c%0%c%0%c%0%c%0%c%0%c%0
        echo player %0%c%0%c%0%c%0%c%0%c%0%c%0%c%0%0%c%0%c%0%c%0%c%0%c%0%c%0%c%0
        echo player %0%c%0%c%0%c%0%c%0%c%0%c%0%c%0%0%c%0%c%0%c%0%c%0%c%0%c%0%c%0
        echo player %0%c%0%c%0%c%0%c%0%c%0%c%0%c%0%0%c%0%c%0%c%0%c%0%c%0%c%0%c%0
      ELSE
        ECHO PLAYER You must do this in a different room.
      ENDIF
    ENDIF
    IFVAR FLAG1 ! 111
      EQUAL FLAG1 111
      ECHO PLAYER Stealing again will commence hangup.
    ENDIF
  ENDIF
ENDIF

IFPREVERB MASSAGE -1
  CLEARVERB
  IFVAR GEN = 1
    IFVAR INTNUM3 = 1
      ECHO OTHERS %N stikes a seductive pose and shows off some chest.
      ECHO PLAYER You strike a seductive pose and show off some chest.
    ELSE
      ECHO OTHERS %N strikes a seductive pose and shows some leg.
      ECHO PLAYER You strike a seductive pose and show off some leg.
    ENDIF
  ENDIF
  IFVAR GEN = 0
    ECHO PLAYER You strike a pose and flex your biceps.
    ECHO OTHERS %N strikes a pose and flexes %h biceps.
  ENDIF
  IFVAR GEN = 2
    ECHO PLAYER You strike a pose and show off some pseudopod.
    ECHO OTHERS %N strikes a pose and shows off some pseudopod.
  ENDIF
ENDIF

IFPREVERB BREW -1
  CLEARVERB
ENDIF

IFPREVERB TAKE -1
  IFVAR INTNUM3 ! 1
    CLEARVERB
  ENDIF
ENDIF

IFPREVERB FILL -1
  CLEARVERB
ENDIF

IFPREVERB CLIMB -1
  IFVAR RAC = 6
    CLEARVERB
    ECHO PLAYER You swish your tail back and forth nervously.
    ECHO OTHERS %N swishes %h tail back and forth nervously.
  ENDIF
ENDIF

IFPREVERB PLAY -1
  CLEARVERB
  ECHO PLAYER I can't think of anything for PLAY.
ENDIF

IFPREVERB YOWL -1
	CLEARVERB
	ECHO PLAYER I can't think of anything for YOWL.
ENDIF
