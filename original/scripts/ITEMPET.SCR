;
; Bunnies
INUMBER 939
NAME 38
WEIGHT 3
VOLUME 4
ARTICLE SOME
SUBSTANCE PAPER
IFPREVERB TOUCH -1
  CLEARVERB
  ECHO PLAYER You pet one of the bunnies on the head.
  ECHO OTHERS %N pets a bunny on the head.
ENDIF
IFPREVERB KISS -1
  CLEARVERB
  ECHO PLAYER You kiss one of the bunnies on the nose!
  ECHO OTHERS %N kisses a bunny on the nose!
ENDIF
IFPREVERB TAKE -1
  RANDOM DUMMY1 1 3 0
  IFVAR DUMMY1 = 1
    CLEARVERB
    ECHO PLAYER You try to pick the bunnies up, but they manage to squirm out of your grasp.
    ECHO OTHERS %N tries to pick up some bunnies, but they manage to squrim out of %h grasp, one after another.
  ENDIF
  IFVAR DUMMY2 = 2
    CLEARVERB
    ECHO PLAYER You leap forward, arms outstretched, and try to grab all of the bunnies at once, but fail miserably.
    ECHO OTHERS %N leaps forward, arms outstretched, and tries to grab all of the bunnies at once, but fails miserably.
  ENDIF
ENDIF
IFPREVERB HUG -1
  CLEARVERB
  ECHO PLAYER You wrap your arms around the entire bundle of bunnies.
  ECHO OTHERS %N wraps %h arms around the entire bundle of bunnies.
ENDIF
IFPREVERB THUMP -1
  CLEARVERB
  ECHO PLAYER You bop one of the bunnies on the head!
  ECHO OTHERS %N bops one of the bunnies on the head!
ENDIF
IFPREVERB DEPOSIT -1
  CLEARVERB
  ECHO PLAYER The clerk looks at you and asks, "Sure, why don't you try depositing a baby next time?"
  GMMSG  ** %N just tried to DEPOSIT bunnies.
ENDIF
IFPREVERB LICK -1
  CLEARVERB
  ECHO PLAYER Yuck. Bunny hair.
  ECHO OTHERS %N licks a bunny. Yuck.
ENDIF
IFPREVERB KICK -1
  CLEARVERB
  ECHO PLAYER You thrust your foot at them, but aren't able to kick any.
  ECHO OTHERS %N tries desperately to kick some bunnies, but can't quite seem to.
ENDIF
IFPREVERB WAVE -1
  CLEARVERB
  ECHO PLAYER You take one of the bunnies by the ears and swing it around wildly!
  ECHO OTHERS %N takes a bunny and swings it by the ears wildly!
ENDIF
IFPREVERB PINCH -1
  CLEARVERB
  ECHO PLAYER You pinch one of the bunnies, causing it to squeek!
  ECHO OTHERS %N pinches a bunny, causing it to squeek!
ENDIF
IFPREVERB2 BREAK -1
  CLEARVERB
  ECHO PLAYER You can't break much with bunnies.
ENDIF
IFPREVERB NIBBLE -1
  CLEARVERB
  ECHO PLAYER You nibble on one of the bunnies' ears!
  ECHO OTHERS %N nibbles on one of the bunnies' ears!
ENDIF
IFPREVERB PULL -1
  CLEARVERB
  ECHO PLAYER You scoop one of the bunnies up into the palm of your hand.
  ECHO OTHERS %N scoops one of the bunnies up into the palm of %h hand.
ENDIF
IFPREVERB PUSH -1
  CLEARVERB
  ECHO PLAYER You give each one of the bunnies a firm pat on the rump, causing them to scatter.
  ECHO OTHERS %N's bunnies scatter in every direction.
ENDIF
IFPREVERB NUZZLE -1
  CLEARVERB
  ECHO PLAYER You bring one of the bunnies up to your neck, and it nuzzles you gently.
  ECHO OTHERS %N's bunnies nuzzle %h neck.
ENDIF
IFPREVERB CUDDLE -1
  CLEARVERB
  ECHO PLAYER You brush one of the bunnies against your cheek.
  ECHO OTHERS %N brushes one of %h bunnies against %h cheek.
ENDIF
;
INUMBER 1890
NAME 377
WEIGHT 2
VOLUME 2
IFVAR ITEMVAL1 ! 1
IFPREVERB2 BREAK -1
  IFVAR ARCHNUM = 1890
    CLEARVERB
    ECHO PLAYER You shatter the squirrel's skull into bits!
    ECHO OTHERS %N shatters %a into bits!
    GMMSG ** %N just smashed a squirrel's skull to bits, feel free to kill %i.
    EQUAL ITEMADJ1 405
    EQUAL ITEMVAL1 1
  ENDIF
ENDIF
IFPREVERB BREAK -1
  IFVAR ARCHNUM = 1890
    CLEARVERB
    ECHO PLAYER You shatter the squirrel's skull into bits!
    ECHO OTHERS %N shatters %a into bits!
    GMMSG ** %N just smashed a squirrel's skull to bits, feel free to kill %i.
    EQUAL ITEMADJ1 405
    EQUAL ITEMVAL1 1
  ENDIF
ENDIF
IFPREVERB KISS -1
  CLEARVERB
  ECHO PLAYER The squirrel nips at your nose as you try to kiss it.
  ECHO OTHERS %N's squirrel nits at %h nose as %s tries to kiss it.
ENDIF
IFPREVERB HUG -1
  CLEARVERB
  ECHO PLAYER The squirrel squirms out of your grasp as you try to smother it.
  ECHO OTHERS %N's squirrel squirms out of %h graps as %s tries to smother it.
ENDIF
IFPREVERB PULL -1
  CLEARVERB
  IFCARRY 1890 -1
    ECHO PLAYER You place the squirrel upon your shoulder.
    ECHO OTHERS %N places %h squirrel upon %h shoulder.
  ELSE
    ECHO PLAYER The squirrel leaps out of the way.
  ENDIF
ENDIF
IFPREVERB TOUCH -1
  CLEARVERB
  ECHO PLAYER You pet the squirrel, and although it doesn't resist, it doesn't seem particularly happy about being touched.
  ECHO OTHERS %N pets a squirrel.
ENDIF
IFPREVERB PUSH -1
  IFCARRY 1890 -1
    CLEARVERB
    ECHO PLAYER You push the squirrel off of your shoulder.
    ECHO OTHERS %N pushes %a off of %h shoulder.
  ENDIF
ENDIF
IFPREVERB PUNCH -1
  CLEARVERB
  ECHO PLAYER You strike your fist at the squirrel, causing it to leap away, never to be heard from again.
  ECHO OTHERS %N strikes %h fist at a squirrel, causing it to leap away, never to be heard from again.
  GMMSG  ** %N just kicked a squirrel. It left %i.
  REMOVEITEM -1
ENDIF
IFPREVERB GAZE -1
  CLEARVERB
  IFCARRY 1890 -1
    ECHO PLAYER You glance up at the squirrel on your shoulder and watch as it, in turn, scans the area around you.
    ECHO OTHERS %N's squirrel carefully eyes the area around you.
  ENDIF
ENDIF
IFPREVERB TAP -1
  CLEARVERB
  ECHO PLAYER You tap the squirrel on the noggin.
  ECHO OTHERS %N taps %h squirrel on the head, causing it to nip at %h finger.
  DAMAGEPLR SLASH 1 As if to tell you that it does not appreciate such gestures, the squirrel nips at your finger.
ENDIF
IFPREVERB THUMP -1
  CLEARVERB
  ECHO PLAYER You pound on the squirrel, nearly squashing it.
  ECHO OTHERS %N pounds on %h squirrel, nearly squashing it.
ENDIF
IFPREVERB KICK -1
  CLEARVERB
  ECHO PLAYER You give the squirrel a swift kick, killing it!
  ECHO OTHERS %N gives a squirrel a swift kick, killing it!
  EQUAL ITEMADJ1 405
  EQUAL ITEMVAL1 1
  GMMSG  ** %N just killed %h squirrel.
ENDIF
IFPREVERB GESTURE -1
  CLEARVERB
  ECHO PLAYER You motion to the squirrel, causing it to fall in step behind you.
  ECHO OTHERS %N's squirrel falls into step behind %i.
ENDIF
IFPREVERB LISTEN -1
  CLEARVERB
  ECHO PLAYER You whisper to the squirrel, asking it if sees any imps.
  ECHO OTHERS %N whispers something to %h squirrel.
  PLREVENT 1
  CONTPLREVENT
  ECHO PLAYER Your squirrel runs down your arm and begins to sniff about the area.
  ECHO OTHERS %N's squirrel runs down %h arm and begins to sniff about the area.
  PLREVENT 1
  CONTPLREVENT
  ECHO PLAYER Your squirrel responds with a series of clicking noises.
  ECHO OTHERS %N's squirrel runs back up %h arm and whispers into %h ear.
ENDIF
IFPREVERB RAISE -1
  CLEARVERB
  ECHO PLAYER You turn to the squirrel questioningly and it whispers into your ear.
  ECHO OTHERS %N's squirrel runs up %h shoulder and whispers into %h ear.
ENDIF
ENDIF
;
VARIABLE IDSCALES
;
INUMBER 926
NAME 541
WEIGHT 4
VOLUME 6
SUBSTANCE CLOTH
IFPREVERB TOUCH -1
  CLEARVERB
  ECHO PLAYER You rub your hand against the snake's scaly side and it wraps itself around your arm.
  ECHO OTHERS %N's snake wraps itself around %h arm as %s strokes its side.
ENDIF
IFPREVERB PUSH -1
  CLEARVERB
  ECHO PLAYER You nudge the snake, causing it to lash out, hissing.
  ECHO OTHERS %N's snake lashes out and hisses.
ENDIF
IFPREVERB WEAR -1
  CLEARVERB
  ECHO PLAYER You pull the snake around your neck.
  ECHO OTHERS %N pulls %a around %h neck.
ENDIF
IFPREVERB BITE -1
  CLEARVERB
  ECHO PLAYER Are you really sure you want to do that?
ENDIF
IFPREVERB WAVE -1
  CLEARVERB
  ECHO PLAYER The snake wriggles around, slithering over your arms and shoulders.
  ECHO OTHERS %N's snake wriggles around, slithering over %h arms and shoulders.
ENDIF
IFPREVERB PLAY -1
  CLEARVERB
  ECHO PLAYER You put the snake down and bob your head back and forth.
  ECHO OTHERS %N puts %a down and bobs %h head back and forth.
  PLREVENT 2
  CONTPLREVENT
  ECHO PLAYER Your snake begins to imitiate your motions and bobs its head back and forth.
  ECHO OTHERS %A bobs its head back and forth.
ENDIF
IFPREVERB USE -1
  CLEARVERB
  ECHO PLAYER You brandish the snake like a weapon.
  ECHO OTHERS %N brandishes %a like a weapon.
ENDIF
IFPREVERB THUMP -1
  CLEARVERB
  DAMAGEPLR SLASH 1 You strike your fist out at the snake, causing it to lash out and sink its fangs into your skin!
  ECHO OTHERS %N strikes %h fist at %a, causing it to lash out and sink its fangs into %h skin!
ENDIF
IFPREVERB DEPOSIT -1
  CLEARVERB
  ECHO PLAYER Somehow, you suspect that the bank does not take snakes.
ENDIF
IFPREVERB PULL -1
  CLEARVERB
  EQUAL DUMMY1 0
  IFVAR IDSCALES < 10
    RANDOM DUMMY2 1 10 0
    IFVAR DUMMY2 = 1
      IFNOITEM 6
        EQUAL DUMMY1 1
      ENDIF
    ENDIF
  ENDIF
  IFVAR DUMMY1 = 1
    ECHO PLAYER You run your hand down the snake's body, pulling off the loose scales and letting them fall to the ground.
    ECHO OTHERS %N runs %h hand down %a's body, pulling off loose scales.
    NEWITEM 6 507 ADJ1=327
  ELSE
    ECHO PLAYER You run your hand down the snake's body, looking for loose scales.
  ENDIF
ENDIF
IFPREVERB KICK -1
  CLEARVERB
  ECHO PLAYER As you move, the snake curls itself around your leg.
  ECHO OTHERS %A curls itself around %n's leg.
ENDIF
IFPREVERB RAISE -1
  CLEARVERB
  ECHO PLAYER You turn an eye towards the snake as it gazes about the area.
  ECHO OTHERS %A sits atop %N, gazing about the area.
ENDIF
IFPREVERB HISS -1
  CLEARVERB
  ECHO PLAYER The snake imitiates you, hissing and flicking its tongue in and out.
  ECHO OTHERS %A hisses, flicking its tongue in and out.
ENDIF
IFPREVERB KISS -1
  CLEARVERB
  ECHO PLAYER You kiss the snake on the head.
  ECHO OTHERS %N kisses %a on the head.
ENDIF
;
INUMBER 934
NAME 565
WEIGHT 2
VOLUME 2
ARTICLE THE
;
IFPREVERB GET -1
  CLEARVERB
  ECHO PLAYER Despite your best efforts to hold it, the frog is able to twist and squirm out of your grasp.
  ECHO OTHERS %n grabs %a in %h hands, but it quickly hops out of %h grasp.
ENDIF
IFPREVERB STEAL -1
  CLEARVERB
  RANDOM DUMMY1 1 100 0
  STRCVT 0 DUMMY1
  ECHO PLAYER You get into position to steal from the frog.
  ECHO PLAYER [Success: 0%%, Roll: %0] Failure!
  ECHO PLAYER You are caught!
  ECHO PLAYER The frog turns to %n and ribbits, "Stop, thief!"
  ECHO OTHERS You look on as %n tries to steal from %a.
  ECHO OTHERS The frog turns to %n and ribbits, "Stop, thief!"
ENDIF
IFPREVERB TOUCH -1
  CLEARVERB
  ECHO PLAYER The frog croaks as you pet it. Yech, it's skin is slimey.
  ECHO OTHERS %n's frog croaks as %i pets it.
  APPEAR %H fingers are all slimy and wet.
ENDIF
IFPREVERB LICK -1
  CLEARVERB
  ECHO OTHERS %n kisses %a deeply.
  ECHO PLAYER You kiss %a deeply and begin to feel ill.
  SPELL 320
ENDIF
IFPREVERB KISS -1
  CLEARVERB
  ECHO PLAYER You kiss %a on the lips, but nothing happens. Were you expecting it to turn into a prince?
  ECHO OTHERS %n kisses %a on the lips!
ENDIF
IFPREVERB THUMP -1
  CLEARVERB
  ECHO PLAYER The frog gives you a dirty look as you rap on its head.
  ECHO OTHERS %n thumps %a on the head.
ENDIF
IFPREVERB WAVE -1
  CLEARVERB
  ECHO PLAYER You wave to %a.
  ECHO OTHERS %n waves to %a.
ENDIF
IFVERB LISTEN -1
  IFVAR LEV < 90
    ECHO PLAYER The frog croaks, "You are not yet ready to hear what I have to say."
  ELSE
    ECHO PLAYER The frog croaks, "You are nearly ready to hear what I have to say."
  ENDIF
ENDIF
IFVERB SNIFF -1
  ECHO PLAYER The frog smells like it has been hopping around swamps recently.
ENDIF
IFPREVERB TAP -1
  CLEARVERB
  ECHO OTHERS %n taps %a on its little shoulder.
  ECHO PLAYER You tap %a on its little shoulder.
ENDIF
IFPREVERB KICK -1
  CLEARVERB
  ECHO OTHERS %n gives %a a swift kick!
  ECHO PLAYER You give %a a swift kick!
ENDIF
IFPREVERB NIBBLE -1
  CLEARVERB
  ECHO PLAYER %a don't play dat.
ENDIF
IFPREVERB NUDGE -1
  CLEARVERB
  ECHO PLAYER You nudge %a.
  ECHO OTHERS %n nudges %a.
ENDIF
;
VARIABLE ELERAAN
;
INUMBER 308
NAME 673
VOLUME 4
WEIGHT 6
INTERIOR 15
CONTAINER IN
IFVAR ITEMVAL2 = 1
  ECHO ALL %A suddenly sprouts six legs and changes color.
  EQUAL ITEMVAL2 0
  RANDOM DUMMY1 1 5 0
  IFVAR DUMMY1 = 1
    EQUAL ITEMADJ2 1108
  ENDIF
  IFVAR DUMMY1 = 2
    EQUAL ITEMADJ2 1094
  ENDIF
  IFVAR DUMMY1 = 3
    EQUAL ITEMADJ2 177
  ENDIF
  IFVAR DUMMY1 = 4
    EQUAL ITEMADJ2 1125
  ENDIF
  IFVAR DUMMY1 = 5
    EQUAL ITEMADJ2 839
  ENDIF
ENDIF
IFVAR RAC ! 110
  IFVAR ELERAAN > 0
    IFVAR INTNUM3 ! 1
      IFNOITEM 8
        ECHO ALL %A suddenly sprouts a spherical ball of fluff which falls to the ground.
        NEWITEM 8 308 VAL2=1 ADJ1=938
      ENDIF
    ENDIF
    EQUAL ELERAAN 0
  ENDIF
ENDIF
IFPREVERB LOOK -1
  CLEARVERB
  ECHO PLAYER This furry creature bears a slight resemblance to a very furry cat, save for the fact that it has six legs and ears that droop over irridescent blue eyes. It also has a small pouch under its belly.
ENDIF
IFPREVERB BREAK -1
  CLEARVERB
  ECHO PLAYER As you try to crush the creature, it squirms out of your hands and runs away!
  ECHO OTHERS %N tries to crush %a, but it squirms out of %h hands and scurries off!
  GMMSG ** %N just tried to destroy %h %a, so it ran off.
  REMOVEITEM -1
ENDIF
IFPREVERB RUB -1
  CLEARVERB
  ECHO PLAYER The creature purrs as you stroke its back.
  ECHO OTHERS %N's eleraan purrs as %h strokes its back.
ENDIF
IFPREVERB SNIFF -1
  CLEARVERB
  ECHO PLAYER The creature nods and mimmics your motions... as if trying to sniff something out ...but does not seem to find anything.
  ECHO OTHERS %N makes sniffing motions at %a, which mimmics them.
ENDIF
IFPREVERB KISS -1
  CLEARVERB
  ECHO PLAYER You kiss the creature's nose.
  ECHO OTHERS %N kisses %a's nose.
ENDIF
IFPREVERB HUG -1
  CLEARVERB
  ECHO PLAYER You wrap your arms around the creature.
  ECHO OTHERS %N wraps %h arms around %a.
ENDIF
IFPREVERB TOUCH -1
  CLEARVERB
  ECHO PLAYER You stroke the creature's fur.
  ECHO OTHERS %N strokes %a's fur.
ENDIF
IFVERB LICK -1
  ECHO PLAYER Great, now your tongue is covered with hair.
  ECHO OTHERS You notice that %n's tongue is covered with hair.
ENDIF
;

; I# 1337 : Mukwa (pet)
INUMBER 1337
NAME 1054
WEIGHT 2
VOLUME 2
MISC
ifpreverb gaze -1
  clearverb
  echo player You get into a staring contest with the mukwa.
  echo others %N gets into a staring contest with %h mukwa.
endif
ifpreverb pet -1
  clearverb
  echo player The mukwa growls contentedly as you pet it.
  echo others %A growls as %n pets it.
endif
ifpreverb rub -1
  clearverb
  echo player You stroke the mukwa's fur.
  echo others %N strokes %h mukwa's fur.
endif
ifpreverb look -1
  ifvar itemval2 = 0
    clearverb
    echo player The creature is long and eel-like, though it bears a coat of fur over its entire body and head.
  endif
endif
ifpreverb wear -1
  clearverb
  echo player You wear the mukwa around your neck.
  echo others %N wears %a around %h neck.
endif
ifpreverb listen -1
  clearverb
  echo player The mukwa is gurgling.
  echo others %N listens intently to %a.
endif
ifpreverb growl -1
  clearverb
  echo player You growl at the mukwa, and it reciprocates.
  echo others %N's mukwa growls at %i.
endif
ifpreverb push -1
  clearverb
  echo player You thrust the mukwa forward, causing it to lash out like a furry weapon.
  echo others %N's mukwa lashes out and bares its fangs.
endif
ifpreverb break -1
  clearverb
  echo others %N's mukwa sinks its fangs deep into %h arm!
  damageplr slash 30 As you turn to abuse the mukwa, it circles and sinks its fangs into you!
endif
ifpreverb thump -1
  clearverb
  echo player You thump on the mukwa's head, knocking it out briefly.
  echo others %N thumps on %h mukwa's head, knocking it out briefly.
endif
;
