NUMBER 1862
NAME Crowded Office

INDOOR_FLOOR
FIXED_LIGHT

*DESCRIPTION_START
Desks, cabinets and tables cram this moderately sized room. While it is
apparent that there is only room for two desks in here, three exist. A
corkboard is on a wall covered with various notes to people. A door leads
back to the hallway.
*DESCRIPTION_END
ITEM 0 65 ADJ1=234 VAL1=10 VAL3=1861 VAL2=1861 LOCKED
ITEM 1 201 ADJ1=355
ITEM 2 384 VAL1=1000 LOCKED VAL3=1861
IFPREVERB OPEN 2
        IFITEM 2 LOCKED
                CLEARVERB
                ECHO PLAYER It won't budge.
        ENDIF
ENDIF
IFVERB LOOK 2
        IFITEM 2 OPEN
                CLEARVERB
                IFVAR PVAL16 > 0
                        STRCVT 0 PVAL16
                        STRCVT 1 PVAL15
                        ECHO PLAYER You see that there are %0 1000-crown bags and a big bag with %1 crowns in the drawer.
                ELSE
                        STRCVT 0 PVAL15
                        ECHO PLAYER You see that there are %0 crowns in the drawer.
                ENDIF
        ENDIF
ENDIF
IFVERB THUMP 2
        IFITEM 2 OPEN
                IFVAR PVAL15 > 0
                        NEWITEM 5 161 ADJ1=147
                        SETITEMVAL 5 1 PVAL15
                        EQUAL PVAL15 0
                        ECHO ALL Coins spill out of the drawer.
                ENDIF
        ENDIF
ENDIF
IFVERB KICK 2
        IFITEM 2 OPEN
                IFVAR PVAL16 > 0
                        NEWITEM 6 161 ADJ1=147
                        SETITEMVAL 6 1 1000
                        SUB PVAL16 1
                        ECHO ALL Coins spill out of the drawer.
                ENDIF
        ENDIF
ENDIF

