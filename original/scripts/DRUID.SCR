ADJDEF 1400 winter
;
MACRO 18
;
IFSAY Winter_Solstice
  NEWITEM 9 546 ADJ1=1273
  NEWPUT 9 239 ADJ3=1400 VAL2=8
  ECHO PLAYER Robyn sets a glass in front of you. "This is my favorite, you know. Great stuff."
  ECHO OTHERS Robyn places a glass in front of %N.
ENDIF
IFSAY Old_Thumper
  NEWITEM 9 546 ADJ1=1273
  NEWPUT 9 239 ADJ2=1272 ADJ3=1085 VAL2=8
  ECHO PLAYER Patti comes over and sets a Thumper in front of you. "Enjoy!"
  ECHO OTHERS Patti puts a glass with a brown ale in front of %N.
ENDIF
IFSAY Sam_Smith's_Oatmeal_Stout
  NEWITEM 9 546 ADJ1=1273
  NEWPUT 9 709 ADJ1=315 VAL2=8
  ECHO ALL Ricky comes over with a glass and a bottle and pours it for you. "Best sweet stout in the world!"
ENDIF
IFSAY Guiness_Stout
  NEWITEM 9 546 ADJ1=1273
  NEWPUT 9 709 ADJ1=102 VAL2=8
  ECHO PLAYER Roka brings a foaming glass of rich, dark stout to you.
  ECHO OTHERS Roka approaches %N and puts a glass of black stout in front of %i.
ENDIF
IFSAY Mill_City_Root_Beer
  ECHO ALL Nick comes over, apologizing "Sorry, we're out of that today."
ENDIF
IFSAY Harpoon_Ale
  ECHO PLAYER Laurie walks over and places a pint of a light golden ale in front of you.
  ECHO OTHERS Laurie places a pint of golden ale in front of %N.
  NEWITEM 9 546 ADJ1=1273
  NEWPUT 9 239 ADJ3=468 VAL2=8
ENDIF
IFSAY Sierra_Nevada_Pale_Ale
  ECHO ALL Judy looks at her list, frowns, and says "Nope, ran out last nite, sorry."
ENDIF
IFSAY Red_Tail_Ale
  ECHO PLAYER Stephanie looks at you and says "You KNOW we can't get that anymore; don't know why it's even on the list."
  ECHO OTHERS Stephanie tells %N that they're out of Red Tail.
ENDIF
IFPREVERB POKE -1
  IFVAR ARCHNUM = 546
    IFVAR ITEMADJ1 = 1273
      ECHO PLAYER A new waitress comes and takes your pint glass away.
      REMOVEITEM -1
    ENDIF
  ENDIF
ENDIF
