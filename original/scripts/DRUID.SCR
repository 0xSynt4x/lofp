MACRO 15
;
VARIABLE SETINTNUM79
VARIABLE MINGFAVOR

IFVAR SETINTNUM79 ! 0
  IFVAR SETINTNUM79 = PLAYERNUM
    EQUAL INTNUM79 111
    EQUAL SETINTNUM79 0
  ENDIF
ENDIF

IFVAR MINGFAVOR = 1
  IFVAR INTNUM79 = 111
    GMMSG %N has the favor of Ming.
  ENDIF
ENDIF

; Arresting RoomX

IFVAR ARRESTEM = PLAYERNUM
  IFVAR WARRANT > 0
    EQUAL ARRESTEM 0
    ECHO OTHERS A group of the King's finest lawkeeps come in and swarm over %N, and in a flurry of magic and steel, kill %i.
    ECHO PLAYER You are pounced on by a group of exquisitely trained lawkeeps and slain.
    KILL PLAYER
    POSITION LAY
    EQUAL WARRANT 0
    IFVAR WEALTH > 25000
      SUB WEALTH 25000
    ENDIF
    IFVAR WEALTH > 25000
      SUB WEALTH 25000
    ENDIF
    IFVAR WEALTH > 25000
      SUB WEALTH 25000
    ENDIF
    IFVAR WEALTH > 25000
      SUB WEALTH 25000
    ENDIF
    IFVAR WEALTH > 25000
      SUB WEALTH 25000
    ENDIF
    IFVAR WEALTH > 25000
      SUB WEALTH 25000
    ENDIF
    IFVAR WEALTH > 25000
      SUB WEALTH 25000
    ENDIF
    IFVAR WEALTH > 25000
      SUB WEALTH 25000
    ENDIF
    ECHO OTHERS After %N is frisked a few times for money, %n is hauled off to jail.
    ECHO PLAYER The lawkeeps search for all your secret stashes of money and then haul you to jail.
    MOVE 340
    AFFECT 340
    ECHO OTHERS %N is tossed in by three of the meanest lawkeeps you've ever seen.
  ENDIF
ENDIF

VARIABLE CREODTODAY
IFVAR CREODTODAY ! 1234
  RANDOM DUMMY1 1 10 0
  IFVAR DUMMY1 = 1
    EQUAL PATCREODFIND 1
  ENDIF
  EQUAL CREODTODAY 1234
ENDIF

IFVAR DRUIDINTNUM3 = 1
  IFVAR DRUIDINTPNUM = PLAYERNUM
  	STRCVT 0 INTNUM3
	  STRCVT 1 RNUM
    GMMSG %N's Intnum3 is %0 and is presently in room number %1.
    EQUAL DRUIDINTNUM3 0
  ENDIF
ENDIF
IFSEEK 36
  IFVAR ITEMVAL1 ! DATE
    EQUAL ITEMBIT0 0
    EQUAL ITEMBIT1 0
  ENDIF
ENDIF
IFSEEK 35
  IFVAR ITEMBIT5 = 1
    IFVAR ITEMVAL1 ! 0
      STRCVT 0 INTNUM3
      STRCVT 1 ITEMVAL5
      IFVAR INTNUM3 = ITEMVAL5
        IFVAR INTNUM3 ! 0
          IFVAR WIELDED = 0
            EQUAL SKILL1 ITEMVAL1
            EQUAL ITEMVAL1 0
            EQUAL ITEMVAL2 30
            EQUAL ITEMVAL3 0
            EQUAL ITEMVAL5 0
            EQUAL ITEMBIT5 0
            ECHO PLAYER Your two weapon skill has been reset because you exited with the mind sai wielded.
            GMMSG %N's mind sai has been detected in a wielded state without it being wielded. Resetting now.
          ENDIF
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF

;
;
; Werewolf detection
;
IFVAR FINDWEREROOM ! 0
  IFVAR FINDWEREROOM = RNUM
    IFVAR INTNUM98 > 0
      ADD FINDWERECOUNT 1
    ENDIF
  ENDIF
ENDIF
IFVAR FINDWERECOUNT ! 0
  IFVAR FINDWEREPNUM = PLAYERNUM
    IFVAR INTNUM98 = 0
      ECHO PLAYER The distinct aroma of the accursed stings your sensitive nose.
    ENDIF
    IFVAR INTNUM98 > 0
      IFVAR FINDWERECOUNT > 1
        ECHO PLAYER You sniff at least one other of your kind here.
      ENDIF
    ENDIF
    EQUAL FINDWERECOUNT 0
    EQUAL FINDWEREROOM 0
  ENDIF
ENDIF
;
MACRO 16
IFVAR DEAD = 0
	IFVAR DUMMY1 ! 0
		RANDOM DUMMY1 1 100 0
		IFVAR DUMMY1 > 80
			RANDOM DUMMY1 1 100 0
			ADD DUMMY1 CON
			IFVAR DUMMY1 < 180
				DAMAGEPLR COLD 5 The icy wind bites into you.
			ENDIF
			EQUAL DUMMY1 0
		ENDIF
	ENDIF
ENDIF
IFVAR TERRAIN = 8
	IFVERB LISTEN -1
		ECHO PLAYER You hear nothing except the howling of the wind.
	ENDIF
	IFPREVERB ASCEND -1
		CLEARVERB
		ECHO PLAYER With these winds that probably wouldn't be a good idea.
	ENDIF
ENDIF
