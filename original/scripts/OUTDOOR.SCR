  ECHO OTHERS %N arrives at the top on the stairway.
  AFFECT 534
  ENDIF
 ENDIF
 IFVAR DUMMY2 < 20
  IFVAR DUMMY2 >= 0
  ECHO PLAYER Halfway up, you nearly stumble, but continue on up the stairway.
  ECHO OTHERS %N barely manages to climb the stairway.
  MOVE 535
  AFFECT 535
  ECHO OTHERS %N scrambles over the top on the stairway.
  AFFECT 534
  ENDIF
 ENDIF
