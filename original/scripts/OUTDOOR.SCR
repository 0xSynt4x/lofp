 ENDIF
 IFVAR DUMMY2 < 0
  IFVAR DUMMY2 >= -20
  ECHO PLAYER You decide the stairway is too risky.
  ECHO OTHERS %N sweats bullets just looking at the stairway.
  ENDIF
 ENDIF
 CLEARVERB
ENDIF
