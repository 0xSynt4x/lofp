;       *** GARIN's SWORD CEVENT
;
; difference between last count and present count
EQUAL janevildif 0
ADD janevildif JANEVILINROOM2
SUB janevildif JANEVILINROOM
; sets last count for next cycle
EQUAL JANEVILINROOM2 JANEVILINROOM
EQUAL JANEVILINROOM 0
IFSEEK 362
  EQUAL JANSWORDRNUM RNUM
  IFVAR janevildif < -7
    ECHO PLAYER Lightbringer begins to glow with a bright white light.
    ECHO OTHERS %N's sword begins to glow with a bright white light.
    EQUAL ITEMVAL2 45
  ELSE
    IFVAR janevildif < -2
      IFVAR JANEVILINROOM2 >= 7
        ECHO PLAYER Lightbringer begins to glow with a bright white light.
        ECHO OTHERS %N's sword begins to glow with a bright white light.
        EQUAL ITEMVAL2 45
      ENDIF
      IFVAR JANEVILINROOM2 < 7
        ECHO PLAYER Lightbringer begins to glow softly with a white light.
        ECHO OTHERS %N's sword begins to glow softly with a white light.
        EQUAL ITEMVAL2 40
      ENDIF
    ELSE
      IFVAR janevildif < 0
        IFVAR JANEVILINROOM2 >= 7
          ECHO PLAYER Lightbringer begins to glow with a bright white light.
          ECHO OTHERS %N's sword begins to glow with a bright white light.
          EQUAL ITEMVAL2 45
        ENDIF
        IFVAR JANEVILINROOM2 < 7
          ECHO PLAYER Lightbringer vibrates with a nearly inaudible hum.
          EQUAL ITEMVAL2 30
        ENDIF
      ENDIF
    ENDIF
  ENDIF
  IFVAR janevildif > 0
    IFVAR JANEVILINROOM2 < 7
      ECHO PLAYER Lightbringer's glow fades to a soft white light.
      ECHO OTHERS The glow from %N's sword fades to a soft white light.
      EQUAL ITEMVAL2 40
    ELSE
      IFVAR JANEVILINROOM2 < 1
        ECHO PLAYER Lightbringer's glow fades altogether.
        ECHO OTHERS The glow from %N's sword fades altogether.
        EQUAL ITEMVAL2 25
      ENDIF
    ENDIF
  ENDIF
ENDIF
