;
;       ***  Climbing Rope
;
INUMBER 958
NAME 1105
EQUAL ITEMADJ1 1218
SUBSTANCE CLOTH
WEIGHT 10
TURNABLE
WORN_BACK
VARIABLE CLIMBSTARTROOM
IFPREVERB LOOK -1
CLEARVERB
        ECHO PLAYER The rope is thin and lightweight, and of a substance you haven't seen before.
ENDIF
IFPREVERB TURN -1
CLEARVERB
        IFVAR ITEMVAL5 > 0
           IFVAR ITEMVAL5 < 10
                ECHO PLAYER You carefully coil the rope.
                ECHO OTHERS %N carefully coils a rope.
                EQUAL ITEMVAL5 0
           ELSE
                ECHO PLAYER The rope is already coiled.
           ENDIF
        ENDIF
ENDIF
IFPREVERB PUSH -1
CLEARVERB
        IFVAR ITEMVAL5 = 0
                ECHO PLAYER You make a large loop in one end of the rope.
                ECHO OTHERS %N makes a large loop in one end of the rope.
                EQUAL ITEMVAL5 1
        ELSE
                ECHO PLAYER You'll need to coil the rope first.
        ENDIF
ENDIF
IFPREVERB WIELD -1
CLEARVERB
        IFVAR ITEMVAL5 = 1
                ECHO PLAYER You hold the loop in one hand, feeding slack to it from the other hand.
                ECHO OTHERS %N takes the loop of a rope in one hand, and feeds slack to it from the other hand.
                EQUAL ITEMVAL5 2
        ELSE
                ECHO PLAYER The rope is not ready to be thrown.
        ENDIF
ENDIF
IFPREVERB WAVE -1
        IFVAR ITEMVAL5 = 2
                CLEARVERB
                ECHO PLAYER You turn the loop in large circle about your head.
                ECHO OTHERS %N turns the loop in a large circle about %h head.
                EQUAL ITEMVAL5 3
        ELSE
        ENDIF
ENDIF
IFPREVERB WEAR -1
        IFVAR ITEMVAL3 = 1
                CLEARVERB
                EQUAL ITEMVAL2 1
                ECHO PLAYER You carefully tie the other end of the rope around your waist.
                ECHO OTHERS %N carefully ties one end of the rope around %h waist.
        ENDIF
ENDIF
IFPREVERB REMOVE -1
        IFVAR ITEMVAL2 = 1
                CLEARVERB
                ECHO PLAYER You untie the rope from around your waist and coil it back up.
                ECHO OTHERS %N unties one end of a rope from around %h waist.
                EQUAL ITEMVAL2 0
        ENDIF
ENDIF
IFPREVERB CLIMB -1
        IFVAR ITEMVAL2 = 1
                EQUAL CLIMBSTARTROOM RNUM
                EQUAL DUMMY1 RNUM
                IFVAR DUMMY1 < ITEMVAL4
                        ECHO PLAYER You lean back on the rope, and walk up the wall, feeding your rope behind you as you climb.
                        ECHO OTHERS %N leans back on the rope and walks up the wall, feeding rope behind %i as %s climbs.
                        DISBAND
                        MOVE ITEMVAL4
                        AFFECT ITEMVAL4
                        ECHO OTHERS %N arrives, walking up the wall on an anchored rope.
                        AFFECT CLIMBSTARTROOM
                ELSE
                        ECHO PLAYER That won't work out so well from here.
                ENDIF
        ELSE
                ECHO PLAYER The rope isn't attached to anything.
        ENDIF
ENDIF
