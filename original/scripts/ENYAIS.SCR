          EQUAL ITEMADJ2 62
        ENDIF
        IFVAR DUMMY3 = 21
          EQUAL ITEMADJ2 419
        ENDIF
        IFVAR DUMMY3 = 22
          EQUAL ITEMADJ2 521
        ENDIF
      ELSE
        ECHO PLAYER Nothing happens.
      ENDIF
    ELSE
      ECHO PLAYER Nothing happens.
    ENDIF
  ELSE
    ECHO PLAYER Nothing happens.
  ENDIF
