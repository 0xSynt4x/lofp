VARIABLE HAPPYMEAL
;
INUMBER 922
NAME 347
WEIGHT 100
VOLUME 20
CONTAINER IN
INTERIOR 100
OPENABLE
IFPREVERB READ -1
  CLEARVERB
  EQUAL DUMMY1 7
  SUB DUMMY1 HAPPYMEAL
  STRCVT 0 DUMMY1
  ECHO PLAYER The readout displays the number %0.
ENDIF
IFPREVERB2 PUT -1
  IFVAR ITEMADJ1 = -1
    IFVAR ITEMADJ2 = -1
      IFVAR HAPPYMEAL < 7
        ADD HAPPYMEAL 1
        CLEARVERB
        ECHO PLAYER As you place the item within the contraption, which humms faintly and begins to glow!
        ECHO OTHERS %N places the item within the contraption, which then begins to glow.
        RANDOM DUMMY1 1 2 0
        RANDOM DUMMY2 1 17 0
        IFVAR DUMMY2 = 0
          EQUAL ITEMADJ1 95
        ENDIF
        IFVAR DUMMY2 = 1
          EQUAL ITEMADJ1 119
        ENDIF
        IFVAR DUMMY2 = 2
          EQUAL ITEMADJ1 178
        ENDIF
        IFVAR DUMMY2 = 3
          EQUAL ITEMADJ1 181
        ENDIF
        IFVAR DUMMY2 = 4
          EQUAL ITEMADJ1 209
        ENDIF
        IFVAR DUMMY2 = 5
          EQUAL ITEMADJ1 279
        ENDIF
        IFVAR DUMMY2 = 6
          EQUAL ITEMADJ1 287
        ENDIF
        IFVAR DUMMY2 = 7
          EQUAL ITEMADJ1 308
        ENDIF
        IFVAR DUMMY2 = 8
          EQUAL ITEMADJ1 318
        ENDIF
        IFVAR DUMMY2 = 9
          EQUAL ITEMADJ1 89
        ENDIF
        IFVAR DUMMY2 = 10
          EQUAL ITEMADJ1 87
        ENDIF
        IFVAR DUMMY2 = 11
          EQUAL ITEMADJ1 56
        ENDIF
        IFVAR DUMMY2 = 12
          EQUAL ITEMADJ1 53
        ENDIF
        IFVAR DUMMY2 = 13
          EQUAL ITEMADJ1 46
        ENDIF
        IFVAR DUMMY2 = 14
          EQUAL ITEMADJ1 37
        ENDIF
        IFVAR DUMMY2 = 15
          EQUAL ITEMADJ1 36
        ENDIF
        IFVAR DUMMY2 = 16
          EQUAL ITEMADJ1 27
        ENDIF
        IFVAR DUMMY2 = 17
          EQUAL ITEMADJ1 14
        ENDIF
; 671 773 241 613 194 585
RANDOM DUMMY3 1 28 0
        IFVAR DUMMY3 = 23
          EQUAL ITEMADJ2 1125
        ENDIF
        IFVAR DUMMY3 = 24
          EQUAL ITEMADJ2 735
        ENDIF
        IFVAR DUMMY3 = 25
          EQUAL ITEMADJ2 839
        ENDIF
