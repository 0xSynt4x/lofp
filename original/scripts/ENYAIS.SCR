          EQUAL ITEMADJ2 184
        ENDIF
        IFVAR DUMMY3 = 7
          EQUAL ITEMADJ2 152
        ENDIF
        IFVAR DUMMY3 = 8
          EQUAL ITEMADJ2 79
        ENDIF
        IFVAR DUMMY3 = 9
          EQUAL ITEMADJ2 75
        ENDIF
        IFVAR DUMMY3 = 10
          EQUAL ITEMADJ2 40
        ENDIF
