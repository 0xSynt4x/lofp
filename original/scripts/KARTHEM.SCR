 EQUAL DIGDOORSEQ 0
 CLOSE 0
ENDIF

IFVERB RECALL -1
 IFVAR SKILL32 > 0
  ECHO OTHERS %n looks pensive for a moment.
  SKILLCHECK 32 -20 TANNRECALL
