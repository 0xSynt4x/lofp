REGIONDEF 150 SEASONS
REGIONDEF 150 TIME
REGIONDEF 150 WINTERTEMP 10
REGIONDEF 150 SUMMERTEMP 70
REGIONDEF 150 SPRINGTEMP 50
REGIONDEF 150 AUTUMNTEMP 30
REGIONDEF 150 TELEPORT RESTRICTED
REGIONDEF 150 SUMMONING ALLOWED
REGIONDEF 150 PRECIPITATION -5
FORAGEDEF FOREST 275 572 1 0
FORAGEDEF FOREST 278 571 1 0
;monsters groups
