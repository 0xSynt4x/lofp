NUMBER 3400
NAME Abandoned Dig, Pit
REGION 150
CALL 33
ITEM 9 693
*DESCRIPTION_START
You have stepped into a gently sloping pit. In its center, a shaft leads straight down into the bedrock. A pair of pulleys and ropes are suspended just within reach over its center. They support some sort of platform, which hangs freely in the shaft. Piles of dirt lay testament to the efforts of the excavators who worked here.
*DESCRIPTION_END
;## Items ##
;2 ropes... one up and one down
ITEM 1 1667 ADJ1=183
ITEM 2 1667 ADJ1=183
EXTEND 1 hanging from the left side of a pulley on a rickety frame
EXTEND 2 hanging from the right side of a pulley on a rickety frame
;Platform
ITEM 8 365 ADJ1=262 ADJ2=355
;platform (room 3401) it is removed and replaced by 3401
; ## Exits ##
EXIT W 550
EXIT ABOVE 2146
; ## Special scripting ##

IFPREVERB STOMP -1
 IFVAR INTNUM3 = 1
  ECHO PLAYER You are standing in:
  ECHO PLAYER The Halls of Karthemos Version 1.2
  ECHO PLAYER Jack & Tann productions, Inc.
  ECHO PLAYER *****************************
  ECHO PLAYER In case of the elevator jamming, set PLATFORMMOTION to 0.
  ECHO PLAYER We thank you for your support.
 ENDIF
ENDIF

IFPREVERB EXAMINE 8
 IFITEM 8
  CLEARVERB
  ECHO PLAYER On the platform you see...
  SHOWROOM 3401
 ENDIF
ENDIF

IFPREVERB JUMP -1
 CLEARVERB
 IFVAR ROUNDTIME < 1
  IFVAR FLAG3 = 2
   EQUAL BODYPOINTS 5
   DAMAGEPLR CRUSH 25 You jump into the pit, and hit bottom!
   ECHO OTHERS %n leaps into the pit and vanishes.
   MOVE 3405
   AFFECT 3405
   ECHO OTHERS %n plummets to the floor from the shaft!
  ELSE
   IFVAR FLAG3 = 1
    ECHO PLAYER The pit looks awfully deep, are you certain you wish to do this?
    ECHO OTHERS %n seems to gather %h nerves for the jump.
    ADD FLAG3 1
   ELSE
    ECHO PLAYER You approach the edge of the pit and prepare to jump.
    ECHO OTHERS %n approaches the pit, preparing to jump.
    ADD FLAG3 1
   ENDIF
  ENDIF
 ENDIF
ENDIF

;pulling ropes goes up and down... also removes platform objects
;and adds them to the proper places... echoes in those rooms.
;use platformmotion if the platform is in motion to stop pulls

IFPREVERB PULL 1
 CLEARVERB
 IFVAR PLATFORMMOTION = 0
  IFVAR PLATFORMLEVEL = 0
   ECHO PLAYER The rope won't budge!
   ECHO OTHERS %n strains at a taut rope in futility.
  ELSE
   EQUAL PLATFORMMOTION 1
   EQUAL ROUNDTIME 20
   ECHO PLAYER You heave and strain at the rope, as something moves up the shaft.
   ECHO OTHERS %n heaves at the rope, as something moves up the shaft.
   AFFECT 3401
   ECHO ALL The ropes go taut as the platform is pulled upwards.
   IFVAR PLATFORMLEVEL = 1
    AFFECT 3402
    REMOVEITEM 8
    ECHO ALL The platform ascends out of sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 2
    AFFECT 3403
    REMOVEITEM 8
    ECHO ALL The platform ascends out of sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 3
    AFFECT 3404
    REMOVEITEM 8
    ECHO ALL The platform ascends out of sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 4
    AFFECT 3405
    REMOVEITEM 8
    ECHO ALL The platform ascends out of sight.
   ENDIF
   AFFECT 3400
   PLREVENT 5
   CONTPLREVENT
   SUB PLATFORMLEVEL 1
   EQUAL PLATFORMMOTION 0
   IFVAR PLATFORMLEVEL = 0
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform ascends into sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 1
    AFFECT 3402
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform ascends into sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 2
    AFFECT 3403
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform ascends into sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 3
    AFFECT 3404
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform ascends into sight.
   ENDIF
   AFFECT 3401
   ECHO ALL The platform ascends into sight of a new ledge.
   EQUAL PLATFORMMOTION 0
  ENDIF
 ELSE
  AFFECT 3401
  IFVAR PLRSINROOM = 0
   AFFECT 3400
   ECHO PLAYER You jerk the ropes free from an obstruction.
   ECHO OTHERS %n jerks the ropes from from an obstruction.
   EQUAL PLATFORMMOTION 0
  ELSE
   ECHO PLAYER The ropes are already in motion.
   ECHO OTHERS %n gazes at the ropes enviously.
  ENDIF
 ENDIF
ENDIF

IFPREVERB PULL 2
 CLEARVERB
 IFVAR PLATFORMMOTION = 0
  IFVAR PLATFORMLEVEL = 4
   ECHO PLAYER The rope won't budge!
   ECHO OTHERS %n strains at a taut rope in futility.
  ELSE
   EQUAL PLATFORMMOTION 1
   EQUAL ROUNDTIME 20
   ECHO PLAYER You heave and strain at the rope as something descends in the shaft.
   ECHO OTHERS %n heaves at the rope as something descends the shaft.
   AFFECT 3401
   ECHO ALL The ropes go taut as the platform is pulled downwards.
   IFVAR PLATFORMLEVEL = 0
    AFFECT 3400
    ECHO ALL The platform vanishes down the shaft.
    REMOVEITEM 8
   ENDIF
   IFVAR PLATFORMLEVEL = 1
    AFFECT 3402
    REMOVEITEM 8
    ECHO ALL The platform descends out of sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 2
    AFFECT 3403
    REMOVEITEM 8
    ECHO ALL The platform descends out of sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 3
    AFFECT 3404
    REMOVEITEM 8
    ECHO ALL The platform descends out of sight.
   ENDIF
   AFFECT 3400
   PLREVENT 5
   CONTPLREVENT
   ADD PLATFORMLEVEL 1
   EQUAL PLATFORMMOTION 0
   IFVAR PLATFORMLEVEL = 4
    AFFECT 3405
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform descends into sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 1
    AFFECT 3402
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform descends into sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 2
    AFFECT 3403
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform descends into sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 3
    AFFECT 3404
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform descends into sight.
   ENDIF
   AFFECT 3401
   ECHO ALL The platform descends into sight of a new ledge.
  ENDIF
 ELSE
  AFFECT 3401
  IFVAR PLRSINROOM = 0
   AFFECT 3400
   ECHO PLAYER You jerk the ropes free from an obstruction.
   ECHO OTHERS %n jerks the ropes from from an obstruction.
   EQUAL PLATFORMMOTION 0
  ELSE
   ECHO PLAYER The ropes are already in motion.
   ECHO OTHERS %n gazes at the ropes enviously.
  ENDIF
 ENDIF
ENDIF

IFPREVERB GO 8
 CLEARVERB
 IFITEM 8
  ECHO PLAYER You step gingerly onto the platform.
  ECHO OTHERS %n steps gingerly onto the platform.
  EQUAL PLATFORMLEVEL 0
  MOVE 3401
  AFFECT 3401
  ECHO OTHERS %n steps onto the platform.
 ENDIF
ENDIF
