NUMBER 3401
NAME Abandoned Dig, Platform
DEEPCAVE
REGION 150
CALL 33
ITEM 9 693
*DESCRIPTION_START
This circular wooden platform is suspended by a pair of ropes attached firmly to two corners. The result of this construction scheme is that the platform seems quite unstable. Sudden movement would probably be a bad idea. A ledge lays within stepping distance.
*DESCRIPTION_END
;## Items ##
;ledge (exit) go script is set depending on where the platform is
ITEM 0 450
;2 ropes... one up and one down
ITEM 1 1667 ADJ1=183
ITEM 2 1667 ADJ1=183
EXTEND 1 hanging from the left side of a pulley far above
EXTEND 2 hanging from the right side of a pulley far above
; ## Exits ##
; ## Special scripting ##
;jumping causes fall to bottom (3405)

IFPREVERB JUMP -1
 CLEARVERB
 IFVAR ROUNDTIME < 1
  IFVAR PLATFORMLEVEL < 3
   EQUAL BODYPOINTS 5
  ENDIF
  IFVAR PLATFORMLEVEL < 4
   DAMAGEPLR CRUSH 25 You jump and fall from the rickety platform!
   ECHO OTHERS %n leaps from the side of the platform and disappears.
   MOVE 3405
   AFFECT 3405
   ECHO OTHERS %n plummets to the floor from the shaft!
  ELSE
   ECHO PLAYER You jump up and down on the grounded platform.
   ECHO OTHERS %n jumps up and down on the grounded platform.
  ENDIF
 ENDIF
ENDIF

;ifentry limits access to 2 people...
IFENTRY -1
 EQUAL PLATFORMMOTION 0
 IFVAR PLRSINROOM > 3
  ECHO PLAYER The platform rocks dangerously and you decide to remove your weight from it.
  ECHO OTHERS %n decides to retreat from the overloaded platform.
  IFVAR PLATFORMLEVEL = 0
   MOVE 3400
   AFFECT 3400
   ECHO OTHERS %n steps back off the platform.
  ENDIF
  IFVAR PLATFORMLEVEL = 1
   MOVE 3402
   AFFECT 3402
   ECHO OTHERS %n steps back off the platform.
  ENDIF
  IFVAR PLATFORMLEVEL = 2
   MOVE 3403
   AFFECT 3403
   ECHO OTHERS %n steps back off the platform.
  ENDIF
  IFVAR PLATFORMLEVEL = 3
   MOVE 3404
   AFFECT 3404
   ECHO OTHERS %n steps back off the platform.
  ENDIF
  IFVAR PLATFORMLEVEL = 4
   MOVE 3405
   AFFECT 3405
   ECHO OTHERS %n steps back off the platform.
  ENDIF
 ENDIF
ENDIF

;pulling ropes goes up and down... also removes platform objects
;and adds them to the proper places... echoes in those rooms.
;use platformmotion if the platform is in motion to stop pulls

IFPREVERB PULL 1
 CLEARVERB
 IFVAR PLATFORMMOTION = 0
  IFVAR PLATFORMLEVEL = 0
   ECHO PLAYER The rope won't budge!
   ECHO OTHERS %n strains at a taut rope in futility.
  ELSE
   EQUAL PLATFORMMOTION 1
   EQUAL ROUNDTIME 20
   ECHO PLAYER You heave and strain at the rope, causing the platform to ascend.
   ECHO OTHERS %n heaves at the rope, causing the platform to ascend.
   IFVAR PLATFORMLEVEL = 1
    AFFECT 3402
    REMOVEITEM 8
    ECHO ALL The platform ascends out of sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 2
    AFFECT 3403
    REMOVEITEM 8
    ECHO ALL The platform ascends out of sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 3
    AFFECT 3404
    REMOVEITEM 8
    ECHO ALL The platform ascends out of sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 4
    AFFECT 3405
    REMOVEITEM 8
    ECHO ALL The platform ascends out of sight.
   ENDIF
   AFFECT 3400
   ECHO ALL The ropes vibrate with motion as you hear the platform moving down the shaft.
   AFFECT 3401
   PLREVENT 5
   CONTPLREVENT
   SUB PLATFORMLEVEL 1
   EQUAL PLATFORMMOTION 0
   IFVAR PLATFORMLEVEL = 0
    AFFECT 3400
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform ascends into sight.
    EQUAL PLATFORMMOTION 0
   ENDIF
   IFVAR PLATFORMLEVEL = 1
    AFFECT 3402
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform ascends into sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 2
    AFFECT 3403
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform ascends into sight.
   ENDIF
   IFVAR PLATFORMLEVEL = 3
    AFFECT 3404
    NEWITEM 8 365 ADJ1=262 ADJ2=355
    ECHO ALL The platform ascends into sight.
   ENDIF
   AFFECT 3401
   ECHO ALL The platform ascends into sight of a new ledge.
  ENDIF
 ELSE
  ECHO PLAYER Someone is already pulling the ropes.
  ECHO OTHERS %n gazes at the ropes enviously.
 ENDIF
ENDIF

