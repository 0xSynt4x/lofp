;Gazes perform showroom based on PLATFORMLEVEL setting

IFPREVERB LOOK 0
 CLEARVERB
 ECHO PLAYER You cast your gaze to the side of the platform...
 ECHO OTHERS %n gazes to the side of the platform.
 IFVAR PLATFORMLEVEL = 0
  SHOWROOM 3400
 ENDIF
 IFVAR PLATFORMLEVEL = 1
  SHOWROOM 3402
 ENDIF
 IFVAR PLATFORMLEVEL = 2
  SHOWROOM 3403
 ENDIF
 IFVAR PLATFORMLEVEL = 3
  SHOWROOM 3404
 ENDIF
 IFVAR PLATFORMLEVEL = 4
  SHOWROOM 3405
 ENDIF
ENDIF

;go script
IFPREVERB GO 0
 CLEARVERB
 IFVAR PLATFORMMOTION = 1
  ECHO PLAYER The platform is moving!
  ECHO OTHERS  %n considers leaping from the moving platform!
 ELSE
  DISBAND
  ECHO PLAYER You step onto the ledge to safety.
  ECHO OTHERS %n steps onto the ledge.
  IFVAR PLATFORMLEVEL = 0
   MOVE 3400
   AFFECT 3400
    ECHO OTHERS %n steps off the platform.
  ENDIF
  IFVAR PLATFORMLEVEL = 1
   MOVE 3402
   AFFECT 3400
   ECHO OTHERS %n steps off the platform.
  ENDIF
  IFVAR PLATFORMLEVEL = 2
   MOVE 3403
   AFFECT 3403
    ECHO OTHERS %n steps off the platform.
  ENDIF
  IFVAR PLATFORMLEVEL = 3
   MOVE 3404
   AFFECT 3404
    ECHO OTHERS %n steps off the platform.
  ENDIF
  IFVAR PLATFORMLEVEL = 4
   MOVE 3405
   AFFECT 3405
    ECHO OTHERS %n steps off the platform.
  ENDIF
 ENDIF
ENDIF
