IFVAR RATINNARDS = 1
IFVAR RATPOWDER = 0

  ADD RATCOUNT 1

  IFVAR RATCOUNT = 2
    AFFECT 3793
    ECHO ALL You hear something happening inside the contraption.
    GMMSG ** Bullet Cevent Message 1.
  ENDIF

  IFVAR RATCOUNT = 4
    AFFECT 3793
    ECHO ALL You hear a whirring noise come from within the contraption.
    GMMSG ** Bullet Cevent Message 2.
  ENDIF

  IFVAR RATCOUNT = 8
    AFFECT 3793
    ECHO ALL The whirring noise ceases.
    GMMSG ** Bullet Cevent Message 3.
  ENDIF

  IFVAR RATCOUNT = 10
    AFFECT 3793
    ECHO ALL The contraption seems to heat up.
    GMMSG **  Bullet Cevent Message 4.
  ENDIF

  IFVAR RATCOUNT = 14
    AFFECT 3793
    ECHO ALL You hear a "click" from within the contraption.
    GMMSG ** Bullet Cevent Message 5.
  ENDIF

  IFVAR RATCOUNT = 18
    EQUAL RATCOUNT 0
    EQUAL RATPOWDER 1
    AFFECT 3793
    ECHO ALL You hear the sound of powder filtering through a tube and a green light on one of the panels goes on.
    ECHO ALL %cThe contraption begins to cool off.
    GMMSG ** Bullet Cevent Message, Final.
  ENDIF

ENDIF
