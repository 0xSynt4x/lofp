ADD FOUNTCOUNT 1
IFVAR FOUNTCOUNT = 90
	EQUAL FOUNTCOUNT 0
	
	; Put Ilhana's CEVENT info here
	
	AFFECT 206
	IFVAR MONTH > 3
		IFVAR MONTH < 10
			RANDOM DUMMY1 1 6 0
			  IFVAR DUMMY1 = 1
			    ECHO ALL The fountain splutters and gurgles as water funnels down its many levels.
			  ENDIF
			  IFVAR DUMMY1 = 2
			    ECHO ALL A slight breeze causes ripples to glide over the surface of the fountain's water.
			  ENDIF
		ENDIF
	ENDIF

AFFECT 3733
