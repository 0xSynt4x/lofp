      AFFECT 3733
    ENDIF
    IFVAR DUMMY1 = 4
      AFFECT 3794
      ECHO ALL The fire shifts slight as it consumes another piece of wood.
      AFFECT 3733
    ENDIF
  ENDIF
ENDIF


