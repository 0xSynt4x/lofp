IFPREVERB FLIP -1
  IFVAR ITEMBIT0 = 0
    CLEARVERB
    EQUAL ITEMBIT0 1
    ECHO PLAYER You flip the dark plastic visor down, covering your eyes.
    ECHO OTHERS %n flips the dark plastic visor on %h helmet down, covering %h eyes.
    PLREVENT 1
    CONTPLREVENT
    ECHO PLAYER A small virtual screen appears before your eyes.
  ELSE
    CLEARVERB
    EQUAL ITEMBIT0 0
    ECHO PLAYER You flip the dark plastic visor up.
    ECHO OTHERS %n flips the dark plastic visor of %h helmet up, revealing his eyes.
    PLREVENT 1
    CONTPLREVENT
    ECHO PLAYER The small virtual screen disappears.
  ENDIF
ENDIF

IFPREVERB TAP -1
  IFITEM -1 WORN
    IFVAR ITEMBIT0 = 1
     CLEARVERB
     STRCVT 0 MANAPOINTS
     STRCVT 1 PSIPOINTS
     STRCVT 2 BODYPOINTS
     STRCVT 3 FATPOINTS
     ECHO PLAYER A luminous read-out scrolls across the virtual screen before your eyes.
     ECHO PLAYER Body remaining:        %2%cMana remaining:        %0%cPsi remaining:         %1%cFatigue remaining:     %3
    ELSE
      CLEARVERB
      ECHO PLAYER The visor is not down.
    ENDIF
  ENDIF
ENDIF

IFPREVERB CONCENTRATE -1
  IFITEM -1 WORN
    IFVAR ITEMBIT0 = 1
      CLEARVERB
      EQUAL ROUNDTIME 5
      ECHO PLAYER As you concentrate, tiny receptacles in your helmet pick up your thoughts.%c
      SPELL 405
    ELSE
      CLEARVERB
      ECHO PLAYER The helmet is not on.
    ENDIF
  ENDIF
ENDIF

VARIABLE HELMETVISION
IFPREVERB RUB -1
  IFITEM -1 WORN
    IFVAR ITEMBIT0 = 1
      IFVAR HELMETVISION < 11
        ADD HELMETVISION 1
        CLEARVERB
        ECHO PLAYER As you concentrate, tiny receptacles in your helmet pick up your thoughts.%c
        SPELL 520 100
      ELSE
        CLEARVERB
        ECHO PLAYER As you concentrate, tiny receptacles in your helmet pick up your thoughts.%cNothing happens.
      ENDIF
    ELSE
      CLEARVERB
      ECHO PLAYER The helm is not on.
    ENDIF
  ENDIF
ENDIF


