		EQUAL ITEMVAL2 0
		EQUAL ITEMVAL3 0
		EQUAL ITEMVAL4 0
		EQUAL ITEMVAL5 0
	ENDIF
ENDIF
		
IFPREVERB LOOK -1 ; For GM's Only.
	IFVAR INTNUM3 = 1
		CLEARVERB
		ECHO PLAYER Hi Ho. Unique item made by Gradrak. Uses global variables. Do not use please.
		ECHO PLAYER Modified by Kreebonker so players could make them.%c
			IFVAR ITEMBIT0 = 1
				ECHO PLAYER A special Injector for Ace, uses variable PATINJECT1 to track uses/day.
				STRCVT 0 PATINJECT1
				ECHO PLAYER PATINJECT1 = %0
			ENDIF
			IFVAR ITEMBIT1 = 1
				STRCVT 0 ITEMVAL3
				ECHO PLAYER Standard Injector, BR3 type. %0 charges remaining.
			ENDIF
			IFVAR ITEMBIT2 = 1
				STRCVT 0 ITEMVAL3
				ECHO PLAYER Standard Injector, Haste type. %0 charges remaining.
			ENDIF
			IFVAR ITEMBIT3 = 1
				STRCVT 0 ITEMVAL3
				ECHO PLAYER Standard Injector, Cure Disease type. %0 charges remaining.
			ENDIF
			IFVAR ITEMBIT4 = 1
				STRCVT 0 ITEMVAL3
				ECHO PLAYER Standard Injector, Cure Posion type. %0 charges remaining.
			ENDIF
			IFVAR ITEMBIT5 = 1
				STRCVT 0 ITEMVAL3
				ECHO PLAYER An Old-type special Injector that uses PATINJECT1. USE it to switch it to the new-type special injector that will still use PATINJECT1.
			ENDIF
			IFVAR ITEMBIT6 = 1
				STRCVT 0 ITEMVAL3
				ECHO PLAYER Standard Injector, Invig 2 type. %0 charges remaining.
			ENDIF
	ELSE
		IFVAR ITEMBIT5 = 1 ; Old type injector, make them switch.
			CLEARVERB
			ECHO PLAYER You can see there is something wrong with %a. USE it to clear up the problem.
		ENDIF
		IFVAR ITEMBIT19 = 1
			CLEARVERB
			ECHO PLAYER You see an empty injector.
		ENDIF
		IFVAR ITEMBIT0 = 1 ; If it is Aces.
			IFVAR ITEMVAL5 = 1
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes white.
			ENDIF
			IFVAR ITEMVAL5 = 2
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes green.
			ENDIF
			IFVAR ITEMVAL5 = 3
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes violet.
			ENDIF
			IFVAR ITEMVAL5 = 4
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes blue.
			ENDIF
			IFVAR ITEMVAL5 = 5
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes yellow.
			ENDIF
				IFVAR PATINJECT1 < 50
					IFVAR PATINJECT1 > 25
						ECHO PLAYER You can see that %a is about half powered-up.
					ELSE
						ECHO PLAYER You can see that %a is about three-quarters powered-up.
					ENDIF
				ELSE
					IFVAR PATINJECT1 < 75
						ECHO PLAYER You can see that %a is about one-quarter powered-up.
					ELSE
						ECHO PLAYER You can see that %a is nearly out of power.
					ENDIF
				ENDIF
		ELSE ; Standard one
			IFVAR ITEMBIT1 = 1
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes white.
			ENDIF
			IFVAR ITEMBIT2 = 1
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes green.
			ENDIF
			IFVAR ITEMBIT3 = 1
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes violet.
			ENDIF
			IFVAR ITEMBIT4 = 1
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes blue.
			ENDIF
			IFVAR ITEMBIT6 = 1
				CLEARVERB
				ECHO PLAYER You see a small plastic cylinder with a small needle at one end and flashing light at the other. The light on top of the injector flashes yellow.
			ENDIF
			STRCVT 0 ITEMVAL3
			ECHO PLAYER You can see that there about %0 charges remaining.
		ENDIF
	ENDIF
ENDIF


IFPREVERB PUSH -1
	IFVAR ITEMBIT0 = 1 ; If it is Aces.
			CLEARVERB
			ECHO PLAYER You change the setting on %a and the light on top of the injector turns white.
			ECHO OTHERS %N fiddles with %h injector. The light on top of it turns white.
			ECHO ALL :::HEALTH INCREASE SETTING CONFIRMED:::
		EQUAL ITEMVAL5 1
	ELSE
		ECHO PLAYER The injector does not look sophisticated enough to do that.
		CLEARVERB
	ENDIF
ENDIF

IFPREVERB PULL -1
	IFVAR ITEMBIT0 = 1 ; If it is Aces.
		CLEARVERB
		ECHO PLAYER You change the setting on %a and the light on top of the injector turns green.
		ECHO OTHERS %N fiddles with %h injector. The light on top of it turns green.
		ECHO ALL :::METABOLIC HYPERBOOST CONFIRMED:::
		EQUAL ITEMVAL5 2
	ELSE
		ECHO PLAYER The injector does not look sophisticated enough to do that.
		CLEARVERB
	ENDIF
ENDIF

IFPREVERB TURN -1
	IFVAR ITEMBIT0 = 1 ; If it is Aces.
		CLEARVERB
		ECHO PLAYER You change the setting on %a and the light on top of the injector turns violet.
		ECHO OTHERS %N fiddles with %h injector. The light on top of it turns violet.
		ECHO ALL :::ANTI-CONTAGION CONFIRMED:::
		EQUAL ITEMVAL5 3
	ELSE
		ECHO PLAYER The injector does not look sophisticated enough to do that.
		CLEARVERB
	ENDIF
ENDIF

IFPREVERB FLIP -1
	IFVAR ITEMBIT0 = 1 ; If it is Aces.
		CLEARVERB
		ECHO PLAYER You change the setting on %a and the light on top of the injector turns blue.
		ECHO OTHERS %N fiddles with %h injector. The light on top of it turns blue.
		ECHO ALL :::ANTI-TOXICITY CONFIRMED:::
		EQUAL ITEMVAL5 4
	ELSE
		ECHO PLAYER The injector does not look sophisticated enough to do that.
		CLEARVERB
	ENDIF
ENDIF

IFPREVERB USE -1
	IFVAR ITEMBIT0 = 1 ; If it is Aces.
		IFVAR PATINJECT1 => 100 ; Pat's global for Ace.
			ECHO PLAYER The injector is out of power.
			CLEARVERB
		ELSE
			IFVAR RAC > 6
				ECHO PLAYER Your race lacks the needed circulatory system to use the injector.
				ECHO OTHERS %n is not sure what to do with %a.
				CLEARVERB
			ELSE
				CLEARVERB
				ECHO PLAYER You push the injector up to a familiar part of your neck.
				ECHO PLAYER You feel a slight needle prick.
				ECHO OTHERS %N stiffens slightly as %h presses the injector against %h neck.
				EQUAL ROUNDTIME 6
					IFVAR ITEMVAL5 = 1
						ADD PATINJECT1 2
						SPELL 318 50
					ENDIF
					IFVAR ITEMVAL5 = 2
						ADD PATINJECT1 5
						SPELL 210 50
					ENDIF
					IFVAR ITEMVAL5 = 3
						ADD PATINJECT1 1
						SPELL 319 50
					ENDIF
					IFVAR ITEMVAL5 = 4
						ADD PATINJECT1 1
						SPELL 303 50
					ENDIF
			ENDIF
		ENDIF
	ELSE ; It's a standard one, ITEMBIT0 = 0 or the orginal one that needs to be changed.
		IFVAR ITEMBIT5 = 1 	; This means it was an original injector.
							; Change it is so it remains special for Ace's one only.
			EQUAL ITEMBIT5 0
			EQUAL ITEMBIT0 1
			GMMSG ** %n just had %h injector changed so that it remain's a special 100 use Injector.
			ECHO PLAYER You adjust %a a bit, try it again.
			CLEARVERB
		ELSE ; Standard injector that players can make.
			IFVAR RAC > 6
				ECHO PLAYER Your race lacks the needed circulatory system to use the injector.
				ECHO OTHERS %n is not sure what to do with %a.
				CLEARVERB
			ELSE
				IFVAR ITEMVAL3 > 0
					CLEARVERB
					ECHO PLAYER You push the injector up to a familiar part of your neck.
					ECHO PLAYER You feel a slight needle prick.
					ECHO OTHERS %N stiffens slightly as %h presses the injector against %h neck.
					EQUAL ROUNDTIME 6
						IFVAR ITEMBIT1 = 1  ; BR3 injector
							SUB ITEMVAL3 2
							SPELL 318 50
						ENDIF
						IFVAR ITEMBIT2 = 1	; Haste injector
							SUB ITEMVAL3 5
							SPELL 210 50
						ENDIF
						IFVAR ITEMBIT3 = 1	; Cure Disease Injector
							SUB ITEMVAL3 1	
							SPELL 319 50
						ENDIF
						IFVAR ITEMBIT4 = 1	; Cure Poison injector
							SUB ITEMVAL3 1
							SPELL 303 50
						ENDIF
						IFVAR ITEMBIT6 = 1	; Invig 2 injector
							SUB ITEMVAL3 2
							SPELL 335 50
						ENDIF
				ELSE
					CLEARVERB
					ECHO PLAYER The injector is out of power.
					IFVAR ITEMBIT19 = 0
						CLEARVERB
						GMMSG ** %n empties an injector.
						EQUAL ITEMADJ1 112
						EQUAL ITEMADJ2 -1
						EQUAL ITEMADJ3 -1
						EQUAL ITEMBIT0 0
						EQUAL ITEMBIT1 0
						EQUAL ITEMBIT2 0
						EQUAL ITEMBIT3 0
						EQUAL ITEMBIT4 0
						EQUAL ITEMBIT5 0
						EQUAL ITEMBIT6 0
						EQUAL ITEMBIT7 0
						EQUAL ITEMBIT8 0
						EQUAL ITEMBIT9 0
						EQUAL ITEMBIT10 0
						EQUAL ITEMBIT11 0
						EQUAL ITEMBIT12 0
						EQUAL ITEMBIT13 0
						EQUAL ITEMBIT14 0
						EQUAL ITEMBIT15 0
						EQUAL ITEMBIT16 0
						EQUAL ITEMBIT17 0
						EQUAL ITEMBIT18 0
						EQUAL ITEMBIT19 1
						EQUAL ITEMVAL1 32000
						EQUAL ITEMVAL2 0
						EQUAL ITEMVAL3 0
						EQUAL ITEMVAL4 0
						EQUAL ITEMVAL5 0
					ENDIF
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDIF

INUMBER 857
NAME 721
WEIGHT 2
VOLUME 2
SUBSTANCE INDESTRUCTABLE
LIQCONTAINER
CONTAINER IN

IFVAR ITEMBIT19 ! 1
	EQUAL ITEMVAL1 32000
	EQUAL ITEMBIT19 1
ENDIF


IFPREVERB OPEN -1
	IFVAR ITEMBIT0 = 1
		CLEARVERB
		ECHO PLAYER You sealed it shut already.
	ELSE
		CLEARVERB
		ECHO PLAYER It is already opened.
	ENDIF
ENDIF

IFPREVERB CLOSE -1
	IFVAR ITEMBIT0 = 1
		CLEARVERB
		ECHO PLAYER You sealed it shut already.
	ELSE
		CLEARVERB
		ECHO PLAYER You can't close that yet.
	ENDIF
ENDIF

