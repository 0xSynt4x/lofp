; Trapped case
INUMBER 895
NAME 294
WEIGHT 3
VOLUME 6
INTERIOR 20
SUBSTANCE SOFTMETAL
CONTAINER IN
OPENABLE
LOCKABLE

ifpreverb touch -1
	echo player %c*%c*%c*
	echo player If you want to this item still, please email kree before 30 April, 1996. Thanks.
	echo player %c*%c*%c*
endif

IFVERB OPEN -1
 IFITEM -1 OPEN
  IFVAR ITEMBIT0 = 1
   EQUAL ITEMBIT0 0
   ECHO PLAYER You open the case, hear a small "click" and realize too late that it was a trap...
   ECHO OTHERS As %n opens %a, you hear a quiet "click"
   ECHO PLAYER The lid springs open and a gelatinous substance burns your face and hands severly!
   DAMAGEPLR BURN 5000 %cThe flames bite into your extremities...
   DAMAGEPLR BURN 5000 %cYou howl in agony!
   DAMAGEPLR BURN 5000 %cYou collapse to the ground in a charred heap.
   ECHO OTHERS %n collapses to the ground in a charred heap.
   APPEAR You see %h face and hands are covered with hideous burns and smoldering flesh.
   DAMAGEALL BURN 50 %cA gelatinous substance leaps from the case burning your extremities!
   REMOVEITEM -1
  ENDIF
 ENDIF
ENDIF

IFVERB LOOK -1
 IFVAR ITEMBIT0 = 1
  IFVAR SKILL12 > 0
    ECHO PLAYER %cFrom the type of lock, you see that there is a spring loaded trap of some kind.
  ENDIF
 ENDIF
ENDIF

IFPREVERB DISARM -1
    SKILLCHECK 12 -245 DUMMY1
; 30 percent chance to disarm at 50 ranks of Trap & Poison Lore.
    EQUAL DUMMY2 SKILL12
    MULT DUMMY2 5
    ADD DUMMY2 25
    SUB DUMMY2 245
    EQUAL DUMMY3 DUMMY1
    MULT DUMMY3 -1
    ADD DUMMY3 DUMMY2
      IFVAR DUMMY1 > 0
        CLEARVERB
        EQUAL ITEMBIT0 0
        STRCVT 0 ITEMBIT0
        GMMSG ** ITEMBIT0 = %0.
        ECHO PLAYER %cYou disarm the trap.
        ECHO OTHERS %n disarms the trap.
      ELSE
        IFVAR DUMMY3 > 98
          CLEARVERB
          EQUAL ITEMBIT0 0
          ECHO PLAYER %cYou goof trying to disarm the trap...
          ECHO OTHERS You see %n slip and set off the trap...
          DAMAGEPLR BURN 5000 %cThe lid springs open and a gelatinous substance burns your face and hands severly!
          APPEAR You see %h face and hands are covered with hideous burns and smoldering flesh.
          DAMAGEALL BURN 50 %cA gelatinous substance leaps from the case burning your extremities!
          REMOVEITEM -1
        ELSE
          CLEARVERB
          ECHO PLAYER %cYou fail to disarm the trap.
          ECHO OTHERS You fail to disarm the trap.
        ENDIF
      ENDIF
ENDIF

IFPREVERB PUSH -1
  IFITEM -1 OPEN
    IFVAR ITEMBIT0 = 0
    SKILLCHECK 12 -115 DUMMY1
    IFVAR DUMMY1 > 0
      CLEARVERB
      EQUAL ITEMBIT0 1
      ECHO PLAYER %cYou set the trap.
      ECHO OTHERS %cYou see %n fiddle with something inside the case.
    ELSE
      CLEARVERB
      ECHO PLAYER %cYou fail to set the trap.
      ECHO OTHERS %cYou see %n fiddle with something inside the case.
    ENDIF
  ENDIF
ENDIF

