;
IFPREVERB load -1
   IFVAR ITEMVAL3 = 0
      EQUAL ITEMBIT1 1
      EQUAL ITEMBIT2 0
      EQUAL ITEMBIT3 0
   ENDIF
   IFVAR ITEMVAL3 = 1
      EQUAL ITEMVAL3 0
      EQUAL ITEMBIT1 0
      EQUAL ITEMBIT2 1
      EQUAL ITEMBIT3 0
   ENDIF
   IFVAR ITEMVAL3 = 2
      EQUAL ITEMVAL3 0
      EQUAL ITEMBIT1 0
      EQUAL ITEMBIT2 0
      EQUAL ITEMBIT3 1
   ENDIF
   IFVAR ITEMVAL3 = 3
      ECHO PLAYER The shotgun magazine is already full.
      CLEARVERB
   ENDIF
ENDIF
;
IFVERB load -1
   IFVAR ITEMVAL3 ! 1
      IFVAR ITEMBIT1 = 1
         EQUAL ITEMVAL3 0
         EQUAL ITEMBIT1 0
      ENDIF
      IFVAR ITEMBIT2 = 1
         EQUAL ITEMVAL3 1
         EQUAL ITEMBIT2 0
      ENDIF
      IFVAR ITEMBIT3 = 1
         EQUAL ITEMVAL3 2
         EQUAL ITEMBIT3 0
      ENDIF
      STOP
   ENDIF
   IFVAR ITEMBIT1 = 1
      EQUAL ITEMBIT1 0
      EQUAL ITEMVAL3 1
      ECHO PLAYER The shotgun magazine now contains one shell.
   ENDIF
   IFVAR ITEMBIT2 = 1
      EQUAL ITEMBIT2 0
      EQUAL ITEMVAL3 2
      ECHO PLAYER The shotgun magazine now contains two shells.
   ENDIF
   IFVAR ITEMBIT3 = 1
      EQUAL ITEMBIT3 0
      EQUAL ITEMVAL3 3
      ECHO PLAYER The shotgun magazine now contains three shells.
   ENDIF
ENDIF
