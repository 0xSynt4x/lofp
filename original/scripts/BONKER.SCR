IFVERB TOUCH -1
  IFVAR ITEMVAL1 ! 111
    CLEARVERB
    GMMSG ** Hey, %n, don't use this Archetype.
    REMOVEITEM -1
  ENDIF
ENDIF

IFPREVERB GET -1
  IFVAR ITEMVAL1 ! 111
    CLEARVERB
    GMMSG ** Hey, %n, don't use this Archetype.
    REMOVEITEM -1
  ENDIF
ENDIF

VARIABLE SHANEVACATION
VARIABLE SHANELEFT

IFPREVERB RUB -1
  IFITEM -1 WORN
    IFVAR SHANEVACATION = 0
      IFVAR REGION = 0
      CLEARVERB
      EQUAL SHANEVACATION 1
      EQUAL SHANELEFT RNUM
      ECHO PLAYER You rub %a, when you hear a small "click".
      ECHO OTHERS %n rubs %a and you hear a small "click".
      ECHO ALL Suddenly, a blinding flash of light appears blinding you.
      MOVEGROUP 3729
      AFFECT 3729
      ECHO OTHERS A blinding light appears before you and then subsides.
      AFFECT SHANELEFT
      ECHO OTHERS The blinding light fades.
      ENDIF
    ENDIF
  ENDIF
ENDIF


; SWING
INUMBER 1875
NAME 1544
WEIGHT 1000
VOLUME 1000
HIDDEN

IFPREVERB GO 2
  IFVAR POSITION ! 1
    CLEARVERB
    ECHO PLAYER You sit down on the swing.
    ECHO OTHERS %n sits down on the swing.
    POSITION SIT
  ELSE
    CLEARVERB
    ECHO PLAYER You already are on the swing.
  ENDIF
ENDIF

IFPREVERB PUSH -1
  IFVAR POSITION = 1
    CLEARVERB
    ECHO PLAYER You push yourself off, and begin to swing lazily.
    ECHO OTHERS %n pushes %iself off and begins to swing lazily.
  ENDIF
ENDIF

; device to make mechanoids all powerful
INUMBER 898
NAME 381
WEIGHT 1
VOLUME 1
TECH
SUBSTANCE SOFTMETAL

ifpreverb touch -1
	echo player %c*%c*%c*
	echo player If you want to this item still, please email kree before 30 April, 1996. Thanks.
	echo player %c*%c*%c*
endif

*DESCRIPTION_START
You see a small cylindrical device made from a shiny metal. A tiny antenna sits at the top.
*DESCRIPTION_END

IFPREVERB TURN -1
  IFVAR RAC = 7
    IFVAR ITEMBIT0 = 1
      EQUAL ITEMBIT0 0
      CLEARVERB
      ECHO PLAYER You reroute power from the device and turn it off.
    ELSE
      EQUAL ITEMBIT0 1
      CLEARVERB
      ECHO PLAYER You reroute power to the device and turn it on.
      ECHO PLAYER A transparent virtual screen appears before you eyes.
     ENDIF
   ELSE
     CLEARVERB
     ECHO PLAYER You can't seem to figure it out.
     ECHO OTHERS %n looks confused as %s tries to use %a.
   ENDIF
ENDIF

IFPREVERB TAP -1
  IFVAR RAC = 7
    IFVAR ITEMBIT0 = 1
      CLEARVERB
      STRCVT 0 MANAPOINTS
      STRCVT 1 PSIPOINTS
      STRCVT 2 BODYPOINTS
      STRCVT 3 FATPOINTS
      ECHO PLAYER A luminous read-out scrolls across the virtual screen before your eyes.
      ECHO PLAYER Body remaining:        %2%cMana remaining:        %0%cPsi remaining:         %1%cFatigue remaining:     %3
    ELSE
      CLEARVERB
      ECHO PLAYER The device is not on.
    ENDIF
   ENDIF
ENDIF

IFPREVERB PUSH -1
  IFVAR RAC = 7
    IFVAR ITEMBIT0 = 1
      IFVAR BODYPOINTS < 26
        CLEARVERB
        ADD BODYPOINTS 100
        EQUAL ROUNDTIME 10
        ECHO PLAYER You enable your healing routine. System performance enhanced.
        ECHO OTHERS %n's eyes glow brilliantly for a few moments.
      ELSE
        IFVAR BODYPOINTS > 25
          IFVAR BODYPOINTS < 76
            CLEARVERB
            ADD BODYPOINTS 50
            EQUAL ROUNDTIME 10
            ECHO PLAYER You enable your healing routine. System performance enhanced.
            ECHO OTHERS %n's eyes glow brilliantly for a few moments.
          ELSE
            CLEARVERB
            ECHO PLAYER Performace efficiency still above standard levels. No action taken.
          ENDIF
        ENDIF
      ENDIF
    ELSE
      CLEARVERB
      ECHO PLAYER The device is not on.
    ENDIF
  ENDIF
ENDIF

IFVERB RECALL -1
  IFVAR RAC = 7
    ECHO PLAYER %cYou immediately recognize this as a performance-boost device for mechanoids.
  ELSE
    ECHO PLAYER %cYou are not sure what it is, but you are sure it is not for you.
  ENDIF
ENDIF


