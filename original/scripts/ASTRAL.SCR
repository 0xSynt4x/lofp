; Region #50 -- Astral plane
;
REGIONDEF 50 WINTERTEMP 0
REGIONDEF 50 SUMMERTEMP 0
REGIONDEF 50 AUTUMNTEMP 0
REGIONDEF 50 SPRINGTEMP 0
REGIONDEF 50 TELEPORT RESTRICTED
REGIONDEF 50 SUMMONING RESTRICTED
REGIONDEF 50 WELLOFLIFE ALLOWED
REGIONDEF 50 EXTRAPLANAR
REGIONDEF 50 DEPART 2099
VARIABLE BLOWUP
;
; Astral Gate --> in
INUMBER 763
NAME 79
PORTAL
WEIGHT 1000
VOLUME 1000
IFPREVERB GO -1
	CLEARVERB
	DISBAND
	IFVAR WIELDED ! 0
		ECHO PLAYER You may not go through an astral gate while wielding.
	ENDIF
	IFVAR WIELDED = 0
		ECHO PLAYER You step through the gateway and find yourself floating in a surreal starscape. You are tethered by a thin, silver cord.
		ECHO OTHERS %N goes through %a.
		MOVE ITEMVAL2
		AFFECT ITEMVAL2
		ECHO OTHERS %N arrives through %a.
		RECALC
	ENDIF
ENDIF
HALFHIDDEN
;
; Astral Gate --> out
INUMBER 859
NAME 79
PORTAL
WEIGHT 1000
VOLUME 1000
IFPREVERB GO -1
	CLEARVERB
	DISBAND
	IFVAR WIELDED ! 0
		CLEARVERB
		ECHO PLAYER You may not go through an astral gate while wielding.
	ENDIF
	IFVAR WIELDED = 0
		ECHO PLAYER The Astral Plane dissolves behind you as you step through the gateway. You can still feel the slight tug of your silver cord although it is no longer visible.
		ECHO OTHERS %N goes through %a.
		MOVE ITEMVAL2
		AFFECT ITEMVAL2
		ECHO OTHERS %N arrives through %a.
		RECALC
	ENDIF
ENDIF
HALFHIDDEN
;
; Astral Gate --> return to home
INUMBER 860
NAME 79
PORTAL
WEIGHT 1000
VOLUME 1000
IFPREVERB GO -1
	CLEARVERB
	DISBAND
	IFVAR WIELDED ! 0
		CLEARVERB
		ECHO PLAYER You may not go through an astral gate while wielding.
	ENDIF
	IFVAR WIELDED = 0
		ECHO OTHERS %N goes through %a.
		ECHO PLAYER The Astral Plane dissolves behind you as you step through the gateway and return to your home world.
		MOVE ITEMVAL2
		AFFECT ITEMVAL2
		ECHO OTHERS %N arrives through %a.
		RECALC
	ENDIF
ENDIF
HALFHIDDEN
;
MACRO 41
IFPREVERB TARGET -1
	CLEARVERB
	ECHO PLAYER He is too ethereal.
ENDIF
IFVAR BLOWUP > 22
	ECHO ALL An astral guardian flattens into a plane, shrinks into a line, becomes a point and disappears.
	NPCMOVE 50
	AFFECT 50
	ECHO ALL An astral guardian arrives.
ENDIF
MACRO 40
IFPREVERB TARGET -1
	CLEARVERB
	ECHO PLAYER It is too ethereal.
ENDIF
ADD BLOWUP 1
IFVAR BLOWUP < 6
	ECHO ALL The time elemental shimmers.
ENDIF
IFVAR BLOWUP > 5
	IFVAR BLOWUP < 16
		ECHO ALL The time elemental begins to shimmer more intensely.
	ENDIF
ENDIF
IFVAR BLOWUP > 15
	IFVAR BLOWUP < 20
		ECHO ALL The shimmer space that is the time elemental begins to expand.
	ENDIF
ENDIF
IFVAR BLOWUP > 19
	IFVAR BLOWUP < 22
		ECHO ALL The shimmering time elemental expands around you filling your sight with shimmering light.
	ENDIF
ENDIF
IFVAR BLOWUP = 22
	IFVAR BLOWUP < 10
		ECHO ALL You feel the ether heating up prickling your skin with its energy.%cAround you the universe begins to melt.
	ENDIF
ENDIF
IFVAR BLOWUP = 23
	ECHO ALL Space begins to collapse around you.
ENDIF
IFVAR BLOWUP = 24
	KILL ALL
	NPCMOVE 50
	ECHO ALL The astral plane contracts violently. There is a tremendous flash of heat!%c Total cremation! [2000 damage]
	EQUAL DEAD 1
	AFFECT 50
	ECHO ALL A time elemental arrives after a job well done.
	EQUAL BLOWUP 0
ENDIF
;
NUMBER 2098
NAME Astral Plane
CHANNEL 84
REGION 50
ASTRAL
MONSTER_GROUP 90
FIXED_LIGHT
*DESCRIPTION_START
The inky blackness of the Astral Plane stretches out in all directions. The infinity of the place is almost overwhelming, and if not for the surreal stars that twinkle and burn throughout, the sense of vastness might be more than most could take. A flickering gate floats in the ether.
*DESCRIPTION_END
EXIT N 2084
EXIT NE 2085
EXIT E 2082
EXIT SE 2088
EXIT S 2087
EXIT SW 2086
EXIT W 2081
EXIT NW 2083
EXIT D 2090
ITEM 0 860 VAL2=1815 ADJ1=477
ITEM 1 861 ADJ1=292
IFVERB RECALL -1
	ECHO PLAYER You recognize this from your studies with The Fold as the gate back to Andor.
ENDIF
IFPREVERB DROP -1
	CLEARVERB
	IFVAR FLAG1 = 1
		ECHO PLAYER Its probably not a good idea to drop things out here.
	ENDIF
	IFVAR FLAG1 = 0
		ECHO PLAYER As %a leaves your hands it flashes out of existance.
		ECHO OTHERS %N drops %a.%c%A flashes out of existance.
		GMMSG %N just lost %a in the Astral Plane.
		ADD FLAG1 1
	ENDIF
ENDIF
IFPREVERB SIT -1
	CLEARVERB
	ECHO PLAYER You draw up your knees and "sit" in the ether.
	ECHO PLAYER %N draws up %h knees and "sits" in the ether.
	POSITION SIT
ENDIF
IFPREVERB LAY -1
	CLEARVERB
	ECHO PLAYER You stretch out horizonitally in the air.
	ECHO OTHERS %N stretches out horizonitally in the air.
	POSITION LAY
ENDIF
IFPREVERB STAND -1
	CLEARVERB
	ECHO PLAYER You straighten out your form.
	ECHO OTHERS %N straightens out %h form.
	POSITION STAND
ENDIF
;
