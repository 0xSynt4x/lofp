IFPREVERB TURN 3
        CLEARVERB
        ECHO PLAYER Try as you might, you cannot make the sconce turn.
ENDIF
IFPREVERB TURN 4
        CLEARVERB
        IFVAR DAN2311 ! 2
                ECHO PLAYER Try as you might, you cannot make the sconce turn.
        ENDIF
        IFVAR DAN2311 = 2
                ECHO PLAYER The sconce turns easily as you twist it, going around one full time before locking into place.
                ECHO OTHERS %N turns the sconce on the east wall, which moves around in one full circle before stopping.
                ECHO ALL You hear a grinding sound, stone rolling over stone, followed by a clank. The entire east wall seems to shudder.
                EQUAL DAN2311 3
        ENDIF
ENDIF
IFPREVERB TURN 1
        CLEARVERB
        ECHO PLAYER You try to turn the torch, but it doesn't move in that direction.
ENDIF
IFPREVERB TURN 2
        CLEARVERB
        ECHO PLAYER You try to turn the torch, but it doesn't move in that direction.
ENDIF

IFPREVERB PUSH 1
        CLEARVERB
        ECHO PLAYER You push on the torch, which doesn't move much. The sconce it's mounted on seems to move a little, though.
        ECHO OTHERS %N pushes on the torch on the east wall sconce. The torch doesn't budge.
ENDIF

IFPREVERB PUSH 4
        CLEARVERB
        IFVAR DAN2311 ! 0
                ECHO PLAYER It won't budge.
        ENDIF
        IFVAR DAN2311 = 0
                ECHO PLAYER You push on the sconce, which depresses into the wall an inch or two, then slides back out.
                ECHO OTHERS %N pushes on the sconce on the east wall, which depresses into the wall an inch or two, then slides back out.
                EQUAL DAN2311 1
                ECHO ALL You hear a grinding sound, stone rolling over stone.
        ENDIF
ENDIF

IFPREVERB PULL 4
        CLEARVERB
        IFVAR DAN2311 > 1
                ECHO PLAYER It won't budge.
        ENDIF
        IFVAR DAN2311 = 0
                ECHO PLAYER You pull on the sconce, which rattles slightly.
                ECHO OTHERS %N pulls on the sconce on the east wall, which rattles slightly.
        ENDIF
        IFVAR DAN2311 = 1
                ECHO PLAYER You pull on the sconce, which slides out of the wall a few inches, then slides back in.
                ECHO OTHERS %N pulls on the sconce on the east wall, which slides out of the stone a few inches on its mountings, then slides back in.
                ECHO ALL You hear a grinding noise, stone rolling over stone.
                EQUAL DAN2311 2
        ENDIF
ENDIF

