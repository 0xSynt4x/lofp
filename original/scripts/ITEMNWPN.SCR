; slugs for a bullet
INUMBER 839
NAME 624
WEIGHT 1
VOLUME 1
ARTICLE SOME
PLURAL
MISC
CRAFTABLE
SUBSTANCE SOFTMETAL
PARAMETER2 38
IFVERB RECALL -1
  IFVAR ORG = 7
    ECHO PLAYER %cIt looks like this would take the work of a very skilled jeweller to make.
  ENDIF
ENDIF
;
;                          *** NEW ITEM CHANGES ***
;                          ***  Woodlore Items  ***
;
; Bell
INUMBER 973
NAME 781
VOLUME 1
WEIGHT 1
AMMO
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
PARAMETER1 4
IFPREVERB RUB -1
  ECHO PLAYER You give the bell a quick polish.
  ECHO OTHERS %N gives %h small bell a quick polish.
  EQUAL ITEMBIT0 1
  CLEARVERB
ENDIF
IFPREVERB TURN -1
  ECHO PLAYER You carefully turn the bell over in your hands and check the bell for nicks or scratches.
  ECHO OTHERS %N carefully turns %h bell over in %h hands and looks it over for imperfections.
  EQUAL ITEMBIT0 0
  CLEARVERB
ENDIF
IFPREVERB PLAY -1
  CLEARVERB
  ECHO PLAYER A clear and pleasant note chimes from the bell as you jingle it.
  ECHO OTHERS A clear and pleasant note chimes from %N's small bell as %s jingles it.
  EQUAL ROUNDTIME 2
  IFVAR ITEMBIT0 = 1
    ROUTINE 1
    EQUAL ITEMBIT0 0
  ENDIF
ENDIF
