ifvar itembit19 = 1
  ifpreverb touch -1
    clearverb
    strcvt 0 intnum3
    gmmsg &&& %N has an Intnum3 of %0 &&&
    ifvar intnum3 = 0
      echo player You touch the medal!
      echo others %N touch the medal!
      echo all The medal says, "No!"
    else
      echo player You touch the medal!
      echo others %N touch the medal!
      echo all The medal says, "Yes!"
    endif
  endif
endif
