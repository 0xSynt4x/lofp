INUMBER 13
NAME 68
WEIGHT 1
VOLUME 1
PLURAL
ARTICLE SOME
AMMO
CRAFTABLE
SUBSTANCE WOOD
PARAMETER1 5
PARAMETER2 12
IFPREVERB WIELD -1
  IFVAR RNUM = 212
    CLEARVERB
    ECHO PLAYER You hurl a dart at a circle drawn on the wall.
    ECHO OTHERS %N hurls a dart at a circle drawn on the wall.
  ENDIF
ENDIF
;
; I# 1250 : Mortar
INUMBER 1250
NAME 764
WEIGHT 1
VOLUME 2
CRAFTABLE
SHIELD
ENCRUSTABLE
SUBSTANCE HARDMETAL
CONTAINER IN
PARAMETER1 30
IFVERB RECALL -1
  PLREVENT 2
  CONTPLREVENT
  ECHO PLAYER You recall that a mortar is designed to be used along with a pestle and that it cannot be used for much of anything else.
  IFVAR SKILL31 ! 0
    PLREVENT 2
    CONTPLREVENT
    ECHO PLAYER Using your knowledge of alchemy you also recall that there are 3 preparatory items needed plus a stat herb.%cYou need to TAP MORTAR to see what is needed to complete a mixture.%cPUT <item> IN MORTAR and then BREAK MORTAR WITH PESTLE once each for the 1st 3 items, which can be done in any order.%cPUT <stat herb> IN MORTAR, PUT PESTLE IN MORTAR and then TAP MORTAR to make the final creme, it will be in your inventory.
  ENDIF
ENDIF
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ------%cGM Notes: Mortar & Pestle%cWIELD MORTAR (Alchmey 30+ needed), PUT <item> IN MORTAR, BREAK MORTAR WITH PESTLE (1st 3 components only) Components are:
    ECHO PLAYER    Light Mud (Arch=1529, Adj3=181)%c   Babich Blossom/Root (Arch=275/494, Adj3=531)%c   Muur Crystal (Arch=1502, Adj3=1103)%c   4th component is any 1 of the 7 stat herbs.
    ECHO PLAYER Player MUST BREAK(1st-3rd) or PUT PESTLE & TAP(4th) after they PUT <item> before leaving the room or he/she loses the component!!!
    ECHO PLAYER There is a 10%% chance + 2%% per use that the pestle will break on the PUT PESTLE step. ITEMVAL1 of the pestle stores the number of uses that have been made.
    ECHO PLAYER Give yourself at least 1 rank of alchemy (Skill #31) and RECALL to see PC instruction set%c------
  ENDIF
ENDIF
IFPREVERB WIELD -1
  IFVAR SKILL31 < 30
    CLEARVERB
    ECHO PLAYER You lack the alchemical knowledge to use this tool.
  ELSE
    IFCARRY 1251 -1
      ECHO PLAYER You turn %a about in your hands for a moment.
      ECHO OTHERS %N turns %a about in %h hands for a moment.
    ELSE
      CLEARVERB
      ECHO PLAYER You don't think a mortar is useful unless you have a pestle.
    ENDIF
  ENDIF
ENDIF
IFPREVERB2 PUT -1
 IFVAR ROUNDTIME < 1
  IFVAR WIELDED = 1250
    EQUAL FLAG4 1
    IFVAR ARCHNUM = 1251
      CLEARVERB
      EQUAL FLAG4 0
      EQUAL FLAG3 1
      ADD ITEMVAL1 1
      RANDOM DUMMY1 1 50 0
      ADD DUMMY1 ITEMVAL1
      ECHO PLAYER You crush the magical herb up with your pestle, preparing it to be absorbed into the mixture.
      ECHO OTHERS %N crushes the magical herb up with %h pestle, preparing it to be absorbed into the mixture.
      IFVAR DUMMY1 > 45
        ECHO PLAYER %A crumbles away, the magic of the mixture disrupting the bonds holding it together.
        ECHO OTHERS %A crumbles away in %N's hands just as %s finishes crushing the special herb.
        REMOVEITEM -1
      ENDIF
      EQUAL ROUNDTIME 30
      ECHO PLAYER [Round: 30 sec]
    ENDIF
    IFVAR ARCHNUM = 1250
      CLEARVERB
      EQUAL FLAG4 0
      ECHO PLAYER For some reason you don't think %a will fit in %b.
    ENDIF
    IFVAR FLAG4 ! 0
      CLEARVERB
      ECHO PLAYER You place %a into %b and begin crushing it.%c[Round: 5 sec]
      ECHO OTHERS %N places %a into %b and begins crushing it.
      EQUAL ROUNDTIME 5
;  Light Mud (Component 1)
      IFVAR ARCHNUM = 1529
        IFVAR ITEMADJ3 = 181
          EQUAL FLAG1 1
          REMOVEITEM -1
        ENDIF
      ENDIF
; Babich Blossom (Component 2)
      IFVAR ARCHNUM = 275
        IFVAR ITEMADJ3 = 531
          EQUAL FLAG1 2
          REMOVEITEM -1
        ENDIF
      ENDIF
; Babich Root (Component 2)
      IFVAR ARCHNUM = 494
        IFVAR ITEMADJ3 = 531
          EQUAL FLAG1 2
          REMOVEITEM -1
        ENDIF
      ENDIF
; Muur Crystal (Component 3)
      IFVAR ARCHNUM = 1502
        IFVAR ITEMADJ3 = 1103
          EQUAL FLAG1 3
          REMOVEITEM -1
        ENDIF
      ENDIF
; Yarrow Lichen (Component 4) Spell # 327 Constitution
      IFVAR ARCHNUM = 328
        IFVAR ITEMADJ3 = 569
          EQUAL FLAG2 327
          REMOVEITEM -1
        ENDIF
      ENDIF
; Quillim Fruit (Component 4) Spell # 328 Agility
      IFVAR ARCHNUM = 416
        IFVAR ITEMADJ3 = 570
          EQUAL FLAG2 328
          REMOVEITEM -1
        ENDIF
      ENDIF
; Malatrin Leaf (Component 4) Spell # 329 Strength
      IFVAR ARCHNUM = 278
        IFVAR ITEMADJ3 = 571
          EQUAL FLAG2 329
          REMOVEITEM -1
        ENDIF
      ENDIF
; Shay-ahm Blossoms (Component 4) Spell # 330 Quickness
      IFVAR ARCHNUM = 275
        IFVAR ITEMADJ3 = 572
          EQUAL FLAG2 330
          REMOVEITEM -1
        ENDIF
      ENDIF
; Zarus Stem (Component 4) Spell # 331 Perception
      IFVAR ARCHNUM = 590
        IFVAR ITEMADJ3 = 573
          EQUAL FLAG2 331
          REMOVEITEM -1
        ENDIF
      ENDIF
; Coriam Seed (Component 4) Spell # 332 Empathy
      IFVAR ARCHNUM = 591
        IFVAR ITEMADJ3 = 574
          EQUAL FLAG2 332
          REMOVEITEM -1
        ENDIF
      ENDIF
; Kurkan Pollen (Component 4) Spell # 333 Willpower
      IFVAR ARCHNUM = 592
        IFVAR ITEMADJ3 = 575
          EQUAL FLAG2 333
          REMOVEITEM -1
        ENDIF
      ENDIF
      IFVAR FLAG1 = 0
        IFVAR FLAG2 = 0
          ECHO PLAYER Almost immediately you realize it is not right for the mixture and carefully remove the scraps, tossing them aside.
          ECHO OTHERS Almost immediately %s removes the remnants of it before they mix in and tosses them aside.
          REMOVEITEM -1
        ENDIF
      ENDIF
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You need to have the mortar in your hand to use it properly.
  ENDIF
 ELSE
   CLEARVERB
   STRCVT 0 ROUNDTIME
   ECHO PLAYER [Wait %0 seconds...]
 ENDIF
ENDIF
IFPREVERB TAP -1
  CLEARVERB
  IFVAR ITEMBIT4 = 1
    IFVAR FLAG3 = 0
      IFVAR FLAG2 ! 0
        ECHO PLAYER You need to crush the stat herb into the mixture to complete the creme first. [PUT PESTLE IN MORTAR]
      ELSE
        ECHO PLAYER You have not yet placed a stat herb into the mixture so it is safe to travel.
      ENDIF
    ENDIF
    IFVAR FLAG3 = 1
      IFVAR FLAG2 = 327
        EQUAL ITEMBIT4 0
        NEWITEM -1 323 ADJ1=569 VAL2=1 VAL3=327
      ENDIF
      IFVAR FLAG2 = 328
        EQUAL ITEMBIT4 0
        NEWITEM -1 323 ADJ1=570 VAL2=1 VAL3=328
      ENDIF
      IFVAR FLAG2 = 329
        EQUAL ITEMBIT4 0
        NEWITEM -1 323 ADJ1=571 VAL2=1 VAL3=329
      ENDIF
      IFVAR FLAG2 = 330
        EQUAL ITEMBIT4 0
        NEWITEM -1 323 ADJ1=572 VAL2=1 VAL3=330
      ENDIF
      IFVAR FLAG2 = 331
        EQUAL ITEMBIT4 0
        NEWITEM -1 323 ADJ1=573 VAL2=1 VAL3=331
      ENDIF
      IFVAR FLAG2 = 332
        EQUAL ITEMBIT4 0
        NEWITEM -1 323 ADJ1=574 VAL2=1 VAL3=332
      ENDIF
      IFVAR FLAG2 = 333
        EQUAL ITEMBIT4 0
        NEWITEM -1 323 ADJ1=575 VAL2=1 VAL3=333
      ENDIF
      EQUAL FLAG2 0
      IFVAR ITEMBIT4 = 0
        ECHO PLAYER Your labors are complete and you now have a single dose of a fine creme as a result.
        IFVAR INTNUM15 < 32760
          IFVAR LEV < 40
            ADD INTNUM15 2
            GMMSG Exp added, level 1
          ELSE
            IFVAR LEV > 200
              ADD INTNUM15 8
              GMMSG Exp added, level 3
            ELSE
              IFVAR LEV > 39
                ADD INTNUM15 5
                GMMSG Exp added, level 2
              ENDIF
            ENDIF
          ENDIF    
        ENDIF      
      ENDIF
    ENDIF
  ELSE
    IFVAR ITEMBIT1 = 0
      ECHO PLAYER The mix needs some kind of earthy creme-like substance.
    ENDIF
    IFVAR ITEMBIT2 = 0
      ECHO PLAYER The mix needs one of two common plant-substances with healing properties.
    ENDIF
    IFVAR ITEMBIT3 = 0
      ECHO PLAYER The mix needs a crystaline substance with body-affecting properties.
    ENDIF
    IFVAR FLAG2 > 326
      IFVAR FLAG3 < 334
        ECHO PLAYER -----%cYou have prepared the mixture with a stat herb, any motion will destroy the mixture and you will need to use a new master component.%c-----
      ELSE
        ECHO PLAYER You have not yet placed a stat herb into the mixture so it is safe to travel.
      ENDIF
    ELSE
      ECHO PLAYER You have not yet placed a stat herb into the mixture so it is safe to travel.
    ENDIF
  ENDIF
ENDIF
;
; I# 1251 : Pestle
INUMBER 1251
NAME 765
WEIGHT 1
VOLUME 2
MISC
CRAFTABLE
ENCRUSTABLE
SUBSTANCE HARDMETAL
PARAMETER2 30
IFVAR ITEMADJ3 = 180
  ECHO ALL %A falls apart, unable to maintain its shape.
  REMOVEITEM -1
ENDIF
IFVERB RECALL -1
  PLREVENT 2
  CONTPLREVENT
  ECHO PLAYER You recall that a pestle is designed to be used along with a mortar, it cannot be used for much of anything else.
ENDIF
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER -----%cGM Notes: Mortar & Pestle%cAdd item 1250 and LOOK at it for complete instructions.%c-----
  ENDIF
ENDIF
IFPREVERB2 BREAK -1
  IFVAR ARCHNUM = 1250
    CLEARVERB
    ECHO PLAYER You grind your pestle into the mortar completely mashing the contents.
    ECHO OTHERS %N puts %b into %a and mashes whatever it contains for a while.
    EQUAL ROUNDTIME 15
    IFVAR FLAG1 = 0
      ECHO PLAYER [Round: 15 sec]
    ENDIF
    IFVAR FLAG1 = 1
      EQUAL ITEMBIT1 1
      EQUAL FLAG1 0
      ECHO PLAYER The light mud you placed into the mortar smoothes out into a creamy substance, all the impurities crumbled up into the mix.%c[Round: 15 sec]
    ENDIF
    IFVAR FLAG1 = 2
      EQUAL ITEMBIT2 1
      EQUAL FLAG1 0
      ECHO PLAYER The juice and flesh of the babich piece mash up into small pieces of pulp and juice for the mixture.%c[Round: 15 sec]
    ENDIF
    IFVAR FLAG1 = 3
      EQUAL ITEMBIT3 1
      EQUAL FLAG1 0
      ECHO PLAYER The muur crystal smashes into a very fine powder to add to the mixture.%c[Round: 15 sec]
    ENDIF
    IFVAR ITEMBIT3 = 1
      IFVAR ITEMBIT2 = 1
        IFVAR ITEMBIT1 = 1
          EQUAL ITEMBIT4 1
          EQUAL ITEMBIT1 0
          EQUAL ITEMBIT2 0
          EQUAL ITEMBIT3 0
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
;
