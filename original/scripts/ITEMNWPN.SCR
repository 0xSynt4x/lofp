; Craftable Items - Woodlore
;
; I# 1155 : Whistle
INUMBER 1155
NAME 642
VOLUME 1
WEIGHT 1
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
BOW_WEAPON
PARAMETER1 7
IFPREVERB PLAY -1
  CLEARVERB
  IFITEM -1 WIELDED
    ECHO PLAYER You let loose a piercing whistle with %a.
    ECHO OTHERS %N lets loose a piercing whistle with %a.
    EQUAL ROUNDTIME 2
  ELSE
    ECHO PLAYER Don't you think having it in your hands might help?
  ENDIF
ENDIF
;
; I# 969 : Chime
INUMBER 969
NAME 777
WEIGHT 1
VOLUME 2
AMMO
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
PARAMETER1 8
IFPREVERB POINT -1
  ECHO PLAYER You proudly display your gleaming chime.
  ECHO OTHERS %N proudly displays his gleaming chime.
  EQUAL ITEMBIT0 1
  CLEARVERB
ENDIF
IFPREVERB RUB -1
  ECHO OTHERS %N polishes the chime, bringing it to high lustre.
  ECHO PLAYER You polish the chime, brining it to high lustre.
  EQUAL ITEMBIT0 0
  CLEARVERB
ENDIF
IFPREVERB PLAY -1
  CLEARVERB
  ECHO PLAYER You strike the chime smartly and it reverberates with a strong pure tone.
  ECHO OTHERS %N stikes the chime smartly and it reverberates with a strong pure tone.
  EQUAL ROUNDTIME 2
  IFVAR ITEMBIT0 = 1
    ROUTINE 1
    EQUAL ITEMBIT0 0
  ENDIF
ENDIF
;
; I# 631 : Flute
INUMBER 631
NAME 620
WEIGHT 5
VOLUME 2
CRAFTABLE
ENCRUSTABLE
;SUBSTANCE INDESTRUCTABLE
SUBSTANCE WOOD
;CRUSH_WEAPON
BOW_WEAPON
PARAMETER1 10
IFPREVERB PLAY -1
  CLEARVERB
  IFITEM -1 WIELDED
    ECHO PLAYER You play the flute with expert skill, producing a lovely tune.
    ECHO OTHERS %N plays %a with expert skill, producing a lovely tune.
    EQUAL ROUNDTIME 2
  ELSE
    ECHO PLAYER Don't you think having it in your hands might help?
  ENDIF
ENDIF
;
; I# 971 : Trumpet
INUMBER 971
NAME 779
WEIGHT 2
VOLUME 2
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
BOW_WEAPON
PARAMETER1 11
IFPREVERB POINT -1
 ECHO PLAYER You brandish the brilliant trumpet with a flourish!
 ECHO OTHERS %N brandishes %h brilliant trumpet with a flourish!
 EQUAL ITEMBIT0 1
 CLEARVERB
ENDIF
IFPREVERB RUB -1
 ECHO PLAYER You restore the trumpet's brilliant shine with a quick buffing.
 ECHO OTHERS %N restores %h trumpet's brilliant shine with a quick buffing.
 EQUAL ITEMBIT0 0
 CLEARVERB
ENDIF
IFPREVERB PLAY -1
  CLEARVERB
  IFITEM -1 WIELDED
    ECHO PLAYER A glorious peal of triumphant sound rings forth from the trumpet as you play it.
    ECHO OTHERS A glorious peal of triumphant sound rings forth from %N's trumpet as %s plays it.
    EQUAL ROUNDTIME 2
    IFVAR ITEMBIT0 = 1
      ROUTINE 2
      EQUAL ITEMBIT0 0
    ENDIF
  ELSE
    ECHO PLAYER Don't you think having it in your hands might help?
  ENDIF
ENDIF
;
; I# 822 : Tambourine
INUMBER 822
NAME 699
WEIGHT 1
VOLUME 3
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
BOW_WEAPON
PARAMETER1 14
IFPREVERB LOOK -1
  ECHO PLAYER The tambourine is made from carefully tanned hide stretched across a polished metal frame with cymbals hammered to parchment thickness. Colorful ribbons tied all around it give the tambourine a festive air.%c
ENDIF
IFPREVERB TAP -1
  CLEARVERB
  ECHO OTHERS The tambourine gives a sharp but melodious jingle when %n strikes it.
  ECHO PLAYER The tambourine gives a sharp but melodious jingle when you strike it.
  EQUAL ROUNDTIME 1
ENDIF
IFPREVERB RUB -1
  CLEARVERB
  ECHO OTHERS The tambourine jingles faintly as %n rubs it.
  ECHO PLAYER The tambourine jingles faintly as you rub it.
ENDIF
IFPREVERB RAP -1
  CLEARVERB
  ECHO PLAYER The tiny cymbals of the tabourine crash sharply but delicately as you rap on it.
  ECHO OTHERS The tiny cymbals of the tambourine crash sharply but delicately as %n raps on it.
;  ROUTINE 2
  EQUAL ROUNDTIME 1
ENDIF
;
; I# 970 : Harmonica
INUMBER  970
NAME 778
VOLUME 1
WEIGHT 1
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
BOW_WEAPON
PARAMETER1 18
IFPREVERB TOUCH -1
  CLEARVERB
  ECHO PLAYER You run your finger across the engraved front of the harmonica.
  ECHO OTHERS %N runs %h finger across the engraved front of %h harmonica.
  EQUAL ITEMBIT0 1
ENDIF
IFPREVERB RUB -1
  CLEARVERB
  ECHO PLAYER You rub the harmonica with a soft cloth, making it gleam.
  ECHO OTHERS %N rubs the harmonica with a soft cloth, making it gleam.
  EQUAL ITEMBIT0 0
ENDIF
IFPREVERB PLAY -1
  CLEARVERB
  IFITEM -1 WIELDED
    ECHO PLAYER You play a low, soothing melody on the harmonica, each long note soulful and sweet.
    ECHO OTHERS %N plays a low, soothing melody on %h harmonica, each long note soulful and sweet.
    EQUAL ROUNDTIME 2
    IFVAR ITEMBIT0 = 1
      ROUTINE 1
      EQUAL ITEMBIT0 0
    ENDIF
  ELSE
    ECHO PLAYER Don't you think having it in your hands might help?
  ENDIF
ENDIF
