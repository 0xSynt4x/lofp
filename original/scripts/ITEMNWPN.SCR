IFPREVERB REMOVE -1
  CLEARVERB
  IFVAR ITEMVAL2 = 0
    ECHO PLAYER It's not in your pocket right now.
  ENDIF
  IFVAR ITEMVAL2 = 1
    EQUAL ITEMVAL2 0
    ECHO PLAYER You take %a out of your breast pocket.
    ECHO OTHERS %N takes %a out of %h breast pocket.
  ENDIF
ENDIF
IFPREVERB WAVE -1
  CLEARVERB
  IFVAR ITEMVAL2 = 1
    ECHO PLAYER You'll have to remove it from your pocket first.
  ENDIF
  IFVAR ITEMVAL2 = 0
    ECHO PLAYER You swing %a around in a wide circle.
    ECHO OTHERS %N swings %a around in a wide circle.
  ENDIF
ENDIF
IFPREVERB OPEN -1
  CLEARVERB
  IFVAR ITEMVAL2 = 1
    ECHO PLAYER You'll have to remove it from your pocket first.
  ENDIF
  IFVAR ITEMVAL2 = 0
    IFVAR ITEMVAL5 = 1
      ECHO PLAYER It's already open.
    ENDIF
    IFVAR ITEMVAL5 = 0
      ECHO PLAYER You push a button on the top of %a and it snaps open.
      ECHO OTHERS %N pushes a button on the top of %a and it snaps open.
      EQUAL ITEMVAL5 1
    ENDIF
  ENDIF
ENDIF
IFPREVERB CLOSE -1
  CLEARVERB
  IFVAR ITEMVAL2 = 1
    ECHO PLAYER You'll have to remove it from your pocket first.
  ENDIF
  IFVAR ITEMVAL2 = 0
    IFVAR ITEMVAL5 = 0
      ECHO PLAYER It's already closed.
    ENDIF
    IFVAR ITEMVAL5 = 1
      ECHO PLAYER You push %a closed with a click.
      ECHO OTHERS %N pushes %a closed with a click.
      EQUAL ITEMVAL5 0
    ENDIF
  ENDIF
ENDIF
IFPREVERB READ -1
  CLEARVERB
  IFVAR ITEMVAL2 = 1
    ECHO PLAYER You'll have to remove it from your pocket first.
  ENDIF
  IFVAR ITEMVAL2 = 0
    IFVAR ITEMVAL5 = 0
      ECHO PLAYER It's closed, so you can't see the face.
    ENDIF
    IFVAR ITEMVAL5 = 1
      ECHO OTHERS %N checks the time on %a.
      EQUAL ITEMVAL3 TIM
      MOD ITEMVAL3 12
      IFVAR ITEMVAL3 = 0
        EQUAL ITEMVAL3 12
      ENDIF
      STRCVT 0 ITEMVAL3
      IFVAR TIM < 12
        ECHO PLAYER It's about %0 am.
      ENDIF
      IFVAR TIM > 11
        ECHO PLAYER It's about %0 pm.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB GET -1
  EQUAL ITEMVAL2 0
ENDIF
;
; Monocle
INUMBER 364
NAME 96
VARIABLE MONOCLEVAL
WEIGHT 1
VOLUME 3
INTERIOR 20
ARTICLE A
CONTAINER UNDER
MISC
DYEABLE
CRAFTABLE
ENCRUSTABLE
SUBSTANCE HARDMETAL
;SUBSTANCE BRITTLE
WORN_DON
PARAMETER2 35
IFPREVERB2 PUT -1
  IFVAR ARCHNUM ! 364
    CLEARVERB
    IFVAR ARCHNUM > 98
      IFVAR ARCHNUM < 158
        ECHO PLAYER You carefully scrutinize %a through your monocle.
        ECHO OTHERS %N carefully scrutinizes %a through %h monocle.
        EQUAL MONOCLEVAL ITEMVAL1
        DIV MONOCLEVAL 16000
        IFVAR MONOCLEVAL ! 0
          ECHO PLAYER The gem is worth no less than 80 gold coins and could be worth alot more.
        ENDIF
        IFVAR MONOCLEVAL = 0
          EQUAL MONOCLEVAL ITEMVAL1
          DIV MONOCLEVAL 200
          STRCVT 0 MONOCLEVAL
          ECHO PLAYER You estimate its worth at about %0 gold coins.
          ECHO PLAYER [Round: 5 secs]
          EQUAL ROUNDTIME 5
        ENDIF
        EQUAL MONOCLEVAL 0
      ELSE
        ECHO PLAYER Your monocle can only appraise gems and jewelry.
      ENDIF
    ELSE
      ECHO PLAYER Your monocle can only appraise gems and jewelry.
    ENDIF
  ENDIF
ENDIF
