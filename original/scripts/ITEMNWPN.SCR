;
; I# 1755 : Flashlight
INUMBER 1755
NAME 587
CRUSH_WEAPON
WEIGHT 2
VOLUME 3
PARAMETER1 2
SUBSTANCE SOFTMETAL
LIGHTABLE
TECH
IFPREVERB LIGHT -1
  IFVAR RNUM > 1899
    IFVAR RNUM < 2000
      EQUAL DANTEMP 1
    ENDIF
  ENDIF
  IFVAR DANTEMP = 0
    IFVAR ORG ! 7
      IFVAR RAC ! 7
        CLEARVERB
        ECHO PLAYER Huh?  How?
        ECHO OTHERS %N fiddles with %a, rattles it, and generally accomplishes nothing.
      ENDIF
    ENDIF
    IFVAR ORG = 7
      ECHO PLAYER You push the recessed switch set into the flashlight. Click!
      ECHO OTHERS %N pushes %h thumb along one part of %a.
      EQUAL FLAG1 1
    ENDIF
    IFVAR RAC = 7
      IFVAR FLAG1 = 0
        ECHO PLAYER You push the recessed switch set into the flashlight. Click!
        ECHO OTHERS %N pushes %h thumb along one part of %a.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFVERB LIGHT -1
  EQUAL ITEMADJ1 -1
ENDIF
IFPREVERB EXTINGUISH -1
  IFVAR RNUM > 1899
    IFVAR RNUM < 2000
      EQUAL DANTEMP 1
    ENDIF
  ENDIF
  IFVAR DANTEMP = 0
    IFVAR ORG ! 7
      IFVAR RAC ! 7
        CLEARVERB
        ECHO PLAYER Huh?  How?
        ECHO OTHERS %N fiddles with %a, rattles it, and generally accomplishes nothing.
      ENDIF
    ENDIF
    IFVAR ORG = 7
      ECHO PLAYER You push the recessed switch set into the flashlight. Click!
      ECHO OTHERS %N pushes %h thumb along one part of %a.
      EQUAL FLAG1 1
    ENDIF
    IFVAR RAC = 7
      IFVAR FLAG1 = 0
        ECHO PLAYER You push the recessed switch set into the flashlight. Click!
        ECHO OTHERS %N pushes %h thumb along one part of %a.
      ENDIF
    ENDIF
  ENDIF
  EQUAL DANTEMP 0
ENDIF
IFVAR ITEMBIT1 = 1
  IFVAR ITEMVAL2 ! 0
    ECHO ALL The dweamor set upon %a is driven out by the item's harsh, technological nature.
    EQUAL ITEMADJ1 -1
    EQUAL ITEMVAL2 0
    EQUAL ITEMBIT1 0
  ENDIF
ENDIF
IFVAR ITEMVAL2 ! 0
  EQUAL ITEMBIT1 1
ENDIF
;
; I# 567 : Crystal Heart
INUMBER 567
NAME 904
WEIGHT 10
VOLUME 3
IFVAR ITEMADJ3 ! 77
  EQUAL ITEMADJ3 77
ENDIF
IFVAR ITEMVAL2 ! 6
  EQUAL ITEMVAL2 6
ENDIF
IFPREVERB LOOK -1
  CLEARVERB
  ECHO PLAYER You see a rounded lump of blue-white crystal matter which glimmers faintly
  ECHO PLAYER with a unique luminescence. It is about the same size as both of your fists
  ECHO PLAYER held together, and nearly the same shape. Within its substance, you notice,
  ECHO PLAYER there are channels... veins and arteries, you suppose. These channels, or
  ECHO PLAYER the clear fluid within them, are the source of the heart's glow.
ENDIF
IFPREVERB EAT -1
  CLEARVERB
  ECHO PLAYER Perhaps drinking out of it would be a better idea... you can't chew crystal.
ENDIF
IFPREVERB DRINK -1
  CLEARVERB
  ECHO OTHERS %N tips back %h head, drinking deeply from %a.
  ECHO PLAYER You tip back your head, drinking the clear fluid from within the heart.
  IFVAR DANHEART ! TIM
    EQUAL DANHEART TIM
    SPELL 105 50
  ENDIF
ENDIF
IFPREVERB PUSH -1
  CLEARVERB
  ECHO PLAYER You gently push the heart, causing it to throb.
  ECHO OTHERS %A throbs.
ENDIF
IFPREVERB OPEN -1
  CLEARVERB
  RANDOM DUMMY1 1 500 100
  STRCVT 0 DUMMY1
  STRCVT 1 STR
  ECHO PLAYER You try to pry the heart open.
  IFVAR DUMMY1 > STR
    ECHO PLAYER [Strength: %1, Roll: %0] You nearly shatter the heart, but you aren't quite strong enough.
    ECHO OTHERS %N tries to pry %a apart.
  ENDIF
  IFVAR DUMMY1 <= STR
    ECHO PLAYER [Strength: %1, Roll: %0] Success! The heart is shattered into a million tiny pieces!
    ECHO OTHERS %N pries open %a, shattering it into a million tiny pieces!
    APPEAR %S seems to be covered in a thin layer of clear, oily fluid.
    REMOVEITEM -1
  ENDIF
ENDIF
IFPREVERB GAZE -1
  CLEARVERB
  ECHO PLAYER You gaze into the crystalline structure of the heart.
  ECHO OTHERS %N gazes deep into the crystalline structure of %a.
ENDIF
IFPREVERB TURN -1
  CLEARVERB
  ECHO PLAYER You turn the heart over in your hands wonderingly.
  ECHO OTHERS %N turns %a over in %h hands wonderingly.
ENDIF
IFPREVERB DESTROY -1
  CLEARVERB
  ECHO PLAYER You notice that the crystalline structure of the heart is nearly impervious to any assault from the outside. Perhaps if you tried to pry it open...
ENDIF
