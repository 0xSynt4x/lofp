;
; Scepter
INUMBER 145
NAME 178
WEIGHT 1
VOLUME 8
MISC
CRAFTABLE
ENCRUSTABLE
PARAMETER2 15
SUBSTANCE HARDMETAL
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER If ITEMBIT1 is set to 1 it is a magical scepter of spider powers
  ENDIF
ENDIF
IFPREVERB RUB -1
  IFVAR ITEMBIT1 = 1
    CLEARVERB
    ECHO PLAYER You scrape your fingers along the shaft of the sceptre.
    ECHO PLAYER A stream of colored lights bursts out of the top of it.
    ECHO OTHERS %N lightly rubs %h sceptre.
    SPELL 505 30
  ENDIF
ENDIF
IFPREVERB WAVE -1
  IFVAR ITEMBIT1 = 1
    EQUAL SPELLNUM 127
    ECHO PLAYER The power of the Web spell floods into you.
    EQUAL ROUNDTIME 1
  ENDIF
ENDIF
IFPREVERB CONCENTRATE -1
  IFVAR ITEMBIT1 = 1
    CLEARVERB
    IFVAR ITEMVAL1 = TIM
      ECHO PLAYER The sceptre can create no spiders right now.
    ELSE
      EQUAL ITEMVAL1 TIM
      RANDOM DUMMY1 1 3 0
      IFVAR DUMMY1 = 1
        ECHO PLAYER Success! The sceptre has created a spider.
        ECHO OTHERS Something shimmers into existence at %N's feet. It is starting to grow!
        GENMON 20
      ENDIF
      IFVAR DUMMY1 = 2
        ECHO PLAYER Success! The sceptre has created a spider.
        ECHO OTHERS Something shimmers into existence at %N's feet. It is starting to grow!
        GENMON 94
      ENDIF
      IFVAR DUMMY1 = 3
        ECHO PLAYER Success! The sceptre has created a spider.
        ECHO OTHERS Something shimmers into existence at %N's feet. It is starting to grow!
        GENMON 207
      ENDIF
    ENDIF
  ENDIF
ENDIF
