;
; I# 299 : Lyre
INUMBER 299
NAME 654
WEIGHT 2
VOLUME 1
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
TURNABLE
BOW_WEAPON
WORN_DON
PARAMETER1 27
IFPREVERB PLAY -1
  CLEARVERB
  IFITEM -1 WIELDED
    IFVAR ITEMVAL1 = 0
      EQUAL ITEMVAL1 1
    ENDIF
    IFVAR ITEMVAL1 = 1
      ECHO PLAYER You begin to play a mournful melody. The notes swell and drop as you weave the dirge. Sadness seems to ooze right out of your fingers.
      ECHO OTHERS %N beings to play %h lyre. The somber notes of a beautifully played dirge reach your ears. The air fills with sadness.
    ENDIF
    IFVAR ITEMVAL1 = 2
      ECHO PLAYER You pluck out a fast-paced jig on your lyre. Your fingers blur and your feet begin to tap. This music is perfect for dancing.
      ECHO OTHERS Fast paced dancing music erupts from %N. %s is playing a jig on %h lyre. Unconciously, your feet begin to tap.
    ENDIF
    IFVAR ITEMVAL1 = 3
      ECHO PLAYER You play a long and storied ballad on your lyre. You sing to it as well, telling a story of a time long gone by.
      ECHO OTHERS %N sings and old ballad and plays accompaniment on %h lyre. It is a story of history and heroism from times long since past.
    ENDIF
    IFVAR ITEMVAL1 = 4
      ECHO PLAYER You strum your lyre, playing mostly chords and not much melody. The affect creates calming background music for you and those around you.
      ECHO OTHERS %N strums %h lyre. Playing calming background music. It is very relaxing.
    ENDIF
    IFVAR ITEMVAL1 = 5
      ECHO PLAYER You play a grand tune on your lyre. Focusing heavily on the downbeats and playing long notes, you weave a rousing tune worthy of royalty.
      ECHO OTHERS %N plays a grand and rousing tune on %h lyre. It reminds you of procession music and you instinctively look around for someone with a title.
    ENDIF
  ELSE
    ECHO PLAYER Don't you think having it in your hands might help?
  ENDIF
ENDIF
IFPREVERB CONCENTRATE -1
  CLEARVERB
  ADD ITEMVAL1 1
  IFVAR ITEMVAL1 = 6
    EQUAL ITEMVAL1 1
  ENDIF
  IFVAR ITEMVAL1 = 1
    ECHO PLAYER You prepare to play a somber dirge.
  ENDIF
  IFVAR ITEMVAL1 = 2
    ECHO PLAYER You prepare to play an upbeat jig.
  ENDIF
  IFVAR ITEMVAL1 = 3
    ECHO PLAYER You prepare to play a long ballad of olde.
  ENDIF
  IFVAR ITEMVAL1 = 4
    ECHO PLAYER You prepare to play some relaxing background music.
  ENDIF
  IFVAR ITEMVAL1 = 5
    ECHO PLAYER You prepare to play a grand melody.
  ENDIF
ENDIF
IFPREVERB TURN -1
  CLEARVERB
  ECHO PLAYER You take great care to tune your lyre.
  ECHO OTHERS %N turns some knobs, attempting to capture perfect pitch.
ENDIF
IFPREVERB RUB -1
  CLEARVERB
  ECHO PLAYER You polish the wood part of your lyre.
  ECHO OTHERS %N polishes %h lyre.
ENDIF
IFPREVERB PULL -1
  CLEARVERB
  IFITEM -1 WIELDED
    ECHO PLAYER You pluck out one single note on the lyre.
    ECHO OTHERS Twang! %N plucks a lyre string.
  ELSE
    ECHO PLAYER Don't you think having it in your hands might help?
  ENDIF
ENDIF
;
; I# 968 : Harp
INUMBER 968
NAME 776
VOLUME 3
WEIGHT 3
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
BOW_WEAPON
WORN_DON
PARAMETER1 30
IFPREVERB PLAY -1
  CLEARVERB
  IFITEM -1 WIELDED
    IFVAR ITEMVAL1 = 0
      EQUAL ITEMVAL1 1
    ENDIF
    IFVAR ITEMBIT0 = 1
      ROUTINE 2
      EQUAL ITEMBIT0 0
    ENDIF
    IFVAR ITEMVAL1 = 1
      ECHO PLAYER You begin to play a mournful melody. The notes swell and drop as you weave the dirge. Sadness seems to ooze right out of your fingers.
      ECHO OTHERS %N beings to play %h harp. The somber notes of a beautifully played dirge reach your ears. The air fills with sadness.
    ENDIF
    IFVAR ITEMVAL1 = 2
      ECHO PLAYER You pluck out a fast-paced jig on your harp. Your fingers blur and your feet begin to tap. This music is perfect for dancing.
      ECHO OTHERS Fast paced dancing music erupts from %N. %s is playing a jig on %h harp. Unconciously, your feet begin to tap.
    ENDIF
    IFVAR ITEMVAL1 = 3
      ECHO PLAYER You play a long and storied ballad on your harp. You sing to it as well, telling a story of a time long gone by.
      ECHO OTHERS %N sings and old ballad and plays accompaniment on %h harp. It is a story of history and heroism from times long since past.
    ENDIF
    IFVAR ITEMVAL1 = 4
      ECHO PLAYER You strum your harp, playing mostly chords and not much melody. The affect creates calming background music for you and those around you.
      ECHO OTHERS %N strums %h harp. Playing calming background music. It is very relaxing.
    ENDIF
    IFVAR ITEMVAL1 = 5
      ECHO PLAYER You play a grand tune on your harp. Focusing heavily on the downbeats and playing long notes, you weave a rousing tune worthy of royalty.
      ECHO OTHERS %N plays a grand and rousing tune on %h harp. It reminds you of procession music and you instinctively look around for someone with a title.
    ENDIF
  ELSE
    ECHO PLAYER Don't you think having it in your hands might help?
  ENDIF
ENDIF
IFPREVERB CONCENTRATE -1
  CLEARVERB
  ADD ITEMVAL1 1
  IFVAR ITEMVAL1 = 6
    EQUAL ITEMVAL1 1
  ENDIF
  IFVAR ITEMVAL1 = 1
    ECHO PLAYER You prepare to play a somber dirge.
  ENDIF
  IFVAR ITEMVAL1 = 2
    ECHO PLAYER You prepare to play an upbeat jig.
  ENDIF
  IFVAR ITEMVAL1 = 3
    ECHO PLAYER You prepare to play a long ballad of olde.
  ENDIF
  IFVAR ITEMVAL1 = 4
    ECHO PLAYER You prepare to play some relaxing background music.
  ENDIF
  IFVAR ITEMVAL1 = 5
    ECHO PLAYER You prepare to play a grand melody.
  ENDIF
ENDIF
IFPREVERB POINT -1
  ECHO PLAYER You carefully inspect the harp, ensuring it is in tune.
  ECHO OTHERS %N carefully inspects the harp to be sure it is in tune.
  EQUAL ITEMBIT0 1
  CLEARVERB
ENDIF
IFPREVERB RUB -1
  ECHO PLAYER You carfully polish the harp, bringing out the rich tones and highlights in the wood.
  ECHO OTHERS %N carefully polishes the harp, bringing out the rich tones and highlights in the wood.
  EQUAL ITEMBIT0 0
  CLEARVERB
ENDIF
;
; Craftable Items - Weaponsmith
;
; I# 959 : Crucible
INUMBER 959
NAME 1582
PARAMETER1 51
WEIGHT 50
VOLUME 8
THROWN_WEAPON
CRAFTABLE
ENCRUSTABLE
SUBSTANCE HARDMETAL
CONTAINER IN
INTERIOR 3
OPENABLE
LATCHABLE
LIGHTABLE
*DESCRIPTION_START
This large metal vessel is built to withstand the intensity of high heat. The lid seals tightly allowing only a glimpse of the interior through the tiny crystal port set into its face. A small nozzle underneath the container itself allows gas to be lit to quickly heat the vessel and its contents.
*DESCRIPTION_END
IFPREVERB WIELD -1
  CLEARVERB
  ECHO PLAYER You heft %a above your head for a moment, but it is too awkward to use for a weapon.
  ECHO OTHERS %n hefts %a above %h head for a moment, then drops it back down with a grunt.
ENDIF
IFPREVERB BREAK -1
  ECHO ALL You damage the crucible and then light it, allowing the heat from the burning gas to melt it.
  REMOVEITEM -1
ENDIF
IFPREVERB2 PUT -1
  IFVAR ARCHNUM ! 1370
    CLEARVERB
    ECHO PLAYER You attempt to put %a in the crucible, but find that it will not fit in the interior designed specifically for a bar of metal.
    ECHO OTHERS %n fiddles with %a and a crucible confusedly.
  ELSE
    EQUAL FLAG3 ITEMVAL2
  ENDIF
ENDIF
IFVERB LIGHT -1
  ECHO ALL The gas jet attachment ignites rapidly, burning with an intense flame.
  add itemval5 1
  IFVAR itemval5 > 32
    ECHO ALL The heat from many uses of the crucible melts its metal surface!
    REMOVEITEM -1
    ECHO ALL The melted metal rapidly liquifies into a shiny pool!
    NEWITEM 9 324
    setitemadj 9 3 FLAG4
  else
    EQUAL ROUNDTIME 30
    EQUAL FLAG4 ITEMADJ3
    IFITEM -1 OPEN
      ECHO PLAYER Lighting the open crucible causing a huge blast of heat to erupt from within!
      DAMAGEPLR BURN 40 You are singed by the heat!
      ECHO OTHERS A huge gout of heat blasts %n from the open crucible!
    ENDIF
    IFVAR ITEMADJ3 ! 893
      ECHO ALL The heat from the burning gas melts the non-refractory metal of the crucible!
      REMOVEITEM -1
      ECHO ALL The melted metal rapidly liquifies into a shiny pool!
      NEWITEM 9 324
      setitemadj 9 3 FLAG4
    ELSE
      PLREVENT 2
      CONTPLREVENT
      IFVAR FLAG3  > 0
        ECHO ALL A purple glow shows through the lid of the crucible.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 5
        ECHO ALL The hue of the glow changes to a deep indigo color.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 10
        ECHO ALL The glow from the heated metal lightens further to a faint blue.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 15
        ECHO ALL The glowing metal within the crucible changes to an aqua hue.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 20
        ECHO ALL The light from within the crucible is almost pure green now.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 25
        ECHO ALL The light burns hotter within the crucible, almost a chartreuse tone.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 30
        ECHO ALL The light showing through the lid is now yellow.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 35
        ECHO ALL The glow from the metal in the crucible burns a hot orange.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 40
        ECHO ALL The light from under the lid is burning a searing red now.
      ENDIF
      PLREVENT 1
      CONTPLREVENT
      IFVAR FLAG3 > 45
        ECHO ALL The glow from the metal being tested heats up to a white hot brilliance!
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFVERB EXTINGUISH -1
  PLREVENT 0
  CONTPLREVENT
  ECHO ALL The crucible and its contents cool rapidly.
ENDIF
IFTOUCH -1
  IFITEM -1 LIT
    DAMAGEPLR BURN 30 The heat from the lit crucible burns you!
    ECHO OTHERS %n winces in pain.
  ENDIF
ENDIF
;
; Non-Craftable Items
;
; I# 1928 : Camcorder
INUMBER 1928
NAME 1573
WEIGHT 5
VOLUME 3
WIELDABLE
TECH
IFPREVERB GAZE -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You gaze through the eyepiece of the camcorder.
    ECHO OTHERS %N pans %a about the room.
    SHOWROOM RNUM
  ENDIF
ENDIF
IFPREVERB TURN -1
  IFITEM -1 WIELDED
    ECHO ALL A red light on %a comes on, then turns off.
    CLEARVERB
  ENDIF
ENDIF
IFPREVERB PUSH -1
  IFITEM -1 WIELDED
    ECHO ALL You hear a whirring sound from %a.
    CLEARVERB
  ENDIF
ENDIF
;
; I# 954 : Pipe
INUMBER 954
NAME 640
WEIGHT 1
VOLUME 1
SUBSTANCE WOOD
ENCRUSTABLE
WIELDABLE
CRUSH_WEAPON
PARAMETER1 1
IFVERB WIELD -1
  ECHO OTHERS %N clenches the pipe between %h teeth and takes a puff.
  ECHO PLAYER You clench the pipe between your teeth and take a relaxing puff or two.
ENDIF
IFVERB PLAY -1
  CLEARVERB
  ECHO PLAYER You blow a series of smoke rings.
  ECHO OTHERS %N blows a series of smoke rings.
ENDIF
IFPREVERB FILL -1
  CLEARVERB
  ECHO OTHERS %N carefully fills %h pipe bowl and tamps down the contents.
  ECHO PLAYER You carefully fill up your pipe and tamp down the contents.
ENDIF
IFPREVERB LIGHT -1
  CLEARVERB
  ECHO OTHERS %N fires up %h pipe.
  ECHO PLAYER You fire up your pipe.
ENDIF
IFVAR ITEMVAL1 = 666
  IFPREVERB PULL -1
    IFITEM -1 WIELDED
      CLEARVERB
      EQUAL RITUALVAL2 37
      ECHO PLAYER As you pull air through the pipe, it makes a sound not unlike the cry of a giant lizard in heat.%c[Round: 10 sec]
      EQUAL ROUNDTIME 10
      ECHO OTHERS %N sucks air through %h pipe, making a sound like a giant lizard in heat.
      SPELL 2 30
    ENDIF
  ENDIF
ENDIF
;
; I# 766 : Cigar
INUMBER 1180
NAME 766
WEIGHT 1
VOLUME 1
SUBSTANCE CLOTH
WIELDABLE
IFPREVERB PULL -1
  CLEARVERB
  ECHO PLAYER You take a long hard pull on your cigar!
  ECHO OTHERS %n takes a hard drag on %h cigar and blows some smoke rings.
ENDIF
IFPREVERB EAT -1
  CLEARVERB
  ECHO PLAYER You bite the tip off of the cigar and spit it out.
  ECHO OTHERS %n bites the tip off of %a and spits it out.
ENDIF
LIGHTABLE
