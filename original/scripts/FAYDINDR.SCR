The floor is constructed of a hardwood, polished to a shiny finish. A few pieces of training equipment are here:  a heavy, stuffed bag used for boxing, a number of iron barbells and a long climbing rope. A door leads back to the street.
*DESCRIPTION_END
ITEM 0 350 VAL2=282
TRAINING 11 30
IFENTRY
	PLREVENT 1
	CONTPLREVENT
	IFVAR RAC = 1
		IFVAR GEN = 0
			STRCPY 0 "boy"
		ELSE
			STRCPY 0 "girl"
		ENDIF
	ENDIF
	IFVAR RAC = 2
		STRCPY 0 "aelf"
	ENDIF
	IFVAR RAC = 3
		STRCPY 0 "highlander"
	ENDIF
	IFVAR RAC = 4
		STRCPY 0 "doggy"
	ENDIF
	IFVAR RAC = 5
		STRCPY 0 "murg"
	ENDIF
	IFVAR RAC = 6
		STRCPY 0 "lizard"
	ENDIF
	IFVAR RAC = 7
		IFVAR GEN = 0
			STRCPY 0 "robo-boy"
		ELSE
			STRCPY 0 "robo-girl"
		ENDIF
	ENDIF
	IFVAR RAC = 8
		STRCPY 0 "ghost"
	ENDIF
	IFVAR RAC ! 7
		ECHO PLAYER Seeing you arrive, Lance comes forward and looks you up and down, frowning. "I see that you are a little flabby-%0. Let me train you and we'll pump-up those puny muscles."
	ELSE
		ECHO PLAYER Seeing you arrive, Lance comes forward and looks you up and down, frowning. "What have we here?  A little %0?  Let me train you to use those hydraulics a little better, %0."
	ENDIF
	IFVAR LANCEGEN ! 1
		GENMON 358
		EQUAL LANCEGEN 1
	ENDIF
ENDIF
EQUAL DUMMY1 0
IFPREVERB KILL -1
	EQUAL DUMMY1 1
ENDIF
IFPREVERB CAST -1
	EQUAL DUMMY1 1
ENDIF
IFPREVERB PROJECT -1
	EQUAL DUMMY1 1
ENDIF
IFPREVERB BACKSTAB -1
	EQUAL DUMMY1 1
ENDIF
IFPREVERB PSI -1
	EQUAL DUMMY1 1
ENDIF
IFVAR DUMMY1 = 1
	ECHO OTHERS Lance gives %n a stern look.
	ECHO PLAYER Lance scolds you with his finger and says, "If you try that again I will step on you like the flabby antlike person you ah."
	CLEARVERB
ENDIF
;
