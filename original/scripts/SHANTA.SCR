  ENDIF
IFPREVERB NUDGE -1
  CLEARVERB
  ECHO PLAYER Petey snarls feriously as he growls threateningly at nothing in particular.
  ECHO OTHERS Petey snarls feriously as he growls threateningly at nothing in particular.
ENDIF
