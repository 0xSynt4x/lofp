IFPREVERB WAVE  -1
  IFVAR ARCHNUM = 890
    IFVAR FLAG1 = 0
      CLEARVERB
      EQUAL FLAG1 1
      ECHO PLAYER You place the marshmellow on the stick you found.
      ECHO OTHERS %n places the marshmellow on the end of a stick %s found.
    ELSE
      IFVAR FLAG1 = 1
        CLEARVERB
        ECHO PLAYER You wave around your stick with a marshmellow attached to the end.
        ECHO OTHERS %n waves around a stick with a marshmellow attached to then end.
      ENDIF
    ENDIF
  ENDIF
ENDIF

IFPREVERB PUSH -1
  IFVAR ARCHNUM = 890
    IFVAR HERBIEPIT = 1
      IFVAR FLAG1 = 1
        IFVAR ITEMADJ2 = -1
          IFVAR ITEMADJ3 = -1
            EQUAL ROUNDTIME 6
            CLEARVERB
            EQUAL ITEMADJ2 877
            EQUAL ITEMADJ3 878
            ECHO PLAYER You hold the stick over the fire and toast the marshmellow.
            ECHO OTHERS %n holds the stick over the fire and toasts %i masrshmellow.
            PLREVENT 2
            CONTPLREVENT
            ECHO ALL You can see the marshmellow brown slightly.
          ELSE
            IFVAR ITEMADJ3 = 878
              EQUAL ROUNDTIME 6
              CLEARVERB
              EQUAL ITEMADJ3 44
              ECHO PLAYER You hold the stick over the fire and toast the marshmellow.
              ECHO OTHERS %n holds the stick over the fire and toasts %i masrshmellow.
              PLREVENT 2
              CONTPLREVENT
              ECHO ALL The marshmellow turns black as it burns.
            ENDIF
          ENDIF
        ELSE
          IFVAR ITEMADJ2 = 877
            IFVAR ITEMADJ3 = 878
              EQUAL ROUNDTIME 6
              CLEARVERB
              EQUAL ITEMADJ2 -1
              ECHO PLAYER You hold the stick over the fire and toast the marshmellow some more.
              ECHO OTHERS %n holds the stick over the fire and toasts the marhmellow some more.
              PLREVENT 2
              CONTPLREVENT
              ECHO ALL You see the marshmellow turn golden brown.
            ENDIF
          ENDIF
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF

