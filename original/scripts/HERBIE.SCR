IFPREVERB GO 2
  IFVAR FLAG2 = 0
    RANDOM DUMMY1 1 4 0
    IFVAR DUMMY1 = 1
      CLEARVERB
      ECHO PLAYER You do a swan dive into the pool.
      ECHO OTHERS %n does a swan dive intot the pool.
      APPEAR You're all wet.
      POSITION LAY
      EQUAL FLAG2 1
      PLREVENT 1
      CONTPLREVENT
      ECHO ALL A group of raccoons show themselves and each hold up a sign reading, "9.0".
    ENDIF
    IFVAR DUMMY1 = 2
      CLEARVERB
      ECHO PLAYER You do a belly flop into the pool.
      ECHO OTHERS %n does a belly flop into the pool.
      APPEAR You're all wet.
      POSITION LAY
      EQUAL FLAG2 1
      PLREVENT 1
      CONTPLREVENT
      ECHO ALL A group of raccoons show themselves and each hold up a sign reading, "5.0".
    ENDIF
    IFVAR DUMMY1 = 3
      CLEARVERB
      ECHO PLAYER You do a triple summersault into the pool.
      ECHO OTHERS %n does a triple summersault into the pool.
      APPEAR You're all wet.
      POSITION LAY
      EQUAL FLAG2 1
      PLREVENT 1
      CONTPLREVENT
      ECHO ALL A group of raccons show themselves and cheer wildly while waving signs that read, "10.0".
    ENDIF
    IFVAR DUMMY1 = 4
      CLEARVERB
      ECHO PLAYER You carefully wade into the pool.
      ECHO OTHERS %n carefully wades intot he pool.
      APPEAR You see that %s is all wet.
      POSITION LAY
      EQUAL FLAG2 1
      PLREVENT 1
      CONTPLREVENT
      ECHO ALL A group of raccons show themsevles and boo loudly.
    ENDIF
  ELSE
   IFVAR FLAG2 = 1
     CLEARVERB
     ECHO PLAYER You're already in the pool, silly.
   ENDIF
  ENDIF
ENDIF

