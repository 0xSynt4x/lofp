IFPREVERB PULL 7
  IFVAR FLAG3 = 0
    EQUAL ROUNDTIME 6
    EQUAL FLAG3 1
    CLEARVERB
    ECHO PLAYER You lay down on a hammock and starts thinking good thoughts.
    ECHO OTHERS %n lay down on a hammock and starts thinking good thoughts.
    POSITION LAY
    PLREVENT 2
    CONTPLREVENT
    ECHO PLAYER You begins to grin just a teensy bit.
    ECHO OTHERS %n begins to grin just a teensy bit.
    PLREVENT 2
    CONTPLREVENT
    ECHO PLAYER You makes a goofy, happy, cheek-to-cheek smiley face.
    ECHO OTHERS %n makes a goofy, happy, cheek-to-cheek smiley face.
  ELSE
    CLEARVERB
    ECHO PLAYER You gently rock the hammock.
    ECHO OTHERS %n gently rocks the hammock back and forth.
  ENDIF
ENDIF
;
IFPREVERB READ 2
  CLEARVERB
  ECHO PLAYER The sign reads, "Welcome to Herbie's Treehouse Hideaway - Visitors are Welcie%c'Everlush lawns' a gift from Menelian Labs."
ENDIF
