NUMBER 1402
NAME The Void
FIXED_LIGHT
ASTRAL
CALL 33
RELOGIN 1401
*DESCRIPTION_START
You are in a place that is not a place, vast and complete yet intangible and unknowable. Time does not exist, for there is no motion. There is no darkness, for there is no light. If there were nothing here, that would at least be something -- and it lacks even that.
*DESCRIPTION_END
EXIT O 1401
IFENTRY
	PLREVENT 1
	CONTPLREVENT
	IFVAR INTNUM85 = 100
    ECHO ALL A voice booms from the void, "What?!?  You do not carry your lens?"
	ENDIF
	IFVAR INTNUM85 < 100
		IFVAR INTNUM83 = 0
      ECHO ALL A voice resonates from the void: "Welcome, creature of Andor. Lord Lintaranz has told us much about you. The time has come for you to voyage beyond the boundaries of your world, if that is your desire. Is it?%c[You may answer 'yes' to affirm].
		ELSE
      CALL 46
			IFCARRY INTNUM83 INTNUM84
				EQUAL DUMMY1 0
        ECHO ALL A voice resonates from the void: "You have returned with %0. Excellent..."
        ECHO ALL The item suddenly sparkles and vanishes.
				REMOVEITEM -1
				IFVAR INTNUM85 < 10
					ADD INTNUM85 1
					IFVAR INTNUM85 = 0
						IFVAR LEV < 20
							EQUAL INTNUM83 1630
							EQUAL INTNUM84 1237
						ENDIF
						IFVAR LEV > 19
							IFVAR LEV < 40
								EQUAL INTNUM83 504
								EQUAL INTNUM84 868
							ENDIF
						ENDIF
						IFVAR LEV > 39
							EQUAL INTNUM83 1554
							EQUAL INTNUM84 1131
						ENDIF
					ELSE
						IFVAR LEV < 20
							RANDOM DUMMY1 1 14 0
						ELSE
							IFVAR LEV < 40
								RANDOM DUMMY3 1 100 0
								IFVAR DUMMY3 < 50
									RANDOM DUMMY2 1 14 0
									RANDOM DUMMY1 1 15 0
									ADD DUMMY1 DUMMY2
								ELSE
									RANDOM DUMMY1 1 15 14
								ENDIF
							ELSE
								RANDOM DUMMY4 1 100 0
								IFVAR DUMMY4 < 50
									RANDOM DUMMY3 1 14 0
									RANDOM DUMMY2 1 15 0
									RANDOM DUMMY1 1 15 0
									ADD DUMMY1 DUMMY2
									ADD DUMMY1 DUMMY3
								ELSE
									RANDOM DUMMY1 1 15 29
								ENDIF
							ENDIF
						ENDIF
						;
						; "Easy" items
						;
						IFVAR DUMMY1 = 1
							EQUAL INTNUM83 1400
							EQUAL INTNUM84 545
						ENDIF
						IFVAR DUMMY1 = 2
							EQUAL INTNUM83 512
							EQUAL INTNUM84 546
						ENDIF
						IFVAR DUMMY1 = 3
							EQUAL INTNUM83 506
							EQUAL INTNUM84 548
						ENDIF
						IFVAR DUMMY1 = 4
							EQUAL INTNUM83 507
							EQUAL INTNUM84 549
						ENDIF
						IFVAR DUMMY1 = 5
							EQUAL INTNUM83 371
							EQUAL INTNUM84 468
						ENDIF
						IFVAR DUMMY1 = 6
							EQUAL INTNUM83 526
							EQUAL INTNUM84 742
						ENDIF
						IFVAR DUMMY1 = 7
							EQUAL INTNUM83 521
							EQUAL INTNUM84 799
						ENDIF
						IFVAR DUMMY1 = 8
							EQUAL INTNUM83 522
							EQUAL INTNUM84 723
						ENDIF
						IFVAR DUMMY1 = 9
							EQUAL INTNUM83 1635
							EQUAL INTNUM84 1127
						ENDIF
						IFVAR DUMMY1 = 10
							EQUAL INTNUM83 1053
							EQUAL INTNUM84 1246
						ENDIF
						IFVAR DUMMY1 = 11
							EQUAL INTNUM83 275
							EQUAL INTNUM84 339
						ENDIF
						IFVAR DUMMY1 = 12
							EQUAL INTNUM83 275
							EQUAL INTNUM84 1247
						ENDIF
						IFVAR DUMMY1 = 13
							EQUAL INTNUM83 1877
							EQUAL INTNUM84 135
						ENDIF
						IFVAR DUMMY1 = 14
							EQUAL INTNUM83 512
							EQUAL INTNUM84 547
						ENDIF
						;
						; "Moderate" items
						;
						IFVAR DUMMY1 = 15
							EQUAL INTNUM83 525
							EQUAL INTNUM84 567
						ENDIF
						IFVAR DUMMY1 = 16
							EQUAL INTNUM83 509
							EQUAL INTNUM84 568
