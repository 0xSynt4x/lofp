							EQUAL INTNUM83 521
							EQUAL INTNUM84 556
						ENDIF
						IFVAR DUMMY1 = 19
							EQUAL INTNUM83 521
							EQUAL INTNUM84 142
						ENDIF
						IFVAR DUMMY1 = 20
							EQUAL INTNUM83 525
							EQUAL INTNUM84 431
						ENDIF
						IFVAR DUMMY1 = 21
							EQUAL INTNUM83 117
							EQUAL INTNUM84 1113
