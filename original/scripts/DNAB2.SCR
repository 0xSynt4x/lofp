							EQUAL INTNUM84 -1
						ENDIF
						IFVAR DUMMY1 = 23
							EQUAL INTNUM83 528
							EQUAL INTNUM84 545
						ENDIF
						IFVAR DUMMY1 = 24
							EQUAL INTNUM83 523
							EQUAL INTNUM84 694
						ENDIF
						IFVAR DUMMY1 = 25
							EQUAL INTNUM83 509
							EQUAL INTNUM84 868
						ENDIF
						IFVAR DUMMY1 = 26
							EQUAL INTNUM83 528
							EQUAL INTNUM84 770
