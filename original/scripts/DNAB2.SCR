							EQUAL INTNUM84 766
						ENDIF
						IFVAR DUMMY1 = 39
							EQUAL INTNUM83 520
							EQUAL INTNUM84 1153
						ENDIF
						IFVAR DUMMY1 = 40
							EQUAL INTNUM83 521
							EQUAL INTNUM84 1153
						ENDIF
						IFVAR DUMMY1 = 41
							EQUAL INTNUM83 669
							EQUAL INTNUM84 1046
						ENDIF
						IFVAR DUMMY1 = 42
							EQUAL INTNUM83 659
							EQUAL INTNUM84 556
						ENDIF
						IFVAR DUMMY1 = 43
							EQUAL INTNUM83 659
							EQUAL INTNUM84 34
						ENDIF
						IFVAR DUMMY1 = 44
							EQUAL INTNUM83 1918
							EQUAL INTNUM84 1381
						ENDIF
					ENDIF
                                        CALL 46
                                        ECHO ALL "You will require further components to construct the lens of worlds. Locate %0 and then return again."
					ELSE
						EQUAL INTNUM85 100
						EQUAL INTNUM84 0
						ECHO PLAYER "You have labored on your scavenger hunt long enough, disciple. Behold!  Your lens of worlds is complete. Take it!"
						NEWITEM 0 1669 VAL3=1
					ENDIF
				ELSE
					ECHO PLAYER A voice booms from the void: "You have not returned with %0. You will not be able to construct a lens of worlds without it. Do not return until you have it in your posession!"
				ENDIF
			ENDIF
		ENDIF
	ENDIF
;
IFSAY yes
	IFVAR INTNUM83 = 0
		ECHO PLAYER The voice resonates: "Excellent. However, the Fold requires that any who wish to navigate our Well of Worlds first pass a series of trials that will test your resolve and commitment to Balance..."
		PLREVENT 2
		CONTPLREVENT
		ECHO PLAYER The voice continues: "Your first trial will be to acquire an assortment of sorcerous components that will allow you to construct what is known as a lens of worlds."
		PLREVENT 2
		CONTPLREVENT
		ECHO PLAYER The voice continues: "The first component you will require is a small quantity of meteoric dust. Please return when you have located some."
		EQUAL INTNUM83 512
		EQUAL INTNUM84 1104
		EQUAL INTNUM85 1
	ENDIF
ENDIF
;

CEVENT 80 100 45
IFSEEK 80
        RANDOM DUMMY1 1 100 0
        IFVAR DUMMY1 < 11
                ADD PVAL15 1
                IFVAR PVAL15 = 1
                        ECHO PLAYER You sense a terrible, far-off feeling of sadness.
                ENDIF
                IFVAR PVAL15 = 2
                        ECHO PLAYER You sense great regret and an overwhelming loss.
                ENDIF
                IFVAR PVAL15 = 3
                        ECHO PLAYER You sense a void within yourself that aches to be filled.
                ENDIF
                IFVAR PVAL15 = 4
                        ECHO PLAYER Your vision swims with the image of a shattered cavern, lit with a terrible red light, its floor littered with the remains of broken eggs and their half-formed, stillborn contents.
                ENDIF
                IFVAR PVAL15 = 5
                        ECHO PLAYER You smell a sulphuric scent for a moment.
                ENDIF
                IFVAR PVAL15 = 6
                        ECHO PLAYER You sense a great and terrible longing deep within yourself.
                ENDIF
                IFVAR PVAL15 = 7
                        ECHO PLAYER A dragon eye orb seems to shiver. Looking at it you see a bead of moisture like a silent tear.
                ENDIF
                IFVAR PVAL15 = 8
                        ECHO ALL You hear a far-off wailing sound, a reptilian scream of sorrow.
                ENDIF
                IFVAR PVAL15 = 9
                        ECHO PLAYER You fall to your knees as pain shoots through your left arm and the right side of your face.
                        ECHO OTHERS %N's right eye suddenly screws tightly shut as %s falls to %h knees, writhing in pain.
			EQUAL ROUNDTIME 20
                        POSITION KNEEL
                ENDIF
                IFVAR PVAL15 = 10
                        ECHO PLAYER Your ears prick up as you hear a tiny yammering sound at your feet... looking down you see that your body is huge, scaly and red... and then the vision fades.
                ENDIF
                IFVAR PVAL15 = 11
                        ECHO PLAYER Your right eye hurts for some reason.
                ENDIF
                IFVAR PVAL15 = 12
                        ECHO PLAYER A name comes unbidden to your lips... Roundwing...
                        ECHO OTHERS %N gasps.
                        ECHO OTHERS %N says, "...Roundwing..."
                ENDIF
                IFVAR PVAL15 = 13
                        ECHO PLAYER Somewhere, you sense, a dragon is crying.
                ENDIF
                IFVAR PVAL15 = 14
                        ECHO PLAYER You sense strife of the mind and an incredible loneliness.
                ENDIF
                IFVAR PVAL15 = 15
                        ECHO PLAYER You hear a faint echo in your mind... your own voice? Or that of some great reptile? Crying, "Do not leave me... I cannot defend them..."
                ENDIF
                IFVAR PVAL15 = 16
                        ECHO PLAYER You feel a deep hunger within you, and sense a terrible decision come to be made.
                ENDIF
                IFVAR PVAL15 = 17
                        ECHO PLAYER A name comes unbidden to your lips... Throtain...
                        ECHO OTHERS %N gasps.
                        ECHO OTHERS %N says, "...Throtain..."
                ENDIF
                IFVAR PVAL15 = 18
                        ECHO PLAYER You feel black hunger deep in your gut as the days become weeks, the weeks years, and still the eggs do not hatch... and your mate does not return...
                ENDIF
                IFVAR PVAL15 = 19
                        ECHO PLAYER Setothos growls, "I must go, for we fly tonight. I shall return if I survive."
                        ECHO PLAYER You growl, "No... the clutch..."
                        ECHO PLAYER Setothos growls, "I am bidden by my leige and I cannot say him nay. Ming K'tuk is my master more surely than we are each others'."
                        ECHO PLAYER You growl, "Do not leave me... I cannot defend them..."
                        ECHO PLAYER Setothos smiles sadly, picking at one wing with a scarlet claw.
                        ECHO PLAYER Setothos growls, "We can always hope for a miracle. I will seal you in so that the diggers cannot find our eggs. Have you enough food?"
                        ECHO PLAYER You growl, "If you return... only if you return."
                        ECHO OTHERS %N growls, "If you return... only if you return."
                ENDIF
	ENDIF
ENDIF

