	ENDIF
ENDIF
IFENTRY
  IFVAR INTNUM6 = 0
    NEWITEM -1 255 ADJ1=181 ADJ2=40
    NEWITEM -1 253 ADJ1=87 ADJ2=40
    NEWITEM -1 217 ADJ1=298 ADJ2=180
    NEWITEM -1 925 VAL1=-1 VAL2=-1 VAL3=-1 VAL4=-1 VAL5=-1
    GMMSG Honk! %N is a newbie.
    ECHO PLAYER [Type HELP to access the help system. Type ASSIST to request a gamemaster as soon as one is available. Type ADVICE for hints on getting started.]
    PLREVENT 2
    CONTPLREVENT
    ECHO PLAYER You have been given tunic, breeches and boots. Please WEAR them immediately. (WEAR TUNIC, WEAR BREECHES, WEAR TUNIC)
    PLREVENT 2
    CONTPLREVENT
    ECHO PLAYER You have also been given a roleplaying OBJECT, which allows you to do enhanced roleplaying actions. TAP the OBJECT to see the rules. Make sure you practice in private.
    PLREVENT 3
    CONTPLREVENT
		ECHO PLAYER A little voice inside your head says, "Keep going west, young one, keep going west."
    EQUAL INTNUM6 2
  ENDIF
ENDIF
IFENTRY
  IFVAR INTNUM6 = 1
    EQUAL INTNUM6 3
  ENDIF
  IFVAR LEV > 10
    EQUAL INTNUM6 3
  ENDIF
ENDIF
IFSAY Seal_the_gate!
  IFITEM 0 CLOSED
    IFITEM 0 UNLOCKED
      IFVAR ORG = 6
        LOCK 0
        AFFECT 6900
        LOCK 0
        AFFECT 201
        ECHO ALL A squad from the Crimson Band comes out with a pair of massive beams and barricades the inner gate.
      ENDIF
      IFVAR ORG = 3
        LOCK 0
        AFFECT 6900
        LOCK 0
        AFFECT 201
        ECHO ALL A squad from the Crimson Band comes out with a pair of massive beams and barricades the inner gate.
      ENDIF
    ELSE
      ECHO PLAYER The gate is already locked.
    ENDIF
  ELSE
    ECHO PLAYER The gate is not closed yet.
  ENDIF
ENDIF
IFSAY Open_the_gate!
  IFITEM 0 CLOSED
    IFITEM 0 LOCKED
      IFVAR ORG = 6
        UNLOCK 0
        OPEN 0
        AFFECT 6900
        UNLOCK 0
        OPEN 0
        AFFECT 201
      ECHO ALL A squad from the Crimson Band comes out and removes the two massive beams which barricades the inner gate.
      ENDIF
      IFVAR ORG = 3
        UNLOCK 0
        OPEN 0
        AFFECT 6900
        UNLOCK 0
        OPEN 0
        AFFECT 201
        ECHO ALL A squad from the Crimson Band comes out and removes the two massive beams which barricades the inner gate.
      ENDIF
    ENDIF
  ELSE
    ECHO PLAYER The gate is already open.
  ENDIF
ENDIF
IFPREVERB GO 1
  IFVAR ORG ! 3
    IFVAR ORG ! 6
      CLEARVERB
      ECHO PLAYER A burly guard stops your from entering the tower.
      ECHO OTHERS A guard in the dual livery of the Lawkeeps and the Crimson Band stops %n from entering the gatehouse tower.
    ENDIF
  ENDIF
ENDIF
IFTOUCH 1
  IFVAR ORG ! 3
    IFVAR ORG ! 6
      CLEARVERB
      ECHO PLAYER A burly guard stops your from entering the tower.
      ECHO OTHERS A guard in the dual livery of the Lawkeeps and the Crimson Band stops %n from entering the gatehouse tower.
    ENDIF
  ENDIF
ENDIF
