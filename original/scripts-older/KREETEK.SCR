	IFVAR STDOOR = 1
		CLEARVERB
		ECHO PLAYER You pull the wall closed, sealing up the doorway once again.
		ECHO OTHERS %n pulls the wall closed, sealing up the doorway once again.
		REMOVEITEM 4
		AFFECT 3713
		REMOVEITEM 4
		ECHO ALL You see the open section of the wall swing close.
		AFFECT 782
		EQUAL STDOOR 0
	ELSE
		CLEARVERB
		ECHO PLAYER The wall doesn't budge.
	ENDIF
ENDIF

IFENTRY -1
	IFVAR STDOOR = 1
