	IFVAR PER > 100
		CLEARVERB
		ECHO PLAYER You can see the outline of a doorway cut through some of the pipes
		ECHO PLAYER and the wall beyond. No wonder those pipes were empty and unuesed!
	ELSE
		ECHO PLAYER You don't notice anything out of the ordinary.
		CLEARVERB
	ENDIF
ENDIF

IFVERB SMELL -1
	ECHO PLAYER %cYou smell dank mildew everywhere.
ENDIF

IFPREVERB PUSH 3
	IFVAR STDOOR = 0
		CLEARVERB
		ECHO PLAYER You lean onto the cooler pipes and push the wall open revealing a doorway!
		ECHO OTHERS %n pushes on some of the unused pipes and opens the wall to reveal a doorway!
		NEWITEM 4 1341 VAL2=3713
		AFFECT 3713
		ECHO ALL You see a section of the wall swing in revealing a doorway!
		NEWITEM 4 1341 VAL2=782
		AFFECT 782
		EQUAL STDOOR 1
	ELSE
		CLEARVERB
		ECHO PLAYER The wall has already been opened up to reveal a doorway.
	ENDIF
ENDIF

IFVERB SEARCH -1
	ECHO PLAYER %cYou notice that some of the pipes on eastern wall are not being used.
ENDIF

