; variables to track monster genning in steam tunnels
VARIABLE STEAMMON1
VARIABLE STEAMMON2
VARIABLE STEAMMONGEND
VARIABLE STEAMMONDEF
VARIABLE CANGEN
VARIABLE MONPERHOUR
VARIABLE STEAMTIM
VARIABLE TOTALSTEAM

; New Steam Tunnels

NUMBER 780
NAME Subway, Steam Tunnel
DEEPCAVE
DARKNESS
REGION 172
CALL 33
*DESCRIPTION_START
Dark, dank and hot. Slime covered pipes run the length of the floor, ceilings
and walls, making it narrow and very difficult to navigate. Rubble is piled
against the northern wall all the way up to the ceiling. A shaft of light from
a hole in the ceiling tries to illuminate the tunnels through the steam. The
tunnel leads off to the south
*DESCRIPTION_END

EXIT S 781

ITEM 1 213 ADJ1=1346 ADJ2=407 VAL2=3783
ITEM 2 1189 ADJ1=1263

IFPREVERB DIG -1
  CLEARVERB
  ECHO PLAYER You can't dig through the floor!
ENDIF

IFVERB LISTEN -1
  ECHO PLAYER %cYou can hear the hiss of steam.
ENDIF

IFVERB GAZE -1
  ECHO PLAYER %cEverywhere you gaze, you can see slime and mold covering the walls and pipes.
ENDIF

IFVERB SMELL -1
	ECHO PLAYER %cYou smell dank mildew everywhere.
ENDIF

IFPREVERB CLIMB 1
	SKILLCHECK 5 25 DUMMY1
	IFVAR DUMMY1 > 0
		ECHO PLAYER You manage to keep your balance as your climb up the slime covered rubble.
		ECHO OTHERS %n manages to keep %h balance as %s climbs up the slime covered rubble.
	ELSE
		CLEARVERB
		POSITION LAY
		DAMAGEPLR CRUSH 10 You lose your footing and slip!
		ECHO OTHERS %n loses %h footing and slips!
		EQUAL STEAMTIM TIM
	ENDIF
ENDIF

IFPREVERB LOOK 1
	CLEARVERB
	ECHO PLAYER You can see that rubble reaches almost all the way to the hole in ceiling.
	ECHO PLAYER However, it looks very slippery.
ENDIF

IFVERB RECALL -1
	ECHO PLAYER %c...but nothing looks familiar.
ENDIF

IFTOUCH 2
	DAMAGEPLR BURN 10 You burn yourself on the hot pipe!
	ECHO OTHERS %n touches a hot pipe and burns %iself!
ENDIF

IFENTRY -1

IFVAR MONPERHOUR = 0
	EQUAL MONPERHOUR 15
ENDIF

; check to see if number of monsters genned this hour exceed number of monsters per hour allowed

IFVAR STEAMMONGEND >= MONPERHOUR ; means too many monsters
	EQUAL CANGEN 1 ; set CANGEN to 1, preventing more monsters from genning
	IFVAR INTNUM3 = 1
		ECHO PLAYER SETTING CANGEN TO 1
	ENDIF
ENDIF

IFVAR STEAMTIM ! TIM ; check to see if we are still in the same hour, if not, reset
	EQUAL STEAMTIM TIM
	EQUAL CANGEN 0
	EQUAL TOTALSTEAM STEAMMONGEND
	EQUAL STEAMMONGEND 0
	IFVAR INTNUM3 = 1
		STRCVT 0 STEAMTIM
		STRCVT 1 TIM
		STRCVT 2 CANGEN
		STRCVT 3 TOTALSTEAM
		STRCVT 4 STEAMMONGEND
		ECHO PLAYER STEAMTIM %0
		ECHO PLAYER TIM %1
		ECHO PLAYER CANGEN %2
		ECHO PLAYER TOTALSTEAM %3
		ECHO PLAYER STEAMMONGEND %4
	ENDIF
ENDIF


IFVAR CANGEN = 0
	IFVAR INTNUM3 ! 1
		IFVAR PLRSINROOM > MONINROOM
			RANDOM DUMMY1 1 100 0
			IFVAR DUMMY1 > 85
				GENMON 146
				ADD STEAMMONGEND 1
				ECHO ALL A spectral worker floats in.
			ENDIF
			IFVAR DUMMY1 < 15
				GENMON 324
				ADD STEAMMONGEND 1
				ECHO ALL A cleaning drone glides in.
			ENDIF
		ENDIF
	ENDIF
ENDIF

ENDIF

