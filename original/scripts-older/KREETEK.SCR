IFPREVERB LOOK 1
  CLEARVERB
  ECHO PLAYER You see an electric book, that is somewhow attached to the desk, but can be easily moved about.
ENDIF

IFPREVERB READ 1
  CLEARVERB
  ECHO PLAYER Written in luminous letters, "Welcome to the Technologist's Guild. Please place
  ECHO PLAYER your hand on the book for encoding."
ENDIF

IFPREVERB LOOK 2
  CLEARVERB
  ECHO PLAYER You see a strange device attached to the wall with a flat smooth
  ECHO PLAYER surface and what appears to be an outline of a hand.
ENDIF

IFPREVERB FLIP 2
  IFVAR PVAL51 = 1
      IFVAR ORG = 7
        CLEARVERB
        ECHO PLAYER You activate the scaning device.
        ECHO OTHERS %n presses a button on the device.
        ECHO ALL %cYou hear a synthetic voice intone, "Begining scan. One moment please."
        ECHO ALL Suddenly, the room is bathed in red light.
        IFVAR PLRSINROOM = 1
          ECHO ALL %cYou hear a synthetic voice intone, "One person present."
          ECHO ALL %cThe red light subsides.
          ECHO ALL You hear a synthetic voice intone, "Scan complete."
        ELSE
          IFVAR PLRSINROOM > 1
            STRCVT 0 PLRSINROOM
            ECHO ALL %cYou hear a synthetic voice intone, "%0 people present."
            ECHO ALL %cThe red light subsides.
            ECHO ALL You hear a synthetic voice intone, "Scan complete."
          ENDIF
        ENDIF
      ELSE
        CLEARVERB
        ECHO PLAYER %cYou feel a slight electric tingle run through you, but nothing else happens.
      ENDIF
    ELSE
      ECHO PLAYER There seems to be no power.
    ENDIF
ENDIF

