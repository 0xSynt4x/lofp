					equal roundtime 60
					echo player You take a large cylinder and fasten it to the workbench with some clamps.
					echo others %n takes a large cylinder and fastens it to the workbench with some clamps.
					echo player [Round: 60 seconds...]
					plrevent 5
					contplrevent
					echo player You then saw off both ends of the cylinder.
					echo others %n saws off both ends of the cylinder.
					plrevent 5
					contplrevent
					echo player Next, you carve some grooves into both ends of the cylinder and the pieces you cut off as well.
					echo others %n makes some grooves into both ends of the cylinder.
					plrevent 5
					contplrevent
					echo player You make a small elongated cut into the center of the cylinder.
					echo others %n makes a small elongated cut into the center of the cylinder.
					plrevent 5
					contplrevent
					echo player You finish working on the large cylinder by screwing on the bottom end, leaving one end still open.
					echo others %n finishes the work on the large cylinder and closes up one end of it.
				endif
			endif
		else
			ifvar Intnum52 = 2
				ifvar archnum = 857 ; small cylinders - piece 2
					ifvar ItemAdj1 = 294 		
						clearverb
						removeitem -1
						equal Intnum52 3
						equal roundtime 10
						echo player Next, you take one of the small charged cylinders and drop it into the open end of the larger cylinder.
						echo others %n inserts one of the smaller charged cylinders into the large one.
						echo player [Round: 10 seconds...]
						plrevent 3
						contplrevent
					endif
				endif
			else
				ifvar Intnum52 = 3
					ifvar ArchNum = 546 ; glass
						ifvar ItemAdj1 = 241 ; polished
							ifvar ItemAdj2 = 78 ; cut
								clearverb
								removeitem -1
								equal Intnum52 4
								equal roundtime 60
								echo player You pick up the other piece of the large cylinder that you cut off.
								echo others %n finds the other piece %s cut off the larger cylinder
								echo player [Round: 60 seconds...]
								plrevent 2
								contplrevent
								echo player You begin to cut out the center of that piece to match the size of the glass you previously cut and polished.
								echo others %n cuts out the center of the piece that %s previously cut from the end of the cylinder.
								plrevent 5
								contplrevent
								echo player Now, you carefully make a groove into the now hollowed-out piece and begin to fit the piece of glass into it.
								echo others %n carefully begins to fit the glass into the now hollowed-out piece.
								plrevent 8
								contplrevent
								echo player You finish fitting the polished glass into the recessed opening of the end of the cylinder.
								echo others %n finished fitting the glass into the end of the cylinder.
								plrevent 5
								contplrevent
							else
								clearverb
								echo player that is not cut or polished enough
							endif
						else
							clearverb
							echo player that is not polished or cut enough
						endif
					endif
				else
					ifvar Intnum52 = 4
						ifvar ArchNum = 884 ; wire
							clearverb
							removeitem -1
							equal intnum52 0
							equal roundtime 55
							GMMSG %n just completed a flashlight.
							echo player You move onto wiring the cylinder up.
							echo others %n begins to wire up the cylinder.
							echo player [Round: 55 seconds...]
							plrevent 5
							contplrevent
							echo player You first loop the wire through the elongated hole you made and connect it to the small charged cylinder.
							echo others %n continues to wire the cylinder.
							plrevent 5
							contplrevent
							echo player You move on to connecting the wire to the end of the glass by adding a filiment and some electrodes.
							echo others %n continues to wire the cylinder.
							plrevent 5
							contplrevent
							echo player Finally, you finish by connecting it all to a switch and screwing the last piece into place.
							echo others %n finishes up the wire and connects everything into place.
							plrevent 3
							contplrevent
							echo player You unfasten the flashlight from the clamps and it rests on the workbench.
							echo others %n unfastens the flashlight from the clamps and it rests on the workbench.
							newput 1 1755
							random dummy1 1 100 0
							ifvar dummy1 < 6
								add intnum68 1
								echo player You feel you have gained technological insight.
								strcvt 0 intnum68
								gmmsg %n's technology skill (intnum68) was increased to %0.
								strcvt 0 dummy1
								gmmsg %0
							else
								strcvt 0 dummy1
								gmmsg %0
								
							endif
						endif
					else
						ifvar intnum52 ! 0
							clearverb
							echo player You've already assembled that piece.
						endif
					endif
				endif
			endif
		endif
endif

