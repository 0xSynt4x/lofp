NUMBER 3638
NAME By a Black Stone Table
CALL 33
 
ITEM 9 693
*DESCRIPTION_START
A massive black flat slab of stone rests atop a small hill, the highest elevation for several hundred feet at least. A few scraggly plants have begun to grow here, but their efforts seem to be in vain. There is an air of unnatural stillness about this place, and a feeling of uneasiness you can't quite place.
*DESCRIPTION_END
OUTDOOR_FLOOR
DAY_LIGHT
EXIT O 310
ITEM 0 91  ADJ1=25  ADJ2=312
EXTEND 0 with some odd dark stains on its surface
IFPREVERB2 PUT 0
  CLEARVERB
  IFVAR ARCHNUM = 107
    IFVAR CHASTABLE ! 0
      ECHO PLAYER There is no room for that.
    ENDIF
    IFVAR CHASTABLE = 0
      IFVAR GOLEMSET ! 0
        ECHO PLAYER There is already a diamond on the table.
      ELSE
        ECHO PLAYER You place %a upon the table.
        ECHO OTHERS %N places %a upon the table.
        EQUAL GOLEMSET 1
      ENDIF
    ENDIF
  ENDIF
  IFVAR ARCHNUM = 650
    IFVAR ITEMADJ1 = 586
      IFVAR CHASTABLE ! 0
        ECHO PLAYER There is already a corpse on the table.
      ENDIF
      IFVAR CHASTABLE = 0
        REMOVEITEM -1
        ECHO PLAYER You place a rotting corpse on the black stone table.
        ECHO OTHERS %N places a rotting corpse on the black stone table.
        EQUAL CHASTABLE 1
      ENDIF
    ENDIF
  ENDIF
  IFVAR ARCHNUM = 1273
    IFVAR ITEMADJ1 = 586
      IFVAR CHASTABLE = 0
        ECHO PLAYER You need to put a corpse on the table before you can add a head.
      ENDIF
      IFVAR CHASTABLE > 1
        ECHO PLAYER The corpse already has a head.
      ENDIF
      IFVAR CHASTABLE = 1
        REMOVEITEM -1
        ECHO PLAYER You carefully sew the head onto the neck of the rotting corpse.
        ECHO OTHERS %N carefully sews a rotting head onto the neck of a rotting corpse with thick black thread.
        ECHO PLAYER [Round: 8 seconds]
        EQUAL ROUNDTIME 8
        EQUAL CHASTABLE 2
      ENDIF
    ENDIF
  ENDIF
  IFVAR ARCHNUM = 649
    IFVAR ITEMADJ1 = 586
      IFVAR CHASTABLE > 3
        ECHO PLAYER The corpse already has two arms.
      ENDIF
      IFVAR CHASTABLE < 2
        ECHO PLAYER It is not yet time for the arms.
      ENDIF
      IFVAR CHASTABLE = 3
        REMOVEITEM -1
        ECHO PLAYER You carefully sew a rotting arm onto the right shoulder of a rotting corpse.
        ECHO OTHERS %N carefully sews a rotting arm onto the right shoulder of a rotting corpse.
        ECHO PLAYER [Round: 8 seconds]
        EQUAL ROUNDTIME 8
        EQUAL CHASTABLE 4
      ENDIF
      IFVAR CHASTABLE = 2
        REMOVEITEM -1
        ECHO PLAYER You carefully sew a rotting arm onto the left shoulder of a rotting corpse.
        ECHO OTHERS %N carefully sews a rotting arm onto the left shoulder of a rotting corpse.
        ECHO PLAYER [Round: 8 seconds]
        EQUAL ROUNDTIME 8
        EQUAL CHASTABLE 3
      ENDIF
    ENDIF
  ENDIF
  IFVAR ARCHNUM = 527
    IFVAR ITEMADJ1 = 586
      IFVAR CHASTABLE < 4
        ECHO PLAYER It is not yet time for the legs.
      ENDIF
      IFVAR CHASTABLE > 6
        ECHO PLAYER The corpse has two legs already.
      ENDIF
      IFVAR CHASTABLE = 5
        REMOVEITEM -1
        ECHO PLAYER You carefully sew a rotting leg onto a rotting corpse.
        ECHO OTHERS %N carefully sews a rotting leg onto a rotting corpse.
        ECHO PLAYER [Round: 8 seconds]
        EQUAL ROUNDTIME 8
        EQUAL CHASTABLE 6
      ENDIF
      IFVAR CHASTABLE = 4
        REMOVEITEM -1
        ECHO PLAYER You carefully sew a rotting leg onto a rotting corpse.
        ECHO OTHERS %N carefully sews a rotting leg onto a rotting corpse.
        ECHO PLAYER [Round: 8 seconds]
        EQUAL ROUNDTIME 8
        EQUAL CHASTABLE 5
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB LOOK 0
  CLEARVERB
  IFVAR CHASTABLE = 0
    ECHO PLAYER The table is empty.
  ENDIF
  IFVAR CHASTABLE > 0
    IFVAR CHASTABLE ! 6
      ECHO PLAYER There is a rotting corpse on the table, missing some limbs.
    ENDIF
