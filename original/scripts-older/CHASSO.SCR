INUMBER 438
  NAME 836
  MISC
  WEIGHT 1000
  VOLUME 1000
  ARTICLE A
  HIDDEN
INUMBER 439
  NAME 836
  FOOD
  WEIGHT 1
  VOLUME 1
  ARTICLE A
  PARAMETER1 8
  IFPREVERB EAT -1
    CLEARVERB
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER You consume the rest of %a.
      ECHO OTHERS %N consumes the rest of %a and wipes off %h chin with a satisfied smile.
    ENDIF
    IFVAR ITEMVAL2 = 2
      ECHO PLAYER You gobble up half the remaining rat, savoring its juicy flesh.
      ECHO OTHERS %N gobbles up half the remaining rat, savoring its juicy flesh.
    ENDIF
    IFVAR ITEMVAL2 = 3
      ECHO PLAYER You bite off the right hind leg of %a, nearly choking on it as you swallow.
      ECHO OTHERS %N bites off the right hind leg of %a, nearly choking on it as %s swallows.
    ENDIF
    IFVAR ITEMVAL2 = 4
      ECHO PLAYER You bite off the left hind leg of %a, crunching on the bones as you chew.
      ECHO OTHERS %N bites off the left hind leg of %a, crunching on the bones as %s chews.
    ENDIF
    IFVAR ITEMVAL2 = 5
      ECHO PLAYER You carefully bite off the right front leg of %a, momentarily getting a toe stuck in your teeth.
      ECHO OTHERS %N carefully bites off the right front leg of %a, momentarily getting a toe stuck in %h front teeth.
    ENDIF
    IFVAR ITEMVAL2 = 6
      ECHO PLAYER You carefully bite off the left front leg of %a.
      ECHO OTHERS %N carefully bites off the left front leg of %a.
    ENDIF
    IFVAR ITEMVAL2 = 7
      ECHO PLAYER You bite the tail off of %a, slurping it down like a long noodle.
      ECHO OTHERS %N bites the tail off of %a, slurping it down like a long noodle.
    ENDIF
    IFVAR ITEMVAL2 = 8
      ECHO PLAYER You bite the head off of %a.
      ECHO OTHERS %N bites the head off of %a.
    ENDIF
    SUB ITEMVAL2 1
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER There's one bite left.
    ENDIF
    IFVAR ITEMVAL2 = 0
      ECHO PLAYER That was the last of it.
      REMOVEITEM -1
    ENDIF
  ENDIF
INUMBER 440
  NAME 381
  FOOD
  WEIGHT 2
  VOLUME 5
  ARTICLE A
  PARAMETER1 3
  IFPREVERB WEAR -1
    CLEARVERB
    IFVAR RAC ! 7
      IFVAR ITEMVAL2 = 0
        ECHO PLAYER It's out of juice.
      ENDIF
      IFVAR ITEMVAL2 ! 0
        ECHO PLAYER You connect the electrodes of %a up to your temples.
        ECHO OTHERS %N connects the electrodes of %a up to %h temples.
        SPELL 103 50
        SUB ITEMVAL2 1
        EQUAL ROUNDTIME 10
        ECHO PLAYER [Round: 10 seconds]
      ENDIF
    ENDIF
    IFVAR RAC = 7
      IFVAR ITEMVAL2 = 0
        ECHO PLAYER It's out of juice.
      ENDIF
      IFVAR ITEMVAL2 ! 0
        ECHO PLAYER You connect the electrodes of %a up to your temples.
        ECHO OTHERS %N connects the electrodes of %a up to %h temples.
        SPELL 335 100
        SUB ITEMVAL2 1
        EQUAL ROUNDTIME 10
        ECHO PLAYER [Round: 10 seconds]
      ENDIF
    ENDIF
  ENDIF
  IFPREVERB EAT -1
    CLEARVERB
    ECHO PLAYER You can't eat that.
  ENDIF
  IFPREVERB LOOK -1
    CLEARVERB
    ECHO PLAYER The device looks like a squat metal box with two electrodes leading out of it.
  ENDIF
INUMBER 551
  NAME 147
  LIQUID
  PARAMETER1 5
  WEIGHT 1
  VOLUME 1
  ARTICLE SOME
  IFPREVERB PULL -1
    CLEARVERB
    IFVAR RAC ! 7
      ECHO PLAYER You smear oil all over yourself.
      ECHO OTHERS %N smears oil all over %iself.
      APPEAR %S is completely covered is black oil.
      EQUAL ROUNDTIME 5
      ECHO PLAYER [Round: 5 seconds]
      SUB ITEMVAL2 1
    ENDIF
    IFVAR RAC = 7
      ECHO PLAYER You oil your joints.
      ECHO OTHERS %N oils %h joints.
      SPELL 515 50
      EQUAL ROUNDTIME 5
      ECHO PLAYER [Round: 5 seconds]
      SUB ITEMVAL2 1
    ENDIF
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER There is one dose left.
    ENDIF
    IFVAR ITEMVAL2 = 0
      ECHO PLAYER That was the last of it.
      REMOVEITEM -1
    ENDIF
  ENDIF
  IFVERB DRINK -1
    ECHO PLAYER Yech!
    SPELL 321 500
  ENDIF
