INUMBER 1833
  NAME 1531
  MISC
  WORN_BELT
  WEIGHT 1
  VOLUME 1
  SUBSTANCE SOFTMETAL
  ENCRUSTABLE
  ARTICLE A
  PARAMETER2 20
  CRAFTABLE
  IFPREVERB WEAR -1
    CLEARVERB
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER It's already in your pocket.
    ENDIF
    IFVAR ITEMVAL2 = 0
      EQUAL ITEMVAL2 1
      ECHO PLAYER You tuck %a in your breast pocket.
      ECHO OTHERS %N tucks %a in %h breast pocket.
    ENDIF
  ENDIF
  IFPREVERB REMOVE -1
    CLEARVERB
    IFVAR ITEMVAL2 = 0
      ECHO PLAYER It's not in your pocket right now.
    ENDIF
    IFVAR ITEMVAL2 = 1
      EQUAL ITEMVAL2 0
      ECHO PLAYER You take %a out of your breast pocket.
      ECHO OTHERS %N takes %a out of %h breast pocket.
    ENDIF
  ENDIF
  IFPREVERB WAVE -1
    CLEARVERB
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER You'll have to remove it from your pocket first.
    ENDIF
    IFVAR ITEMVAL2 = 0
      ECHO PLAYER You swing %a around in a wide circle.
      ECHO OTHERS %N swings %a around in a wide circle.
    ENDIF
  ENDIF
  IFPREVERB OPEN -1
    CLEARVERB
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER You'll have to remove it from your pocket first.
    ENDIF
    IFVAR ITEMVAL2 = 0
      IFVAR ITEMVAL5 = 1
        ECHO PLAYER It's already open.
      ENDIF
      IFVAR ITEMVAL5 = 0
        ECHO PLAYER You push a button on the top of %a and it snaps open.
        ECHO OTHERS %N pushes a button on the top of %a and it snaps open.
        EQUAL ITEMVAL5 1
      ENDIF
    ENDIF
  ENDIF
  IFPREVERB CLOSE -1
    CLEARVERB
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER You'll have to remove it from your pocket first.
    ENDIF
    IFVAR ITEMVAL2 = 0
      IFVAR ITEMVAL5 = 0
        ECHO PLAYER It's already closed.
      ENDIF
      IFVAR ITEMVAL5 = 1
        ECHO PLAYER You push %a closed with a click.
        ECHO OTHERS %N pushes %a closed with a click.
        EQUAL ITEMVAL5 0
      ENDIF
    ENDIF
  ENDIF
  IFPREVERB READ -1
    CLEARVERB
    IFVAR ITEMVAL2 = 1
      ECHO PLAYER You'll have to remove it from your pocket first.
    ENDIF
    IFVAR ITEMVAL2 = 0
      IFVAR ITEMVAL5 = 0
        ECHO PLAYER It's closed, so you can't see the face.
      ENDIF
      IFVAR ITEMVAL5 = 1
        ECHO OTHERS %N checks the time on %a.
        EQUAL ITEMVAL3 TIM
        MOD ITEMVAL3 12
        IFVAR ITEMVAL3 = 0
          EQUAL ITEMVAL3 12
        ENDIF
        STRCVT 0 ITEMVAL3
        IFVAR TIM < 12
          ECHO PLAYER It's about %0 am.
        ENDIF
        IFVAR TIM > 11
          ECHO PLAYER It's about %0 pm.
        ENDIF
      ENDIF
    ENDIF
  ENDIF
  IFPREVERB GET -1
    EQUAL ITEMVAL2 0
  ENDIF
