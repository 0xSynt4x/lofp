INUMBER 1830
  NAME 329
  MISC
  CONTAINER IN
  WEIGHT 1
  VOLUME 5
  IFPREVERB OPEN -1
    IFVAR ITEMVAL5 ! 0
      CLEARVERB
      ECHO PLAYER You open %a, allowing a single flitterer to escape, and quickly close it again.
      ECHO OTHERS %N opens %a, and a beautiful golden winged creature flies out.
      SUB ITEMVAL5 1
      GENMON 99
    ENDIF
    IFVAR ITEMVAL5 = 0
      CLEARVERB
      ECHO PLAYER There are no more flitterers in the cage.
    ENDIF
  ENDIF
  IFPREVERB PUSH -1
    CLEARVERB
    ECHO PLAYER You press a concealed button on the bottom of %a.
    RANDOM DUMMY1 1 100 0
    EQUAL ITEMVAL2 DUMMY1
    IFVAR ITEMVAL5 > 9
      ECHO PLAYER The cage appears to be full to capacity.
    ELSE
      MOD ITEMVAL2 3
      IFVAR ITEMVAL2 ! 1
        ECHO ALL A mysterious scent wafts from %a. Several minutes later, a beautiful golden flitterer alights upon it. %N slams the door shut, trapping it inside.
        ECHO PLAYER [Roundtime: 30 seconds]
        EQUAL ROUNDTIME 30
        ADD ITEMVAL5 1
      ENDIF
      IFVAR ITEMVAL2 = 1
        ECHO ALL A mysterious scent wafts from %a, but nothing else seems to happen.
        ECHO PLAYER It would seem no flitterers caught the scent.
        ECHO PLAYER [Roundtime: 30 seconds]
        EQUAL ROUNDTIME 30
      ENDIF
    ENDIF
  ENDIF
