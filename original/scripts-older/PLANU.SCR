EXTEND 2 of sparkling water
PUT 2 198 ADJ1=56 VAL2=100

IFVERB DRINK -1
        IFVAR ARCHNUM = 198
                IFVAR ITEMADJ1 = 56
                        ECHO PLAYER The pure, clean water is a balm to your soul and mind.
		ENDIF
        ENDIF
ENDIF

IFSAY Guard_yourself_my_home.
        IFVAR INTNUM61 = 79
                ECHO ALL You feel a sense of acknowledgement as something seems to shimmer behind the falls.
                EQUAL SHINLOCK 0
        ENDIF
        IFVAR INTNUM61 ! 79
                ECHO ALL You hear a groaning sound. Suddenly a fist formed from the stuff of clouds materializes and strikes!
                PLREVENT 1
		CONTPLREVENT
                ECHO ALL %N is slammed by the fist!
                DAMAGEPLR CRUSH 900 The fist smashes you!
        ENDIF
ENDIF

IFSAY Open_the_way!
        IFVAR INTNUM61 = 79
                ECHO ALL You feel a sense of acknowledgement as something seems to shimmer behind the falls.
                EQUAL SHINLOCK 1
        ENDIF
        IFVAR INTNUM61 ! 79
		ECHO ALL You hear a groaning sound. Suddenly a fist formed from the stuff of clouds materializes and strikes!
                PLREVENT 1
                CONTPLREVENT
                ECHO ALL %N is slammed by the fist!
                DAMAGEPLR CRUSH 900 The fist smashes you!
        ENDIF
ENDIF

IFPREVERB GO -1
        IFVAR ARCHNUM = 198
                CLEARVERB
                IFVAR FLAG3 = 33
			ECHO PLAYER You dive deeper into the water, going under the falls themselves, where you see that you can swim east, through an arch.
                        ECHO OTHERS %N swims about in the pool, coming to rest beneath the tumbling falls.
                        EQUAL FLAG2 22
                ENDIF
                IFVAR FLAG3 ! 33
                        ECHO OTHERS %N steps into the pool at the foot of the waterfall.
                        ECHO PLAYER You step into the pool at the foot of the waterfall. The clear, cool water supports your weight in a comfortable fashion.
                        EQUAL FLAG3 33
                ENDIF
        ENDIF
ENDIF

IFPREVERB GO 2
        CLEARVERB
        ECHO OTHERS %N steps into the pool at the foot of the waterfall.
        ECHO PLAYER You step into the pool at the foot of the waterfall. The clear, cool water supports your weight in a comfortable fashion.
        EQUAL FLAG3 33
ENDIF

IFVAR FLAG3 = 33
        IFPREVERB SIT -1
                CLEARVERB
                ECHO PLAYER You sit down in the cool water.
                ECHO OTHERS %N sits down, submerging in the pool up to %h chest.
		POSITION SIT
        ENDIF
        IFPREVERB LAY -1
                CLEARVERB
                ECHO PLAYER You lie down, putting your head under the water.
                ECHO OTHERS %N submerges %iself entirely in the pool.
                POSITION LAY
        ENDIF
        IFPREVERB WAVE -1
                CLEARVERB
                ECHO PLAYER You splash about in the pool.
                ECHO OTHERS %N splashes about in the pool.
	ENDIF
        IFPREVERB KICK -1
                CLEARVERB
                ECHO PLAYER You kick up a stream of water.
                ECHO OTHERS %N kicks up a stream of water!
        ENDIF
        IFPREVERB JUMP -1
                CLEARVERB
		ECHO PLAYER You jump up and down, sending water everywhere!
                ECHO OTHERS %N jumps up and down, sending water everywhere!
        ENDIF
        IFPREVERB PUSH -1
		CLEARVERB
                ECHO PLAYER You push against the bottom of the pool, coasting through the water.
                ECHO OTHERS %N pushes against the bottom of the pool, coasting through the cool water
        ENDIF
        IFPREVERB ROLL -1
                CLEARVERB
                ECHO PLAYER You roll about in the cool, refreshing water.
                ECHO OTHERS %N rolls about in the cool, refreshing water.
        ENDIF
ENDIF

IFPREVERB SMELL -1
	ECHO OTHERS %N breathes deeply.
        CLEARVERB
        ECHO PLAYER The crisp, clean scent of the pine needles fills your head with good thoughts and better emotions.
ENDIF

IFENTRY
        IFVAR NIGHT = 1
                RANDOM DUMMY1 1 100 0
                IFVAR DUMMY1 < 35
                        RANDOM DUMMY2 1 3
                        IFVAR DUMMY2 = 1
                                PLREVENT 40
				CONTPLREVENT
                                ECHO ALL A shooting star lights up the night sky with its bright tail for one brief moment.
                        ENDIF
                        IFVAR DUMMY2 = 2
                                PLREVENT 33
                                CONTPLREVENT
                                ECHO ALL A gentle breeze stirs a group of lightning bugs awake. Their blinking, flashing bodiesbreak up the darkness until they settle in place again.
                        ENDIF
                        IFVAR DUMMY2 = 3
                                PLREVENT 3
                                CONTPLREVENT
                                ECHO ALL You hear a sound from the stand of white pines.
				PLREVENT 2
                                CONTPLREVENT
                                ECHO ALL You identify the sound as the hooting of an howl and calm your beating heart.
                        ENDIF
                ENDIF
        ENDIF
ENDIF

