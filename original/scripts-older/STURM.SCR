ITEM 8 1305
IFPREVERB SIT -1
	IFVAR FLAG1 ! 1
		CLEARVERB
		POSITION SIT
		ECHO PLAYER You take a seat on the couch.
		ECHO OTHERS %N takes a seat on the couch.
		EQUAL FLAG1 1
	ENDIF
ENDIF
IFPREVERB LAY -1
	IFVAR FLAG1 ! 2
		CLEARVERB
		POSITION LAY
		ECHO PLAYER You lay down on the plush rug in front of the fireplace.
		ECHO OTHERS %N lays down on the plush rug in front of the fireplace.
		EQUAL FLAG1 2
	ENDIF
ENDIF
IFPREVERB STAND -1
	IFVAR FLAG1 = 1
		CLEARVERB
		ECHO PLAYER You get up from the couch.
		ECHO OTHERS %N gets up from the couch.
		POSITION STAND
		EQUAL FLAG1 0
	ENDIF
	IFVAR FLAG1 = 2
		CLEARVERB
		ECHO PLAYER You get up off the rug.
		ECHO OTHERS %N gets up off the rug.
		POSITION STAND
		EQUAL FLAG1 0
	ENDIF
ENDIF
IFPREVERB LIGHT 7
	CLEARVERB
	IFVAR ITEMVAL5 = 0
		ECHO OTHERS %N starts to build a small fire in the fireplace.
		ECHO PLAYER You build a small fire in the fireplace.
		REMOVEITEM 7
		NEWITEM 7 195 VAL5=1
		NEWPUT 7 196 ADJ1=755
	ELSE
		ECHO PLAYER The fire is already lit.
	ENDIF
ENDIF
IFPREVERB POKE 7
	CLEARVERB
	IFVAR ITEMVAL5 = 1
		ECHO OTHERS %N stokes the fire until it blazes up nicely.
		ECHO PLAYER You stoke the fire until it blazes up nicely.
	ELSE
		ECHO PLAYER The fire is not lit.
	ENDIF
ENDIF
IFVERB RECALL -1
	ECHO PLAYER As you think back to all the stories you have heard about dragons, one comes quickly to mind. A mighty dragon, Banethalas, who was a friend to man and once was the guardian of Everwind Valley in the Teeth of Shartan and the village within. He disappeared years ago just before the attack on the Village of Everwind. No one has heard from him since.
ENDIF
IFSAY BANE
	ECHO OTHERS %N becomes very still.
	ECHO PLAYER The statue turns to you and says "Welcome in peace to this home. May you always bask in sunshine and soar with the wind."
	SPELL 201
ENDIF
IFSAY BANETHALAS
	ECHO OTHERS %N becomes very still.
	ECHO PLAYER The statue turns to you and says "Welcome in peace to this home. May you always bask in sunshine and soar with the wind."
	SPELL 201
ENDIF

IFSAY HAIL_BROTHER!
  IFVAR STURMTALON = 0
    EQUAL STURMTALON 1
    ECHO ALL The statue turns it head and says, "Hail brother!"
    ECHO ALL The statue animates for a moment, lifting a giant talon to reveal an opening.
    NEWITEM 9 72 VAL2=440
    AFFECT 440
    ECHO ALL The statue animates for a moment, lifting a giant talon to reveal an opening.
    NEWITEM 9 72 VAL2=759
    AFFECT 759
  ELSE
    ECHO ALL The statue turns it head and says, "Hail brother!"
  ENDIF
ENDIF

IFSAY GUARD_THE_WAY
  IFVAR STURMTALON = 1
    EQUAL STURMTALON 0
    ECHO ALL The statue turns it head says, "Always have I guarded you and yours."
    ECHO ALL The statue animates for a moment, lowering its talon blocking an opening.
    REMOVEITEM 9
    AFFECT 440
    ECHO ALL The statue animates for a moment, lowering its talon blocking an opening.
    REMOVEITEM 9
    AFFECT 759
  ELSE
    ECHO ALL The statue turns it head and says, "Always have I guarded you and yours."
  ENDIF
ENDIF

