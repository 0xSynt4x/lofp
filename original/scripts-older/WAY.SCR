;
;---------------------------------------------------
;
;change the time interval to every 30 seconds instead of 75. 
CEVENT 61 10 2238
;----declare variables for timers
VARIABLE WAYBARBRAWL
VARIABLE PROPHETPORTAL
VARIABLE FIREPOTS
VARIABLE ITSADRAKIN
;
;Put the timers in action
;
ADD WAYBARBRAWL 1
ADD PROPHETPORTAL 1
;adds a random to the firepots timer
RANDOM DUMMY1 1 10 0
IFVAR FIREPOTS < 30
  ADD FIREPOTS DUMMY1
ENDIF
IFVAR ITSADRAKIN > 10
  EQUAL ITSADRAKIN 0
  ELSE
  ADD ITSADRAKIN 1
ENDIF
IFVAR ITSADRAKIN = 1
    AFFECT 206  
    ECHO ALL A dark shadow flits across the fountain. Looking up, you see a drakin warrior wheeling away through the clouds.
     AFFECT 201
     ECHO ALL  A shout goes up from the wall as the sentry spots a drakin skimming overhead.
ENDIF
IFVAR ITSADRAKIN = 2
     AFFECT 206
     ECHO ALL You hear a crash and whoosh of flame from nearby as a drakin firepot hits its target.
ENDIF
IFVAR ITSADRAKIN = 5
    AFFECT 206
        ECHO ALL A fire cart races by headed for the Poor Quarters.
ENDIF
IFVAR ITSADRAKIN = 6
        AFFECT 204
        ECHO ALL A dazed adventurer steps out into the bazaar, still groggy from being rezzed. He mutters under his breath about damned drakins.
ENDIF
IFVAR ITSADRAKIN = 7
        AFFECT 206
        ECHO ALL A squadron of drakins pass by overhead in precise battle formation.
ENDIF
IFVAR ITSADRAKIN = 8
        AFFECT 3176
        ECHO ALL A table of patrons looks up with a hostile glare as a drakin merchant enters. She looks around, then slowly backs out the door.
ENDIF
IFVAR ITSADRAKIN = 9
  AFFECT 201
  ECHO ALL You hear a muffled curse, and a volley of arrows arches into the sky as drakins wheel in toward the center of the city.
ENDIF

;
;Define the events
;
;barbrawl event once per minute
;
IFVAR WAYBARBRAWL > 1
AFFECT 2238
RANDOM dummy1 1 5 0
IFVAR dummy1 = 1
    ECHO ALL A broken bottle flies across the room, narrowly missing your ead.
ENDIF
IFVAR dummy1 = 2
     ECHO ALL A fat drunken drakin staggers up to you, takes a wild swing at your head and then passes out.
ENDIF
IFVAR dummy1 = 3
   ECHO ALL A bar room brawl begins and rages from table to table for a few moments.
ENDIF
;reset brawl timer
EQUAL WAYBARBRAWL 0
ENDIF
;
;portal every 2 minutes 
;
IFVAR PROPHETPORTAL > 3
AFFECT 1505
  RANDOM dummy2 1 8 0
IFVAR dummy2 = 1
   ECHO ALL A strange mist clouds the portal and suddenly a view of Fayd comes into focus, you swear you can hear the sounds of the merchants and commoners.
ENDIF
IFVAR dummy2 = 2
     ECHO ALL A strange mist clouds the portal and suddenly a view of hero's hill comes to life, you notice however that there seem to be many new statues that you never have seen before.
ENDIF
IFVAR dummy2 = 3
     ECHO ALL A strange mist clouds the portal and instantly a dark, strange, land comes to life that is obviously not any place on Andor. A sudden loud scream is heard followed by laughter, and you shudder at the implications.
ENDIF
IFVAR dummy2 = 4
       ECHO ALL A strange mist clouds the portal and a beautiful tropical island comes into view. The smell of salt air wisps past your nostrils as you gaze at the various citizens in what seems to be a tropical sea-faring town.
ENDIF
IFVAR dummy2 = 5
        ECHO ALL A strange mist clouds the portal and you are shocked to see what can only be described as the pit of Hell, you swear that you can feel the heat radiating from the portal.
ENDIF
IFVAR dummy2 = 6
         ECHO ALL A strange mist clouds the portal and suddenly the view of a clear blue sky comes into focus. The gently floating clouds in the crisp summer air seems to smile warmly upon you.
ENDIF
;reset portal timer
EQUAL PROPHETPORTAL 0
ENDIF
