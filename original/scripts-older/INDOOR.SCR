;
MACRO 99
IFPREVERB POKE -1
	ECHO PLAYER You poke the sheep.
	ECHO OTHERS %N is performing unspeakable acts on the sheep.
	CLEARVERB
ENDIF
IFPREVERB HUG -1
	ECHO PLAYER The sheep protests with a "Baah!" as you hug it.
	ECHO OTHERS The sheep protests with a "Baah!" as %n hugs it.
	CLEARVERB
ENDIF
IFPREVERB KISS -1
	ECHO PLAYER You kiss the sheep, ignoring the health considerations involved.
	ECHO OTHERS %N kisses the sheep.
	CLEARVERB
ENDIF
IFPREVERB TOUCH -1
	ECHO PLAYER You pet the sheep.
	ECHO OTHERS %N pets the sheep.
	CLEARVERB
ENDIF
IFPREVERB GET -1
	CLEARVERB
	IFITEM 9
		ECHO PLAYER There doesn't seem to be room to do that here.
		STOP
	ENDIF
	IFNOITEM 9
		IFVAR DEAD = 1
			EQUAL ROUNDTIME 10
			ECHO OTHERS %N sneaks bravely up to the ferocious dead sheep.
			ECHO PLAYER You go to clip the sheep, but discover that the wool has been ruined.%c [Round: 10 sec]
		ENDIF
		IFVAR SLEEPING = 1
			EQUAL ROUNDTIME 10
			ECHO OTHERS %N sneaks up on the sleeping sheep and clips off some wool.
			ECHO PLAYER You sneak up on the sleeping sheep and clip off some wool.%c [Round: 10 sec]
			NEWITEM 9 1374
		ENDIF
		IFVAR SLEEPING = 0
			IFVAR DEAD = 0
				ECHO OTHERS %n tries to catch the sheep!
				ECHO PLAYER You attempt to catch the sheep and hold it down to cut off some of its wool.%c
				SKILLCHECK 15 0 DUMMY1
				IFVAR DUMMY1 >= 0
					EQUAL ROUNDTIME 20
					ECHO OTHERS You witness the amazing sight of %n's expertise in wool gathering. Within moments of catching the sheep %s successfully clips off a generous portion or wool.%c>%c%N lets the sheep go.
					ECHO PLAYER %cYou nimbly catch the wooly sheep and clip off a generous portion of wool.%c [Round: 20 sec]
					NEWITEM 9 1374
				ENDIF
				IFVAR DUMMY1 < 0
					IFVAR DUMMY1 > -15
						EQUAL ROUNDTIME 5
						ECHO OTHERS The sheep evades %n's grasp.
						ECHO PLAYER The sheep avoids your grasp.%c [Round: 5 sec]
					ENDIF
				ENDIF
				IFVAR DUMMY1 < -14
					EQUAL ROUNDTIME 5
					ECHO OTHERS %N falls flat on %h face, and the sheep bites %i.
					ECHO PLAYER Just when you thought you had it, the sheep slips from your grasp.%c [Round: 5 sec]
					DAMAGEPLR SLASH 4 To add injury to insult, the sheep gives you a little bite.
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDIF
