NUMBER 2015
NAME Abner's raft
*DESCRIPTION_START
This is a simple craft constructed from logs strapped together. One of Abner's sons uses a long pole to push and guide the raft across the river.
*DESCRIPTION_END
ASTRAL
EXIT ABOVE 2150
DAY_LIGHT
IFLOGIN
	EQUAL INTNUM7 0
	MOVE 556
ENDIF
IFENTRY
	ECHO PLAYER Abner's son informs you that the raft will be leaving in less than a minute.
	IFNOITEM 0
		NEWITEM 0 412
		SETEVENT 2 10 ALWAYS
		CONTEVENT 2
		REMOVEITEM 0
		ECHO ALL Without so much as a warning, Abner's son lifts up the gangplank and pushes off. You'll be on the other side of the river soon.
		AFFECT 556
		ECHO ALL One of Abner's sons suddenly picks up the gangplank and shoves off without you.
		REMOVEITEM 1
		REMOVEITEM 2
		AFFECT 2015
		SETEVENT 3 10 ALWAYS
		CONTEVENT 3
		ECHO ALL You are about halfway across the river now. Abner's son groans and sweats with effort as he continues to push you across.
		SETEVENT 4 10 ALWAYS
		CONTEVENT 4
		ECHO ALL The raft arrives on the other side of the river. Abner's son secures it with a rope and puts down the gangplank.
		NEWITEM 1 412
		EQUAL INTNUM7 0
	ENDIF
ENDIF
IFPREVERB GO 0
	ECHO PLAYER You exit the raft via the gangplank, realizing that you could miss the boat.
	ECHO OTHERS %N heads down the gangplank.
	MOVE 556
	AFFECT 556
	ECHO OTHERS %N gets off the raft.
	AFFECT 2015
	CLEARVERB
ENDIF
IFPREVERB GO 1
	ECHO PLAYER You exit the raft via the gangplank.
	ECHO OTHERS %N heads down the gangplank.
	EQUAL INTNUM7 0
	MOVE 558
	AFFECT 558
	ECHO OTHERS %N gets off Abner's raft.
	AFFECT 2015
	IFVAR PLRSINROOM = 0
		AFFECT 558
		ECHO ALL As the last passenger steps off the raft, Abner's son gives one of Ebby's daughters an ugly look, picks up the gangplank and head back across the river.
		AFFECT 2015
		REMOVEITEM 1
	ENDIF
	CLEARVERB
ENDIF
IFVERB JUMP -1
	IFVAR FLAG1 = 1
		ECHO PLAYER You jump into the river!
		ECHO OTHERS %N jumps into the river... hope %s can swim!
		EQUAL INTNUM7 0
		MOVE 2014
		AFFECT 2014
		ECHO OTHERS %N just jumped from Abner's Raft into the river!
		AFFECT 2015
	ENDIF
	IFVAR FLAG1 = 0
		ECHO PLAYER Jumping around on a little wooden raft like this is not a smart idea.
		ECHO OTHERS %N endangers everyone's life by jumping around the raft.
		EQUAL FLAG1 1
	ENDIF
	CLEARVERB
ENDIF
;
NUMBER 2016
NAME Ebby's dinghy
*DESCRIPTION_START
This is a tiny craft of questionable water-worthiness. Another one of Ebby's daughters uses a pair of oars to row the boat across the river.
*DESCRIPTION_END
ASTRAL
EXIT ABOVE 2150
DAY_LIGHT
IFLOGIN
	EQUAL INTNUM8 0
	MOVE 558
ENDIF
IFENTRY
	ECHO PLAYER One of Ebby's daughters informs you that the dinghy will be leaving in under a minute.
	IFNOITEM 0
		NEWITEM 0 412
		SETEVENT 6 10 ALWAYS
		CONTEVENT 6
		REMOVEITEM 0
		ECHO ALL Without so much as a warning, Ebby's daughter lifts up the gangplank and pushes off. You'll be on the other side of the river soon.
		AFFECT 558
		ECHO ALL One of Ebby's daughters suddenly picks up the gangplank and rows off without you.
		REMOVEITEM 2
		REMOVEITEM 3
		AFFECT 2016
		SETEVENT 18 10 ALWAYS
		CONTEVENT 18
		ECHO ALL You are about halfway across the river now. Ebby's daughter glows with effort as she continues to row you across.
		SETEVENT 19 10 ALWAYS
		CONTEVENT 19
		ECHO ALL The dinghy arrives on the otherside of the river. Ebby's daughter secures it with a rope and puts down the gangplank.
		NEWITEM 1 412
		EQUAL INTNUM8 0
	ENDIF
ENDIF
IFPREVERB GO 0
	ECHO PLAYER You exit the raft via the gangplank, realizing that you could miss the boat.
	ECHO OTHERS %N steps into the dinghy.
	MOVE 558
	AFFECT 558
	ECHO OTHERS %N steps out of the dinghy.
	AFFECT 2016
	CLEARVERB
ENDIF
IFPREVERB GO 1
	ECHO PLAYER You exit the raft via the gangplank.
	ECHO OTHERS %N heads down the gangplank.
	EQUAL INTNUM8 0
	MOVE 556
	AFFECT 556
	ECHO OTHERS %N gets off Ebby's dinghy.
	AFFECT 2016
	IFVAR PLRSINROOM = 0
		AFFECT 558
		ECHO ALL Ebby's daughter gives one of Abner's sons an ugly look, picks up the gangplank and rows back across the river.
		AFFECT 2016
		REMOVEITEM 1
	ENDIF
	CLEARVERB
ENDIF
IFVERB JUMP -1
	IFVAR FLAG1 = 1
		ECHO PLAYER You jump into the river!
		ECHO OTHERS %N jumps into the river... hope %s can swim!
		EQUAL INTNUM8 0
		MOVE 2014
		AFFECT 2014
		ECHO OTHERS %N just jumped from Abner's Raft into the river!
		AFFECT 2016
	ENDIF
	IFVAR FLAG1 = 0
		ECHO PLAYER Jumping around on a little boat like this is not a smart idea.
		ECHO OTHERS %N endangers everyone's life by rocking around the boat.
		EQUAL FLAG1 1
	ENDIF
	CLEARVERB
ENDIF
