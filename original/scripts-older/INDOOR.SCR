EXTEND 1 from one reality into another
IFENTRY
	ECHO OTHERS The empty space around %n ripples as %s draws nearer and nearer, coming to rest next to you.
	SETITEMVAL 1 2 DAMNEXIT1
	EQUAL ROUNDTIME 5
ENDIF
IFVERB SIT -1
	EQUAL FLAG1 50
ENDIF
IFVERB LAY -1
	EQUAL FLAG1 50
ENDIF
IFVERB STAND -1
	EQUAL FLAG1 0
ENDIF
