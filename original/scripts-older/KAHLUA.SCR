MACRO 19
IFENTRY
  IFVAR DISGUISED ! 1
    IFVAR INTNUM3 ! 1
      IFVAR ORG ! 20
        RANDOM DUMMY1 1 10 0
        IFVAR DUMMY1 > 3
          DAMAGEPLR SLASH 50 An armed member of the Order of the Way slashes at you.
        ENDIF
        GENMON 133
      ENDIF
    ENDIF
  ENDIF
ENDIF
