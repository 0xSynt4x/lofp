
;

NUMBER 2308
NAME Tower, Oval Room
REGION 181
CHANNEL 181
IFVAR INTNUM3 ! 1
        CALL 65
ENDIF

*DESCRIPTION_START
You are in the west side of an elliptical oval room, a place without
furniture or markings. The floor has a single spot upon it, a circle about
large enough to stand in.
*DESCRIPTION_END

EXIT E 2309

ITEM 0 1677
PUT 0 840
IFPREVERB LOOK -1
        IFVAR ARCHNUM = 840
                CLEARVERB
                ECHO PLAYER The circle's size is hard to pin down. You thought it was smaller than this...
        ENDIF
ENDIF
IFPREVERB GO -1
        IFVAR ARCHNUM = 840
                CLEARVERB
                ECHO PLAYER You step into the circle.
                ECHO OTHERS %N steps into the circle.
                EQUAL DUMMY1 PLRSINROOM
                AFFECT 2309
                EQUAL DUMMY2 PLRSINROOM
                AFFECT 2308
                SUB DUMMY1 DUMMY2
                IFVAR DUMMY1 < -1
                        ECHO ALL You feel the floor shift slightly upwards.
                        AFFECT 2309
                        ECHO ALL You feel the floor shift slightly downwards.
                ENDIF
                IFVAR DUMMY1 > 1
                        ECHO ALL You feel the floor shift slightly downwards.
                        AFFECT 2309
                        ECHO ALL You feel the floor shift slightly upwards.
                ENDIF
                IFVAR DUMMY1 > -2
                        IFVAR DUMMY1 < 2
                                ECHO ALL The floor moves up a little, down a little, then rises, forcing you through the ceiling! The sensation is much like sinking through mud...
                                MOVEALL 2311
                                AFFECT 2309
                                ECHO ALL The floor moves up a little, down a little, then rises, forcing you through the ceiling! The sensation is much like sinking through mud...
                                MOVEALL 2311
                                AFFECT 2311
                                ECHO ALL The towertop shivers and deforms, shapes rising from it.
                        ENDIF
                ENDIF
        ENDIF
ENDIF



;
