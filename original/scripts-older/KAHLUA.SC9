;Witchlet's Office
NUMBER 1315
NAME Witchlet's Cottage
FIXED_LIGHT
LOOM
ASTRAL
*DESCRIPTION_START
A blackened iron cauldron hangs above glowing coals in the brick hearthed
fireplace. Bundles of withered herbs hang from the rafters, dropping pollen
and dust as you pass under them. In one corner, a row of steel cages stand,
some occupied, others awaiting Witchlet's latest experiment. 
*DESCRIPTION_END
ITEM 0 1505
PUT 0 1497 ADJ1=42
ITEM 1 361 ADJ1=112
EXTEND 1 with an iron-barred door
ITEM 2 343 ADJ1=33
ITEM 3 1515

IFPREVERB TAKE -1
  IFVAR ARCHNUM = 1497
    CLEARVERB
    ECHO PLAYER You scoop up a ladle full of bubbling liquid and drink it.
    RANDOM DUMMY1 1 10 0
    IFVAR DUMMY1 = 1
      SPELL 133
      SPELL 133
      SPELL 133
    ENDIF
    IFVAR DUMMY1 = 2
      SPELL 315
      SPELL 321 30
    ENDIF
    IFVAR DUMMY1 = 3
      SPELL 536
    ENDIF
    IFVAR DUMMY1 = 4
      spell 324
    ENDIF
    IFVAR DUMMY1 = 5
      ECHO PLAYER You feel your ears begin to grow.
      APPEAR Donkey ears sprout from %n's head.
    ENDIF
    IFVAR DUMMy1 = 6
      ECHO PLAYER You feel suddenly powerful.
      ADD FATPOINTS 200
    ENDIF
    IFVAR DUMMY1 = 7
      ECHO PLAYER Mana races through your body!
      ADD MANAPOINTS 300
    ENDIF
    IFVAR DUMMY1 = 8
      ECHO PLAYER You suddenly feel completely drained.
      SUB FATPOINTS 150
    ENDIF
    IFVAR DUMMY1 = 9
      ECHO PLAYER You feel suddenly odd, as if your molecules were thinning out.
      SPELL 225
    ENDIF
    ENDIF
ENDIF
IFPREVERB GO 1
  CLEARVERB
  IFVAR FLAG1 ! 5
    CLEARVERB
    ECHO PLAYER You step inside the cage and the door slams shut.
    ECHO OTHERS %n steps inside the cage and the door slams shut.
    EQUAL FLAG1 5
    SPELL 231 300
  ELSE
    ECHO PLAYER You *are* in the cage....
  ENDIF
ENDIF
IFTOUCH -1
  IFVAR FLAG1 = 5
    CLEARVERB
    ECHO PLAYER You can't reach that from here.
  ENDIF
ENDIF
IFPREVERB CAST -1
  IFVAR FLAG1 = 5
    CLEARVERB
    ECHO PLAYER There's barely room to move in here, let alone cast a spell.
  ENDIF
ENDIF
IFSAY Witchlet_is_a_goddess
  IFVAR FLAG1 = 5
    EQUAL FLAG1 0
    ECHO ALL The cage door swings open.
  ENDIF
ENDIF
