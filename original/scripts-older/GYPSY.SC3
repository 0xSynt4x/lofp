   NEWITEM 8 546 ADJ1=1226 ADJ2=77
   NEWPUT 8 237 ADJ1=259 ADJ2=1 VAL2=10
  ELSE
   ECHO PLAYER There is a glass on the ground.
   CLEARVERB
  ENDIF
 ENDIF
ENDIF
