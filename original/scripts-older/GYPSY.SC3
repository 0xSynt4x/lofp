ITEM 2 376 ADJ1=357
ITEM 3 346 ADJ1=1110
EXTEND 3 in relief
ITEM 4 72 ADJ1=87 VAL2=2439
EXTEND 4 leading back along a wide transverse root
ITEM 5 60 ADJ1=440 ADJ2=1110 VAL2=3452
ITEM 6 60 ADJ1=440 ADJ2=1110 VAL2=3453
EXTEND 5 leading to a small forge
EXTEND 6 leading to a fletching workshop
