IFITEM 6
	IFPREVERB PULL 6
		CLEARVERB
		EQUAL DUMMY4 STR
		DIV DUMMY4 2
                SUB HAVPILE1 DUMMY4
                IFVAR HAVPILE1 > 0
			ECHO PLAYER You pull a chunk of rubble from the ramp into the hallway.
			ECHO OTHERS %N pulls some rubble into the hallway.
                        NEWITEM 8 1221
                        ADD HAVPILE2 1
		ELSE
			ECHO PLAYER You pull the last rock from the ramp into the hallway.
			ECHO OTHERS Yeah!  %N just pulled the last stuff from the ramp.
                        IFVAR HAVPILE2 > 0
				ECHO ALL Jarrot exclaims "Well, don't even think of going down the ramp until you get the hallway cleaned!
			ENDIF
		ENDIF
	ENDIF
ENDIF
IFITEM 8
	IFPREVERB GET 8
                SUB HAVPILE2 1
		ECHO PLAYER Jarrot says "Good, good. Now take it outside and drop it."
                IFVAR HAVPILE2 = 0
                        IFVAR HAVPILE1 = 0
				ECHO PLAYER Jarrot exclaims "Great job everyone!"
                        ENDIF
                ENDIF
	ENDIF
ENDIF
IFNOITEM 7
        IFVAR HAVPILE2 > 0
                NEWITEM 7 1221
        ENDIF
ENDIF
