IFVERB PUSH 0
  IFVAR sharkey => 1
    ADD sharkey1 1
     IFVAR sharkey1 = 1
       ECHO PLAYER The headstone seems to shift a little bit.
       ECHO OTHERS %N pushes the headstone and it seems to shift a bit.
     ENDIF
     IFVAR sharkey1 = 2
       ECHO PLAYER The headstone seems to shift a little bit.
       ECHO OTHERS %N pushes the headstone and it seems to shift a bit.
     ENDIF
     IFVAR sharkey1 = 3
       ECHO PLAYER The headstone seems to shift a little bit and then locks into place. You hear what sounds like the earth shifting to the south.
       ECHO OTHERS The headstone shifts a bit as %N pushes it and then locks into place. From the south you can hear what sounds like earth shifting.
       AFFECT 2588
       ECHO ALL The earth begins to shift underneath the withered tree, exposing, after a moment, an open grave!
       NEWITEM 1 231 VAL2=2589
       AFFECT 2587
     ENDIF
     IFVAR sharkey1 > 3
       ECHO PLAYER The headstone is stuck.
       ECHO OTHERS %N tries to push the headstone, to no avail.
     ENDIF
  ENDIF
ENDIF
