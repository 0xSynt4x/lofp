IFPREVERB DEPART -1
  CLEARVERB
  ECHO PLAYER Eternity Inc has given up it's right to resurrect you while you are being interrogated.
  GMMSG %n just tried to depart from the interogration room.
ENDIF

IFPREVERB TOUCH 1
  CLEARVERB
  DAMAGEPLR ELECTRIC 15 You get a mild shock as you near the force-field.
ENDIF

IFPREVERB GO 1
  IFVAR LAWOPENING = 0
    IFVAR LAWBREAKOUT = 0
      CLEARVERB
      ECHO PLAYER A force-field blocks your path.%C
      DAMAGEPLR ELECTRIC 30 Trying to pass through the force-field, %n gets a shock and gets thrown against the far wall.
      POSITION LAY
    ELSE
      IFVAR LAWBREAK > 15
       IFVAR LAWBREAK < 20
        CLEARVERB
        ECHO PLAYER A force-field blocks your path.%C
        DAMAGEPLR ELECTRIC 5 Trying to pass through the force-field, %n gets a shock and gets thrown against the far wall.
        ECHO PLAYER But you notice that the field is weaker.
        POSITION LAY
        ADD LAWBREAK 1
       ELSE
        ECHO PLAYER The force-field has weakened enough for you to pass through.
       ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF

IFPREVERB TOUCH 2
   IFVAR ORG = 3
      IFVAR LAWOPENING = 0 ; FORCE-FIELD IS UP.
        CLEARVERB
        EQUAL LAWOPENING 1
        ECHO ALL %n enters something on the panel.%cThe force-field is switched off.
        REMOVEITEM 1
        NEWITEM 1 716 VAL2=1491
        AFFECT 1491
        ECHO ALL The force-field is switched off.
        REMOVEITEM 1
        NEWITEM 1 716 VAL2=351
      ELSE ; Forcie-field is down.
        IFVAR LAWBREAKOUT = 1
        	ECHO PLAYER The force field looks weakened.
        ENDIF
        CLEARVERB
        EQUAL LAWOPENING 0
        ECHO ALL %n enters something on the panel.%cThe force-field is switched on.
        REMOVEITEM 1
        NEWITEM 1 716 ADJ1=1178 VAL2=1491
        AFFECT 1491
        ECHO ALL The force-field is switched on.
        REMOVEITEM 1
        NEWITEM 1 716 ADJ1=1178 VAL2=351
     ENDIF
   ELSE
     CLEARVERB
     ECHO ALL %N enters something on the panel.%cNothing happens.
   ENDIF
ENDIF

IFPREVERB BREAK 2
  IFVAR LAWBREAK > 15
    CLEARVERB
    ECHO ALL %n's blow to the panel has weakened the force-field.
    EQUAL LAWBREAKOUT 1
  ELSE
    ADD LAWBREAK 1
  ENDIF
ENDIF

IFPREVERB LOOK 2
  IFVAR LAWBREAK > 15
    CLEARVERB
    ECHO PLAYER You can see that the panel has been smashed. Exposed wiring and broken pieces of buttons can be seen.
  ELSE
    IFVAR LAWBREAK < 5
      CLEARVERB
      ECHO PLAYER You can see a panel with several rows of numbered buttons on it.
    ELSE
      CLEARVERB
      ECHO PLAYER The panel looks like it has taken a beaten.
    ENDIF
  ENDIF
ENDIF

IFPREVERB PUSH 2
  IFVAR LAWBREAKOUT ! 0
    IFVAR INTNUM68 > 19 ; TECHNOLOGISTS ONLY CAN FIX THE FORCIE-FIELD
      CLEARVERB
      GMMSG %n is fixing the lawkeepers panel.
      ADD INTNUM68 1
		ECHO PLAYER %cYou feel you have gained technological insight.
      EQUAL ROUNDTIME 60
      EQUAL LAWBREAKOUT 0
      EQUAL LAWBREAK 0
      STRCVT 0 ROUNDTIME
      ECHO PLAYER You begin to rewire the broken controls...
      ECHO PLAYER [Round: %0 seconds]
      ECHO OTHERS %n goes to work on the smashed panel..
      PLREVENT 5
      CONTPLREVENT
      ECHO PLAYER You connect some more wires and test out a few buttons.
      ECHO OTHERS %n continues to work on the smashed panel.
      PLREVENT 5
      CONTPLREVENT
      ECHO PLAYER You hook up the last wire, and something shorts out.
      ECHO OTHERS %n makes a few more connections, and a spark or two flies out of the panel.
      PLREVENT 5
      CONTPLREVENT
      ECHO PLAYER You make a final connection, and everything seems to work fine.
      ECHO OTHERS %n finishes with the repairs and begins to put the panel back into place.
      PLREVENT 5
      CONTPLREVENT
      ECHO PLAYER Finished, you put the last screw back into place.
      ECHO OTHERS %n finishes re-attaching the panel.
    ELSE
      CLEARVERB
      ECHO PLAYER You make an attempt to fix the smashed panel, but realize quickly that you lack the technological training.
      ECHO OTHERS %n makes an attempt to fix the smashed panel, but can't seem to figure out what to do.
    ENDIF
  ENDIF
ENDIF
