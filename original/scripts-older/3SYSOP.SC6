IFSAY I_swear_upon_my_heart.
        IFVAR HEAROATH = 1
                ECHO ALL The officers all nod.
                EQUAL INTNUM6 21
                EQUAL WARRANT 0
                EQUAL HEAROATH 0
        ENDIF
