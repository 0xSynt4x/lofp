IFENTRY
	GMMSG %N just entered the Palace Treasure Room!
ENDIF
IFVERB OPEN 4
	GMMSG %N has found the royal treasure! Will %h steal it?
	IFITEM 4 UNLOCKED
		IFVAR PVAL40 = 2
			ECHO ALL Whatever treasure was here is gone now!
		ENDIF
		IFVAR PVAL40 = 1
			NEWPUT 4 145 ADJ1=93 ADJ2=114 ADJ3=275 VAL1=10000000 VAL4=9001
			NEWPUT 4 314 ADJ1=230 ADJ2=650 ADJ3=5 VAL1=10000000 VAL2=15 VAL3=212 VAL4=9001
			NEWPUT 4 161 ADJ1=147 VAL1=15000 VAL4=9001
			EQUAL PVAL40 2
		ENDIF
	ENDIF
ENDIF
IFVERB SEARCH -1
	RANDOM DUMMY1 1 5 0
	IFVAR DUMMY1 = 5
		ECHO PLAYER You find an plain leather chest among the the mounds of treasure in the room.
	ENDIF
ENDIF
