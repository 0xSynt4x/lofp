; Root
INUMBER 494
NAME 435
WEIGHT 1
VOLUME 1
ARTICLE SOME
SUBSTANCE INSUBSTANTIAL
FOOD
PARAMETER1 10
REAGENT
ifpreverb cast -1
  ifvar itemadj3 = 542
    ifvar manapoints > 26
      ifvar spellnum = 343
        div manapoints 2
        equal idhealroom1 rnum
        equal idheal1 skill30
        div idheal1 2
        clearverb
        equal spellnum 0
        echo others As %n gestures at %a, it vanishes!
        echo player The mandrake root is consumed in the incantation!
        removeitem -1
      endif
    endif
  endif
endif
