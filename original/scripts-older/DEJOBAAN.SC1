INUMBER 1004
NAME 679
WEIGHT 1
WORN_DON

IFVAR ITEMVAL1 = 1
        IFVERB RUB -1
                ECHO OTHERS You get the feeling that %N is about to utter something very important.
                PLREVENT 2
                CONTPLREVENT
                SPELL 219
        ENDIF
ENDIF

IFVAR ITEMVAL1 = 2
        IFVERB RUB -1
                PLREVENT 1
                CONTPLREVENT
                RANDOM DUMMY1 1 2 0
                IFVAR DUMMY1 = 1
                        ECHO ALL A voice sings, "I rode from the hills with a gleam in my eye."
                        PLREVENT 1
                        CONTPLREVENT
                        ECHO ALL A voice sings, "The wind blew around me, ahead crows filled the sky"
                        PLREVENT 1
                        CONTPLREVENT
                        ECHO ALL A voice sings, "The houses were burning with flames golden red"
                        PLREVENT 1
                        CONTPLREVENT
                        ECHO ALL A voice sings, "The people were running their eyes filled with dread."
                ENDIF
                IFVAR DUMMY1 = 2
                        ECHO ALL A voice sings, I urged my steed onward at a furious pace"
                        PLREVENT 1
                        CONTPLREVENT
                        ECHO ALL A voice sings, Raced into the town through the streets filled with haze"
                        PLREVENT 1
                        CONTPLREVENT
                        ECHO ALL A voice sings, As we entered the courtyard the assailants all fled"
                        PLREVENT 1
                        CONTPLREVENT
                        ECHO ALL A voice sings, There on the ground lay the town's founders dead."
                ENDIF
        ENDIF
ENDIF

IFVAR ITEMVAL1 = 3
        IFVERB RUB -1
                PLREVENT 2
                CONTPLREVENT
        ENDIF
ENDIF
