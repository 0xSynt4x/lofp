; Blood
INUMBER 948
NAME 637
LIQUID
WEIGHT 1
VOLUME 1
PARAMETER1 4
SUBSTANCE INSUBSTANTIAL
ARTICLE SOME
ifpreverb cast -1
  ifvar spellnum = 139
    ifvar manapoints < 50
      equal itemval1 0
    endif
    ifvar itemval1 > 200
      gmmsg  ** %N has summoned a SSI demon, whee!
      removeitem -1
      equal manapoints 0
      equal spellnum 0
      echo all A hole of utter blackness forms. Light collects around it, but is repelled.
      equal ritualval2 295
      spell 2
    else
      equal manapoints 0
      equal spellnum 0
      removeitem -1
      echo player As you gesture at the blood, it dries up into nothing.
      echo others As %n gesture at some demonic blood, it dries up.
    endif
  endif
  ifvar spellnum = 412
    equal itemval1 manapoints
    equal manapoints 0
    clearverb
    echo others %N gestures at %a.
    echo player You channel your remaining mana into the blood.
    equal spellnum 0
    echo player [Round: 15 sec]
    equal roundtime 15
  endif
endif
ifpreverb touch -1
  ifvar itemadj2 = 777
    ifvar flag4 = 10
      clearverb
      echo player Your fingers are still wet with the demon's blood.
    else
      clearverb
      echo player You dip your fingertips within the blood.
      echo others %N dips %h fingertips within some demonic blood.
      equal flag4 10
      add itemval1 50
      ifvar intnum3 = 1
        strcvt 0 itemval1
        echo player [GM: VAL1= %0/200]
      endif
      appear %H fingers are wet with the blood of demons.
    endif
  endif
endif
ifverb gaze -1
  ifvar itemadj2 = 777
    ifvar itemval2 = 0
    equal itemval2 1
    echo player It collects into a small pool.
    endif
  endif
endif
ifverb drink -1
  ifvar itemadj2 = 777
    spell 351
  endif
endif
ifverb touch -1
  ifvar itemadj2 = 777
    ; spell 351
  else
    equal dummy1 0
    ifvar rac ! 8
    ifvar rac ! 7
      echo player You feel the blood seep through your skin and into your veins.
      add bodypoints itemval1
      sub itemval2 1
      ifvar itemval2 < 0
        echo player That was the last of it.
        removeitem -1
      endif
    endif
    endif
  endif
endif
