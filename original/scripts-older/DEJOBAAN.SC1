;
; Jar of disease
inumber 697
name 350
substance indestructable
ifvar itemval1 ! 1
        ifvar intnum3 ! 1
                clearverb
                removeitem -1
        else
                echo player Ichiro 3/10/95 Auction item: Jar of Disease. Itemval1 should equal 1 for this UNIQUE item.
        endif
endif
ifpreverb look -1
        clearverb
        echo player The jar is small enough to fit in the palm of your hand and contains a
        echo player strange pink crystalline substance that seems to be growing on its sides. As
        echo player you look closely, you can see thin pink flecks collecting.
        echo player
        echo player The substance is currently covering the bottom of the jar.
endif
ifpreverb wave -1
        clearverb
        echo others %N waves %a.
        echo player You wave the jar, causing all of the pink crystalline substance to flake off of the sides.
endif
ifpreverb open -1
        clearverb
        echo player You begin to open the jar easily for a moment, then realize that it is twisting itself back shut!
endif

inumber 698
name 675
bow_weapon
parameter1 16
substance softmetal
ifpreverb look -1
        ifvar intnum3 = 1
                echo player Ichiro 3/10/95 auction item, non-unique. Push to load. This message shows to GM's only.
        endif
endif
ifpreverb push -1
        clearverb
        echo player You press a button on the side of the taser and a thin black panel opens, exposing its interior.
        echo others %N presses a button on the side of %a.
        echo player [Round: 1 sec]
        equal roundtime 1
        ifvar itemval3 = 0
                random dummy1 1 10 0
                equal itemval3 dummy1
                plrevent 2
                contplrevent
                echo player The taser emits a brief WOOOSH and its cover slides back.
                echo others %N's taser emits a brief WOOOSH and its cover slies back.
        else
                plrevent 2
                contplrevent
                echo player The panel slides back.
        endif
endif
ifpreverb pull -1
        clearverb
        echo player You pull your taser to the ready and duck to one side.
        echo others %N pulls %h taser to the ready and ducks to one side.
endif
ifpreverb turn -1
        clearverb
        echo player You try to twirl the taser around your finger but realize that it has no trigger guard.
        echo others %N tries to twirl %a around %h finger but realizes that it has no trigger guard.
endif
ifpreverb light -1
        clearverb
        gmmsg  ** %N lost %h taser trying to blow everyone up with it. Let's see if the explosion happens!
        echo player You apply flame to the taser and it fizzles away as though it were made from onion paper.
        echo others %N applies flame to %a and it fizzles away as though it were made from onion paper.
        removeitem -1
        plrevent 2
        contplrevent
        echo all Suddenly, the air before %N combusts!
        damageall burn 190 %N is caught within the flames!
endif
