; (gooey) sap
INUMBER 1542
NAME 1452
ARTICLE SOME
DYE
PARAMETER3 607
REAGENT
ifpreverb light -1
  clearverb
  equal itemadj1 526
  echo player You apply flame to the sap.
  echo others %N applies flame to some gooey sap.
endif
ifpreverb rub -1
  ifvar itemadj1 = 526
    clearverb
    appear %H is covered with gooey sap.
    echo others %N rubs some burning sap into %h skin.
    ifvar intnum90 > 0
      echo player You rub the sap into your skin but nothing happens.
    else
      ifvar skill6 ! 1
        gmmsg  ** %N uses burning sap to increase D&P for a while.
        echo player You rub the sap into your skin and immediately begin to move with greater ease.
        add skill6 1
        EQUAL INTNUM90 8
        EQUAL INTNUM89 1
      else
        echo player You rub the sap into your skin but nothing happens.
      endif
    endif
    removeitem -1
  endif
endif
