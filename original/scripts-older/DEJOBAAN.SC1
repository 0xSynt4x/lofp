; Water
INUMBER 198
NAME 224
ARTICLE SOME
LIQUID
WEIGHT 1
VOLUME 1
HIDDEN
IFPREVERB DRINK -1
    ifvar itemval2 < 500
  IFVAR ITEMVAL3 ! 0
    SETITEMVAL -1 3 315
    SETITEMVAL -1 2 1
  ENDIF
    endif
ENDIF
ifpreverb cast -1
  ifvar itemval2 > 24
    ifvar spellnum = 412
      clearverb
      ifvar manapoints > 39
        sub manapoints 40
        echo player You gesture into the pool of water, causing its surface to ripple.
        echo others As %n gestures into a pool of water, its surface ripples.
        equal itemval1 1
      else
        echo player You do not have enough mana remaining to incant this ritual.
        equal spellnum 0
      endif
    endif
    ifvar spellnum = 215
    ifvar itemval1 = 1
      clearverb
      ifvar manapoints > 39
        sub manapoints 40
        echo player As you gesture into the pool of water, an image forms beneath its surface.
        echo others As %n gestures into a pool of water, an image forms beneath its surface.
        equal itemval1 2
      else
        echo player You do not have enough mana remaining to complete this ritual.
        equal spellnum 0
      endif
    endif
    endif
  endif
endif
ifpreverb look -1
  ifvar itemval1 = 2
    clearverb
    equal dummy2 0
    echo others %N gazes deeply into a pool of water.
    echo player You gaze deeply through the water's rippled surface...

    ifvar plrmark1 > 0
      equal dummy2 1
      showroom plrmark1
    endif
    ifvar plrmark2 > 0
      equal dummy2 1
      showroom plrmark2
    endif
    ifvar plrmark3 > 0
      equal dummy2 1
      showroom plrmark3
    endif
    ifvar plrmark4 > 0
      equal dummy2 1
      showroom plrmark4
    endif
    ifvar plrmark5 > 0
      equal dummy2 1
      showroom plrmark5
    endif
    ifvar plrmark6 > 0
      equal dummy2 1
      showroom plrmark6
    endif
    ifvar plrmark7 > 0
      equal dummy2 1
      showroom plrmark7
    endif
    ifvar plrmark8 > 0
      equal dummy2 1
      showroom plrmark8
    endif
    ifvar plrmark9 > 0
      equal dummy2 1
      showroom plrmark9
    endif
    ifvar plrmark10 > 0
      equal dummy2 1
      showroom plrmark10
    endif
    ifvar dummy2 = 0
      echo player ...you see nothing.
    endif

    random dummy1 1 20 0
    ifvar dummy1 = 1
      equal itemval1 0
      echo player The water's surface stills.
      plrevent 2
      contplrevent
      echo others The water's surface stills.
    endif
  endif
endif
