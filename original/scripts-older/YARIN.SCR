IFENTRY
  SPELL 250
  IFCARRY 1843 -1
    IFITEM -1 WORN
      ECHO ALL A burly guard says, "Greetings %n, welcome back."
    ENDIF
    ELSE
      ECHO ALL A burly guard says, "Welcome to the Library of Yarin."
    ENDIF
  ENDIF


IFPREVERB OPEN 0
  CLEARVERB
  IFVAR yarin = 1
    ECHO PLAYER The book is already open.
  ENDIF
    IFVAR yarin = 0
      ECHO PLAYER You carefully open the book to the first page.
      ECHO OTHERS %N carefully opens the book to the first page.
      EQUAL yarin 1
      EQUAL yarin1 1
    ENDIF
  ENDIF

IFPREVERB CLOSE 0
  CLEARVERB
  IFVAR yarin = 0
    ECHO PLAYER The book is already closed.
  ENDIF
    IFVAR yarin = 1
      ECHO PLAYER You carefully close the book.
      ECHO OTHERS %N carefully closes the book.
      EQUAL yarin 0
      EQUAL yarin1 0
    ENDIF
  ENDIF

IFPREVERB TURN 0
  CLEARVERB
  IFVAR yarin = 1
    ECHO PLAYER You flip to another page.
    ECHO OTHERS %N flips to another page.
    ADD yarin1 1
  ENDIF
ENDIF

IFPREVERB LOOK 0
  CLEARVERB
  IFVAR yarin = 0
    ECHO PLAYER The book is impressively bound in tan leather.
  ENDIF
    IFVAR yarin = 1
      ECHO PLAYER The book is open to a page.
    ENDIF
  ENDIF

IFPREVERB READ 0
  CLEARVERB
  IFVAR yarin1 = 1
    ECHO PLAYER                     Faydian Chronicles
    ECHO PLAYER                     The Circle of Yarin
    ECHO PLAYER            
    ECHO PLAYER      Compiled by Ria Shehee, High priestess and humble servant of the Goddess,
    ECHO PLAYER      Yarin.
    ECHO PLAYER                  
    ECHO PLAYER      Faithfully rendered herin by the scribes of the temple and submitted to
    ECHO PLAYER      all of the Circles.
    ECHO PLAYER              
    ECHO PLAYER      Contributions include those by:
    ECHO PLAYER              		
    ECHO PLAYER      Sammuel Coolhearted, Priest
    ECHO PLAYER      Shantine Windsong, Former High Priestess
    ECHO PLAYER      Other followers of the Faydian Circle
    ECHO OTHERS %N reads the book.
  ENDIF  
    IFVAR yarin1 = 2
      ECHO PLAYER                           The Goddess Yarin
      ECHO PLAYER    
      ECHO PLAYER          Yarin is a true goddess who ascended from mortality to
      ECHO PLAYER      immortality and Godhood. She is devoted to finding, gathering,
      ECHO PLAYER      and saving knowledge from all times and all worlds so that it might
      ECHO PLAYER      never be lost.
      ECHO PLAYER      
      ECHO PLAYER          She has been referred to as the Goddess of Knowledge and Magic,
      ECHO PLAYER      The All-Seeing One and Our Lady of Knowledge and Wisdom.
      ECHO PLAYER     
      ECHO PLAYER          Some followers of other Gods do not look favorably upon Yarin
      ECHO PLAYER      because she does not blindly follow the paths of what they refer to
      ECHO PLAYER      as "the light" or "the dark", but seeks to remain neutral in order
      ECHO PLAYER      to fulfill her purpose. 
      ECHO OTHERS %N reads the book.
    ENDIF
      IFVAR yarin1 = 3
        ECHO PLAYER          Those who join the Circle of Yarin must accept the purpose of
        ECHO PLAYER      Yarin as their own, however they may pursue knowledge in their own
        ECHO PLAYER      way, using their own means.  Yarin does not dictate to her
        ECHO PLAYER      followers, but rather helps and guides them along the path to
        ECHO PLAYER      knowledge and understanding.
        ECHO PLAYER       
        ECHO PLAYER          The followers of Yarin are a diverse group. Craftsmen, healers,
        ECHO PLAYER      mages,psi users, and warriors, bound together and to Yarin in a
        ECHO PLAYER      Circle. Followers of the "light" and followers of the "dark" who
        ECHO PLAYER      for the sake of knowledge lay aside all other concerns and give
        ECHO PLAYER      their all to Yarin and learning. They join together to face danger,
        ECHO PLAYER      hardship, victory, and defeat all in the pursuit of knowledge and
        ECHO PLAYER      wisdom.
        ECHO PLAYER        
        ECHO PLAYER          This is the key, to lay aside all other things and join together,
        ECHO PLAYER      May the Circle remain unbroken and Yarin guide us.
        ECHO OTHERS %N reads the book.
      ENDIF
        IFVAR yarin1 = 4
          ECHO PLAYER This is the last page.
          ECHO PLAYER          If you wish to know any more about Yarin or the Faydian Circle
          ECHO PLAYER      please feel free to inquire of any of the Circle members. We can be
          ECHO PLAYER      identified by the emerald yarinite medallion we all wear.
          ECHO OTHERS %N reads the book.
        ENDIF
      ENDIF
