MACRO 29
IFVAR PLRSINROOM > 1
	IFVAR TOOMANYMITES < 10
		RANDOM DUMMY1 1 10 0
		IFVAR DUMMY1 = 5
			ECHO ALL The mite rider removes a tiny horn from his cloak and blows it.
			GENMON 364
			ECHO ALL A rock mite burrows in from the wall.
			ADD TOOMANYMITES 1
		ENDIF
	ENDIF
ENDIF
