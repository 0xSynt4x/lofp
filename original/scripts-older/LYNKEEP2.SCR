IFPREVERB LOOK 8
  IFVAR RATPOWDER = 0
    CLEARVERB
    ECHO PLAYER You see a panel with some small lights.%cA small light is unlit.
  ELSE
    CLEARVERB
    ECHO PLAYER You see a panel with some small lights.%cA small light glows with a soft green light.
  ENDIF
ENDIF
IFPREVERB LOOK 3
  CLEARVERB
  ECHO PLAYER You see a wide metal box that stands nearly fifteen feet tall.
  ECHO PLAYER A flat shelf is situated under what appears to be a small press
  ECHO PLAYER connected to the lever. To one side, you see a narrow slot
  ECHO PLAYER that leads down into the contraption. A container sits to one
  ECHO PLAYER edge of the shelf.
ENDIF
IFPREVERB2 PUT 6
  IFVAR ARCHNUM = 880
    IFVAR RATINNARDS = 0
      REMOVEITEM -1
      EQUAL RATINNARDS 1
    ELSE
      CLEARVERB
      ECHO PLAYER The contraption is full.
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You are not sure what is supposed to go in here, but that sure isn't it.
  ENDIF
ENDIF
IFPREVERB OPEN 3
    CLEARVERB
    ECHO PLAYER You can't seem to find anything to open.
ENDIF
IFPREVERB LOOK 4
  IFVAR CASINGS = 1
    IFVAR SLUGS = 1
      EQUAL BULLETSTEMP 12
      SUB BULLETSTEMP BULLETS
      IFVAR BULLETSTEMP < 12
        STRCVT 0 BULLETSTEMP
        CLEARVERB
        ECHO PLAYER You see a tiny vise-grip with a small metal contraption mounted both above and below a small metal press.
        ECHO PLAYER %cYou can see there are %0 sets left in the tracks.
      ELSE
        CLEARVERB
        ECHO PLAYER You see a tiny vise-grip with a small metal contraption mounted both above and below a small metal press.
        ECHO PLAYER %cYou see that both tracks are filled.
      ENDIF
    ELSE
      CLEARVERB
      ECHO PLAYER You see a tiny vise-grip with a small metal contraption mounted both above and below a small metal press.
      ECHO PLAYER %cYou see that the upper track is empty.
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You see a tiny vise-grip with a small metal contraption mounted both above and below a small metal press.
    ECHO PLAYER %cYou see that the tracks are empty.
  ENDIF
ENDIF
IFPREVERB2 PUT 4
  IFVAR ARCHNUM = 843
    IFVAR ITEMADJ3 = 32
    IFVAR CASINGS = 0
      EQUAL CASINGS 1
      CLEARVERB
      REMOVEITEM -1
      EQUAL ROUNDTIME 15
     ECHO PLAYER You place the casings into the lower metal track.
      ECHO OTHERS %N loads some casings into a metal track leading up to the small metal press.
    ELSE
      CLEARVERB
      ECHO PLAYER There already are some casings installed on the lower track.
    ENDIF
    ELSE
      CLEARVERB
      ECHO PLAYER The casings are made of the wrong material.
    ENDIF
  ELSE
    IFVAR ARCHNUM = 839
      IFVAR CASINGS = 1
        IFVAR SLUGS = 0
          EQUAL SLUGS 1
          EQUAL TEMPADJ1 ITEMADJ1
          EQUAL TEMPADJ2 ITEMADJ2
          EQUAL TEMPADJ3 ITEMADJ3
          CLEARVERB
          REMOVEITEM -1
          EQUAL ROUNDTIME 15
          ECHO PLAYER You place some slugs into the upper metal track.
          ECHO OTHERS %N loads some slugs into a metal track leading up to the small metal press.
        ELSE
          CLEARVERB
          ECHO PLAYER There already are some slugs installed on the upper track.
        ENDIF
      ELSE
        CLEARVERB
        ECHO PLAYER It would help to install the casings first.
      ENDIF
    ELSE
      CLEARVERB
      ECHO PLAYER That won't seem to fit in either of the metal tracks.
    ENDIF
  ENDIF
ENDIF
IFPREVERB PULL 5
IFVAR ROUNDTIME ! 0
  CLEARVERB
  STRCVT 0 ROUNDTIME
  ECHO PLAYER [Wait %0 seconds...]
ELSE
IFVAR BULLETBROKEN = 0
  IFVAR CASINGS = 1
    IFVAR SLUGS = 1
      IFVAR RATPOWDER = 1
       IFVAR BULLETS < 11
          CLEARVERB
          ADD BULLETS 1
          EQUAL ROUNDTIME 20
          ECHO PLAYER You pull down on the lever and the two tracks move in line with the press.
          ECHO OTHERS %N pulls down on the lever and the two small tracks move.
          PLREVENT 1
          CONTPLREVENT
          ECHO ALL You see some powder fill up the casing from a tiny tube that leads into the contraption.
          PLREVENT 1
          CONTPLREVENT
          ECHO PLAYER You pull down on the lever again and push the two pieces of metal together.
          ECHO OTHERS %N pulls down on the lever again pushing the two pieces of metal together.
          PLREVENT 1
          CONTPLREVENT
          ECHO ALL Finally the press releases the two tracks, and advances forward to next one.
        ELSE
          IFVAR BULLETS = 11
            EQUAL BULLETS 0
            EQUAL RATPOWDER 0
            EQUAL RATINNARDS 0
            EQUAL SLUGS 0
            EQUAL CASINGS 0
            ADD BULLETSMADE 1
            EQUAL ROUNDTIME 20
            STRCVT 0 BULLETSMADE
            GMMSG ** %N just made bullet set #%0 for the day.
            ECHO PLAYER You pull down on the lever and the two tracks move in line with the press.
            ECHO OTHERS %N pulls down on the lever and the two small tracks move.
            PLREVENT 1
            CONTPLREVENT
            ECHO ALL You see some powder fill up the casing from a tiny tub that leads into the contraption.
            PLREVENT 1
            CONTPLREVENT
           ECHO PLAYER You pull down on the lever again and push the two pieces of metal together.
            ECHO OTHERS %N pulls down on the lever again pushing the two pieces of metal together.
            PLREVENT 1
            CONTPLREVENT
           ECHO ALL Finally the press releases and the bullets slide off the tracks and into the contraption.%cThe tracks reset themselves.
            NEWPUT 7 1065 ADJ1=TEMPADJ1 ADJ2=TEMPADJ2 ADJ3=TEMPADJ3 VAL3=12
            RANDOM DUMMY1 1 100 0
            STRCVT 0 DUMMY1
            GMMSG ** DUMMY1 = %0.
              IFVAR DUMMY1 < 6
                EQUAL BULLETBROKEN 1
                GMMSG ** Bullet making machine just broke.
               ECHO ALL %cYou hear a loud "CLUNK!" from somewhere inside the contraption.
              ENDIF
          ENDIF
        ENDIF
      ELSE
        CLEARVERB
        ECHO PLAYER You lack the necessary powder to continue.
      ENDIF
    ELSE
      CLEARVERB
      ECHO PLAYER You lack the necessary slugs to continue.
    ENDIF
  ELSE
    CLEARVERB
    ECHO PLAYER You lack the necessary casings to continue.
  ENDIF
ELSE
  CLEARVERB
  ECHO PLAYER You're not sure what is wrong with it, but this thing is definitely broken.
ENDIF
ENDIF
ENDIF
IFPREVERB KICK 3
IFVAR BULLETBROKEN = 1
  IFVAR ORG = 7
    IFVAR INTNUM68 > 10
      EQUAL BULLETBROKEN 0
      CLEARVERB
      ECHO PLAYER You kick %a!
      ECHO OTHERS %n kicks %a!
      PLREVENT 1
      CONTPLREVENT
      ECHO ALL You hear a loud "CLUNK!" fom within %a.
    ENDIF
  ENDIF
ENDIF
