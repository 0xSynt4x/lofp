    ENDIF
    IFVAR BOXGAME3 = 7
     IFVAR ITEMBIT7 = 0
      EQUAL ITEMBIT7 1
      ECHO PLAYER You uncover the picture of Cat on your side of the board.
      ECHO OTHERS %n uncovers the picture of Cat on %h side of the board.
     ELSE
      IFVAR ITEMBIT17 = 0
