      ENDIF
     ENDIF
    ENDIF
    IFVAR BOXGAME3 = 8
     IFVAR ITEMBIT8 = 0
      EQUAL ITEMBIT8 1
      ECHO PLAYER You uncover the picture of Snake on your side of the board.
      ECHO OTHERS %n uncovers the picture of Snake on %h side of the board.
     ELSE
      IFVAR ITEMBIT18 = 0
       ADD ITEMVAL4 1
       ECHO PLAYER You place a stone in the hollow on your side of the board.
       ECHO OTHERS %n places a stone in the hollow on %h side of the board.
      ENDIF
     ENDIF
    ENDIF
    IFVAR BOXGAME3 = 9
     IFVAR ITEMBIT9 = 0
      EQUAL ITEMBIT9 1
      ECHO PLAYER You uncover the picture of Boar on your side of the board.
      ECHO OTHERS %n uncovers the picture of Boar on %h side of the board.
     ELSE
      IFVAR ITEMBIT19 = 0
       ADD ITEMVAL4 1
       ECHO PLAYER You place a stone in the hollow on your side of the board.
       ECHO OTHERS %n places a stone in the hollow on %h side of the board.
      ENDIF
     ENDIF
    ENDIF
   IFVAR BOXGAME3 = 10
     IFVAR ITEMBIT0 = 0
      EQUAL ITEMBIT0 1
      ECHO PLAYER You uncover the picture of Wolf on your side of the board.
      ECHO OTHERS %n uncovers the picture of Wolf on %h side of the board.
     ELSE
      IFVAR ITEMBIT10 = 0
       ADD ITEMVAL4 1
       ECHO PLAYER You place a stone in the hollow on your side of the board.
       ECHO OTHERS %n places a stone in the hollow on %h side of the board.
      ENDIF
     ENDIF
    ENDIF
   ENDIF
   IFVAR INTNUM3 = ITEMVAL3
    IFVAR BOXGAME3 = 1
     IFVAR ITEMBIT11 = 0
      EQUAL ITEMBIT11 1
      ECHO PLAYER You uncover the picture of Deer on your side of the board.
      ECHO OTHERS %n uncovers the picture of Deer on %h side of the board.
     ELSE
      IFVAR ITEMBIT1 = 0
