		EQUAL DANTEMP 1
	ENDIF
	IFVAR ITEMVAL2 = 700
		ECHO PLAYER The fourth segment of the center stone is glowing.
		EQUAL DANTEMP 1
	ENDIF
	IFVAR DANTEMP = 0
		ECHO PLAYER The center stone is dark.
	ENDIF
	EQUAL DANTEMP 0
ENDIF
