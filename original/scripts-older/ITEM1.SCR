;
;I# 868 : Key to create portal to pristine forest
INUMBER 868
NAME 119
KEY
WEIGHT 1
VOLUME 1
WORN_NECK
IFVAR RNUM ! 92
	IFVAR RNUM ! 93
		IFITEM -1 WORN
			IFVERB CONCENTRATE -1
				IFVAR PORTMADE ! 0
					ECHO PLAYER You feel the tug of magic for a moment, but it soon fades.
				ENDIF
				IFVAR PORTMADE = 0
					IFVAR REGION < 3
						EQUAL PORTMADE 1
						EQUAL RETROOM RNUM
						IFITEM 9
							ECHO PLAYER You feel the tug of magic for a moment, but it soon fades.
						ENDIF
						IFNOITEM 9
							ECHO PLAYER Suddenly, a soft blue light appears before you.
							ECHO OTHERS Suddenly, a soft blue light appears just before %n.
							NEWITEM 9 869 ADJ1=298 ADJ2=29 VAL2=92
							AFFECT 92
							SETITEMVAL 0 2 RETROOM
						ENDIF
					ENDIF
					IFVAR REGION > 2
						ECHO PLAYER You feel the tug of magic for a moment, but it soon fades.
					ENDIF
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDIF
