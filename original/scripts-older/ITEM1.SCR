;
; Potion
INUMBER 160
NAME 162
LIQUID
WEIGHT 1
VOLUME 1
PARAMETER1 4
SUBSTANCE INSUBSTANTIAL
ifvar itemval3 = 2000
  ifverb drink -1
    IFVAR INTNUM90 = 0
      equal intnum90 6
      EQUAL INTNUM89 1
      GMMSG %N drank some Heal the Body potion.
      random dummy1 1 100 0
      add dummy1 500
      add bodypoints dummy1
      echo player You feel amazingly healthy!
      echo others %N looks amazingly healthy!
    ENDIF
  endif
  ifpreverb analyze -1
    ifvar skill31 > 0
      clearverb
      echo player You ascertain that this potion has properties similar to the "Heal the Body" spell.
    endif
  endif
endif


ifvar itemval3 = 321
  ifpreverb analyze -1
    ifvar skill31 > 0
      ifvar itemval1 = 1
	      clearverb
	      echo player You acertain that this potion has properties similar to the 'Poison' spell, but that it has been strangely transmuted.
        ifvar itemval5 > 5
        	echo player Someone has psionically imprinted this potion.
        endif
        ifvar itemval5 = 0
        	echo player The potion has not been psionically imprinted.
        endif
        strcvt 0 itemval2
        echo player You think that there are %0 sips left.
      endif
    endif
  endif
  ifpreverb concentrate -1
    ifvar itemval1 = 0
    clearverb
      ifvar skill28 > 29
	      echo player You focus your psi powers on the potion. You slowly transmute it on the molecular level. It turns black and begins to fizz.
  	    echo player [Round: 20 Sec]
    	  equal roundtime 20
      	echo others %N focuses on the potion. It slowly turns black and begins to fizz.
	      equal itemval1 1
  	    equal itemadj1 1044
    	  equal itemadj3 25
      else
	      echo player You focus your psi powers on the potion, but you don't feel you know enough mind over matter to transmute it.
  	    echo others %N focuses on the potion.
      endif
    else
	    echo player You focus your psi powers on the potion, but nothing happens.
  	  echo player [Round: 5 sec]
    	equal roundtime 5
	    echo others %N focuses on the potion.
    endif
  endif
  ifpreverb project -1
	  clearverb
    ifvar itemval1 = 1
      ifvar itemval5 = 0
      	echo player You project your brainpattern into the fizzing potion.
	      echo others %N stares at a potion, unmoving for a long time.
  	    echo player [Round: 30 Sec]
    	  equal roundtime 30
      	equal itemval5 intnum3
	      equal itemadj1 221
      else
	      echo player You project your brainpattern into the potion, but realize that someone has imprinted it already.
  	    echo others %N stares at a potion for a few seconds.
      endif
    else
	    echo player You attempt to project your brainpattern into the potion, but realize that it has not been transmuted yrt.
  	  echo others %N stares at a potion for a few seconds.
    endif
  endif
  ifverb drink -1
    ifvar itemval5 = intnum3
      ifvar ppoison1 = 0
	      equal ppoison1 intnum3
  	    gmmsg )))%N just drank a brain fizz drug.(((
    	  echo player You feel very dizzy and sick. Your temples throb.
      	echo others %N's temples begin to throb.
      else
        ifvar ppoison2 = 0
          gmmsg )))%N just drank a brain fizz drug.(((
          equal ppoison2 intnum3
          echo player You feel very dizzy and sick. Your temples throb.
          echo others %N's temples begin to throb.
        else
          ifvar ppoison3 = 0
            gmmsg )))%N just drank a brain fizz drug.(((
            equal ppoison3 intnum3
            echo player You feel very dizzy and sick. Your temples throb.
            echo others %N's temples begin to throb.
          endif
        endif
      endif
    endif
    ifvar itemval5 ! intnum3
      echo player You feel another person's brainpattern try to merge with your own!
      echo others %N screams and clutches %h head!
      damageplr bodyonly 25 You feel incredibly sick and disoriented.
    endif
  endif
endif

ifvar itemval3 = 315
  ifpreverb concentrate -1
    ifvar itemval1 = 0
      clearverb
      ifvar skill28 > 29
	      equal itemval3 321
  	    echo player You focus your psi powers on the potion. You slowly transmute it on the molecular level. It turns black and begins to fizz.
    	  echo player [Round: 20 Sec]
      	equal roundtime 20
	      echo others %N focuses on the potion. It slowly turns black and begins to fizz.
  	    equal itemval1 1
    	  equal itemadj1 1044
      	equal itemadj3 25
      else
	      echo player You focus your psi powers on the potion, but you don't feel you know enough mind over matter to transmute it.
  	    echo others %N focuses on the potion.
      endif
    else
	    echo player You focus your psi powers on the potion, but nothing happens.
  	  echo player [Round: 5 sec]
    	equal roundtime 5
	    echo others %N focuses on the potion.
    endif
  endif
endif
ifpreverb look -1
  ifvar skill31 > 11
     clearverb
     strcvt 1 itemval2
     ifvar itemval2 = 1
      echo player You estimate that there is 1 dose remaining.
      else
      echo player You estimate that there are %1 doses remaining.
     endif
  endif
endif
ifpreverb analyze -1
  ifvar skill31 > 0
    ifvar spellnum = 1000
      clearverb
      echo player You ascertain that this potion has properties similar to the "Restore Mana" spell.
    endif
    ifvar spellnum = 1001
      clearverb
      echo player You ascertain that this potion has properties similar to the "Convultions" spell.
    endif
    ifvar spellnum = 1002
      clearverb
      echo player You ascertain that this potion has properties similar to the "Imbue Power" spell.
    endif
  endif
endif
