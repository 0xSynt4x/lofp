PARAMETER1 12
CRAFTABLE
ENCRUSTABLE
SUBSTANCE WOOD
IFVAR ITEMADJ1 = 87
  IFVAR ITEMADJ3 = 1240
    IFVAR TIM = 0
      IFVAR DEMSTAFFCHARGE = 0
        EQUAL ITEMVAL5 10
        EQUAL DEMSTAFFCHARGE 1
        ECHO ALL The dark mahogany staff glows with newly absorbed energy.
      ENDIF
    ELSE
      EQUAL DEMSTAFFCHARGE 0
    ENDIF
    IFPREVERB2 CONCENTRATE -1
      CLEARVERB
      IFVAR ITEMVAL5 > 0
        IFVAR TERRAIN ! 3
          ECHO PLAYER The dark mahogany staff suffuses you with a soothing warmth.
          ECHO OTHERS %N is suffused with a soothing warmth from the dark mahogany staff.
          SPELL 317 50
          SUB ITEMVAL5 1
        ELSE
          SPELL 318 100
          ECHO OTHERS Tendrils of power seep into the dark mahogany staff, then up into %N's body.
          ECHO PLAYER The dark mahogany staff pulls power from the forest then to your body.
          SUB ITEMVAL5 1
        ENDIF
      ELSE
        ECHO PLAYER The dark mahogany staff's heart seems empty.
      ENDIF
    ENDIF
    IFPREVERB2 RUB -1
      CLEARVERB
      ECHO PLAYER The dark mahogany staff lovingly writhes in your grasp.
      ECHO OTHERS The dark mahogany staff seems to caress %N's hand.
    ENDIF
    IFPREVERB2 POKE -1
      CLEARVERB
      ECHO PLAYER The dark mahogany staff moves in an intricate pattern, bringing your hands with it.
      ECHO OTHERS %N executes a precise series of moves with the staff.
    ENDIF
  ENDIF
ENDIF
;
ifvar itemadj2 = 440
  ifpreverb wield -1
    ifvar idchaosstaves = 0
      random idchaosstaves 1 1000 0
    endif
    ifvar itemval1 ! idchaosstaves
      equal itemval5 0
      equal itemval1 idchaosstaves
    endif
    add itemval5 1
    ifvar itemval5 < 4
      random dummy1 1 12 0
      ifvar dummy1 = 1
        equal ritualval2 7
      endif
      ifvar dummy1 = 2
        equal ritualval2 8
      endif
      ifvar dummy1 = 3
        equal ritualval2 9
      endif
      ifvar dummy1 = 4
        equal ritualval2 10
      endif
      ifvar dummy1 = 5
        equal ritualval2 11
      endif
      ifvar dummy1 = 6
        equal ritualval2 15
      endif
      ifvar dummy1 = 7
        equal ritualval2 20
      endif
      ifvar dummy1 = 8
        equal ritualval2 21
      endif
      ifvar dummy1 = 9
        equal ritualval2 3
      endif
      ifvar dummy1 = 10
        equal ritualval2 4
      endif
      ifvar dummy1 = 11
        equal ritualval2 5
      endif
      ifvar dummy1 = 12
        equal ritualval2 6
      endif
      spell 2
    endif
  endif
endif
