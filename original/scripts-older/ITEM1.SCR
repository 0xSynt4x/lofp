;
;I# 953 : Crimson Band Ring
INUMBER 953
NAME 167
MISC
WEIGHT 1
VOLUME 1
WORN_RING
SUBSTANCE HARDMETAL
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
     ECHO PLAYER This is the crimson band ring!
  ENDIF
ENDIF
IFTOUCH -1
; Garin's Check
  IFVAR INTNUM3 ! 71
;  Marcolan's check
    IFVAR INTNUM3 ! 697
      IFVAR ORG ! 6
        ECHO PLAYER A force you cannot quite identify prevents you from taking the ring.
        CLEARVERB
      ENDIF
    ENDIF
  ENDIF 
ENDIF
IFVERB RUB -1
  ECHO PLAYER You feel courageous!
  CLEARVERB
ENDIF
IFVERB WEAR -1
  EQUAL INTNUM13 100
ENDIF
IFVERB REMOVE -1
  EQUAL INTNUM13 0
ENDIF
IFVERB LEAN -1
  CLEARVERB
  IFITEM -1 WIELDED
    ECHO PLAYER You lean on your weapon.
    ECHO OTHERS %n leans upon %h weapon.
  ELSE
    ECHO PLAYER You sigh tiredly.
    ECHO OTHERS %n sighs tiredly.
  ENDIF
ENDIF
IFPREVERB SCOWL -1
  ECHO PLAYER You scowl threateningly.
  ECHO OTHERS %n scowls threateningly.
  CLEARVERB
ENDIF
IFPREVERB GLARE -1
  ECHO PLAYER You cast around with a gaze like steel.
  ECHO OTHERS %n gets a steely glint in %h eye.
  CLEARVERB
ENDIF
IFPREVERB PULL -1
  ECHO PLAYER You try to scratch an itch.
  ECHO OTHERS %n squirms and tries to scratch %h back through %h armor.
  CLEARVERB
ENDIF
IFPREVERB TURN -1
  CLEARVERB
  IFVAR ITEMVAL2 ! TIM
    IFVAR ITEMVAL1 < 15
      ADD ITEMVAL1 1
      ECHO PLAYER You feel energized!!
      ECHO OTHERS %n fiddles with %h ring.
      SPELL 335 100
    ELSE
      EQUAL ITEMVAL2 TIM
      EQUAL ITEMVAL1 0
      ECHO PLAYER You get the impression that you have expended the energy of the ring for this hour.
    ENDIF
  ELSE
    ECHO PLAYER You get the impression that you have expended the energy of the ring for this hour.
  ENDIF
ENDIF
