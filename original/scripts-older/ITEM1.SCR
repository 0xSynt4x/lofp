; Dust, with creod loop
INUMBER 512
NAME 451
SKIN
WEIGHT 1
VOLUME 1
SUBSTANCE INSUBSTANTIAL
ARTICLE SOME
REAGENT
flipable
IFPREVERB FLIP -1
        IFVAR ITEMVAL1 = 1
        CLEARVERB
        EQUAL PDUSTROOM RNUM
        ECHO PLAYER You flip a handful of dust into the air. Suddenly, the air fills with bright sparkling color.
        ECHO OTHERS %N tosses something into the air. Suddenly, the air fills with bright, sparkling color.
        SPELL 230 30
        removeitem -1
        else
        clearverb
        echo player You don't see a way to do that.
        endif
ENDIF
