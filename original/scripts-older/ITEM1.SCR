; Sword (long)
INUMBER 46
NAME 201
WEIGHT 4
VOLUME 6
PARAMETER1 8
SLASH_WEAPON
SUBSTANCE HARDMETAL
IFPREVERB PULL -1
    IFITEM -1 WIELDED
		 CLEARVERB
     ECHO PLAYER You raise %a in salute.
     ECHO OTHERS %N raises %a in salute.
    ENDIF
ENDIF
IFPREVERB TURN -1
	IFITEM -1 WIELDED
		CLEARVERB
		ECHO PLAYER You slowly turn the sword until it catches the light on its blade.%c[Round: 3 sec]
		ECHO OTHERS %N slowly turns %a until the light catches on its blade in an impressive manner.
		EQUAL ROUNDTIME 3
	ENDIF
ENDIF
IFPREVERB KICK -1
	IFITEM -1 WIELDED
		CLEARVERB
		ECHO PLAYER You slap the flat of the sword's blade against your leg.
		ECHO OTHERS %N slaps the flat of %a against %h leg.
	ENDIF
ENDIF
