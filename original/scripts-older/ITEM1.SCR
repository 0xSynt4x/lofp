;
; Helm with lightability routine.
INUMBER 56
NAME 107
WEIGHT 10
VOLUME 3
PARAMETER1 5
PARAMETER2 0
ARMOR
ENCRUSTABLE
WORN_HEAD
SUBSTANCE HARDMETAL
LIGHTABLE

IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER Gradrak says, "If itembit5 = 1, this helm has a lightbulb on it, like a miner's helmet.
    ECHO PLAYER Shadow says, "And if ITEMBIT1 = 1 this becomes a tech helm, will cast Night Vision when tapped and Telepathy when concentrated on. This is an auction item and should stay unique.
  ENDIF
ENDIF

IFPREVERB LIGHT -1
  IFVAR ITEMBIT5 ! 1
    CLEARVERB
    ECHO PLAYER You can't light that.
  ELSE
    ECHO PLAYER You flip the tiny switch on your electric miner's helmet. The bulb sputters to life.
    ECHO OTHERS %N fiddles with something near %h head. Suddenly, the light on thier helm begins to glow.
 ENDIF
ENDIF

IFPREVERB UNLIGHT -1
  IFVAR ITEMBIT5 ! 1
    ECHO PLAYER You can't do that.
    CLEARVERB
  ELSE
    ECHO PLAYER You switch off the light on your helm.
    ECHO OTHERS %N switches off the light on %h helm.
  ENDIF
ENDIF

IFPREVERB TAP -1
  IFVAR ITEMBIT1 = 1
    CLEARVERB
    ECHO OTHERS The lens on %N's helm glows red for a moment.
    ECHO PLAYER You hear a dry voice intone, "Vision enhancment initiated."
    SPELL 520 40
  ENDIF
ENDIF

IFPREVERB CONCENTRATE -1
  IFVAR ITEMBIT1 = 1
    CLEARVERB
    ECHO OTHERS Some circuits on %N's helm light up briefly.      
    ECHO PLAYER You hear a dry voice intone, "Telepathic enhancment initiated."
    SPELL 403 40
  ENDIF
ENDIF

