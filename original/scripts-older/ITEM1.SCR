IFPREVERB WAVE -1
  IFVAR ITEMval5 = 1
    IFVAR DAY = 1
      EQUAL DUMMY1 1
    ENDIF
    IFVAR ITEMBIT19 = 1
      EQUAL DUMMY1 1
    ENDIF
    IFVAR DUMMY1 = 1
      clearverb
      IFVAR ITEMVAL2 = 1
  IFVAR PATMIRROR1 < 4
    ECHO PLAYER You wave the jagged mirror through the air and instinctivly squint to avoid the flash.
    ECHO OTHERS %N waves a mirror through the air, causing a flash.
    EQUAL RITUALVAL2 368
    SPELL 2
    add patmirror1 1
    equal itembit19 0
  ELSE
    echo player You wave a jagged mirror through the air, but no light or energy comes out of it.
    echo others %N waves a jagged mirror through the air.
  endif
      endif
      IFVAR ITEMVAL2 = 2
  IFVAR PATMIRROR2 < 4
    ECHO PLAYER You wave the jagged mirror through the air and instinctivly squint to avoid the flash.
    ECHO OTHERS %N waves a mirror through the air, causing a flash.
    EQUAL RITUALVAL2 368
    SPELL 2
    add patmirror2 1
    equal itembit19 0
  ELSE
    echo player You wave a jagged mirror through the air, but no light or energy comes out of it.
    echo others %N waves a jagged mirror through the air.
  endif
      endif
      IFVAR ITEMVAL2 = 3
  IFVAR PATMIRROR3 < 4
    ECHO PLAYER You wave the jagged mirror through the air and instinctivly squint to avoid the flash.
    ECHO OTHERS %N waves a mirror through the air, causing a flash.
    EQUAL RITUALVAL2 368
    SPELL 2
    add patmirror3 1
    equal itembit19 0
  ELSE
    echo player You wave a jagged mirror through the air, but no light or energy comes out of it.
    echo others %N waves a jagged mirror through the air.
  endif
      endif
      IFVAR ITEMVAL2 = 4
  IFVAR PATMIRROR4 < 4
    ECHO PLAYER You wave the jagged mirror through the air and instinctivly squint to avoid the flash.
    ECHO OTHERS %N waves a mirror through the air, causing a flash.
    EQUAL RITUALVAL2 368
    SPELL 2
    add patmirror4 1
    equal itembit19 0
  ELSE
    echo player You wave a jagged mirror through the air, but no light or energy comes out of it.
    echo others %N waves a jagged mirror through the air.
  endif
      endif
    else
    echo player Hmm, it seems to be out of power for now.
    endif
  endif
endif
ifpreverb cast -1
  ifvar spellnum = 519
  clearverb
    ifvar itembit19 = 1
