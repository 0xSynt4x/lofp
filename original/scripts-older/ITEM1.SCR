IFPREVERB CONCENTRATE -1
  IFVAR ITEMBIT1 = 1
  CLEARVERB
    IFVAR ITEMVAL1 = TIM
    ECHO PLAYER The sceptre can create no spiders right now.
ELSE
    EQUAL ITEMVAL1 TIM
    RANDOM DUMMY1 1 3 0
    IFVAR DUMMY1 = 1
    ECHO PLAYER Success! The sceptre has created a spider.
    ECHO OTHERS Something shimmers into existence at %N's feet. It is starting to grow!
    GENMON 20
    ENDIF
    IFVAR DUMMY1 = 2
    ECHO PLAYER Success! The sceptre has created a spider.
    ECHO OTHERS Something shimmers into existence at %N's feet. It is starting to grow!
    GENMON 94
    ENDIF
    IFVAR DUMMY1 = 3
    ECHO PLAYER Success! The sceptre has created a spider.
    ECHO OTHERS Something shimmers into existence at %N's feet. It is starting to grow!
    GENMON 207
    ENDIF
  ENDIF
ENDIF
