;
;I# 1556 : Drumstick
INUMBER 1556
NAME 1078
WEIGHT 1
VOLUME 1
FOOD
PARAMETER1 4
IFPREVERB EAT -1
	IFVAR RAC < 7
		CLEARVERB
		IFVAR ROUNDTIME > 0
			STRCVT 0 ROUNDTIME
			ECHO PLAYER [Wait %0 seconds...]
		ENDIF
		IFVAR ROUNDTIME = 0
			EQUAL ROUNDTIME 5
			SUBITEMVAL -1 2 1
			IFVAR ITEMVAL2 < 1
				REMOVEITEM -1
				ECHO PLAYER Somehow the taste gives you a warm and special feeling.%cThat was the last of it.%c [Round: 5 sec]
				ECHO OTHERS %N gobbles up the last of the drumstick.
				SPELL 316
			ENDIF
			IFVAR ITEMVAL2 > 0
				ECHO PLAYER Somehow the taste gives you a warm and special feeling.%c [Round: 5 sec]
				ECHO OTHERS %N takes a bite from %h drumstick.
				SPELL 316
			ENDIF
		ENDIF
	ENDIF
ENDIF
