;
; Eye
INUMBER 520
NAME 244
SKIN
WEIGHT 1
VOLUME 1
SUBSTANCE CLOTH
REAGENT
IFPREVERB CAST -1
  IFVAR SPELLNUM = 412
    IFVAR MANAPOINTS > 8
      CLEARVERB
      EQUAL SPELLNUM 0
      EQUAL ITEMVAL3 1
      ECHO PLAYER As you gesture at %a, it becomes cloudy.
      ECHO OTHERS As %n gestures at %a, it becomes cloudy.
      SUB MANAPOINTS 9
    ENDIF
  ENDIF
  IFVAR SPELLNUM = 215
    IFVAR MANAPOINTS > 9
      IFVAR ITEMVAL3 = 1
        CLEARVERB
        EQUAL SPELLNUM 0
        EQUAL ITEMVAL3 2
        ECHO PLAYER You gesture at the eye and it becomes transluscent. An faint image forms within its retina.
        ECHO OTHERS %N gestures at %a.
      ELSE
        ECHO OTHERS %N gestures at %a.
        ECHO PLAYER You realize that the eye has not yet been prepared...
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFVAR ITEMVAL3 = 2
  IFPREVERB LOOK -1
    RANDOM DUMMY1 1 10 0
    ECHO OTHERS %N looks deep into %a.
    ECHO PLAYER You gaze deep into the eye...
    SHOWROOM EYEDEADRNUM
    IFVAR DUMMY1 = 1
      ECHO ALL The eye crumbles.
      REMOVEITEM -1
    ENDIF
  ENDIF
ENDIF
