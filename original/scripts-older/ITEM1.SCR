SUBSTANCE CLOTH
;
; Fireplace
INUMBER 195
NAME 75
VOLUME 100
WEIGHT 1000
CONTAINER IN
INTERIOR 50
LIGHTABLE
HIDDEN
IFPREVERB LOOK -1
  IFVAR INTNUM3 ! 1
     CLEARVERB
     ECHO PLAYER The following verbs are associated with the fireplace, I'll leave it up to you to discover what they all do:
     ECHO PLAYER %cLIGHT LEAN POKE PUSH EXTINGUISH and all others associated with touching it.
  ELSE
     ECHO PLAYER The following verbs are currently used with the fireplace:
     ECHO PLAYER LIGHT-lights fire, changes adj1 to 526 <burning> and sets itemval 5 to whatever was itemadj1.
     ECHO PLAYER EXTINGUISH-resets itemadj1 to what was stored in itemval5, extinguishes fire.
     ECHO PLAYER EXTINGUISH-if unlit, pushes coals around.
     ECHO PLAYER LEAN-leans against the mantle....
     ECHO PLAYER PUSH-add log to lit fire, add kindling to unlit one.
     ECHO PLAYER POKE-stokes fire till blazing...
     ECHO PLAYER IFTOUCH captures all other forms of touching...
  ENDIF
ENDIF
IFPREVERB LIGHT -1
  CLEARVERB
  IFVAR ITEMADJ1 ! 526
    ECHO PLAYER You carefully light a fire in the fireplace.
    ECHO OTHERS %N lights a fire the fireplace.
    SETITEMVAL -1 5 ITEMADJ1
    SETITEMADJ -1 1 526
  ELSE
    ECHO PLAYER It's already been lit.
  ENDIF
ENDIF
IFPREVERB LEAN -1
  CLEARVERB
  IFVAR ITEMADJ1 = 526
    ECHO PLAYER You relax against the mantle and warm your back.
    ECHO OTHERS %N relaxes against the mantle and warms %h back.
  ELSE
    ECHO PLAYER You relax against the mantle.
    ECHO OTHERS %N relaxes against the mantle.
  ENDIF
ENDIF
IFPREVERB TOUCH -1
  IFVAR ITEMADJ1 = 526
    CLEARVERB
    ECHO PLAYER You warm your hands by the roaring fire.
    ECHO OTHERS %n warms %h hands by the roaring fire.
  ENDIF
ENDIF
IFPREVERB POKE -1
  CLEARVERB
  IFVAR ITEMADJ1 = 526
    ECHO OTHERS %N stokes the fire until it blazes up nicely.
    ECHO PLAYER You stoke the fire until it blazes up nicely.
  ELSE
    ECHO PLAYER The fire is not lit.
  ENDIF
ENDIF
IFPREVERB PUSH -1
   CLEARVERB
   IFVAR ITEMADJ1 = 526
      ECHO PLAYER You add a log to the fire.
      ECHO OTHERS %N adds a log to the fire.
   ELSE
      ECHO PLAYER You add some kindling to the fireplace.
      ECHO OTHERS %N puts some kindling in the fireplace, preparing to light it.
   ENDIF
ENDIF
IFPREVERB EXTINGUISH -1
  CLEARVERB
  IFVAR ITEMADJ1 = 526
    ECHO PLAYER You cover the fireplace and let the flames die down.
    ECHO OTHERS %N covers the fireplace and lets the flames die down.
    SETITEMADJ -1 1 ITEMVAL5
    EQUAL ITEMVAL5 -1
  ELSE
    ECHO PLAYER You scatter the coals, making sure the fire is completely out.
    ECHO OTHERS %N scatters the coals in the fireplace.
  ENDIF
ENDIF
