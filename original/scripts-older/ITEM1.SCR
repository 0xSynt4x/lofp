;
; Orb
INUMBER 144
NAME 151
MISC
WEIGHT 1
VOLUME 2
SUBSTANCE STONE
VARIABLE STEPED
IFPREVERB PUSH -1
  IFVAR ITEMBIT5 = 1
    CLEARVERB
    IFVAR ITEMVAL5 ! TIM
      IFVAR ITEMVAL1 = 0
        EQUAL ITEMVAL5 TIM
        EQUAL ITEMVAL1 1
        ECHO PLAYER You push in a stud on the orb. You hear an audible "CLICK".
        ECHO OTHERS %N pushes in a stud on %h orb. You hear an audible "CLICK".
      ELSE
        ECHO PLAYER The orb is already armed.
      ENDIF
    ELSE
      ECHO PLAYER The orb is still re-charging.
    ENDIF
  ENDIF
ENDIF
IFPREVERB DROP -1
  IFVAR ITEMBIT5 = 1
    IFVAR ITEMVAL1 = 1
    EQUAL ITEMVAL1 0
    ECHO PLAYER You hurl the orb to the ground! You immediately smell brimstone.
    ECHO OTHERS %N throw an orb to the ground which spits out a could of brimsone.
    PLREVENT 1
    CONTPLREVENT
    EQUAL ITEMVAL1 0
    DAMAGEALL BURN 50 You get scorched by a wave of fire.
    ECHO PLAYER You take out some burn salve and annoint yourself.
    ECHO OTHERS %N takes out a well used tube of burn salve and applied some to %hself.
    ADD BODYPOINTS 30
    ENDIF
  ENDIF
ENDIF
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    CLEARVERB
    ECHO PLAYER Gradrak spews, "If the itembit19 = 1, this is a unique and magical imp orb.
    ECHO PLAYER Gradrak says, "If this itembit 5 = 1, this is a once per hour grenade. Push then drop.
    ECHO PLAYER Shadow says, "When the ITEMBIT1 = 1 this becomes a spying orb, when thumped it captures the room number it is in then when it is gazed at it shows that room."
  ENDIF
  IFVAR ITEMBIT19 = 1
    CLEARVERB
    ECHO PLAYER The swirls of colors clear as you gaze into the orb. Inside you see a
    ECHO PLAYER a little green man, sitting in a plush, easy chair. He looks up at you and
    ECHO PLAYER sighs, shaking his head at the stupidity of mortals.
  ENDIF
ENDIF
IFPREVERB WAVE -1
  IFVAR ITEMBIT19 = 1
    RANDOM DUMMY1 1 4 0
    IFVAR DUMMY1 = 1
      ECHO ALL A whiny voice yells out, "You pathetic moron! Stop pushing on me, I'm trying to bake some cookies!", as %N pushes on the orb.
    ENDIF
    IFVAR dummy1 = 2
      ECHO ALL An angry voice screams, as the orb vibrates with fury, "You just made me spill my brandy, you idiotic offspring of a Hill Giant!"
    ENDIF
    IFVAR dummy1 = 3
      ECHO ALL The little green fellow sticks his head out of the orb and glares at %N, "I'm entertaining a beautiful young pixie, and you're shaking us off the bed! That I can handle by myself!". The head then disappears back into the orb, growling.
    ENDIF
    IFVAR dummy1 = 4
      ECHO ALL A sickly, sweet voice, oozing with insincerity, emanates from the orb, "Why thank you, master, I really didn't want to sleep anyways. Now that I'm awake, I think I'll do something, just for you, oh everglorious master whom I worship every day!". A faint, bluish light covers %N, when it clears %s looks different...
      RANDOM dummy2 1 4 0
      IFVAR dummy2 = 1
        APPEAR %N has small pink elephants, wearing plaid tu-tu's, dancing around %h head.
      ENDIF
      IFVAR dummy2 = 2
        APPEAR %N's nose is two feet long and is spotted with brilliantly glowing pink circles.
      ENDIF
      IFVAR dummy2 = 3
        ECHO OTHERS %N brays like a donkey, "Hee-haw! Hee-haw!"
        APPEAR %N has large blue donkey ears and a swishing tail.
      ENDIF
      IFVAR dummy2 = 4
        APPEAR %N's lips hang to %h stomach, glowing with a faint, puke-green color.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB RUB -1
  IFVAR ITEMBIT19 = 1
    IFVAR ITEMVAL5 ! DAY
      IFVAR ITEMVAL3 ! TIM
        RANDOM DUMMY3 1 12 0
        IFVAR DUMMY3 = 1
          ECHO PLAYER The little green man sighs, "Very well, you oafish mortal, you can have a cookie."
          ECHO OTHERS You hear some muttering emanate from the orb and then a cookie appears.
          NEWITEM 9 790 ADJ1=54 ADJ2=718
          EQUAL ITEMVAL3 TIM
        ENDIF
        IFVAR DUMMY3 = 2
          ECHO PLAYER The orb pulses slightly, "Hmmm, you look like you need something to test yourself against...Here, this Ravager looks lonely, and is a poor conversationalist anyways..."
          ECHO OTHERS The orb pulses slightly and then you see a Ravager gazing hungrily at you...
          GENMON 123
          EQUAL ITEMVAL3 TIM
        ENDIF
        IFVAR dummy3 = 3
          ECHO PLAYER A pouty voice emanates from the orb, "I've got a headache, go away."
        ENDIF
        IFVAR dummy3 = 4
          ECHO PLAYER The little green man says, "You look a bit weak, here let me help you."
          ECHO OTHERS A green glow covers %N for a moment...
          EQUAL ITEMVAL3 TIM
        ENDIF
        IFVAR DUMMY3 >= 5
          IFVAR DUMMY3 <= 8
            ECHO PLAYER The little green man looks at you thoughtfully and says, "You look like you could need some healing."
            ECHO OTHERS You hear a sigh emanate from the orb, "Stupid here needs some healing, guess I have to help %i."
            SPELL 318 30
            EQUAL ITEMVAL3 TIM
          ENDIF
        ENDIF
        IFVAR dummy3 = 9
          ECHO PLAYER The little green man says, "A bit peaked are we? Drink a little bit too much last night? Guess I have to help you, even though you're an idiot?"
          ECHO OTHERS A white glow covers %N.
          SPELL 335 30
          EQUAL ITEMVAL3 TIM
        ENDIF
        IFVAR dummy3 = 10
          ECHO PLAYER The little green man says, "I think you need some protection...."
          ECHO OTHERS A voice from the orb whispers to you, "This moron is not going to survive without me, so..."
          SPELL 326 30
          EQUAL ITEMVAL3 TIM
        ENDIF
        IFVAR DUMMY3 => 11
          ECHO PLAYER The little green man says, "A bit lethargic and slow today? Not that it's anything out of the ordinary..."
          ECHO OTHERS A voice whispers, chuckling under its breath, from the orb, "%N is slower than molasses, couldn't even outrace, or for that matter outhink, a Stone Ogre."
          SPELL 210 30
          EQUAL ITEMVAL3 TIM
        ENDIF
      ENDIF
      IFVAR STEPED >= 20
        EQUAL ITEMVAL5 DAY
      ENDIF
    ENDIF
    IFVAR ITEMVAL5 = DAY
      ECHO PLAYER You hear snoring emanating from the orb.
      ECHO OTHERS Loud snores shake your surroundings, emanating from %N's orb.
    ENDIF
  ENDIF
ENDIF

IFPREVERB THUMP -1
  IFVAR ITEMBIT1 = 1
    CLEARVERB
    ECHO OTHERS %N's small orb shimmers slightly.
    ECHO PLAYER You see an image of the room in which you stand inside the orb.
    EQUAL ITEMVAL1 RNUM
  ENDIF
ENDIF

IFPREVERB GAZE -1
  IFVAR ITEMBIT1 = 1
    CLEARVERB
    ECHO OTHERS %N looks closely at a small orb.
    SHOWROOM ITEMVAL1
  ENDIF
ENDIF
