INUMBER 1212
NAME 939
ARMOR
WORN_NECK
PARAMETER1 20
SUBSTANCE BRITTLE
;
;I# 343 : Hearth
INUMBER 343
NAME 334
WEIGHT 1000
VOLUME 1000
MISC
HIDDEN
CONTAINER IN
INTERIOR 500

IFPREVERB LIGHT -1
  CLEARVERB
  IFVAR ITEMVAL5 = 0
    ECHO OTHERS %N starts to build a small fire in the hearth.
    ECHO PLAYER You build a small fire in the hearth.
    SETITEMVAL -1 5 1
  ELSE
    ECHO PLAYER The fire is already lit.
  ENDIF
ENDIF
IFPREVERB POKE -1
  CLEARVERB
  IFVAR ITEMVAL5 = 1
    ECHO OTHERS %N stokes the fire until it blazes up nicely.
    ECHO PLAYER You stoke the fire until it blazes up nicely.
  ELSE
    ECHO PLAYER The fire is not lit.
  ENDIF
ENDIF
IFPREVERB UNLIGHT -1
  CLEARVERB
  IFVAR ITEMVAL5 = 1
     ECHO OTHERS %N douses the fire in the hearth.
     ECHO PLAYER You douse the fire in the hearth.
     SETITEMVAL -1 5 0
  ELSE 
     ECHO PLAYER There is no fire there to douse.
  ENDIF
ENDIF
IFTOUCH -1
  IFVAR ITEMVAL5 = 1
    IFVAR WOLFFORM ! 1
      CLEARVERB
      ECHO PLAYER You warm your hands over the fire.
      ECHO OTHERS %N warms %h hands over the fire.
    ELSE
      CLEARVERB
      ECHO PLAYER You curl up at edge of the hearth near the fire.
      ECHO OTHERS %n curls up at the edge of the hearth.
      POSITION LAY
    ENDIF
  ENDIF
ENDIF
;
;I# 1211 : Tiny Castle
INUMBER 1211
NAME 938
WEIGHT 1
VOLUME 1
MISC
IFVERB RUB -1
	IFVAR REGION > 2
		ECHO PLAYER %A appears cleaner.
	ENDIF
	IFVAR REGION < 3
		IFITEM 9
			ECHO PLAYER %A appears cleaner.
		ENDIF
		IFNOITEM 9
			IFVAR MKCASTLE = 1
				ECHO PLAYER %A appears cleaner.
			ENDIF
			IFVAR MKCASTLE ! 1
				EQUAL MKCASTLE 1
				ECHO ALL A shimmering gate appears.
				NEWITEM 9 68 OPEN UNLOCKED VAL2=90 ADJ1=287
				EQUAL castret RNUM
				AFFECT 90
				SETITEMVAL 0 2 castret
			ENDIF
		ENDIF
	ENDIF
ENDIF
