IFVAR ITEMADJ2 = 545
  IFPREVERB EAT -1
    CLEARVERB
    ECHO OTHERS %N takes a bite out of %a.
    IFVAR INTNUM90 > 0
      ECHO PLAYER Nothing happens as you take a bite out of the eye.
    ELSE
      IFVAR SKILL5 ! 1
        GMMSG  ** %N take a bite out of a spider eye.
        ECHO PLAYER You take a bite out of the eye and swallow it. The palms of your hands become extremely sticky.
        ADD SKILL5 10
        EQUAL INTNUM90 7
        EQUAL INTNUM89 1
      ELSE
        ECHO PLAYER Nothing happens as you take a bite out of the eye.
      ENDIF
    ENDIF
    RANDOM DUMMY1 1 10 0
    IFVAR DUMMY1 = 1
      REMOVEITEM -1
      ECHO PLAYER That was the last of it.
    ENDIF
  ENDIF
ENDIF
