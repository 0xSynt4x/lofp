VOLUME 1000
HIDDEN
;
;I# 1215 : Sword with defensive spell
INUMBER 1215
NAME 201
SLASH_WEAPON
WEIGHT 6
VOLUME 5
PARAMETER1 10
IFTOUCH -1
  IFVAR INTNUM3 = 1
    CLEARVERB
    ECHO PLAYER This sword casts a protective spell. Every time you concentrate
    ECHO PLAYER on it, while wielded, it casts a Globe of Protection; this also
    ECHO PLAYER drops the VAL5 by one, until it no longer crits at all. If you
    ECHO PLAYER decide to recharge this for a player, make sure that the method
    ECHO PLAYER or payment for the recharge is far from easy.
  ENDIF
ENDIF
IFPREVERB PULL -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You raise %a in salute.
    ECHO OTHERS %N raises %a in salute.
  ENDIF
ENDIF
IFVERB CONCENTRATE -1
	IFITEM -1 WIELDED
    IFVAR ITEMVAL5 > 0
      ECHO PLAYER The pommel of the sword glows brightly!
	    ECHO OTHERS The pommel of %n's sword glows brightly!
      SPELL 105 20
	    SUB ITEMVAL5 1
    ENDIF
	ENDIF
ENDIF
