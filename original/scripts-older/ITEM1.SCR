;I# 674 : cluster
INUMBER 674
NAME 575
WEIGHT 1000
VOLUME 1000
MISC
HIDDEN
ARTICLE SOME
PLURAL
;I# 675 : Grimoire of Chaos!
inumber 675
name 576
weight 8
volume 4
substance indestructable
openable
ifpreverb look -1
        clearverb
        echo player The title reads, "Ye Olde Gimoire of Chaos!"
endif
iftouch -1
        ifvar intnum3 = 1
        echo player Gradrak yelps, "If the itembit0 = 1 This is a UNIQUE item belonging to the Silver Arcana.
        endif
endif
ifpreverb recall -1
        ifvar skill32 > 12
        clearverb
        echo player You recognize this book as the Grimoire of Chaos. According to legend, once it is unlocked, you can open it one or more times a day to create powerful magical affects.
        echo player At this time, you do not know how to unlock it.
        endif
endif
ifpreverb open -1
        ifvar itembit0 = 1
                ifvar itemval3 ! 0
                        ifvar patgrim = 0
                        clearverb
                        echo player You open the Grimoire of Chaos. It automatically flips to a random page.
                        echo others %N opens up the Grimoire of Chaos. You see it's pages turning automatically until it stops on one page.
                        equal patgrim 1
                        plrevent 1
                        contplrevent
                        echo all The pages stop turning.
                        plrevent 1
                        contplrevent
                        random dummy1 1 13 0
                                ifvar dummy1 = 1
                                echo player You look onto a picture of an intense looking man wearing silvery blue silk robes. The picture comes to life and the man stares into your eyes. You feel him mentally probe you....
                                echo player You feel different.
                                echo others %N gazes into the grimoire, then stiffens and touches %h head.
                                add wil 5
                                endif
                                ifvar dummy1 = 2
                                echo player The page you see is a forest scene. You can see nothing odd at first, but the more you stare, the more you see. In all, there are nine hidden Aelfs in the picture.
                                echo player You feel more perceptive.
                                echo others %N stares at the grimoire for a long time.
                                add per 1
                                endif
                                ifvar dummy1 = 3
                                echo player A wave of energy flows out of the grimoire. Some of it clings to you!
                                echo others A wave of energy flows out of the grimoire. Some of it clings to %N!
                                equal manapoints 999
                                equal psipoints 999
                                endif
                                ifvar dummy1 = 4
                                echo player You see a page with just the word "Falchatha" on it. You speak this words without thinking about it...
                                echo others %N glances at the grimoire and says, "Falchata" in a voice which is not %h own.
                                equal ritualval2 85
                                spell 2
                                endif
                                ifvar dummy1 = 5
                                echo player The page lands on a picture of a magical cauldron. As you look more closely at it, some sort of orange goop bubbles out of the cauldron and lands next to you.
                                echo others Some sort of orange goop flies out of the grimoire and lands near %N.
                                newitem 9 323 adj1=1132 adj2=225 val2=3 val3=332
                                endif
                                ifvar dummy1 = 6
                                echo player You get a close up picture of an active volcano.... Say isn't that lava coming towards you?
                                echo others %N begins to duck....
                                damageplr burn 80 The lava hits you directly!
                                damageall burn 40 You get sprayed by lava!
                                endif
                                ifvar dummy1 = 7
                                echo player You see nothing but the flames of hell. Suddenly, a demonic assassin leaps out of the grimoire and lands right next to you.
                                echo others A demonic assassin leaps out of the grimoire and lands near you!
                                genmon 140
                                endif
                                ifvar dummy1 = 8
                                        ifvar region = 0
                                        echo player A giant shadowy hand flied out of the grimoire and slams you into the sky miles away. You take massive damage!
                                        echo others %N is hurled into the sky by a giant shadowy first which comes right out of %h grimoire!
                                        move 2152
                                        equal bodypoints -10
                                        else
                                        damageplr crush 100 You are crushed by a massive wind blast!
                                        echo others %N is slammed to the ground by a destructive blast of wind!
                                        position lay
                                        endif
                                endif
                                ifvar dummy1 = 9
                                echo player You gaze at a realistic picture of the lava below the Blood of Andor. Without thinking, you will yourself to be there.
                                echo others %N looks into the grimoire, then simply vanishes.
                                move 1769
                                endif
                                ifvar dummy1 = 10
                                echo player You gaze upon a painting of Kaliban. The painting comes to life and a hand reaches out to touch you.
                                echo others %N gazes into the grimoire for a second. Then an ephemeral-like hand reaches out and touches %i.
                                echo player You feel that you have been blessed by Kaliban.
                                add align 8
                                endif
                                ifvar dummy1 = 11
                                echo player As soon as the grimoire opens, dark shadows erupt from its pages. You quickly shut it, but you still feel tainted.
                                echo others AS soon as the grimoire opens, dark shadows erupt from it! %N quickly shuts it.
                                sub align 8
                                endif
                                ifvar dummy1 = 12
                                echo player You are hit in the face with a dazzling beam of light.
                                echo others %N is hit in the face with a dazzling beam of light.
                                spell 324 30
                                endif
                                ifvar dummy1 = 13
                                echo player You glance at a passage and before you can stop yourself you read 10 words. You recognize those words as having imfluence on aging.
                                echo others %N glances into the grimoire and seems to age before your eyes.
                                add age 10
                                endif
                        else
                        clearverb
                        echo player You can't open it.
                        endif
                endif
        endif
endif
