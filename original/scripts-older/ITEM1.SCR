;
; Fissure (no portal)
INUMBER 430
NAME 335
WEIGHT 1000
VOLUME 1000
MISC
CONTAINER IN
INTERIOR 30
HIDDEN
;
;
;
;
;
; Fizz
INUMBER 463
NAME 429
LIQUID
PARAMETER1 8
PARAMETER2 1
WEIGHT 1
VOLUME 1
ifpreverb drink -1
        ifvar itemadj1 = 209
                echo player You take a big sip of the mysterious fizz.
                echo others %N takes a big sip of the mysterious fizz.
                clearverb
                ifvar itemval2 = 1
                        removeitem -1
                        echo player That was the last of it.
                endif
                sub itemval2 1
                add intnum41 10
                equal dummy1 con
                sub dummy1 100
                sub dummy1 intnum41
                ifvar dummy1 > 0
                        echo player It makes your tongue tingle.
                        echo others %N gets an odd look on %h face.
                else
                        random dummy2 1 5 0
                        ifvar dummy2 = 5
                                equal intnum41 0
                                random dummy3 1 10 0
                                ifvar dummy3 = 1
                                        echo player You stand up and scream, "Yowie Wowie!" Then the floor jumps up and hits you in the face.
                                        echo others %N stands up and screams, "Yowie Wowie!", spins around once, then tips over.
                                        position lay
                                        spell 218 30
                                endif
                                ifvar dummy3 = 2
                                        echo player Your vision gets blurry and suddenly tip over.
                                        echo others First %N's left eye goes to center, then %h right eye does the same. Both eyes then roll back into %h head.
                                        echo others %N exclaims, "Gaaaah!", then falls over backwards.
                                        position lay
                                        spell 218 30
                                endif
                                ifvar dummy3 = 3
                                        echo player You belch a horrendous belch. The vapors knock you silly.
                                        echo others %N belches a horrendous belch. In addition to being noxious, the vapors from %h stomach seem poisonous.
                                        damageall poison 2 Yuck, the stink is horrible.
                                        position lay
                                        spell 218 30
                                endif
                                ifvar dummy3 = 4
                                        echo player You sneeze and strange yellow foam comes out of your nose! In suprise, you hit your head and knock yourself out.
                                        echo others %N sneezes and strange yellow foam comes out of %h nose! %N looks very suprised and %s knocks his head and keels over.
                                        position lay
                                        spell 218 30
                                endif
                                ifvar dummy3 = 5
                                        echo player For some reason, you repeatedly bang your head against the nearest solid object until you are unconscious.
                                        echo others %N bangs %h head repeatedly against the nearest table until %s knocks himself out.
                                        position lay
                                        equal bodypoints -5
                                endif
                                ifvar dummy3 = 6
                                        echo player You yell, "Quick everyone, to the north!"
                                        echo others %N yells, "Quick everyone, to the north!"
                                        ifvar exitn = -1
                                                echo player You run right into a wall to the north.
                                                echo others %N runs right into a wall to the north.
                                                position lay
                                                equal bodypoints -5
                                        else
                                                move exitn
                                                affect exitn
                                                echo others %N runs up to you, keels over and falls asleep.
                                                position lay
                                                spell 218
                                        endif
                                endif
                                ifvar dummy3 = 7
                                        echo player There is fuzz growing on your tongue, you swear it! You try to scrape it off with your fingers.
                                        echo others %N sticks out %h tongue and starts trying to scrape something off of it....
                                        echo player You accidentally hiccup and bite your hand! You fall over.
                                        echo others %N hiccups a few fizzy bubbles, bites %h hand and falls over.
                                        position lay
                                        spell 218 30
                                endif
                                ifvar dummy3 = 8
                                        echo player You suddenly begin to float. Wow, this is great. Unfortunately, you fall asleep before you can fly anywhere.
                                        echo others %N suddenly begins to float, then falls asleep. %S actaully hovers while sleeping for a split second.....then hits the ground.
                                        position lay
                                        spell 224 30
                                        spell 218 30
                                endif
                                ifvar dummy3 = 9
                                        echo player A purple imp walks up to you and whispers, "Hey, it's time for you to pass out!" It knocks you unconcious with a spotted pink hammer and pushes you over....How rude!
                                        echo others %N mumbles something about rude purple imps with spotted pink hammers and keels over.
                                        position lay
                                        equal bodypoints -5
                                endif
                                ifvar dummy3 = 10
                                        echo player You feel your insides boiling and bubbling. You suddenly wonder if you have any insurance left...right before you explode.
                                        echo others %N gets a funny look on %h face...then %s explodes!
                                        echo others Needless to say, it is pretty gross.
                                        equal dead 1
                                        position lay
                                        equal bodypoints -1000
                                        gmmsg ****%N just got killed by drinking Gradrak's 'special' drinking contest fizz!****
                                endif
                        endif
                endif
        endif
endif

