ifvar itembit0 = 1
        ifpreverb wield -1
                ifvar itemval1 = 0
                equal itemval1 skill13
                equal itemval5 intnum3
                echo player You feel all of your knowledge of edged weapons dribble from your mind.
                equal skill13 0
                else
                echo player The epee looks you see if you were the last person to wield it...
                        ifvar intnum3 = itemval5
                        echo player ....You are.
                        else
                        clearverb
                        echo player ...You are not.
                        echo player The epee will not let you wield it.
                        endif
                endif
        endif
        ifpreverb unwield -1
                ifvar intnum3 = itemval5
                equal itemval5 0
                equal skill13 itemval1
                equal itemval1 0
                echo player You slowly regain your knowledge of edged weapons.
                else
                echo player You feel no changes to your knowledge.
                endif
        endif
endif
