;
;I# 1113 : Wristlet
INumber 1113
Name 872
MISC
WEIGHT 1
VOLUME 2
CRAFTABLE
ENCRUSTABLE
PARAMETER2 3
SUBSTANCE SOFTMETAL
WORN_WRIST
TURNABLE
IFVAR ITEMBIT0 = 1
	;----------------------------set device-------------------	
	IFPREVERB CONCENTRATE -1
		IFVAR ITEMVAL1 = 0
			SETITEMVAL -1  1 INTNUM3
		ENDIF        			
  	ENDIF
	;-------------------keeps it from being dropped or deposited
	IFPREVERB DROP -1
  		CLEARVERB
		ECHO PLAYER The wristlet refuses to budge.
	ENDIF
	IFPREVERB DEPOSIT -1
		CLEARVERB
		ECHO PLAYER The wristlet refuses to budge.
	ENDIF
	;-------------------------- prevent taking wristlet thats not yours -------------------------
	IFPREVERB TAKE -1
		IFVAR ITEMVAL1 ! INTNUM3
			CLEARVERB
			DAMAGEPLR ELECTRIC 170 The wristlet jumps from your grasp and flares darkly, zapping you.
			ECHO OTHERS %N reaches for %a, but it flares with a black snap.
			GMMSG **%n just tried to take a Technomancer wristlet.
		ENDIF
    	ENDIF
	;------------------------ prevent theft ----------------------
	IFPREVERB STEAL -1
		IFVAR ITEMVAL1 ! INTNUM3
			CLEARVERB
			DAMAGEPLR ELECTRIC 170 The wristlet jumps from your grasp and flares darkly, zapping you.
			ECHO OTHERS %N reaches for %a, but it flares with a black snap.
			GMMSG **%n just tried to steal a Technomancer wristlet.
		ENDIF
    	ENDIF
    	;---------------------defense----------------
   	IFPREVERB TURN -1
		CLEARVERB
		ECHO PLAYER You tap a code into your wristlet and it speaks to you:
  		ECHO OTHERS %N taps %h wristlet and it speaks in a mechanical voice:
   		ECHO ALL The voice says, "Initiation of defensive measures ..."
  		SPELL 102
  		SUB MANAPOINTS 10
    	ENDIF
   	;--------------------offense-----------------
   	IFPREVERB TAP -1
		CLEARVERB
		ECHO PLAYER You tap a code into your wristlet and it speaks to you:
  		ECHO OTHERS %N taps %h wristlet and it speaks in a mechanical voice:
   		ECHO ALL The voice says, "Initiation of offensive measures ..."
  		SPELL 532
		ECHO Player Feel the fire of the atom!!! %c
      		DAMAGE ELECTRIC 25 Lightning crackles from the wristlet to %n.
		SUB MANAPOINTS 30
   	ENDIF
ENDIF
