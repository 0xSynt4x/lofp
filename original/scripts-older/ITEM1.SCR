; Lilacs
INUMBER 273
NAME 276
WEIGHT 1
VOLUME 1
MISC
ARTICLE SOME
PLURAL
SUBSTANCE PAPER
AMMo
ifpreverb look -1
  ifvar intnum3 = 1
    echo player Gradrak snorts, "If this has an itemval5 of 1, sniffing it will pull the player into the earth for a time.
  endif
endif
ifvar itemval5 = 1
  IFPREVERB SNIFF -1
    ifvar roundtime > 0
      strcvt 0 roundtime
      echo player [Round: %0 Sec]
    else
      clearverb
      IFVAR TERRAIN < 13
        SUB ITEMVAL3 1
        ECHO PLAYER You take a deep whiff of the lilacs. Suddenly, the earth yields to you and you sink right into it. The lilac you smelled crumbles into dirt.
        ECHO OTHERS %N takes a deep whiff of a lilac. One of the flowers crumbles and %s sinks right into the earth.
        EQUAL ROUNDTIME 5
        EQUAL PLILACS RNUM
        MOVE 1901
        AFFECT 1901
        ECHO OTHERS The ground opens up in front of you and %N climbs out of the hole.
        echo others The hole seals up behind %i.
        ifvar itemval3 < 1
          echo player That was the last lilac.
          removeitem -1
        endif
      ENDIF
    ENDIF
  endif
ENDIF
