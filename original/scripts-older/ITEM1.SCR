; Chocolate
INUMBER 1391
NAME 1457
WEIGHT 1
VOLUME 1
PARAMETER1 2
FOOD
SUBSTANCE BRITTLE
IFVERB EAT -1
	IFVAR ITEMVAL5 = 0
		RANDOM DUMMY1 1 7 0
		SETITEMVAL -1 5 DUMMY1
	ENDIF
	IFVAR ITEMVAL5 = 1
		IFVAR ITEMVAL3 ! 0
			ROUTINE 1
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 = 2
		IFVAR ITEMVAL3 ! 0
			ROUTINE 2
		ENDIF
	ENDIF
	IFVAR ITEMVAL5 = 3
		ECHO PLAYER As you chew on the chocolate you bite down on something hard. It's a gem!
		ECHO OTHERS %N bites down on something hard, then spits out a gem!
		RANDOM DUMMY1 1 5 0
		IFVAR DUMMY1 = 1
			ECHO ALL A diamond bounces to the ground.
