;
; Monocle
INUMBER 364
NAME 96
VARIABLE MONOCLEVAL
WEIGHT 1
VOLUME 3
INTERIOR 20
ARTICLE A
CONTAINER UNDER
MISC
DYEABLE
CRAFTABLE
ENCRUSTABLE
SUBSTANCE HARDMETAL
;SUBSTANCE BRITTLE
WORN_DON
PARAMETER2 35
IFPREVERB2 PUT -1
  IFVAR ARCHNUM ! 364
    CLEARVERB
    IFVAR ARCHNUM > 98
      IFVAR ARCHNUM < 158
        ECHO PLAYER You carefully scrutinize %a through your monocle.
        ECHO OTHERS %N carefully scrutinizes %a through %h monocle.
        EQUAL MONOCLEVAL ITEMVAL1
        DIV MONOCLEVAL 16000
        IFVAR MONOCLEVAL ! 0
          ECHO PLAYER The gem is worth no less than 80 gold coins and could be worth alot more.
        ENDIF
        IFVAR MONOCLEVAL = 0
          EQUAL MONOCLEVAL ITEMVAL1
          DIV MONOCLEVAL 200
          STRCVT 0 MONOCLEVAL
          ECHO PLAYER You estimate its worth at about %0 gold coins.
          ECHO PLAYER [Round: 5 secs]
          EQUAL ROUNDTIME 5
        ENDIF
        EQUAL MONOCLEVAL 0
      ELSE
        ECHO PLAYER Your monocle can only appraise gems and jewelry.
      ENDIF
    ELSE
      ECHO PLAYER Your monocle can only appraise gems and jewelry.
    ENDIF
  ENDIF
ENDIF
