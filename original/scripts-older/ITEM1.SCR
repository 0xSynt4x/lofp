;I# 796 : Bracelet
INUMBER 796
NAME 33
WEIGHT 1
VOLUME 1
WORN_WRIST
MISC
IFVAR itemval1 > 3500
	RANDOM dummy2 1 300 0
	IFVAR dummy2 < 2
		ECHO ALL You hear a strange crackling noise, and a tiny wisp of smoke rises from deep inside the bracelet.
		EQUAL itemval1 0
		CLEARVERB
	ENDIF
ENDIF
IFPREVERB turn -1
	IFITEM -1 WORN
		IFVAR ITEMVAL1 > 3500
			CLEARVERB
			ECHO PLAYER As you turn the bezel of the bracelet around, the next segment of the center stone glows brightly.
			ECHO OTHERS %n fiddles with %h bracelet.
			IFVAR itemval2 = 202
				EQUAL itemval2 121
				STOP
			ENDIF
			IFVAR itemval2 = 121
				EQUAL itemval2 527
				STOP
			ENDIF
			IFVAR itemval2 = 527
				EQUAL itemval2 700
				STOP
			ENDIF
			IFVAR itemval2 = 700
				EQUAL itemval2 202
				STOP
			ENDIF
			EQUAL itemval2 202
		ENDIF
	ENDIF
ENDIF
IFPREVERB touch -1
	IFVAR ITEMVAL1 > 3500
		IFVAR QUESTISON = 0
			CLEARVERB
			ECHO PLAYER The moment you touch the bracelet, you feel yourself escaping the normal bounds of your body. A moment later, you reform in a different location.
			ECHO OTHERS %N touches %h bracelet and vanishes!
			RANDOM dummy1 1 7 0
			ADD dummy1 itemval2
			MOVE dummy1
		ENDIF
		IFVAR QUESTISON = 1
			CLEARVERB
			ECHO PLAYER The bracelet makes a tiny click. (It probably is just refusing to work during a quest.)
		ENDIF
	ENDIF
ENDIF
IFPREVERB look -1
