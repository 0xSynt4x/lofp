    echo player You cast a sunray at the jagged mirror, but notice that it was already charged.
    echo others %N gestures at a jagged mirror.
    else
    equal spellnum 0
    echo player You focus a ray of the sun into the jagged mirror, it absorbs the energy.
    echo others %N gestures at a jagged mirror and a ray of sunlight flows into it.
    equal itembit19 1
    endif
  endif
endif
