	DAMAGEALL BURN 40 Suddenly searing hot oil pours down from the ceiling.
ENDIF
IFSAY FRIEND
	IFVAR INTNUM22 < 0
		ECHO ALL A voice screams, "No not you! You are not welcome here."
	ENDIF
	IFVAR INTNUM22 = 0
		ECHO ALL A voice calls out to you, "Prove it!"
	ENDIF
	IFVAR INTNUM22 > 0
		IFVAR PLRSINROOM > 1
			ECHO ALL A voice calls out, "We know you %n, but who are those with you?"
		ENDIF
		IFVAR PLRSINROOM = 1
			ECHO ALL A voice calls out, "Come in %N."%c>%cYou hear a click in the gate, and it slowly opens.
			EQUAL FLAG1 2
			EQUAL OPNOW 2
		ENDIF
	ENDIF
ENDIF
IFPREVERB2 PUT 2
	ECHO OTHERS %N puts %a on the gate's shelf.
	IFVAR INTNUM22 >= 0
		IFVAR ITEMVAL1 <= 301
			ECHO ALL You hear a call out from the gate, "Go away!
		ENDIF
		IFVAR ITEMVAL1 > 300
			ECHO ALL A webbed hand reaches over the gate an grabs %a.
			REMOVEITEM -1
			PLREVENT 5
			CONTPLREVENT
			ECHO ALL You hear a voice call out from the gate, "I have decided to let you in."%c>%cYou hear a click in the gate, and it slowly opens.
			EQUAL FLAG1 2
			EQUAL OPNOW 2
		ENDIF
	ENDIF
	IFVAR INTNUM22 < 0
		IFVAR ITEMVAL1 <= 3001
			ECHO ALL You hear a curse call out from the gate, "Go away! It will take more than that to redeem you."
		ENDIF
		IFVAR ITEMVAL1 > 3000
			ECHO ALL A webbed hand reaches over the gate an grabs %a.
			REMOVEITEM -1
			PLREVENT 5
			CONTPLREVENT
			ECHO ALL You hear a voice call out from the gate, "We have decided to give you another chance."%c>%cYou hear a click in the gate, and it slowly opens.
			EQUAL FLAG1 2
			EQUAL OPNOW 2
		ENDIF
	ENDIF
ENDIF
IFVERB GO 2
	IFVAR OPNOW = 2
		CLEARVERB
		IFVAR FLAG1 = 2
			CLEARVERB
			MOVEGROUP 1853
			ECHO OTHGROUP The gate closes behind %p. You hear the lock click shortly afterward.
			AFFECT 1853
			ECHO OTHGROUP %P is ushered through the gate bye Moiya.
			EQUAL OPNOW 0
			ADD INTNUM22 1
			IFVAR INTNUM22 < 0
				ECHO GROUP Moiya scowls at %n, "You better behave yourself," she says.
			ENDIF
			IFVAR INTNUM22 = 1
				ECHO GROUP An amphibious creature smiles at %p. She says, "Welcome stranger. This is the Gurkan Home, and I am Moiya."
			ENDIF
			IFVAR INTNUM22 >= 2
				IFVAR INTNUM22 < 20
					ECHO ALL Moiya says, "Welcome back %N."%c>%cMoiya smiles at you.
				ENDIF
			ENDIF
			IFVAR INTNUM22 >= 20
				ECHO ALL Moiya exclaims, "Welcome back %n, old friend, always good to see you!"
				ECHO ALL Moiya incants a spell.%c>%cMoiya gestures at %n.
				SPELL 318
				ECHO ALL Moiya incants a spell.%c>%cMoiya gestures at %n.
			ENDIF
		ENDIF
		IFVAR FLAG1 ! 2
			ECHO GROUP The gate suddenly slams shut! "Not you!" yells the voice.
			EQUAL OPNOW 0
		ENDIF
	ENDIF
ENDIF
