      EQUAL ITEMVAL2 1
      EQUAL ITEMVAL3 107
      ROUTINE 2
    ENDIF
    IFVAR DUMMY1 = 3
      ECHO PLAYER A few drops of cool water shower you, evaporating almost as soon as they fall.
      ECHO OTHERS %N is sprinkled by a brief, cool rainshower.
      EQUAL ITEMVAL2 1
      EQUAL ITEMVAL3 108
      ROUTINE 2
    ENDIF
    IFVAR DUMMY1 = 4
      ECHO PLAYER The earth rumbles briefly beneath you, yet you have no trouble keeping your footing.
      ECHO OTHERS The ground rumbles briefly beneath %N's feet.
      EQUAL ITEMVAL2 1
      EQUAL ITEMVAL3 123
      ROUTINE 2
    ENDIF
    IFVAR DUMMY1 = 5
      ECHO PLAYER Light shimmers around you, pale silver and white.
      ECHO OTHERS Pale light glimmers around %N for a moment.
      EQUAL ITEMVAL2 1
      EQUAL ITEMVAL3 109
      ROUTINE 2
    ENDIF
    IFVAR DUMMY1 = 6
      ECHO PLAYER Shadows deepen around you, whispering softly before fading again.
      ECHO OTHERS The shadows around %N deepen and whisper for a moment.
      EQUAL ITEMVAL2 1
      EQUAL ITEMVAL3 144
