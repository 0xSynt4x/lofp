
;
;

VARIABLE BPPLAT
VARIABLE POPLAT
VARIABLE DOPLAT

;
;

CEVENT 82 2 2340
IFVAR DOPLAT ! 0
        ADD BPPLAT DOPLAT
        IFVAR DOPLAT = 1
                IFVAR BPPLAT = 1
                        ECHO ALL The platform lurches and rises away from the boulder, soaring north across the island.
                        REMOVEITEM 1
                        AFFECT 2341
                        ECHO ALL The stone platform lurches and rises away from you.
                        REMOVEITEM 1
                        AFFECT 2340
                ENDIF
                IFVAR BPPLAT = 2
                        ECHO ALL The platform circles about its own center for a moment as it cuts diagonally across the surface of the lake, rising all the while through the warm red mist.
                ENDIF
                IFVAR BPPLAT = 3
                        ECHO ALL The platform begins to rise straight up, towards the ledge high, high above you.
                ENDIF
                IFVAR BPPLAT = 4
                        ECHO ALL The platform continues to rise, wobbling slightly as it avoids a rocky outcropping.
                ENDIF
                IFVAR BPPLAT = 5
                        ECHO ALL The platform begins to decelerate as it rises, approaching the round ledge a short distance above.
                        AFFECT 2339
                        ECHO ALL You see a stone platform rising up from below towards the ledge.
                        AFFECT 2340
                ENDIF
                IFVAR BPPLAT = 6
                        ECHO ALL The platform comes level with the rounded ledge, reaching the top of its course.
                        NEWITEM 1 450 VAL2=2339
                        AFFECT 2339
                        ECHO ALL The platform rises to be level with you, reaching the top of its course.
                        NEWITEM 1 365
                        AFFECT 2340
                ENDIF
                IFVAR BPPLAT < 0
                        EQUAL BPPLAT 0
                        EQUAL DOPLAT 0
                        ECHO ALL The platform settles into place with a "thump".
                ENDIF
                IFVAR BPPLAT > 6
                        EQUAL BPPLAT 6
                        EQUAL DOPLAT 0
                        ECHO ALL The platform sways crazily for a moment, then stops moving.
                ENDIF
        ENDIF
        IFVAR DOPLAT = -1
                IFVAR BPPLAT = 5
                        ECHO ALL The platform drops suddenly, revolving slightly as it plummets like a stone!
                        REMOVEITEM 1
                        AFFECT 2339
                        ECHO ALL The stone platform drops suddenly out of sight!
                        REMOVEITEM 1
                        AFFECT 2340
                ENDIF
                IFVAR BPPLAT = 4
                        ECHO ALL The platform ceases its slow rotation as it continues to fall through the mist. Trails of disturbed red vapor follow you through the cavern air.
                ENDIF
                IFVAR BPPLAT = 3
                        ECHO ALL The platform slows down dramatically, almost ceasing its downward motion.
                ENDIF
                IFVAR BPPLAT = 2
                        ECHO ALL The platform continues to descend slightly, but now revolves again, picking up speed as it flies off over the reddish waters of the lake.
                ENDIF
                IFVAR BPPLAT = 1
                        ECHO ALL The platform begins to stop revolving as it soars southward over an island of black stone.
                        AFFECT 2341
                        ECHO ALL You see the platform approaching from the north.
                ENDIF
                IFVAR BPPLAT = 0
                        ECHO ALL The platform comes up to the side of a large boulder, reaching the bottom of its course.
                        NEWITEM 1 78 VAL2=2341
                        AFFECT 2341
                        ECHO ALL The platform comes level with the boulder.
                        NEWITEM 1 365
                ENDIF
                IFVAR BPPLAT < 0
                        EQUAL BPPLAT 0
                        EQUAL DOPLAT 0
                        ECHO ALL The platform settles into place with a "thump".
                ENDIF
                IFVAR BPPLAT > 6
                        EQUAL BPPLAT 6
                        EQUAL DOPLAT 0
                        ECHO ALL The platform sways crazily for a moment, then stops moving.
                ENDIF
        ENDIF
ENDIF
IFVAR DOPLAT = 0
        ECHO ALL The platform hovers, bobbing in place.
ENDIF


