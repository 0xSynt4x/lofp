IFPREVERB POINT -1
  IFVAR FLAG2 > 199
		IFVAR ARCHNUM = 161
			CLEARVERB
      IFVAR DANBET ! 0
				ECHO PLAYER Someone else has already placed a bet.
      ELSE
				STRCVT 0 ITEMVAL1
				ECHO PLAYER You place your bet for %0 gold.
				ECHO OTHERS %N bets %0 gold coins at the craps table.
				EQUAL DANBET ITEMVAL1
				REMOVEITEM -1
				EQUAL FLAG2 205
				EQUAL DUMMY3 0
			ENDIF
		ENDIF
	ENDIF
ENDIF
IFPREVERB GET 4
	CLEARVERB
	IFVAR FLAG2 < 200
		ECHO PLAYER You'll have to go over to the craps table first.
	ENDIF
	IFVAR FLAG2 > 199
		IFVAR DANDICE = 1
			ECHO PLAYER You'll have to wait until they're available.
		ENDIF
		IFVAR DANDICE = 0
			IFVAR FLAG2 < 205
				ECHO PLAYER You have not yet placed a bet.
			ENDIF
			IFVAR FLAG2 > 204
				EQUAL DANDICE 1
				ECHO PLAYER You take the dice and rattle them in your hands.
				ECHO OTHERS %N takes the dice and rattles them in %h hands.
				IFVAR FLAG2 = 205
				EQUAL FLAG2 210
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDIF
IFPREVERB PUSH 4
	CLEARVERB
	IFVAR FLAG2 < 200
		ECHO PLAYER You're not standing at the craps table.
	ENDIF
	IFVAR FLAG2 > 199
		IFVAR DANDICE = 0
			ECHO PLAYER You're not holding the dice yet.
		ENDIF
		IFVAR DANDICE = 1
			IFVAR FLAG2 < 210
				ECHO PLAYER You're not the one with the dice.
			ENDIF
      IFVAR FLAG2 = 215
				ECHO OTHERS %N tosses the dice down to the other end of the table.
