  IFVAR INTNUM3 ! 1
    IFVAR INTNUM61 = 0
      EQUAL INTNUM61 1
      ECHO PLAYER The bartender asks, "What'cha have?"
    ENDIF
    IFVAR INTNUM61 = 79
      ECHO OTHERS The bartender nods to %n and says, "Hi, Boss."
      ECHO PLAYER The bartender nods to you and says, "Hi, Boss."
    ENDIF
