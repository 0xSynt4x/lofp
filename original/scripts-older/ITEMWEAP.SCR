;
; I# 549 : Tusk
INUMBER 549
NAME 461
CHARGE_WEAPON
WEIGHT 2
VOLUME 1
PARAMETER1 5
;
; I# 558 : Sidebow
INUMBER 558
NAME 314
BOW_WEAPON
WEIGHT 8
VOLUME 4
PARAMETER1 16
PARAMETER2 562
SUBSTANCE WOOD
CRAFTABLE
ENCRUSTABLE
IFPREVERB LOOK -1
  CLEARVERB
  ECHO PLAYER The sidebow is an unusual weapon, a small crossbow with straps and buckles
  ECHO PLAYER attached which are meant for wearing the device on one's wrist. It is the
  ECHO PLAYER product of the latest technology, incorporating the same tricky design
  IFVAR ITEMVAL3 = 0
    ECHO PLAYER used in the rare double crossbows. Currently there are 4 empty slots.
  ENDIF
  IFVAR ITEMVAL3 ! 0
    STRCVT 0 ITEMVAL3
    ECHO PLAYER used in the rare double crossbows. Currently %0 of 4 slots are loaded.
  ENDIF
ENDIF
IFPREVERB WIELD -1
  IFVAR ITEMVAL5 = 0
    CLEARVERB
    ECHO PLAYER You will have to strap that onto your forearm first.
  ENDIF
ENDIF
IFPREVERB WEAR -1
  CLEARVERB
  IFVAR ITEMVAL5 > 0
    EQUAL ROUNDTIME 2
    ECHO PLAYER You tighten the straps on the sidebow.%c[Round: 2 sec]
  ENDIF
  IFVAR ITEMVAL5 = 0
    EQUAL ROUNDTIME 5
    ECHO PLAYER You strap and buckle the sidebow to your forearm.%c[Round: 5 sec]
    ECHO OTHERS %N straps and buckles %a to %h forearm.
    EQUAL ITEMVAL5 1
  ENDIF
ENDIF
IFPREVERB UNWIELD -1
  IFVAR ITEMVAL5 > 0
    CLEARVERB
    ECHO PLAYER You'll have to unbuckle it first.
    ECHO PLAYER (Try pulling it off your arm.)
  ENDIF
ENDIF
IFPREVERB PULL -1
  IFVAR ITEMVAL5 > 0
    CLEARVERB
    EQUAL ROUNDTIME 5
    ECHO PLAYER You unbuckle the sidebow and remove it from your forearm.%c[Round: 5 sec]
    ECHO OTHERS %N unbuckles %a and removes it from %h forearm.
    EQUAL ITEMVAL5 0
  ENDIF
ENDIF
IFPREVERB LOAD -1
  IFVAR ITEMVAL3 < 4
    EQUAL ITEMVAL1 ITEMVAL3
    EQUAL ITEMVAL3 0
  ENDIF
ENDIF
IFVERB LOAD -1
  IFVAR ITEMVAL3 = 1
    IFVAR ITEMVAL1 = 0
      ECHO PLAYER There is now one quarrel in the sidebow, with room for three more.
      EQUAL ITEMVAL3 1
    ENDIF
    IFVAR ITEMVAL1 = 1
      ECHO PLAYER There are now two quarrels in the sidebow, with room for two more.
      EQUAL ITEMVAL3 2
    ENDIF
    IFVAR ITEMVAL1 = 2
      ECHO PLAYER There are now three quarrels in the sidebow, with room for one more.
      EQUAL ITEMVAL3 3
    ENDIF
    IFVAR ITEMVAL1 = 3
      ECHO PLAYER The sidebow is now fully loaded, with four quarrels in it.
      EQUAL ITEMVAL3 4
    ENDIF
    EQUAL ITEMVAL1 0
  ENDIF
ENDIF
;
; I# 568 : Ch'chak
INUMBER 568
NAME 1422
TWOHAND_WEAPON
WEIGHT 100
VOLUME 20
PARAMETER1 40
SUBSTANCE HARDMETAL
IFVERB RECALL -1
  IFVAR SKILL32 > 0
    ECHO PLAYER You've heard tales of a subterranean race of giants who live far away from
    ECHO PLAYER the Deep Realms below Fayd, a race called the ch'trell. They are said to be
    ECHO PLAYER savage warriors who wield huge weapons just like this one... rockmen of the
    ECHO PLAYER eastern wastes are also said to employ them.
  ENDIF
ENDIF
IFPREVERB LOOK -1
  CLEARVERB
  ECHO PLAYER You see a long, heavy club fashioned from some sort of heavy, black wood with
  ECHO PLAYER no bark. A single line of symbols has been carved into it in a spiral from the
  ECHO PLAYER base to the widened tip. Three huge blades have been set into the weapon's
  ECHO PLAYER thickened end, blades formed from reddish-white stone.
ENDIF
IFPREVERB READ -1
  CLEARVERB
  ECHO PLAYER You try to read the symbols running along the ch'chak...
  SKILLCHECK 32 -60 DUMMY1
  IFVAR DUMMY1 >= 0
    ECHO PLAYER ...slash and smash and crush and kill and drink the blood of our enemies' children and eat their skulls and steal their animals...
  ENDIF
  IFVAR DUMMY1 < 0
    ECHO PLAYER It's all gibberish to you.
  ENDIF
ENDIF
IFPREVERB PULL -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You pull the ch'chak up over your head with some effort, preparing to strike a mighty blow.
    ECHO OTHERS %N pulls %a up over %h head, preparing to strike a mighty blow.
  ENDIF
ENDIF
IFPREVERB PUSH -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You brandish the ch'chak menacingly.
    ECHO OTHERS %N brandishes %a menacingly.
  ENDIF
ENDIF
IFPREVERB LEAN -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You lean against the ch'chak, which easily supports your weight.
    ECHO OTHERS %N leans against %a.
    IFVAR HEI < 70
      ECHO OTHERS You note that the ch'chak is quite a bit taller than %s is.
    ENDIF
  ENDIF
ENDIF
IFPREVERB TURN -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You turn the ch'chak over and over in your hands.
    ECHO OTHERS %N turns %a over and over in %h hands.
  ENDIF
ENDIF
IFPREVERB WIELD -1
  RANDOM DUMMY1 1 300 100
  IFVAR DUMMY1 > STR
    CLEARVERB
    ECHO PLAYER You try to get a good grip on the ch'chak, but fail. %c[Round: 1 sec]
    EQUAL ROUNDTIME 1
    ECHO OTHERS %N tries to wield %a, but fails to get a good grip on the heavy weapon.
  ENDIF
ENDIF
