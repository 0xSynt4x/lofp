;
;                              ~~~ AMMO
;
; Bolts
INUMBER 4
NAME 26
WEIGHT 1
AMMO
VOLUME 1
PARAMETER1 1
PARAMETER2 24
SUBSTANCE WOOD
ARTICLE SOME
PLURAL
CRAFTABLE
IFPREVERB LATCH -1
  CLEARVERB
  IFVAR ITEMVAL3 < 21
    EQUAL FLAG4 ITEMVAL3
    ECHO PLAYER You prepare the last of your bolts for loading into the stock of your customized double crossbow.%c[LATCH CROSSBOW to load, do not leave room until you do this!!]
    REMOVEITEM -1
  ENDIF
  IFVAR ITEMVAL3 > 20
    SUB ITEMVAL3 20
    EQUAL FLAG4 20
    ECHO PLAYER You prepare the twenty of your bolts for loading into the stock of your customized double crossbow.%c[LATCH CROSSBOW to load, do not leave room until you do this!!]
  ENDIF
ENDIF
;
;
;                              ~~~ CB_WEAPONS
;
; I# 1235 : Sword (Sunstrike, CB weapon)
INUMBER 1235
NAME 201
SLASH_WEAPON
WEIGHT 11
VOLUME 5
PARAMETER1 13
SUBSTANCE HARDMETAL
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cThis is the CB sword SUNSTRIKE, it uses ITEMVAL1 to accumulate usage charges, 500 charges per Sergeant-at-Arms. %c----  
  ENDIF
ENDIF
IFVERB CONCENTRATE -1
  IFVAR ALIGN >= -1
    ADD ITEMVAL1 1
    IFVAR ITEMVAL1 < 450
      ECHO PLAYER A voice speaks in your mind, "Armor up, master."
      ECHO OTHERS A glimmering field of fire emanates from the sword and covers %N.
      SPELL 102 150
    ENDIF
    IFVAR ITEMVAL1 >= 450
      IFVAR ITEMVAL1 < 500
        ECHO PLAYER A voice speaks in your mind, "I tire master, but I'll do my best."
        RANDOM DUMMY1 1 40 0
        IFVAR DUMMY1 < 20
          ECHO PLAYER A voice speaks in your mind, "Armor up, master."
          ECHO OTHERS A glimmering field of fire emanates from the sword and covers %N.
          SPELL 102 150
        ENDIF
        IFVAR DUMMY1 >= 20
          ECHO PLAYER A voice speaks in your mind, "I am sorry master."
          ECHO OTHERS A glowing outline of armor begins to appear around &N, then fades.
        ENDIF
      ENDIF
    ENDIF
    IFVAR ITEMVAL1 >= 500
      ECHO PLAYER A voice speaks in your mind, "I can serve you no more. Pass me on and my new master will rejuvinate me."
      SETITEMVAL -1 2 25
      SETITEMVAL -1 3 0
      SETITEMVAL -1 5 0
    ENDIF
  ENDIF
  IFVAR ALIGN < -1
    ECHO PLAYER The sword ignores you. You hear a feminine voice mocking your futility. 
  ENDIF
ENDIF
IFVERB TAP -1
  IFVAR ALIGN >= -1
    ADD ITEMVAL1 5 
    CLEARVERB
    IFVAR ITEMVAL1 < 450
      ECHO PLAYER A voice speaks in your mind, "This will help free you %N."
      SPELL 510 150
    ENDIF
    IFVAR ITEMVAL1 >= 450
      IFVAR ITEMVAL1 < 500
        ECHO PLAYER A voice speaks in your mind, "I tire master, but I'll do my best."
        RANDOM DUMMY1 1 40 0
        IFVAR DUMMY1 < 20
          ECHO PLAYER A voice speaks in your mind, "This will help free you %N."
          SPELL 510 150
        ENDIF
        IFVAR DUMMY1 >= 20
          ECHO PLAYER A voice speaks in your mind, "I am sorry master."
          ECHO OTHERS %N's sword emanates and orange glow for a moment, then fades.
        ENDIF
      ENDIF
    ENDIF
    IFVAR ITEMVAL1 >= 500
      ECHO PLAYER A voice speaks in your mind, "I can serve you no more. Pass me on and my new master will rejuvinate me."
      SETITEMVAL -1 2 25
      SETITEMVAL -1 3 0
      SETITEMVAL -1 5 0
    ENDIF
  ENDIF
  IFVAR ALIGN < -1
    ECHO PLAYER The sword ignores you. You hear a feminine voice mocking your futility.
  ENDIF
ENDIF
IFVERB WIELD -1
  IFVAR ALIGN => -1
    IFVAR ITEMVAL1 >= 0
      IFVAR ITEMVAL1 <= 100
        ECHO PLAYER A voice, from the sword it seems, speaks in your mind, "Ahh, you are pure of heart we will get along well. It is a pleasure to serve you %N."
        SETITEMVAL -1 2 50
        SETITEMVAL -1 3 2
        SETITEMVAL -1 5 150
      ENDIF
    ENDIF
    IFVAR ITEMVAL1 > 100
      IFVAR ITEMVAL1 <= 200
        ECHO PLAYER A voice, from the sword it seems, speaks in your mind, "Ahh, you are pure of heart we will get along well. It is a pleasure to serve you %N."
        SETITEMVAL -1 2 45
        SETITEMVAL -1 3 2
        SETITEMVAL -1 5 110
      ENDIF
    ENDIF
    IFVAR ITEMVAL1 > 200
      IFVAR ITEMVAL1 <= 300
        ECHO PLAYER A voice, from the sword it seems, speaks in your mind, "Ahh, you are pure of heart we will get along well. It is a pleasure to serve you %N."
        SETITEMVAL -1 2 40
        SETITEMVAL -1 3 2
        SETITEMVAL -1 5 100
      ENDIF
    ENDIF
    IFVAR ITEMVAL1 > 300
      IFVAR ITEMVAL1 <= 400
        ECHO PLAYER A voice, from the sword it seems, speaks in your mind, "Ahh, you are pure of heart we will get along well. It is a pleasure to serve you %N."
        SETITEMVAL -1 2 35
        SETITEMVAL -1 3 2
        SETITEMVAL -1 5 90
      ENDIF
    ENDIF
    IFVAR ITEMVAL1 > 400
      IFVAR ITEMVAL1 < 500
        ECHO PLAYER A voice, from the sword it seems, speaks in your mind, "Ahh, you are pure of heart we will get along well. It is a pleasure to serve you %N."
        SETITEMVAL -1 2 30
        SETITEMVAL -1 3 2
        SETITEMVAL -1 5 80
      ENDIF
    ENDIF
    IFVAR ITEMVAL1 >= 500
      GMMSG %N has depleted the powers of Sunstrike, get ahold of the current Bander GM, please.
      ECHO PLAYER The sword speaks, "I'm sorry master, it is time to pass me on, I can no longer aid thee as other than a sword."
      SETITEMVAL -1 2 25
      SETITEMVAL -1 3 0
      SETITEMVAL -1 5 0
    ENDIF
  ELSE
    ECHO OTHERS %N grimaces a bit as %s wields Sunstrike.
    GMMSG %N has wielded Sunstrike, oops, bet that hurt.
    DAMAGEPLR BODYONLY 150 A voice booms in your mind, "%N! You have a blackness in your heart. Serve you I must, but pleasant it will not be!" You feel a wave of disgust emanating form the sword and it goes silent.
    SETITEMVAL -1 2 10
    SETITEMVAL -1 3 0
    SETITEMVAL -1 5 0
    IFVAR ALIGN <= -10
      DAMAGEPLR BURN 250 Cretin! How dare you even touch me with such a foul taint on your soul. Feel my heat!
    ENDIF
  ENDIF
ENDIF
IFPREVERB PULL -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You raise %a in salute.
    ECHO OTHERS %N raises %a in salute.
  ENDIF
ENDIF
IFVERB WAVE -1
 IFITEM -1 WIELDED
  IFVAR ALIGN >= -1
    ADD ITEMVAL1 5
    IFVAR ITEMVAL1 < 450
      ECHO PLAYER A voice speaks in your mind, "This will protect you and your companions %N."
      ECHO GROUP %N waves SUNSTRIKE around, and you feel a wave of protection emanate from it.
      SPELL 130 150
    ENDIF
    IFVAR ITEMVAL1 >= 450
      IFVAR ITEMVAL1 < 500
        ECHO PLAYER A voice speaks in your mind, "I tire master, but I'll do my best."
        RANDOM DUMMY1 1 40 0
        IFVAR DUMMY1 < 20
          ECHO PLAYER A voice speaks in your mind, "This will protect you and your companions %N."
          ECHO GROUP %N waves SUNSTRIKE around, and you feel a wave of protection emanate from it.
          SPELL 130 150
        ENDIF
        IFVAR DUMMY1 >= 20
          ECHO PLAYER A voice speaks in your mind, "I am sorry master."
          ECHO OTHERS %N's sword emanates a bright glow for a moment, then dims again.
        ENDIF
      ENDIF
    ENDIF
    IFVAR ITEMVAL1 >= 500
      ECHO PLAYER A voice speaks in your mind, "I can serve you no more. Pass me on and my new master will rejuvinate me."
      SETITEMVAL -1 2 25
      SETITEMVAL -1 3 0
      SETITEMVAL -1 5 0
    ENDIF
  ENDIF
  IFVAR ALIGN < -1
    ECHO PLAYER The sword ignores you. You hear a feminine voice mocking your futility.
  ENDIF
 ENDIF
ENDIF
IFPREVERB RAISE -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You raise SUNSTRIKE into the air straight above your head, the weapon aglow with fire.
    ECHO OTHERS %N raises SUNSTRIKE into the air, the weapon burns with a bright flame.
  ENDIF
ENDIF
IFPREVERB SELL -1
  CLEARVERB
  ECHO PLAYER SUNSTRIKE refuses to be sold to a mere merchant. How dare you?
ENDIF
IFPREVERB LEAN -1
  CLEARVERB
  ECHO PLAYER You lean on SUNSTRIKE and wince as you notice a tiny scortchmark is formed.
  ECHO OTHERS %N leans on SUNSTRIKE and you notice %i jump slightly at something %s sees.
ENDIF
;
; I# 1662 : Crimson Band Standard
INUMBER 1662
NAME 1103
CRUSH_WEAPON
WEIGHT 50
VOLUME 25
PARAMETER1 10
SUBSTANCE HARDMETAL
;ARTICLE THE
VARIABLE CBSTANDMAGIC
VARIABLE INITMAGIC
;EQUAL ITEMADJ3 977
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cItembit6 = 1 is a crimson battle standard, IB7=1 is an initiate battle standard.%c----
  ENDIF
ENDIF
IFPREVERB WIELD -1
  CLEARVERB
  ECHO PLAYER The standard cannot be wielded as a weapon.
ENDIF
IFVERB DROP -1
  IFVAR ITEMADJ1 = 374
    ECHO PLAYER Since %a is broken it cannot be raised.
  ENDIF
  IFVAR ITEMADJ1 ! 374
    IFVAR RNUM = 2713
      IFVAR ITEMBIT6 = 1
        ECHO PLAYER You then unfurl %a and mount it in its stand for all to see.
        ECHO OTHERS %N then unfurls %a, mounting it in its stand for all to see.
        EQUAL ITEMADJ1 976
        IFVAR ORG = 6
          IFVAR CBSTANDMAGIC < 33
            SPELL 130 100
            ADD CBSTANDMAGIC 4
          ENDIF
        ENDIF
      ENDIF
      IFVAR ITEMBIT6 = 2
        ECHO PLAYER As you unfurl %a and place it in its stand, an unfelt breeze stirs a faint whisper of silk.
        ECHO OTHERS As %N unfurls %a and places it in its stand, an unfelt breeze stirs a faint whisper of silk.
        EQUAL ITEMADJ1 976
      ENDIF
    ENDIF
    IFVAR RNUM ! 2713
      IFVAR TERRAIN >= 3
        ECHO PLAYER You then unfurl %a and plant it firmly into the ground for all to see.
        ECHO OTHERS %N then unfurls %a, planting it firmly into the ground for all to see.
        IFVAR ITEMBIT6 = 1
          IFVAR ORG = 6
            IFVAR CBSTANDMAGIC < 33
              SPELL 130 100
              ADD CBSTANDMAGIC 4
            ENDIF
          ENDIF
        ENDIF
      ELSE
        ECHO PLAYER You cannot plant the standard indoors.
      ENDIF
    ENDIF
  ENDIF  
ENDIF
IFPREVERB GET -1
  IFVAR ITEMADJ1 ! 374
    EQUAL ITEMADJ1 -1
  ENDIF
  IFVAR ITEMADJ1 = 976
    IFVAR ITEMBIT6 = 1
      IFVAR ORG = 6
        ECHO PLAYER You pull %a from the ground and furl it.
        ECHO OTHERS %N pulls %a from the ground and furls it.
      ENDIF
      IFVAR ORG ! 6
        ECHO OTHERS %N has seized the Standard!
      ENDIF
    ENDIF
    IFVAR ITEMBIT7 = 1
      IFVAR ORG = 6
        ECHO PLAYER You pull %a from the ground and furl it.
        ECHO OTHERS %N pulls %a from the ground and furls it.
      ENDIF
      IFVAR ORG ! 6
        ECHO OTHERS %N has seized the Standard!
      ENDIF
    ENDIF
    IFVAR ITEMBIT6 ! 1
      IFVAR ITEMBIT7 ! 1
        ECHO PLAYER You pull %a from the ground and furl it.
        ECHO OTHERS %N pulls %a from the ground and furls it.
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB BREAK -1
  CLEARVERB
  IFVAR ITEMADJ1 ! 374
    RANDOM DUMMY1 1 100 0
    ADD DUMMY1 STR
    IFVAR DUMMY1 < 160
      ECHO PLAYER You strike %a with all your might, but it does not break!
      ECHO OTHERS %N strikes %a with all %h might, but it does not break!%c[Round: 5 sec]
      EQUAL ROUNDTIME 5
    ENDIF	
    IFVAR DUMMY1 > 159
      IFVAR DUMMY1 < 240
        IFVAR ITEMADJ1 ! 975
          ECHO PLAYER You strike %a with all your might, knocking it to the ground!
          ECHO OTHERS %N strikes %a with all %h might, knocking it to the ground!%c[Round: 10 sec]
          EQUAL ITEMADJ1 975
          EQUAL ROUNDTIME 10
        ELSE
          ECHO PLAYER You strike %a with all your might, but it does not break!
          ECHO OTHERS %N strikes %a with all %h might, but it does not break!%c[Round: 5 sec]
          EQUAL ROUNDTIME 5
        ENDIF
      ENDIF
    ENDIF
    IFVAR DUMMY1 > 239
      ECHO PLAYER With a thunderous crack, %a is broken asunder by your blow!
      ECHO OTHERS With a thunderous crack, %a is broken asunder by %N's mighty blow!%c[Round: 10 sec]
      EQUAL ITEMADJ1 374
      IFVAR ITEMBIT6 = 1
        SPELL 230
        PLREVENT 4
        CONTPLREVENT
        SPELL 138
        ECHO PLAYER A wave of energy pours forth from the %a, knocking everything down in its path.
        POSITION LAY
      ENDIF
      EQUAL ROUNDTIME 10
    ENDIF
  ELSE
    ECHO PLAYER The standard is already broken, so you can't do much else to it.
  ENDIF
ENDIF
IFPREVERB SALUTE -1
  CLEARVERB
  IFVAR ITEMADJ1 = 976
    ECHO PLAYER You come to attention and salute %a smartly.
    ECHO OTHERS %N comes to attention and salutes %a smartly.
  ELSE
    ECHO PLAYER The standard is not raised.
  ENDIF
ENDIF
IFPREVERB CONCENTRATE -1
  IFVAR ITEMBIT6 = 1
    IFVAR ORG = 6
      IFVAR ITEMADJ1 = 976
        CLEARVERB
        IFVAR CBSTANDMAGIC < 33
          ECHO PLAYER As you concentrate upon %a it glows briefly, and a wave of warmth passes over you.
          SPELL 318
          ADD CBSTANDMAGIC 2
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB GAZE -1
  IFVAR ITEMBIT6 = 1
    IFVAR ORG = 6
      IFVAR ITEMADJ1 = 976
        CLEARVERB
        IFVAR CBSTANDMAGIC < 33
          ECHO PLAYER As you gaze proudly upon %a, you are filled with renewed strength!
          SPELL 209
          ADD CBSTANDMAGIC 2
        ENDIF
      ENDIF
    ENDIF
  ENDIF
  IFVAR ITEMBIT7 = 1
    IFVAR ITEMADJ1 = 976
      IFCARRY 131 989
        IFVAR INITMAGIC < 13
          CLEARVERB
          ECHO PLAYER As you gaze upon %a, you are filled with a sense of pride and courage.
          SPELL 347 100
          ADD INITMAGIC 2
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFPREVERB LOOK -1
  IFVAR ITEMBIT6 = 1
    CLEARVERB
    ECHO PLAYER Mounted on an ivory-tipped rod of uquart, the Standard of the Crimson Band flutters in the slightest breeze. Emblazoned on the ancient silk standard is a fierce eagle, wings spread, grasping a brilliant star ruby in its talons.
  ENDIF
  IFVAR ITEMBIT7 = 1
    CLEARVERB
    ECHO PLAYER A brilliant crimson banner flies from a bright white pole tipped with a flaming blade.
  ENDIF
ENDIF
IFPREVERB STEAL -1
  CLEARVERB
  ECHO PLAYER Yeah right, maybe it'll fit in your pocket.
ENDIF
