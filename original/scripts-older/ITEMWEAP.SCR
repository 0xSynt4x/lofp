;
; I# 43 : Stiletto
INUMBER 43
NAME 197
PUNCTURE_WEAPON
WEIGHT 1
VOLUME 1
PARAMETER1 2
SUBSTANCE HARDMETAL
CRAFTABLE
ENCRUSTABLE
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cItembit6 = 1 makes this a poison dagger (ex-1640), turn(poison 25), conc(spell 225), -1 to VAL2/use, if VAL2=0 the weapon evaporates%c----
  ENDIF
  IFVAR ITEMBIT6 = 1
    CLEARVERB
    ECHO PLAYER You see a long, straight-bladed stiletto forged from black elkyri. It seems
    ECHO PLAYER to throb slightly as you look at it, reminding you unpleasantly of some small
    ECHO PLAYER and lethal ebonscaled snake just waiting for something to sink its fangs into
    ECHO PLAYER with the greatest of delight. Its handle is wrapped in a strip of clean white
    ECHO PLAYER leather, and its pommel resembles a faintly-defined, leering human skull.
  ENDIF
ENDIF
IFVAR ITEMBIT6 = 1
  IFPREVERB TURN -1
    CLEARVERB
    ECHO PLAYER You twist the skull on the pommel all the way around, causing its eyes to glow red for a moment.
    ECHO OTHERS %N fiddles with %a, causing the eyes on the skull to glow red.
    SUB ITEMVAL2 1
    EQUAL ITEMVAL4 75
    IFVAR ITEMVAL2 < 1
      ECHO ALL The stiletto suddenly emits a loud hissing sound, seeming to corrode before your very eyes. Within moments nothing remains of it but a cloud of black vapor...
      REMOVEITEM -1
    ENDIF
  ENDIF
  IFPREVERB CONCENTRATE -1
    CLEARVERB
    ECHO PLAYER You send your mind into the dagger's substance...
    SPELL 225
    SUB ITEMVAL2 1
  ENDIF
ENDIF
;
; I# 45 : Sword (short)
INUMBER 45
NAME 201
SLASH_WEAPON
WEIGHT 11
VOLUME 5
PARAMETER1 13
SUBSTANCE HARDMETAL
CRAFTABLE
ENCRUSTABLE
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cItembit6  = 1 makes this a special Dahkahn sword (ex-599), uses ITEMVAL1
    ECHO PLAYER Itembit7  = 1 makes this Wrathe's sword (ex-654), uses ITEMVAL1
    ECHO PLAYER Itembit8  = 1 makes this a nonfighting sword (ex-810), uses ITEMVAL1
    ECHO PLAYER Itembit9  = 1 makes this the Sword of the Avatar (ex-837), damages Align <0 or >750
    ECHO PLAYER Itembit10 = 1 makes this a sword which casts Globe 1 on conc. (ex-1215), it uses VAL5 and will stop critting and recharge should be very hard
    ECHO PLAYER Itembit11 = 1 makes this a good/evil slayer based on alignment of wielder (ex-1798)
    ECHO PLAYER Itembit12 = 1 makes this Siryx's sword a fiery/icy/elctric crit, concentrate (ex-1104) uses SETEVENT 41 and ITEMVAL1%c----
  ENDIF
  IFVAR ITEMBIT6 = 1
    ECHO PLAYER A strange symbol on the blade glimmers slightly.
  ENDIF
  IFVAR ITEMBIT9 = 1
    ECHO PLAYER The elegant blade is long and thin and engraved with tiny runes along its length on both sides. The pommel is a white gold ring inset with a cold blue sapphire and the flaring crossguard curves in opposite directions.
  ENDIF
ENDIF
IFVAR ITEMBIT6 = 1
  IFVAR ALIGN < -2
    EQUAL ITEMVAL1 15
  ENDIF
  IFVAR ALIGN > -3
    IFVAR ALIGN < 4
      EQUAL ITEMVAL1 45
    ENDIF
  ENDIF
  IFVAR ALIGN > 3
    EQUAL ITEMVAL1 75
  ENDIF
  IFVERB RECALL -1
    ECHO PLAYER This sword has the symbol of Dahkahn on the blade.
  ENDIF
  IFVERB WIELD -1
    ECHO OTHERS %N seems to struggle with %h weapon...
    ECHO PLAYER You feel the weapon pressing its will against yours.
    RANDOM dummy1 1 50 25
    ADD dummy1 ITEMVAL1
    IFVAR dummy1 > WIL
      SUB dummy1 WIL
      DAMAGE ELECTRIC dummy1 The weapon fights its wielder!
      DAMAGE SLASH 6 The weapon tries to cut itself free.
    ENDIF
  ENDIF
  IFVERB CONCENTRATE -1
    RANDOM dummy1 1 75 5
    ADD dummy1 ITEMVAL1
    IFVAR WIL > dummy1
      ECHO OTHERS The weapon attempts to fight %n's will, but fails.
      SPELL 208 10
      SPELL 210 10
      SPELL 102 10
    ELSE
      RANDOM dummy2 2 25 1
      DAMAGE ELECTRIC dummy2 The weapon refuses to submit!
      DAMAGE SLASH 6 The weapon tries to cut itself free.
    ENDIF
  ENDIF
ENDIF
IFVAR ITEMBIT7 = 1
  IFPREVERB PULL -1
    IFITEM -1 WIELDED
      IFVAR ITEMVAL3 < 5
        IFVAR ITEMVAL5 > 3
          CLEARVERB
          ECHO PLAYER You raise the sword up in a salute. It uses the elemental energy to form protection!
          ECHO OTHERS %N raises the sword up in a salute. Energy starts to form a bubble around %i.
          SPELL 130 40
          SUB ITEMVAL5 3
        ELSE
          ECHO PLAYER It screams, "Feed Me!"
        ENDIF
      ELSE
        ECHO PLAYER You don't think the sword has the right kind of energy active for protection.
      ENDIF
    ENDIF
  ENDIF
  IFVERB LOOK -1
    RANDOM FLAG2 1 20 0
    IFVAR FLAG2 = 1
      SPELL 519 250
      POSITION LAY
      EQUAL ROUNDTIME 10
      EQUAL SPELLNUM 139
      EQUAL DEMONZAP PLAYERNUM
      ECHO PLAYER You are surrounded by a black glow!
      ECHO OTHERS %N is surrounded by a black glow.
      ECHO PLAYER You hear a demonic laugh...
    ENDIF
    IFVAR FLAG2 ! 1
      SPELL 338 250
      EQUAL ROUNDTIME 3
      ECHO PLAYER [Round: 3 seconds]
      SUB MANAPOINTS 5
    ENDIF
    ECHO PLAYER You gaze at %a.
    ECHO OTHERS %N gazes at %a.
  ENDIF
  IFPREVERB2 PUT -1
    CLEARVERB
    IFVAR ARCHNUM = 116
      ECHO PLAYER You feed %a to your sword.
      ECHO OTHERS %N feeds %a to %h sword.
      ECHO ALL The sword consumes it with a satisfied burp.
      REMOVEITEM -1
      EQUAL ITEMVAL1 1
    ENDIF
    IFVAR ARCHNUM = 119
      ECHO PLAYER You feed %a to your sword.
      ECHO OTHERS %N feeds %a to %h sword.
      ECHO ALL The sword consumes it with a satisfied burp.
      REMOVEITEM -1
      EQUAL ITEMVAL1 2
    ENDIF
    IFVAR ARCHNUM = 121
      ECHO PLAYER You feed %a to your sword.
      ECHO OTHERS %N feeds %a to %h sword.
      ECHO ALL The sword consumes it with a satisfied burp.
      REMOVEITEM -1
      EQUAL ITEMVAL1 3
    ENDIF
    IFVAR ARCHNUM = 118
      ECHO PLAYER You feed %a to your sword.
      ECHO OTHERS %N feeds %a to %h sword.
      ECHO ALL The sword consumes it with a satisfied burp.
      REMOVEITEM -1
      EQUAL ITEMVAL1 4
    ENDIF
    IFVAR ARCHNUM = 108
      ECHO PLAYER You feed %a to your sword.
      ECHO OTHERS %N feeds %a to %h sword.
      ECHO ALL The sword consumes it with a satisfied burp.
      REMOVEITEM -1
      EQUAL ITEMVAL1 5
    ENDIF
    IFVAR ARCHNUM = 107
      ECHO PLAYER You feed %a to your sword.
      ECHO OTHERS %N feeds %a to %h sword.
      ECHO ALL The sword consumes it with a satisfied burp.
      REMOVEITEM -1
      EQUAL ITEMVAL1 6
    ENDIF
  ENDIF
  IFPREVERB TURN -1
    CLEARVERB
    ECHO PLAYER You turn the pommel of %a.
    ECHO OTHERS %N turns the pommel of %a.
    IFVAR ITEMVAL1 = 0
      ECHO ALL It screams, "Feed me!"
    ENDIF
    IFVAR ITEMVAL1 = 1
      ECHO ALL Its blade shimmers and glows, bursting into dull red flame.
      EQUAL ITEMADJ1 125
      EQUAL ITEMVAL3 2
      EQUAL ITEMVAL5 40
    ENDIF
    IFVAR ITEMVAL1 = 2
      ECHO ALL You hear a crack as its blade freezes, forming crystals of ice.
      EQUAL ITEMADJ1 166
      EQUAL ITEMVAL3 3
      EQUAL ITEMVAL5 40
    ENDIF
    IFVAR ITEMVAL1 = 3
      ECHO ALL With a fizzle and a smell of ozone, crackling electricity appears around its blade.
      EQUAL ITEMADJ1 641
      EQUAL ITEMVAL3 4
      EQUAL ITEMVAL5 40
    ENDIF
    IFVAR ITEMVAL1 = 4
      ECHO ALL A dull light appears around its blade.
      EQUAL ITEMADJ1 365
      EQUAL ITEMVAL3 21
      EQUAL ITEMVAL5 3
    ENDIF
    IFVAR ITEMVAL1 = 5
      ECHO ALL It begins to glow.
      EQUAL ITEMADJ1 145
      EQUAL ITEMVAL3 22
      EQUAL ITEMVAL5 3
    ENDIF
    IFVAR ITEMVAL1 = 6
      ECHO ALL Its blade begins to shimmer strangely.
      EQUAL ITEMADJ1 287
      EQUAL ITEMVAL3 9
      EQUAL ITEMVAL5 3
    ENDIF
    EQUAL ITEMVAL1 0
  ENDIF
ENDIF
IFVAR ITEMBIT8 = 1
  IFPREVERB TAP -1
    CLEARVERB
    ECHO PLAYER The sword exclaims, "No, no don't make me do it!" as it vibrates wildly as if trying to get away.
    ECHO OTHERS The sword exclaims, "No, no don't make me do it!" as it vibrates wildly as if trying to get away.
    ADD ITEMVAL1 1
  ENDIF
  IFPREVERB POKE -1
    CLEARVERB
    ECHO PLAYER The sword trembles as you hear it say, "I'm just a big toothpick, not at all suitable for fighting!"
    ECHO OTHERS %N's sword trembles as you hear it say, "I'm just a big toothpick, not at all suitable for fighting!"
    ADD ITEMVAL1 1
  ENDIF
  IFPREVERB NUDGE -1
    CLEARVERB
    ECHO PLAYER As you nudge the sword it cries out, "How would you like to be stuck into some icky creature's gut!?"
    ECHO OTHERS As %N nudges %h sword it cries out, "How would you like to be stuck into some icky creature's gut!?"
    ADD ITEMVAL1 1
  ENDIF                                                                                                     '
  IFPREVERB PUSH -1
    CLEARVERB
    ECHO PLAYER The sword wiggles around as it tries to cuddle up against you as it coo's, "Make love, not war!"
    ECHO OTHERS %N's sword siggles around as it tries to cuddle up against %N as it coo's, "Make love, not war!"
    ADD ITEMVAL1 1
  ENDIF
  IFPREVERB PULL -1
    CLEARVERB
    ECHO PLAYER As you wrestle with the sword it shakes violently shouting, "I'm too young for battle! You go right ahead, I'll just watch!"
    ECHO OTHERS As %N wrestles with %h sword it shakes violently shouting, "I'm too young for battle! You go right ahead, I'll just watch!"
    ADD ITEMVAL1 1
  ENDIF
  IFPREVERB THUMP -1
    CLEARVERB
    ECHO PLAYER The sword tries to wiggle its way into a safe spot in your belongings as it states, "I'm not scared, I'm just too tired right now."
    ECHO OTHERS %N's sword tries to wiggle its way into a safe spot in %N's belongings as it states, "I'm not scared, I'm just too tired right now."
    ADD ITEMVAL1 1
  ENDIF
  IFVERB WIELD -1
    IFVAR ITEMVAL1 > 5
      ECHO PLAYER You hear the sword sigh loudly and say, "Oh, alright, I guess I can try" as you wield it.
      ECHO OTHERS You hear %N's sword sigh loudly and say, "Oh, alright, I guess I can try" as %N wields it.
    ENDIF
    IFVAR ITEMVAL1 < 6
      CLEARVERB
      ECHO PLAYER The sword twists around and around making it impossible for you to grab hold of it and wield it.
      ECHO OTHERS %N's sword twists around and around making it impossible for %N to grab hold of it and wield it.
    ENDIF
  ENDIF
  IFVERB UNWIELD -1
    CLEARVERB
    ECHO PLAYER The sword exclaims happily, "Sure am glad that's over!" as you unwield it.
    ECHO OTHERS %N's sword exclaims happily, "Sure am glad that's over!" as %N unwields it.
    EQUAL ITEMVAL1 0
  ENDIF
ENDIF
IFVAR ITEMBIT9 = 1
  IFTOUCH -1
    IFVAR ALIGN < 0
      CLEARVERB
      ECHO PLAYER The instant you wrap your hand fully around the hilt a jolt of intense electricity courses through your body. You cannot retain a grip on the sword and drop it.
      ECHO OTHERS %n takes hold of the Sword of the Avatar and blue electricty runs the length of the blade, point to hilt, and courses through %h body.
      DAMAGEPLR ELECTRIC 60 The jolt of energy sets your synapses afire!
    ENDIF
    IFVAR ALIGN > 750
      CLEARVERB
      ECHO PLAYER The instant you wrap your hand fully around the hilt a jolt of intense electricity courses through your body. You cannot retain a grip on the sword and drop it.
      ECHO OTHERS %n takes hold of the Sword of the Avatar and blue electricty runs the length of the blade, point to hilt, and courses through %h body.
      DAMAGEPLR ELECTRIC 60 The jolt of energy sets your synapses afire!
    ENDIF
  ENDIF
ENDIF
IFVAR ITEMBIT10 = 1
  IFVERB CONCENTRATE -1
    IFITEM -1 WIELDED
      IFVAR ITEMVAL5 > 0
        ECHO PLAYER The pommel of the sword glows brightly!
        ECHO OTHERS The pommel of %n's sword glows brightly!
        SPELL 105 20
        SUB ITEMVAL5 1
      ENDIF
    ENDIF
  ENDIF
ENDIF
IFVAR ITEMBIT11 = 1
  IFPREVERB WIELD -1
    IFVAR ALIGN > 0
      ECHO PLAYER As you reach for your sword, it glows briefly with a white light.
      ECHO OTHERS %N's sword glows white as it is wielded.
      EQUAL ITEMVAL3 9
      STRCVT 0 ITEMVAL5
      GMMSG %N's %a is a x%0 evil slayer.
    ENDIF
    IFVAR ALIGN < 0
      ECHO PLAYER As you reach for your sword, it glows briefly with a red light.
      ECHO OTHERS %N's sword glows red as it is wielded.
      EQUAL ITEMVAL3 8
      STRCVT 0 ITEMVAL5
      GMMSG %N's %a is a x%0 good slayer.
    ENDIF
    IFVAR ALIGN = 0
      EQUAL ITEMVAL3 0
    ENDIF
  ENDIF
ENDIF
IFVAR ITEMBIT12 = 1
  IFITEM -1 WIELDED
    IFVERB CONCENTRATE -1
      ADD ITEMVAL1 1
      IFVAR ITEMVAL1 = 0
        ECHO ALL The electricity flowing over %n's blade disperses.
        EQUAL ITEMADJ1 526
        EQUAL ITEMVAL3 2
        SETEVENT 41 2
        CONTEVENT 41
        ECHO PLAYER Your blade suddenly becomes a towering inferno!
        DAMAGEPLR BURN 50 The blade burns you!
        ECHO OTHERS %n's blade suddenly becomes a towering inferno of fire!
        ECHO OTHERS %n flinches in pain.
      ENDIF
      IFVAR ITEMVAL1 = 1
        ECHO ALL %n's blade cools down to a more normal temperature.
        EQUAL ITEMADJ1 375
        EQUAL ITEMVAL3 3
        SETEVENT 41 2
        CONTEVENT 41
        ECHO PLAYER Ice suddenly forms over the blade, chilling you to the bone!
        ECHO OTHERS Huge lays of ice crystalize over %n's blade!
        ECHO OTHERS %n flinches in pain!
        DAMAGEPLR COLD 50 The blade freezes you!
      ENDIF
      IFVAR ITEMVAL1 = 2
        ECHO ALL %n's blade heats up to a more normal temperature.
        EQUAL ITEMADJ1 376
        EQUAL ITEMVAL3 4
        SETEVENT 41 2
        CONTEVENT 41
        ECHO PLAYER Electricity suddenly crackles over your blade!
        ECHO OTHERS Huge sheets of electricity crackle over %n's blade!
        ECHO OTHERS %N flinches in pain!
        DAMAGEPLR BURN 50 The blade burns you!
      ENDIF
      IFVAR ITEMVAL1 = 2
        SUB ITEMVAL1 3
      ENDIF
    ENDIF
  ENDIF
ENDIF
;
; I# 46 : Sword (short, light)
INUMBER 46
NAME 201
SLASH_WEAPON
WEIGHT 10
VOLUME 5
PARAMETER1 13
SUBSTANCE HARDMETAL
ENCRUSTABLE
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cItembit6 = 1 makes this Wrathe's sword (ex-1750), uses ITEMVAL1, INTNUM3=10 is wielder%c----
  ENDIF
  IFVAR ITEMBIT6 = 1
    ECHO PLAYER The glistening blade is formed from a amalgam of swirling metals. Hints of
    ECHO PLAYER shadowsteel, albescent and elkyri all have bonded with other unknown metals
    ECHO PLAYER to form its razor edge. A sweeping hilt of platinum and gold, inlaid with
    ECHO PLAYER fine gem stones seems to invite your hand to grasp it. This is a blade
    ECHO PLAYER unlike all others.
  ENDIF
ENDIF
IFVAR ITEMBIT6 = 1
  IFPREVERB WIELD -1
    IFITEM -1 WIELDED
     CLEARVERB
     ECHO PLAYER It is already wielded.
    ELSE
      IFVAR INTNUM3 ! 10
        CLEARVERB
        ECHO PLAYER It feels clumsy and quite lifeless in your hands. And you decide that it isn't even worth the effort to hold it.
        EQUAL ITEMVAL2 -100
      ENDIF
      IFVAR INTNUM3 = 10
        ECHO PLAYER You grasp the hilt firmly and it almost seems to form itself within to conform with your grasp. The blade seems an extension of your own arm.
        IFVAR SKILL13 > 35
          EQUAL ITEMVAL2 35
        ENDIF
        IFVAR SKILL13 < 36
          EQUAL ITEMVAL2 SKILL13
        ENDIF
      ENDIF
    ENDIF
  ENDIF
  IFVAR INTNUM3 = 10
    IFPREVERB RAISE -1
      IFVAR ITEMVAL1 > 299
        IFITEM -1 WIELDED
          EQUAL dummy1 ITEMVAL1
          MOD dummy1 100
          IFVAR dummy1 ! TIM
            CLEARVERB
            ECHO PLAYER You raise your sword high over head catching stray streams of light and reflecting them around yourself.
            ECHO OTHERS %N raises %h sword high over %h head. Its supple blade catches stray streams of light, reflecting them into a glowing aura around %i.
            ECHO PLAYER [Round: 10 secs.]
            EQUAL ROUNDTIME 10
            EQUAL ITEMVAL1 TIM
            SPELL 130 30
          ELSE
            CLEARVERB
            ECHO PLAYER You have already invoked a power of the sword once this hour.
          ENDIF
        ENDIF
      ENDIF
    ELSE
      ECHO ALL %N's sword screams, "You will get nothing from me until I'm fed!"
    ENDIF
    IFPREVERB CONCENTRATE -1
      IFITEM -1 WIELDED
        CLEARVERB
        ECHO PLAYER You gaze into the swirling blade of the sword and reach out with your prayers to your diety.
        ECHO OTHERS %N bows %h head towards the sword and appears to be seeking solace in its strength.
        ECHO PLAYER [Round: 2 secs.]
        EQUAL ROUNDTIME 2
        SPELL 347 50
      ENDIF
    ENDIF
    IFPREVERB PUT -1
      IFVAR ITEMVAL1 > 99
        MOD ITEMVAL1 100
      ENDIF
      IFVAR ARCHNUM = 107
        CLEARVERB
        ECHO PLAYER You place a diamond in the hilt of your sword and it quickly fuses into the metal beneath.
        ECHO OTHERS %N places a diamond on the hilt of %h sword and it quickly fuses into the metal.
        ADD ITEMVAL1 100
        REMOVEITEM -1
      ENDIF
      IFVAR ARCHNUM = 119
        CLEARVERB
        ECHO PLAYER You place a sapphire in the hilt of your sword and it quickly fuses into the metal beneath.
        ECHO OTHERS %N places a sapphire on the hilt of %h sword and it quickly fuses into the metal.
        ADD ITEMVAL1 200
        REMOVEITEM -1
      ENDIF
      IFVAR ARCHNUM = 117
        CLEARVERB
        ECHO PLAYER You feed the hungry sword its required price.
        ECHO OTHERS %N quickly shoves a pearl into the sword's hilt.
        ADD ITEMVAL1 300
        REMOVEITEM -1
      ENDIF
    ENDIF
    IFPREVERB RUB -1
      IFVAR ITEMVAL1 > 99
        IFVAR ITEMVAL1 < 200
          CLEARVERB
          ECHO PLAYER You polish the sword lovingly..allowing it to summon the power of the diamond.
          EQUAL ITEMVAL3 21
          EQUAL ITEMVAL5 2
        ENDIF
      ENDIF
      IFVAR ITEMVAL1 > 199
        IFVAR ITEMVAL1 < 300
          CLEARVERB
          ECHO PLAYER You polish the sword lovingly..allowing it to summon the power of the sapphire.
          ECHO OTHERS %N polishes %h sword with loving care.
          EQUAL ITEMVAL3 22
          EQUAL ITEMVAL5 2
        ENDIF
      ENDIF
    ENDIF
  ENDIF
ENDIF
