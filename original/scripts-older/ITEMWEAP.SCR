;
; I# 3 : Blowgun
INUMBER 3
NAME 23
BOW_WEAPON
WEIGHT 1
VOLUME 1
PARAMETER1 6
PARAMETER2 13
SUBSTANCE WOOD
CRAFTABLE
ENCRUSTABLE
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cItembit6 = 1 makes this a poison blowgun (ex-621)%c----
  ENDIF
  IFVAR ITEMBIT6 = 1
    CLEARVERB
    ECHO PLAYER The blowgun is made from a six foot long bamboo shoot. It's outer surface has
    ECHO PLAYER been coated with a hard, waxy substance to prevent loss of any air pressure.
    ECHO PLAYER A sack of stitched lizardskin hangs from the blowhole of the weapon and seems
    ECHO PLAYER to contain a liquid of some sort.
  ENDIF
  IFVAR ITEMVAL3 = 1
    ECHO PLAYER The blowgun appears to be loaded.
  ENDIF
ENDIF
IFVAR ITEMBIT6 = 1
  IFPREVERB PUSH -1
    CLEARVERB
    IFVAR ITEMVAL3 = 1
      ADD ITEMVAL5 1
      IFVAR ITEMVAL5 < 201
        ECHO PLAYER You reach up and squeeze the lizardskin sack and hear the liquid squirt into the shaft.
        ECHO OTHERS %n reaches up to a lizardskin sack hanging from the blowhole of %h blowgun and gently squeezes it.
        RANDOM ITEMVAL1 1 100 0
        IFVAR ITEMVAL1 <= 60
          EQUAL ITEMVAL1 0
          EQUAL ITEMVAL4 75
        ENDIF
      ENDIF
      IFVAR ITEMVAL5 > 200
        ECHO PLAYER You squeeze the lizardskin sack but do not hear any of the liquid eject into the pole.
      ENDIF
    ENDIF
    IFVAR ITEMVAL3 ! 1
      ECHO PLAYER The blowgun is not loaded.
    ENDIF
  ENDIF
ENDIF
;
; I# 5 : Bo-Stick
INUMBER 5
NAME 29
DRAKIN_CRUSH
WEIGHT 8
VOLUME 4
PARAMETER1 10
SUBSTANCE WOOD
CRAFTABLE
ENCRUSTABLE
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cItembit6 = 1 makes this an electric bo-stick (ex-1193), turn to activate, do not use ITEMADJ2 and no PUT/DROP/GIVE/DEPOSIT allowed%c----
  ENDIF
ENDIF
IFVAR ITEMBIT6 = 1
  IFPREVERB TURN -1
    IFITEM -1 WIELDED
      IFVAR ITEMADJ2 ! 1178
        CLEARVERB
        ECHO OTHERS %n begins to twirl %a in a clockwise direction.
        ECHO PLAYER You begin to twirl %a in a clockwise direction.
        EQUAL ITEMADJ2 1178
        EQUAL ITEMVAL3 4
        EQUAL ITEMVAL5 20
        PLREVENT 4
        CONTPLREVENT
        ECHO OTHERS As %n's bo-stick spins faster and faster it begins to crackle with electricity.
        ECHO PLAYER As your bo-stick spins faster and faster it begins to crackle with electricity.
        PLREVENT 4
        CONTPLREVENT
        ECHO OTHERS When %n stops twirling the bo-stick it crackles with energy.
        ECHO PLAYER When you stop twirling the bo-stick it crackles with energy.
      ELSE
        CLEARVERB
        ECHO OTHERS %n begins spinning %a in a counter-clockwise direction.
        ECHO PLAYER You begin to spin %a in a counter-clockwise direction.
        EQUAL ITEMADJ2 -1
        EQUAL ITEMVAL3 0
        EQUAL ITEMVAL5 0
        PLREVENT 4
        CONTPLREVENT
        ECHO OTHERS As the bo-stick spins faster and faster it begins to throw off arcs of electricity.
        ECHO PLAYER As the bo-stick spins faster and faster it begins to throw off arcs of electricity.
        PLREVENT 4
        CONTPLREVENT
        ECHO ALL When the bo-stick stops spinning it is just a normal bo-stick again.
      ENDIF
    ENDIF
  ENDIF
  IFPREVERB GIVE -1
    CLEARVERB
    ECHO PLAYER For some odd reason you can't seem to let go of %a!
  ENDIF
  IFPREVERB DROP -1
    CLEARVERB
    ECHO PLAYER For some odd reason you can't seem to let go of %a!
  ENDIF
  IFPREVERB PUT -1
    CLEARVERB
    ECHO PLAYER For some odd reason you can't seem to let go of %a!
  ENDIF
  IFPREVERB DEPOSIT -1
    CLEARVERB
    ECHO PLAYER For some odd reason you can't seem to let go of %a!
  ENDIF
ENDIF
