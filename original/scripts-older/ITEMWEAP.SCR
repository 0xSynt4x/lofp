  ENDIF
  IFVAR ITEMBIT6 = 1
    ECHO PLAYER Two pieces of polished ivory have been carved into the visages of eagles,
    ECHO PLAYER their mouths open and their claws extended to form the image of an
    ECHO PLAYER attack in progress.
  ENDIF
ENDIF
IFVAR ITEMBIT6 = 1
  IFPREVERB PULL -1
    CLEARVERB
    IFVAR ITEMVAL5 ! DATE
      EQUAL ITEMVAL1 0
    ENDIF
    IFVAR ITEMVAL1 < 10
      ADD ITEMVAL1 1
      EQUAL ITEMVAL5 DATE
      ECHO ALL The shrill cry of hunting eagles emits from %N's bow and then descends in the form of a shimmering field around %N.
      SPELL 105 40
    ELSE    
      ECHO ALL %N's bow emits the shrill hunting cry of the eagle.
    ENDIF
  ENDIF
ENDIF
