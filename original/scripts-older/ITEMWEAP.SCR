; I# 16 : Greatsword
INUMBER 16
NAME 101
TWOHAND_WEAPON
WEIGHT 26
VOLUME 7
PARAMETER1 28
SUBSTANCE HARDMETAL
CRAFTABLE
ENCRUSTABLE
ifpreverb latch -1
  ifvar itemadj3 = 25
    clearverb
    echo player You flip the black greatsword out a window!
    echo others %N flips a black greatsword out a window!
    removeitem -1
  endif
endif
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cItembit6 = 1 makes this the Preceptor of Amilor's Greatsword (ex-1591) INTNUM61=79 to be able to use.%c----
  ENDIF
  IFVAR ITEMBIT6 = 1
    CLEARVERB
    ECHO PLAYER Formed from the powerful components and imbued with the power of Amilor
    ECHO PLAYER the sword of the Preceptor is an awe-inspiring weapon. Delicate swirls of
    ECHO PLAYER bluish silver extend throughout the blade, forming shimmering waves of
    ECHO PLAYER water.%c
  ENDIF
ENDIF
IFVAR ITEMBIT6 = 1
  IFTOUCH -1
    IFVAR INTNUM61 ! 79
      CLEARVERB
      ECHO PLAYER You are gently kept from touching the sword by the power of Amilor.
      ECHO OTHERS %N begins to touch the greatsword, but then seems to think better of it.
    ENDIF
  ENDIF
  IFVERB WIELD -1
    ECHO ALL Scintillating rays of ocean blue light streak from the greatsword, illuminating the area in the glow of Amilor's power, as %N holds it ready for combat.
  ENDIF
  IFPREVERB RUB -1
    CLEARVERB
    ADD ITEMVAL3 1
    IFVAR ITEMVAL3 = 1
      ECHO PLAYER A cone of swirling cold and snow surrounds you, the fury of winter in its midst, slowly the elemental power seeps into your greatsword!
      ECHO OTHERS A cone of swirling cold and snow surrounds %N, the elemental fury of winter at its midst, slowly the the power seeps into the blade.
      EQUAL ITEMVAL3 3
      EQUAL ITEMVAL5 50
    ENDIF
    IFVAR ITEMVAL3 = 4
      ECHO PLAYER Jagged beams of lightning streak from the sky and infuse the greatsword with their power!
      ECHO OTHERS %N lifts %h greatsword to the sky intoning, "Father, grant me the power!", a moment later jagged beams of lightning streak from the sky into the swords blade.
      EQUAL ITEMVAL3 4
      EQUAL ITEMVAL5 50
    ENDIF
    IFVAR ITEMVAL3 < 3
      IFVAR ITEMVAL3 > 4
      ECHO PLAYER You slowly allow the elements to fade from the blade, uttering a short prayer to Amilor as you do.
      ECHO OTHERS %N allows the power of the elements to fade from the blade, uttering a short prayer to Amilor as he does.
      EQUAL ITEMVAL3 0
      EQUAL ITEMVAL5 0
    ENDIF
  ENDIF
  IFPREVERB CARESS -1
    CLEARVERB
    IFVAR ITEMVAL1 ! DATE
      ECHO ALL %N kneels to the floor, placing the greatsword before %iself. %N slowly begins to chant an ancient prayer to Amilor ending with, "Father, protect us in this our task that we do for your glory." Waves of blue light extend out from where the pommel touches the floor, enveloping everyone close to %N with Amilor's protection.
      SPELL 130 100
      EQUAL ITEMVAL1 DATE
    ELSE
      ECHO PLAYER You utter a short prayer to Amilor while touching the greatsword, it glows faintly for a moment.
      ECHO OTHERS %N utters a short prayer to Amilor while touching the greatsword which glows faintly for a moment.
    ENDIF
  ENDIF
ENDIF
