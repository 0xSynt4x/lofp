;
; I# 594 : Dagger (critter-weapon)
INUMBER 594
NAME 66
PUNCTURE_WEAPON
WEIGHT 2
VOLUME 1
PARAMETER1 3
SUBSTANCE HARDMETAL
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%CThis is a posion dagger, push to coat the blade, player takes poison damage equal to what the blade will do, +1 per push%c----  
  ENDIF
  ECHO PLAYER This clear dagger seems to be hollow... Hmmm...
ENDIF
IFPREVERB PUSH -1
  CLEARVERB
  IFVAR ROUNDTIME > 0
    STRCVT 0 ROUNDTIME
    ECHO PLAYER [Round: %0 Sec]
  ENDIF
  IFVAR ROUNDTIME = 0
    ECHO PLAYER You give the dagger a little squeeze on the hilt, and a tiny trickle of venom drips onto the blade.
    ECHO OTHERS %N is fiddling with %h dagger.
    EQUAL ROUNDTIME 10
    ECHO PLAYER [Round: 10 Sec]
    IFVAR ITEMVAL4 = 0
      EQUAL ITEMVAL4 51
      IFVAR RAC < 7
        DAMAGEPLR POISON 1 The poison stings!
        ECHO OTHERS %N winces in pain.
      ENDIF
    ELSE
      IFVAR ITEMVAL4 < 79
        ADD ITEMVAL4 1
        IFVAR RAC < 7
          EQUAL dummy1 ITEMVAL4
          SUB dummy1 50
          DAMAGEPLR POISON dummy1 The poison stings!
          ECHO OTHERS %N winces in pain.
        ENDIF
      ELSE
        ECHO PLAYER You think that the dagger is about as coated as it will get.
      ENDIF
    ENDIF
  ENDIF
ENDIF
