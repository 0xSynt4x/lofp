;
; I# 1110 : Blade (Phasing, uses C# 72)
INUMBER 1110
NAME 690
TWOHAND_WEAPON
WEIGHT 1
VOLUME 7
PARAMETER1 15
SUBSTANCE INDESTRUCTABLE
IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ----%cSEEK must = 72 for the weapon CEVENT to operate properly.%c----
  ENDIF
ENDIF
IFPREVERB WIELD -1
  ECHO ALL %n's blade phases into existance for a brief moment before shimmering out again.
  ECHO PLAYER You feel the blade still in your hand, but can't see it anywhere!
ENDIF
IFTOUCH -1
  IFVERB GET -1
    ECHO PLAYER The blade flickers as you reach for it.
  ELSE
    CLEARVERB
    ECHO OTHERS %N makes an obscure gesture.
    ECHO PLAYER You can't see the phase blade, but you reach out and touch it.
  ENDIF
ENDIF
;
; C# 72 : Phase Blade effects (I# 1110)
CEVENT 72 15 699
IFSEEK 72
  RANDOM dummy3 1 5 0
  IFITEM -1 WIELDED
    IFVAR dummy3 = 1
      ECHO PLAYER Your phase blade shimmers into existence for a moment.
      ECHO OTHERS %n's phase blade shimmers into existence for a moment.
    ENDIF
    IFVAR dummy3 = 2
      ECHO PLAYER Your phase blade pulses with light.
      ECHO OTHERS %n's phase blade pulses with light.
    ENDIF
    IFVAR dummy3 = 3
      ECHO PLAYER Shimmering streaks of lightning flicker up your phase blade.
      ECHO OTHERS Shimmering streaks of lightning flicker up %n's phase blade.
    ENDIF
    IFVAR dummy3 = 4
      ECHO PLAYER A piece of your phase blade becomes substantial for a moment looking like a strange piece of steel hanging in mid air, before shimmering out of existance.
      ECHO OTHERS A piece of %n's phase blade becomes substantial for a moment looking like a strange piece of steel hanging in mid air, before shimmering out of existance.
    ENDIF
    IFVAR dummy3 = 5
      ECHO PLAYER The tip of your phase blade becomes substantial for a moment looking like a strange piece of steel hanging in mid air, before shimmering out of existance.
      ECHO OTHERS The tip of %n's phase blade becomes substantial for a moment looking like a strange piece of steel hanging in mid air, before shimmering out of existance.
    ENDIF
  ENDIF
ENDIF
