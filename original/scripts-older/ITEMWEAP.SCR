;                              ~~~ UNREPAIRED ITEMS
;
INUMBER 1762
NAME 166
WEIGHT 10
VOLUME 6
BOW_WEAPON
PARAMETER1 60
PARAMETER2 1756
IFTOUCH -1
 IFVAR NOKILL = 0
  DAMAGEPLR BURN 40 Yow! It's HOT!
 ENDIF
ENDIF
IFPREVERB LOOK -1
 CLEARVERB
 ECHO PLAYER The concussion rifle is a long device of Ancient make, every angle smoothed
 ECHO PLAYER a bit by some process you do not understand well enough to name. It almost
 ECHO PLAYER seems alive, though you doubt it truly can be called so. A few knobs and
 ECHO PLAYER buttons are set into its side, as well as indicator lights for some sort of
 ECHO PLAYER readout.
 IFVAR ORG = 7
  ECHO PLAYER You figure you can turn the knobs, push the buttons and read the lights.
 ENDIF
ENDIF
IFPREVERB CAST -1
 EQUAL SPELLNUM 0
 ECHO PLAYER The Ancient metal seems to repel the force of the spell with ease.
 IFVAR ORG = 7
  ECHO PLAYER You suspect that it's the result of the omni-radiation shielding.
 ENDIF
ENDIF
IFPREVERB READ -1
 IFVAR ORG = 7
  CLEARVERB
  ECHO PLAYER You call upon your training as a technologist and attempt to decipher the
  ECHO PLAYER lights on the side of the rifle... some seem to indicate Reserve power, while
  ECHO PLAYER others indicate the number of charges that are actuall ready to fire.
  STRCVT 0 ITEMVAL5
  STRCVT 1 ITEMVAL3
  ECHO PLAYER ...hmm. There seem to be %0 shots of Reserve power in the stock, and %1 shots
  ECHO PLAYER actually ready to fire.
 ENDIF
ENDIF
IFPREVERB TURN -1
 CLEARVERB
 ECHO PLAYER You turn a knob on the side of the rifle, and a few lights shift and blink. %C[Round: 7 sec]
 EQUAL ROUNDTIME 7
 ECHO OTHERS %N turns a knob on the side of %a and a few lights shift on its side.
 IFVAR ITEMVAL3 > 7
  IFVAR ORG = 7
   ECHO PLAYER As there are already eight charges in the primary chamber, no power is transferred from the Reserve area.
  ENDIF
 ENDIF
 IFVAR ITEMVAL3 < 8
  IFVAR ITEMVAL5 > 10
   EQUAL DUMMY1 8
   SUB DUMMY1 ITEMVAL3
   SUB ITEMVAL5 DUMMY1
   EQUAL ITEMVAL3 8
   IFVAR ORG = 7
    STRCVT 0 DUMMY1
    ECHO PLAYER You have just transferred %0 charges from the Reserve to the primary chamber.
   ENDIF
  ENDIF
 ENDIF
ENDIF
IFPREVERB PUSH -1
 CLEARVERB
 ECHO PLAYER You push a button on the side of the rifle, causing a faint glow to appear
 ECHO PLAYER around the end of the barrel.
 ECHO OTHERS %N pushes a button on the side of %a.
 EQUAL ITEMVAL2 25
 IFVAR ORG = 7
  ECHO PLAYER Hmmm... it's almost like magic... perhaps the all-energy theorists are right.
 ENDIF
ENDIF
IFTOUCH -1
 RANDOM DUMMY2 1 100 0
 IFVAR DUMMY2 < 3
  EQUAL ITEMVAL2 0
 ENDIF
ENDIF
IFPREVERB LOAD -1
 IFITEM -1 WIELDED
  EQUAL ITEMVAL3 0
 ENDIF
ENDIF
IFVERB LOAD -1
 IFITEM -1 WIELDED
  IFVAR ITEMVAL3 = 1
   EQUAL ITEMVAL3 0
   ADD ITEMVAL5 4
   ECHO PLAYER The lights on the side of the rifle move a bit.
   IFVAR ORG = 7
    ECHO PLAYER One charge from the clip has been converted into 4 charges in the Reserve chamber.
   ENDIF
  ENDIF
 ENDIF
ENDIF
IFPREVERB DEPOSIT -1
 ECHO PLAYER The clerk exclaims, "Not glowing red-hot like that!"
 CLEARVERB
ENDIF
;
;
INUMBER 779
NAME 595
WEIGHT 1
VOLUME 1
SLASH_WEAPON
PARAMETER1 1
IFPREVERB LOOK -1
	CLEARVERB
	IFVAR ITEMVAL2 = 0
		ECHO PLAYER The knife is a thin tube of silvery metal about as long as your hand
		ECHO PLAYER with a triangular blade at the top of it. All but the very edge of
		ECHO PLAYER the blade is covered in a fine mesh of golden metal wires. Halfway
		ECHO PLAYER along the handle there seems to be a swivel-joint.
	ENDIF
	IFVAR ITEMVAL2 > 0
		ECHO PLAYER You can barely make out the silvery shape as you squint and peer
		ECHO PLAYER at the knife. Along the edge of its triangular blade is a line of
		ECHO PLAYER solid white light, so bright that as you look away all you can
		ECHO PLAYER see for a few moments are phantom trails of purple and black.
		EQUAL ROUNDTIME 4
		ECHO OTHERS %N suddenly throws back %h head and squeezes %h eyes shut.
		PLREVENT 1
		CONTPLREVENT
		ECHO OTHERS %N blinks and wipes the tears from %h eyes.
	ENDIF
ENDIF
IFPREVERB TURN -1
	CLEARVERB
	ECHO PLAYER You turn the two segments that make up the knife until they "click!"
	ECHO OTHERS %N turns the two segments of %a until they stop with a "click!"
	IFVAR ITEMVAL2 > 0
		EQUAL ITEMVAL2 0
		EQUAL ITEMVAL5 0
		EQUAL ITEMVAL3 0
		ECHO ALL The white-hot edge of the knife stops glowing.
		EQUAL DUMMY3 1
	ENDIF
	IFVAR ITEMVAL2 = 0
		IFVAR DUMMY3 ! 1
			IFITEM -1 WIELDED
				IFVAR ITEMVAL1 < 43
				ECHO ALL A brilliant white light suddenly blazes forth from the blade of %a!
				EQUAL ITEMVAL2 5
				EQUAL ITEMVAL3 2
				SETITEMVAL -1 5 5
				RANDOM DUMMY1 1 10 0
				IFVAR DUMMY1 = 1
				ADD ITEMVAL1 1
				ENDIF
				ENDIF
			ENDIF
		ENDIF
	ENDIF
	EQUAL DUMMY3 0
ENDIF
