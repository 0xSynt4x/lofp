  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You pull the arm which wears your sklisht into a defensive position.
    ECHO OTHERS %N assumes a defensive stance, brandishing %a warily on %h forearm.
  ENDIF
ENDIF
IFPREVERB TURN -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You spin the sklisht by one of its straps, ready to use it.
    ECHO OTHERS %N spins %a by one of its straps, presenting a whirling wall of razor-sharp spines.
  ENDIF
ENDIF
IFPREVERB PUSH -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You push at the fleshy part of the sklisht, marveling at its still-living condition.
    ECHO OTHERS %N puts %h hand to the base of %a and pushes at an odd angle.
    IFVAR ITEMVAL1 ! DATE
      ECHO ALL One of the largest spines falls loose from the sklisht.
      NEWITEM -1 1927 ADJ1=1282 VAL4=60
      EQUAL ITEMVAL1 DATE
    ENDIF
  ENDIF
ENDIF
