NAME 592
THROWN_WEAPON
WEIGHT 1
VOLUME 1
PARAMETER1 6
SUBSTANCE BRITTLE
IFPREVERB TURN -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You turn the doip, getting a better grip on it.
    ECHO OTHERS %N turns %a, getting a better grip on it.
  ENDIF
ENDIF
IFVERB TAP -1
  IFITEM -1 WIELDED
    IFVAR ITEMVAL1 = 1
      ECHO ALL The narrow blades pop back into the doip's globular form.
      EQUAL ITEMVAL1 2
    ENDIF
    IFVAR ITEMVAL1 = 0
      ECHO ALL The doip suddenly quivers, and a dozen sharp, narrow blades pop out of it!
      EQUAL ITEMVAL1 1
    ENDIF
    IFVAR ITEMVAL1 = 2
      EQUAL ITEMVAL1 0
    ENDIF
  ENDIF
ENDIF
IFVERB RECALL -1
  IFVAR SKILL32 > 0
    ECHO PLAYER You seem to recall that the doip is a weapon developed by early
    ECHO PLAYER tribes of murgs, a dangerous throwing weapon with concealable
    ECHO PLAYER blades secreted within it. Its oblong shape, with its pointed
    ECHO PLAYER ends and bulging middle, is thought to make it easier to throw
    ECHO PLAYER if one knows how.
  ENDIF
ENDIF
IFPREVERB LOOK -1
  CLEARVERB
  IFVAR ITEMVAL1 = 0
    ECHO PLAYER You see an oblong ellipsoid with pointed ends.
  ENDIF
  IFVAR ITEMVAL1 = 1
    ECHO PLAYER You see an oblong ellipsoid with pointed ends. About a dozen wickedly sharpened blades poke out of it at odd angles.
  ENDIF
ENDIF
IFPREVERB CAST -1
  CLEARVERB
  ECHO OTHERS %N gestures at %a.
  ECHO PLAYER You gesture at a doip.
  ECHO ALL The doip seems to snicker.
ENDIF
;
; I# 651 : Claws (Specialization)
INUMBER 651
NAME 238
SLASH_WEAPON
WEIGHT 1
VOLUME 1
PARAMETER1 1
ARTICLE SOME
SUBSTANCE INDESTRUCTABLE
IFPREVERB GET -1
  IFVAR SKILL4 < 10
    CLEARVERB
    ECHO PLAYER You are not skilled enough in the way of the claw to wield these.
  ENDIF
  IFVAR SKILL4 > 9
    ECHO PLAYER [You may now specialize in your natural claws by typing 'SPEC CLAWS']
    IFVAR SKILL13 < 10
      IFVAR SKILL13 = 0
        EQUAL INTNUM96 999
      ENDIF
      IFVAR SKILL13 ! 0
        EQUAL INTNUM96 SKILL13
      ENDIF
      EQUAL SKILL13 10
    ENDIF
  ENDIF
  AFFECT 3639
  NEWPUT 1 651  ADJ1=1130
ENDIF
IFPREVERB WIELD -1
  IFVAR SKILL4 < 10
    CLEARVERB
    ECHO PLAYER You are not skilled enough in the way of the claw to wield these.
  ENDIF
  IFVAR SKILL4 > 9
    ECHO PLAYER [You may now specialize in your natural claws by typing 'SPEC CLAWS']
    IFVAR SKILL13 < 10
      IFVAR SKILL13 = 0
        EQUAL INTNUM96 999
      ENDIF
      IFVAR SKILL13 ! 0
        EQUAL INTNUM96 SKILL13
      ENDIF
      EQUAL SKILL13 10
    ENDIF
  ENDIF
ENDIF
IFPREVERB UNWIELD -1
  IFVAR INTNUM96 ! 0
    IFVAR INTNUM96 = 999
      EQUAL SKILL13 0
    ENDIF
    IFVAR INTNUM96 ! 999
      EQUAL SKILL13 INTNUM96
    ENDIF
    EQUAL INTNUM96 0
  ENDIF
ENDIF
IFPREVERB DEPOSIT -1
  CLEARVERB
  ECHO PLAYER You cannot give those away.
ENDIF
IFPREVERB GIVE -1
  CLEARVERB
  ECHO PLAYER You cannot give those away.
ENDIF
IFPREVERB2 PUT -1
  CLEARVERB
  IFVAR ARCHNUM = 651
    ECHO PLAYER You put %a away.
    ECHO OTHERS %N puts %a away.
    REMOVEITEM -1
    IFVAR INTNUM96 ! 0
      IFVAR INTNUM96 = 999
        EQUAL SKILL13 0
      ENDIF
      IFVAR INTNUM96 ! 999
        EQUAL SKILL13 INTNUM96
      ENDIF
      EQUAL INTNUM96 0
    ENDIF
  ENDIF
ENDIF
IFPREVERB DROP -1
  CLEARVERB
  ECHO PLAYER You put %a away.
  ECHO OTHERS %N puts %a away.
  REMOVEITEM -1
  IFVAR INTNUM96 ! 0
    IFVAR INTNUM96 = 999
      EQUAL SKILL13 0
    ENDIF
    IFVAR INTNUM96 ! 999
      EQUAL SKILL13 INTNUM96
    ENDIF
    EQUAL INTNUM96 0
  ENDIF
ENDIF
