IFPREVERB LOOK -1
  IFVAR INTNUM3 = 1
    ECHO PLAYER ---%cType 1: ADJ1=87, ADJ2=1240, druidic healing staff, concentrate, 10 uses per game day
    ECHO PLAYER Type 2: ADJ2=440, summoning staff, wield, 3 uses per day
    ECHO PLAYER Type 3: ITEMBIT6 = 1, INTNUM43 = 24, Shemrite Staff, push/pull/rub%c---
    ECHO PLAYER Type 4: ITEMBIT7 = 1, magical staff, VAL1 stores # of charges, tap/wave%c---
  ENDIF
  IFVAR ITEMBIT7 = 1
    ECHO PLAYER Sigils of indefinate purpose are etched over the surface of the staff. Strangely the bottom of the staff looks the most worn of all, no doubt due to constant striking on the ground while used for walking.
  ENDIF
ENDIF
IFVAR ITEMADJ1 = 87
  IFVAR ITEMADJ3 = 1240
    IFVAR ITEMVAL1 ! DATE
      EQUAL ITEMVAL1 DATE
      EQUAL ITEMVAL5 10
      ECHO ALL The dark mahogany staff glows with newly absorbed energy.
    ENDIF
    IFPREVERB CONCENTRATE -1
      CLEARVERB
      IFVAR ITEMVAL5 > 0
        IFVAR TERRAIN ! 3
          ECHO PLAYER The dark mahogany staff suffuses you with a soothing warmth.
          ECHO OTHERS %N is suffused with a soothing warmth from the dark mahogany staff.
          SPELL 317 50
          SUB ITEMVAL5 1
        ELSE
          SPELL 318 100
          ECHO OTHERS Tendrils of power seep into the dark mahogany staff, then up into %N's body.
          ECHO PLAYER The dark mahogany staff pulls power from the forest then to your body.
          SUB ITEMVAL5 1
        ENDIF
      ELSE
        ECHO PLAYER The dark mahogany staff's heart seems empty.
      ENDIF
    ENDIF
    IFPREVERB RUB -1
      CLEARVERB
      ECHO PLAYER The dark mahogany staff lovingly writhes in your grasp.
      ECHO OTHERS The dark mahogany staff seems to caress %N's hand.
    ENDIF
    IFPREVERB POKE -1
      CLEARVERB
      ECHO PLAYER The dark mahogany staff moves in an intricate pattern, bringing your hands with it.
      ECHO OTHERS %N executes a precise series of moves with the staff.
    ENDIF
  ENDIF
ENDIF
ifvar itemadj2 = 440
  ifpreverb wield -1
    IFVAR ITEMVAL1 ! DATE
      EQUAL ITEMVAL1 DATE
      EQUAL ITEMVAL5 0
    ENDIF
    add itemval5 1
    ifvar itemval5 < 4
      random dummy1 1 12 0
      ifvar dummy1 = 1
        equal ritualval2 7
      endif
      ifvar dummy1 = 2
        equal ritualval2 8
      endif
      ifvar dummy1 = 3
        equal ritualval2 9
      endif
      ifvar dummy1 = 4
        equal ritualval2 10
      endif
      ifvar dummy1 = 5
        equal ritualval2 11
      endif
      ifvar dummy1 = 6
        equal ritualval2 15
      endif
      ifvar dummy1 = 7
        equal ritualval2 20
      endif
      ifvar dummy1 = 8
        equal ritualval2 21
      endif
      ifvar dummy1 = 9
        equal ritualval2 3
      endif
      ifvar dummy1 = 10
        equal ritualval2 4
      endif
      ifvar dummy1 = 11
        equal ritualval2 5
      endif
      ifvar dummy1 = 12
        equal ritualval2 6
      endif
      spell 2
    endif
  endif
endif
IFVAR ITEMBIT6 = 1
  IFTOUCH -1
    IFVAR INTNUM43 = 24
      ECHO PLAYER You feel a beautiful, musical voice speak in your mind, "Greetings, friend."
      ECHO OTHERS A shimmering silvery glow covers %N, and the sound of lilting, musical notes fills the air for a moment.
    ELSE
      CLEARVERB
      ECHO PLAYER A gentle voice fills your mind, "I am not for you."
      ECHO OTHERS %N is rebuffed in %h attemtps to touch the staff.
    ENDIF
  ENDIF
  IFPREVERB PUSH -1
    IFVAR INTNUM43 = 24
      CLEARVERB
      ECHO PLAYER You hold the staff close, humming a simple, yet melodic tune to it, after a moment you feel its power caress you.
      ECHO OTHERS %N holds the staff close and begins humming a simple, yet melodic tune to it, after a moment you see the staff glow brightly.
      SPELL 105 30
    ENDIF
  ENDIF
  IFPREVERB PULL -1
    IFVAR INTNUM43 = 24
      CLEARVERB
      ECHO PLAYER You add your inner strength to the staff, using it to bring forth light that drives away the shadows for a brief moment...
      ECHO OTHERS Brilliant white light, filled with purity and strength flows into the area, driving all shadows away for a moment...
    ENDIF
  ENDIF
  IFPREVERB RUB -1
    IFVAR INTNUM43 = 24
      CLEARVERB
      ECHO PLAYER You feel the power of Shemri's song lift your spirits and those around you...
      ECHO OTHERS A beautiful song rises into the air, filled with the power of Shemri, filling your hearts and souls with her strength.
    ENDIF
  ENDIF
ENDIF
IFVAR ITEMBIT7 = 1
  IFPREVERB TAP -1
    CLEARVERB
    ECHO PLAYER You tap your staff soundly on the ground and bands of energy briefly coat its surface.
    ECHO OTHERS %N taps %h staff on the ground and it is instantly engulfed in crackling energy which soon dissolves away.
    IFVAR ITEMVAL3 = 4
      EQUAL ITEMVAL3 1
    ELSE
      ADD ITEMVAL3 1
    ENDIF
  ENDIF
  IFPREVERB WAVE -1
    CLEARVERB
    IFVAR ITEMVAL1 > 0
      ECHO PLAYER You wave your staff through the air calling on its mystic nature.
      ECHO OTHERS %N waves %h staff before %i seeming to call on its power.
      SUB ITEMVAL1 1
      IFVAR ITEMVAL3 = 1
        SPELL 133 200
      ENDIF
      IFVAR ITEMVAL3 = 2
        SPELL 225 100
      ENDIF
      IFVAR ITEMVAL3 = 3
        SPELL 235 100
      ENDIF
      IFVAR ITEMVAL3 = 4
        SPELL 343 150
      ENDIF
    ELSE
      ECHO PLAYER You wave your staff, but it seems to have lost its ability to aid you.
      ECHO OTHERS %N waves %h staff before %i trying to call on its power.
    ENDIF
  ENDIF
ENDIF
