ENDIF

IFPREVERB PRAY -1
  ECHO PLAYER Through the hissing of the flames, you hear the word "obsidian".
  ECHO OTHERS %N says a prayer to the fire spirits.
ENDIF

IFPREVERB2 PUT 3
  IFVAR ARCHNUM = 114
    IFVAR ITEMADJ2 = 241
      REMOVEITEM -1
      ECHO PLAYER The obsidian sinks into the altar and is gone.
      ECHO OTHERS %N places an obsidian on the altar.
      PLREVENT 0
      CONTPLREVENT
      ECHO PLAYER Your injuries begin to seal together more quickly.
      ECHO OTHERS Flames dance across %N, yet %s is unharmed.
      CLEARVERB
      SPELL 343 50
    ENDIF
  ENDIF
ENDIF

IFPREVERB GO 2
  DISBAND
  ECHO PLAYER You step into the pit, confident in your ability to ignore the flames.
  PLREVENT 1
  CONTPLREVENT
  ECHO OTHERS %N walks into the pit of coals and flame!
ENDIF
;
NUMBER 1264
NAME Flame Pit
ASTRAL
FIXED_LIGHT
CALL 33
*DESCRIPTION_START
Nothing is visible past the flames and waves of intense heat.
*DESCRIPTION_END
EXIT O 1263
