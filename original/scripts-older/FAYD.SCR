; This is the entrance to the ever-popular "Delving Down Under" script.
IFVERB GO 1
	IFVAR DELVE = 1
		IFVAR LEV < 11
			CLEARVERB
			ECHO PLAYER You step into the corner, you fall down an unseen hole...%c
			ECHO OTHERS %N disappears into the shadowy corner.
			MOVE 1601
			POSITION LAY
			AFFECT 1601
			ECHO OTHERS %N comes flying out of the overhead chute and lands in a heap beside you!
		ENDIF
		IFVAR LEV > 10
			ECHO PLAYER You decide you are just getting too big for these kinds of things, and you decide to do something else.
		ENDIF
	ENDIF
ENDIF
