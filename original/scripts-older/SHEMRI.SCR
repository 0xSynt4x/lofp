IFPREVERB OPEN 4
        IFITEM 4 LOCKED
                CLEARVERB
                ECHO PLAYER It won't budge.
        ENDIF
ENDIF
IFVERB LOOK 4
        IFITEM 4 OPEN
                CLEARVERB
                IFVAR PVAL87 > 0
                        STRCVT 0 PVAL87
                        STRCVT 1 PVAL86
                        ECHO PLAYER You see that there are %0 1000-crown bags and a big bag with %1 crowns in the drawer.
                ELSE
                        STRCVT 0 PVAL86
                        ECHO PLAYER You see that there are %0 crowns in the drawer.
                ENDIF
        ENDIF
ENDIF
IFVERB THUMP 4
        IFITEM 4 OPEN
                IFVAR PVAL86 > 0
                        NEWITEM 5 161 ADJ1=147
                        SETITEMVAL 5 1 PVAL86
                        EQUAL PVAL86 0
                        ECHO ALL Coins spill out of the drawer.
                ENDIF
        ENDIF
ENDIF
IFVERB KICK 4
        IFITEM 4 OPEN
                IFVAR PVAL87 > 0
                        NEWITEM 6 161 ADJ1=147
                        SETITEMVAL 6 1 1000
                        SUB PVAL87 1
                        ECHO ALL Coins spill out of the drawer.
                ENDIF
        ENDIF
ENDIF
