;
INUMBER 694
Name 540
WEIGHT 1000
VOLUME 3
MISC
HIDDEN
SUBSTANCE CLOTH
IFVAR ITEMADJ3 = 1251
        IFPREVERB2 PULL -1
                CLEARVERB
                IFVAR ITEMVAL5 = -1
                        ECHO PLAYER You find, to your dismay, that the jilka plant had been completely
                        ECHO PLAYER and then checked again.  The lack of extra roots and exposure to the air
                        ECHO PLAYER has killed the plant, and it withers to dust.
                        REMOVEITEM -1
                ENDIF
                IFITEM -1
                        IFVAR ITEMVAL5 = 0
                                ECHO PLAYER You notice that this jilka plant has already been harvested enough.
                                SUB ITEMVAL5 1
                        ENDIF
                ENDIF
                IFVAR ITEMVAL5 > 0
                        SUB ITEMVAL5 1
                        EQUAL DUMMY1 WEA
                        NEWITEM -1 705 ADJ3=1251 VAL2=DUMMY1
                        ECHO PLAYER You gently pull up a root cluster and harvest one from it.
                        EQUAL ROUNDTIME 75
                        ECHO PLAYER [Round: 75 secs]
                ENDIF
        ENDIF
ENDIF
