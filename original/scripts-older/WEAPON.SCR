; Dagger
INUMBER 12
NAME 66
WEIGHT 1
PUNCTURE_WEAPON
VOLUME 1
PARAMETER1 4
CRAFTABLE
ENCRUSTABLE
SUBSTANCE HARDMETAL
IFPREVERB PLAY -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You clean under your fingernails with the dagger.
    ECHO OTHERS %N cleans under %h fingernails with %a.
  ENDIF
ENDIF
IFPREVERB FLIP -1
  CLEARVERB
  ECHO PLAYER You toss the dagger up into the air...
  ECHO OTHERS %N tosses %a into the air...
  ECHO ALL ...the dagger tumbles end over end in the air...
  RANDOM DUMMY1 1 100 QUI
  IFVAR DUMMY1 >= 130
    ECHO PLAYER ...and you catch it easily.
    ECHO OTHERS ...and %s catches it easily.
  ENDIF
  IFVAR DUMMY1 < 130
    ECHO OTHERS ...and %n cuts %iself as %s tries to catch it!
    DAMAGEPLR SLASH 2 ...and you cut yourself as try to catch it!
  ENDIF
ENDIF
ifpreverb latch -1
  clearverb
  ifvar itemadj3 = 272
    echo player You stomp the rusty dagger into dust!
    echo others %N stomps a rusty dagger into dust!
    removeitem -1
  endif
endif
