;
; Shotgun
INUMBER 1057
NAME 185
WEIGHT 10
VOLUME 4
PARAMETER1 23
PARAMETER2 283
BOW_WEAPON
WIELDABLE
SUBSTANCE HARDMETAL
IFPREVERB LOAD -1
  IFVAR ITEMBIT5 = 1
    clearverb
    IFVAR ITEMVAL1 >= 10
      ECHO PLAYER It is fully loaded.
      ECHO OTHERS %N tried to jam more shells in %h shotgun.
    ELSE
      ECHO PLAYER You cram another shell into the shotgun.
      ECHO OTHERS %N stuffs a shell into %h shotgun.
      ADD ITEMVAL1 1
    ENDIF
  ENDIF
ENDIF
IFPREVERB PUSH -1
  IFVAR ITEMBIT5 = 1
    clearverb
    IFVAR ITEMVAL3 > 0
      ECHO PLAYER You have a round in the chamber already.
      ECHO OTHERS %N tries to slide the pump on %h shotgun, but it won't budge.
    ELSE
      IFVAR ITEMVAL1 > 0
        ECHO PLAYER Cha-Chok! You push then pull the pump on your shotgun.
        ECHO OTHERS Cha-Chok! %N pushes, then pulls a slide on the barrel of %h shotgun.
        EQUAL ITEMVAL3 1
        SUB ITEMVAL1 1
        EQUAL ROUNDTIME 1
      ENDIF
    ENDIF
  ENDIF
ENDIF
;
; Sword
INUMBER 1235
NAME 201
WEIGHT 10
VOLUME 7
PARAMETER1 13
SLASH_WEAPON
WIELDABLE
IFVERB CONCENTRATE -1
  IFVAR ALIGN >= 0
    ADD INTNUM19 1
    IFVAR INTNUM19 < 46
      ECHO PLAYER A voice speaks in your mind, "Armor up, master."
      ECHO OTHERS A glimmering field of fire emanates from the sword and covers %N.
      SPELL 102
    ENDIF
    IFVAR INTNUM19 >= 46
      IFVAR INTNUM19 < 80
        ECHO PLAYER A voice speaks in your mind, "I tire master, but I'll do my best."
        RANDOM DUMMY1 1 40 0
        IFVAR DUMMY1 < 20
          ECHO PLAYER A voice speaks in your mind, "Armor up, master."
          ECHO OTHERS A glimmering field of fire emanates from the sword and covers %N.
          SPELL 102
        ENDIF
        IFVAR DUMMY1 >= 20
          ECHO PLAYER A voice speaks in your mind, "I am sorry master
          ECHO OTHERS A glowing outline of armor begins to appear around &N, then fades.
        ENDIF
      ENDIF
    ENDIF
    IFVAR INTNUM19 >= 80
      ECHO PLAYER A voice speaks in your mind, "I can serve you no more. Pass me on and my new master will rejuvinate me."
      SETITEMVAL -1 3 0
      SETITEMVAL -1 5 0
    ENDIF
  ENDIF
  IFVAR ALIGN < 0
    ECHO PLAYER The sword ignores you.
  ENDIF
ENDIF
IFVERB TAP -1
  IFVAR ALIGN >= 0
    ADD INTNUM19 1
    IFVAR INTNUM19 < 46
      ECHO PLAYER A voice speaks in your mind, "This will help free you %N."
      SPELL 510
    ENDIF
    IFVAR INTNUM19 >= 46
      IFVAR INTNUM19 < 80
        ECHO PLAYER A voice speaks in your mind, "I tire master, but I'll do my best."
        RANDOM DUMMY1 1 40 0
        IFVAR DUMMY1 < 20
          ECHO PLAYER A voice speaks in your mind, "This will help free you %N."
          SPELL 510
        ENDIF
        IFVAR DUMMY1 >= 20
          ECHO PLAYER A voice speaks in your mind, "I am sorry master
          ECHO OTHERS %N's sword emanates and orange glow for a moment, then fades.
        ENDIF
      ENDIF
    ENDIF
    IFVAR INTNUM19 >= 80
      ECHO PLAYER A voice speaks in your mind, "I can serve you no more. Pass me on and my new master will rejuvinate me."
      SETITEMVAL -1 3 0
      SETITEMVAL -1 5 0
    ENDIF
  ENDIF
  IFVAR ALIGN < 0
    ECHO PLAYER The sword ignores you.
  ENDIF
ENDIF
IFVERB WIELD -1
  IFVAR ALIGN => 0
    IFVAR INTNUM19 < 80
      ECHO PLAYER A voice, from the sword it seems, speaks in your mind, "Ahh, you are pure of heart we will get along well. It is a pleasure to serve you %N."
      SETITEMVAL -1 3 5
      SETITEMVAL -1 5 18
    ENDIF
  ELSE
    ECHO PLAYER A voice booms in your mind, "%N! You have a blackness in your heart. Serve you I must, but pleasant it will not be!" You feel waves of disgust emanating from the sword and it goes silent.
    ECHO OTHERS %N grimaces a bit as %s wields Sunstrike.
    SPELL 314
    SETITEMVAL -1 3 0
    SETITEMVAL -1 5 0
  ENDIF
ENDIF
IFPREVERB PULL -1
  IFITEM -1 WIELDED
    CLEARVERB
    ECHO PLAYER You raise %a in salute.
    ECHO OTHERS %N raises %a in salute.
  ENDIF
ENDIF
