;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;Room 401
NUMBER 148
 NAME Hotel Escapades, Room 401
 REGION 0
 INDOOR_FLOOR
 FIXED_LIGHT
 CHANNEL 1

*DESCRIPTION_START
Across from an elegant king-sized bed stands a wooden dresser beneath a framed 
mirror that makes the room seem larger. Nightstands on either side of the
comfortable bed support lamps with green shades. Next to the large simulated
picture window a wooden desk provides hotel stationery.
*DESCRIPTION_END

 EXIT O 144
 ; Hallway door
 ITEM 0 350 VAL2=144 UNLOCKED
 ; Bed
 ITEM 1 74
 ; Nightstand
 ITEM 2 1401
 ; Dresser
 ITEM 3 1402
 ; Mirror
 ITEM 4 657
 ; Chair
 ITEM 5 215 ADJ1=311
 ; Desk, wooden
 ITEM 6 328 ADJ1=1101
 ; Window
 ITEM 7 1123

 IFPREVERB LOOK 7
  CLEARVERB

  RANDOM ITEMVAL5 1 2 0

  IFVAR ITEMVAL5 = 1
   STRCPY 0 "The_view_from_the_window_reveals_an_enchanting_landscape.
  ENDIF

  IFVAR ITEMVAL5 = 2
   STRCPY 0 "Gazing_out_the_window_from_four_stories_high,_you_feel_as_if_surveying_your_domain.
  ENDIF

  RANDOM ITEMVAL5 1 4 0

  IFVAR ITEMVAL5 = 1
   STRCPY 1 "You_notice_a_flock_of_birds_circling_in_the_sky.
  ENDIF

  IFVAR ITEMVAL5 = 2
   STRCPY 1 "You_watch_two_people_on_the_sidewalk_below_embrace_passionately.
  ENDIF

  IFVAR ITEMVAL5 = 3
   STRCPY 1 "Your_hazy_reflection_is_superimposed_on_the_landscape.
  ENDIF

  IFVAR ITEMVAL5 = 4
   STRCPY 1 "A_hawk_glides_in_lazy_circles_with_placid_wings_as_it_rides_a_thermal.
  ENDIF

  ECHO OTHERS %N gazes at a simulated window.
  ECHO PLAYER %0 %1

 ENDIF

