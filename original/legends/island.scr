NUMBER 1215
NAME The Blue Room
REGION 0
INDOOR_FLOOR
FIXED_LIGHT
CHANNEL 777

;door 2nd floor landing
ITEM 0 350 VAL2=1214
;bed
ITEM 1 73          
;mint
ITEM 7 178 ADJ1=163 ADJ2=606
;window
ITEM 2 1123
;pillow
ITEM 3 757
;chair
ITEM 4 215
;table
ITEM 5 1007
;bottle
PUT 5  117 VAL5=9               

*DESCRIPTION_START
This bedroom is tastefully decorated in shades of blue taken from sea and sky. 
The picture window looks north along the coast. A small round table with 
two chairs is placed in front of the window, and on it is a bottle of 
champagne in an ice bucket. A chocolate mint is laid on the pillow. You 
notice that there is no phone, no television, nothing to mar the peace and 
restfulness you feel here.
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 1
insert bed description here (velvet covers, satin sheets)
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 3
insert chair description here  
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 2
 INSERT WINDOW VIEW
*DESCRIPTION_END
*
*DESCRIPTION_START ITEM EXAM 5
 INSERT TABLE DESCRIPTION HERE
*DESCRIPTION_END



VARIABLE BED1


IFPREVERB PULL 1
  IFVAR BED1 = 0
      CLEARVERB
      ECHO PLAYER You carefully fold the velvet coverlet at the end of the bed.
      ECHO OTHERS %n neatly folds down the velvet coverlet, revealing the silk sheets.
      EQUAL BED1 1
   ENDIF
  ELSE   
      CLEARVERB
      ECHO PLAYER The bed is already turned down.
ENDIF
   

IFPREVERB GO 1
   IFVAR BED1 = 0
     CLEARVERB
     ECHO PLAYER You stretch out on the velvet coverlet and relax.
     ECHO OTHERS %n stretches out on the velvet coverlet.
   ELSE
      ECHO PLAYER You slip between the silk sheets, shivering at the touch of luxury.
      ECHO OTHERS %n slips between the silk sheets sighing happily.
      EQUAL FLAG1 1
      POSITION LAY
   ENDIF   
ENDIF   
 

IFPREVERB LAY -1
   CLEARVERB
   IFVAR POSITION = 0
      ECHO PLAYER You climb into bed.
      ECHO OTHERS %N climbs into bed.
      EQUAL FLAG1 1
   ENDIF
   IFVAR POSITION = 1
      IFVAR FLAG1 = 0
         ECHO PLAYER You lay back on the sofa.
         ECHO OTHERS %N lays back on the sofa.
      ENDIF
      IFVAR FLAG1 = 1
         ECHO PLAYER You lay back in bed.
         ECHO OTHERs %N lays back in bed.
      ENDIF
   ENDIF
   IFVAR POSITION = 2
      ECHO PLAYER You're already laying down.
   ENDIF
   IFVAR POSITION = 3
      ECHO PLAYER You climb into bed.
      ECHO OTHERS %N climbs into bed.
   ENDIF
   POSITION LAY
ENDIF
               
IFPREVERB LAUGH -1
   CLEARVERB
   ECHO PLAYER You laugh out loud.
   ECHO OTHERS %n laughs.
ENDIF

IFPREVERB GET -1
   IFVAR ARCHNUM = 117
      IFVAR ITEMVAL5 = 9
         CLEARVERB
         ECHO PLAYER You pour the champagne into a slender fluted glass.
         ECHO OTHERS %n pours champagne into a slender fluted glass.
         NEWITEM 6 472 ADJ1=889 ADJ2=1319
         NEWPUT 6 218 VAL1=5
      ENDIF
   ENDIF
ENDIF
      
IFPREVERB SIT -1
   CLEARVERB
   IFVAR POSITION = 0
      ECHO PLAYER You take a seat and relax on the comfortable chair.
      ECHO OTHERS %n takes a seat and relaxes on the comfortable chair.
   ENDIF
   IFVAR POSITION = 1
      ECHO PLAYER You're already sitting.
   ENDIF
   IFVAR POSITION = 2
      ECHO PLAYER You sit up.
      ECHO OTHERS %N sits up.
   ENDIF
   IFVAR POSITION = 3
      ECHO PLAYER You take a seat and relax on the comfortable chair.
      ECHO OTHERS %n takes a seat and relaxes on the comfortable chair.
   ENDIF
   POSITION SIT
ENDIF

IFENTRY
   IFNOITEM 7
      NEWITEM 7 178 ADJ1=163 ADJ2=204
   ENDIF
ENDIF

