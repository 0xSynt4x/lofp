 INSERT WINDOW VIEW
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 5
 INSERT TABLE DESCRIPTION HERE
*DESCRIPTION_END



VARIABLE BED1


IFPREVERB PULL 1
  IFVAR BED1 = 0
      CLEARVERB
      ECHO PLAYER You carefully fold the velvet coverlet at the end of the bed.
      ECHO OTHERS %n neatly folds down the velvet coverlet, revealing the silk sheets.
      EQUAL BED1 1
   ENDIF
  ELSE   
      CLEARVERB
      ECHO PLAYER The bed is already turned down.
ENDIF
   

IFPREVERB GO 1
   IFVAR BED1 = 0
     CLEARVERB
     ECHO PLAYER You stretch out on the velvet coverlet and relax.
     ECHO OTHERS %n stretches out on the velvet coverlet.
   ELSE             
      CLEARVERB
      ECHO PLAYER You slip between the silk sheets, shivering at the touch of luxury.
      ECHO OTHERS %n slips between the silk sheets sighing happily.
      EQUAL FLAG1 1
      POSITION LAY
   ENDIF   
ENDIF   
 

IFPREVERB LAY -1
