;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;North bedroom
NUMBER 1214
 NAME Herlighy Home
 REGION 0
 INDOOR_FLOOR
 FIXED_LIGHT
 CHANNEL 1

*DESCRIPTION_START
Someone seems to have recently been in this bedroom, because the cobwebs have
been swept away from the bed and nightstand.
*DESCRIPTION_END

 EXIT O 1210

 ; Hallway door
 ITEM 0 351 VAL2=1210 UNLOCKED
 ; Closet door
 ITEM 1 352 VAL2=1217 UNLOCKED
 ; Bed (72-74 are all beds)
 ITEM 2 72
 ; Nightstand
 ITEM 3 1401
 ; Dresser
 ITEM 4 1402
 ; Mirror
 ITEM 5 657
 ; Incense
 ITEM 6 548
 ; Candle
 ITEM 7 176
 ; Radio
 ITEM 8 1301

 IFPREVERB HIDE -1
  CLEARVERB
  ECHO PLAYER You grope around, trying to hide.
  ECHO OTHERS %N gropes around, trying to hide.
 ENDIF

 IFENTRY
  EQUAL ROUNDTIME 1
  AFFECT 1217
  ECHO OTHERS You sense someone enter the bedroom. 
 ENDIF

 EQUAL ITEMVAL5 0

 IFPREVERB RECALL -1
  ECHO PLAYER With the door latched, ducking, hula'ing, jigging, kissing, moaning, nibbling, pacing, panting, shivering and swooning seem more intimate.
  CLEARVERB
 ENDIF

 IFVERB OUT -1
  EQUAL ITEMVAL5 1
 ENDIF

 IFVERB GO 0
  EQUAL ITEMVAL5 1
 ENDIF

 ; Go bed
 IFVERB GO 2
  ECHO PLAYER You lay down on the soft bed.
  ECHO OTHERS %N lays down on the soft bed.
  EQUAL POSITION 2
 ENDIF

 VARIABLE DKG_LATCH1

 ; Latch bedroom door
 IFVERB LATCH 0
  ECHO ALL The room feels more intimate now.
  EQUAL DKG_LATCH1 1
 ENDIF

 ; Unlatch bedroom door
 IFVERB UNLATCH 0
  ECHO ALL The room feels less intimate now.
  EQUAL DKG_LATCH1 0
 ENDIF

 ; Special handling when the door is latched
 IFVAR DKG_LATCH1 = 1

   IFPREVERB CARESS -1
    ECHO PLAYER You give a sensual caress.
    ECHO OTHERS %N gives you a sensual caress.
    CLEARVERB
   ENDIF
   
   IFPREVERB DUCK -1
    ECHO PLAYER You bend down.
    ECHO OTHERS %N bends down.
    CLEARVERB
   ENDIF
   
   IFPREVERB HULA -1
    ECHO PLAYER You rock your hips.
    ECHO OTHERS %N rocks %h hips.
    RANDOM ITEMVAL5 1 100 0
    IFVAR ITEMVAL5 > 50
     ECHO ALL The bed makes a loud squeek.
    ENDIF
    CLEARVERB
   ENDIF
   
   IFPREVERB JIG -1
    ECHO PLAYER You shimmy.
    ECHO OTHERS %N shakes %iself for you.
    CLEARVERB
   ENDIF
   
   IFVERB KISS -1
    ECHO OTHERS You feel your pulse speed up.
   ENDIF

   IFPREVERB MOAN -1
    ECHO PLAYER You moan in ecstasy.
    ECHO OTHERS %N moans in ecstasy.
    CLEARVERB
   ENDIF
   
   IFPREVERB NIBBLE -1
    ECHO PLAYER You nibble with your lips.
    ECHO OTHERS %N nibbles you with %h lips.
    CLEARVERB
   ENDIF
   
   IFPREVERB PACE -1
    ECHO PLAYER You move back and forth rhythmically.
    ECHO OTHERS %N moves back and forth rhythmically.
    CLEARVERB
   ENDIF
   
   IFPREVERB PANT -1
    ECHO PLAYER You breathe heavily.
    ECHO OTHERS %N breathes heavily in passion.
    CLEARVERB
   ENDIF
   
   IFPREVERB SHIVER -1
    ECHO PLAYER You shiver with pleasure.
    ECHO OTHERS %N shivers with pleasure.
    CLEARVERB
   ENDIF

   IFPREVERB SHUDDER -1
    ECHO PLAYER Your body shudders with sexual tension.
    ECHO OTHERS %n's body shudders with sexual tension.
    CLEARVERB
   ENDIF
   
   IFPREVERB SWOON -1
    ECHO PLAYER You feel weak with passion.
    ECHO OTHERS %n swoons with passion.
    CLEARVERB
   ENDIF
   
   ; Look in the mirror
   IFPREVERB GAZE 5
    CLEARVERB
    ECHO PLAYER You look around the room in the mirror.
    ECHO OTHERS %N sneaks a look at you in the mirror.
   ENDIF

   ; Look at the candle
   IFPREVERB GAZE 7
    CLEARVERB
    ECHO PLAYER You look at the room by candlelight.
    ECHO OTHERS %N is illuminated by the flickering candlelight.
   ENDIF

   ; Push the bed
   IFPREVERB PUSH 2
    ECHO PLAYER You arch your body.
    ECHO OTHERS %N arches %h body.
    CLEARVERB
   ENDIF

   ; Pull the bed
   IFPREVERB PULL 2
    ECHO PLAYER You press yourself against your partner.
    ECHO OTHERS %N presses against you.
    CLEARVERB
   ENDIF

 ENDIF

 ; Climb bed
