CEVENT 6 3 3349  
;Training film counter
VARIABLE JABFILM
;damage counter
VARIABLE JABDMG
;sets room to which to  echo atmospherics, and to which to move players on random move.
VARIABLE JABROOM     
;room to send damage string to
VARIABLE JABROOM2
;move timer
VARIABLE JABMVE
;atmospheric echo string
VARIABLE JABSTR
;Lightshow timer
VARIABLE LIGHTSHOW
;lightshow string
VARIABLE LIGHTS
VARIABLE JABDMGTYPE
;
IFVAR JABFILM < 30
  ADD JABFILM 1
  ELSE
  EQUAL JABFILM 0
ENDIF     
AFFECT 3306
IFVAR JABFILM = 0
  ECHO ALL There is a whirring sputter, and the light on the mist comes to life, swirling into a maze of color.
ENDIF
AFFECT 3306
IFVAR JABFILM = 1
  ECHO ALL A voice issues from the swirling colors, droning monotonously.
ENDIF
AFFECT 3306
IFVAR JABFILM = 2
  ECHO ALL It intones, "After centuries of exile, a scouting party has discovered a portal to return us to our home...
ENDIF
AFFECT 3306
IFVAR JABFILM = 3
  ECHO ALL ...and fate has delivered our ancient enemies into our hands.
  ECHO ALL What follows are reports from the scouting party on each of  the members of the Order.
ENDIF
AFFECT 3306
IFVAR JABFILM = 4
  ECHO ALL The swirling colors coalesce, forming a picture of the Meeting Hall of the Arcana Tower. The focus slowly tightens until the silver rose fills the screen.
ENDIF
AFFECT 3306
IFVAR JABFILM = 5
  ECHO ALL The voice continues, "This is the meeting hall of the Order of the White Rose."
ENDIF
AFFECT 3306
IFVAR JABFILM = 6
  ECHO ALL The focus widens again to encompass the entire table, showing a meeting in progress.
ENDIF
AFFECT 3306
IFVAR JABFILM = 7
  ECHO ALL The focus begins to narrow again, until the face of Lianna fills the mist.
ENDIF      
AFFECT 3306
IFVAR JABFILM = 8
  ECHO ALL The voice over intones, "This is Lianna, Mistress of the  Order. Should you encounter her, your surest strategy is to...
ENDIF      
AFFECT 3306
IFVAR JABFILM = 9
  ECHO ALL ...cast silence immediately, before she has a chance to  envelop herself and her companions in protective bubbles.
ENDIF
AFFECT 3306
IFVAR JABFILM = 10
  ECHO ALL The focus moves slowly to the left until the wavering form of  Myrdhyn is centered.
ENDIF
AFFECT 3306
IFVAR JABFILM = 11
  ECHO ALL The voice over intones, "This disembodied aelf is known as  Myrdhyn Wenthal. His knowledge of lore and sagecraft is legendary, as is...
ENDIF
AFFECT 3306
IFVAR JABFILM = 12
  ECHO ALL his penchant for reasonable discussion over violence. The scouts suggest distracting him with discourse while a shape positions itself for attack."
ENDIF
AFFECT 3306
IFVAR JABFILM = 13
  ECHO ALL Once again the focus shifts left, bringing Mariella into view.
ENDIF
AFFECT 3306
IFVAR JABFILM = 14
  ECHO ALL The voice over drones, "This wolfling is Mariella Silverleaf, a mage of better than average ability.
ENDIF
AFFECT 3306
IFVAR JABFILM = 15
  ECHO ALL She is often guarded by her husband, Emanon Demonslayer. She was an apprentice of this man..."
ENDIF
AFFECT 3306
IFVAR JABFILM = 16
  ECHO ALL The focus again shifts left moving to show the smoke-wreathed form of Linnaeus Wanderfar.
ENDIF
AFFECT 3306
IFVAR JABFILM = 18
  ECHO ALL "...Linnaeus Wanderfar, former Grand Master of the Order. Be extremely careful of casting magic near him...
ENDIF
AFFECT 3306
IFVAR JABFILM = 19
  ECHO ALL "...as something in his aura seems to warp spells, causing unexpected results."
ENDIF      
AFFECT 3306
IFVAR JABFILM = 20
  ECHO ALL The focus continues to move to the left, around the side of  the table, bringing Cabot into view.
ENDIF      
AFFECT 3306
IFVAR JABFILM = 21
  ECHO ALL The voice over intones, "Somewhat unusual in an order devoted  to magic is this man, Cabot. He is a powerful psionist..
ENDIF      
AFFECT 3306
IFVAR JABFILM = 22
 ECHO ALL "...akin to the mindbenders of this plane. One of our scouts observed him fashioning a chair of the molecules in the air..
 ECHO ALL "and sitting in it."
ENDIF      
AFFECT 3306
IFVAR JABFILM = 23
  ECHO ALL As the focus continues to move left, the voice intones, "Seated next to Cabot is the ephemeral known as Tigre.."
ENDIF
AFFECT 3306
IFVAR JABFILM = 24
  ECHO ALL "...the rumor is that he was a familiar belonging to a former member of the Order..
  ECHO ALL "Despite his rather ridiculous appearance, he should not be  taken lightly. He is a mage of no small ability."
ENDIF
AFFECT 3306
IFVAR JABFILM = 25
  ECHO ALL Once again, the focus shifts left, onto the pert face of Sun. The voice intones, "Sun Light.."
ENDIF
AFFECT 3306
IFVAR JABFILM = 26
  ECHO ALL "...a female mage of considerable ability. Our scout suggests silencing her on sight...
ENDIF
AFFECT 3306
IFVAR JABFILM = 27
  ECHO ALL "as much for your own sanity as to prevent her from incanting spells."
ENDIF
IFVAR JABFILM = 28
  ECHO ALL Sun's face is replaced by that of Chronis. The voice over intones...
ENDIF
AFFECT 3306
IFVAR JABFILM = 29
  ECHO ALL "The mage, Chronis. Our scouts were able to learn little about this mysterious mage, but advise extreme caution."
ENDIF
AFFECT 3306
IFVAR JABFILM = 30
  ECHO ALL The picture fades into a swirl of color, as the voice over  intones, "These are our enemy, study them well and be prepared!"
  ECHO ALL The light on the mist dims and a soft whir suggests the end of the film.
ENDIF
AFFECT 3349
;damage timer.. can you beat the clock?
;adds random number from 1 to 5 to JABDMG, which serves as trigger for random 
;damage to players in the area.
;
IFVAR JABDMG < 60
   RANDOM DUMMY1 1 5 0
   ADD JABDMG DUMMY1
 ELSE
  RANDOM JABROOM2 1 50 0
  ADD JABROOM2 3300
  EQUAL JABDMG 0
ENDIF
;sets damage type for random damage to players when the jabdmg clock runs out                                                                 
IFVAR JABDMG > 59
      RANDOM JABDMGTYPE 1 500 0
      MOD JABDMGTYPE 5
      AFFECT JABROOM2
      IFVAR PLRSINROOM ! 0
         RANDOM DUMMY1 1 500 0 
         MOD DUMMY1 50
         ADD DUMMY1 35
         IFVAR JABDMGTYPE = 0
           DAMAGEPLR COLD dummy1 A bolt of nearly black lightning sears you with bonechilling cold.
           ECHO OTHERS %n is struck by a bolt of black lightning.
         ENDIF
         IFVAR JABDMGTYPE = 1
           DAMAGEPLR COLD DUMMY1 An icy wind whirls around you, nearly flaying your skin with cold.
           ECHO OTHERS %n is caught up in an icy whirlwind.
         ENDIF
         IFVAR JABDMGTYPE = 2
           DAMAGEPLR CRUSH DUMMY1 The air suddenly implodes, crushing you with bruising force.
           ECHO OTHERS %n suddenly staggers as if hit by an enormous force.
         ENDIF
         IFVAR JABDMGTYPE = 3
           DAMAGEPLR CRUSH DUMMY1 There is a whirr of wings, and something strikes you, knocking you over.
           POSITION LAY
           ECHO OTHERS %n is knocked to the ground by an unseen force.
         ENDIF
         IFVAR JABDMGTYPE = 4
           DAMAGEPLR ELECTRIC DUMMY1 LIghtning arcs up from the ground through the soles of your feet.
         ENDIF
         RANDOM DUMMY1 1 10 0                 
         EQUAL JABDMG DUMMY1
      ENDIF               
ENDIF
;timer for random moves from rms 3306, 3315, 3324, 3333 and 3342 to JABROOM
IFVAR JABMVE < 80
  RANDOM DUMMY1 1 5 0  
  ADD JABMVE DUMMY1
ENDIF
IFVAR JABMVE > 79
;chooses one of ten echoes to be sent to a room determined randomly
  RANDOM JABSTR 1 10 0
  RANDOM JABROOM 1 50 0
  ADD JABROOM 3300   
  AFFECT JABROOM
  ECHO ALL There is a nearly imperceptible shift in the ether. %0
  AFFECT 3350
  ECHO ALL There is a nearly imperceptible shift in the ether. %0
  AFFECT 3349
  EQUAL JABMVE 0
ENDIF
;
;yep, these are the echoes.. if you add more, change the preceding RANDOM to 
;reflect the total number of echoes  e.g. 15 echoes would be RANDOM DUMMY1 1 
;15 0
;
IFVAR JABSTR = 1
  STRCPY 0 "The_ground_beneath_your_feet_suddenly_turns_to_quagmire.
ENDIF
;
IFVAR JABSTR = 2
  STRCPY 0 "Your_surroundings_are_bathed_in_iridescence_as_a_flash_of_dark_lightning_arcs_nearby.
ENDIF
IFVAR JABSTR = 3
  STRCPY 0 "Dark_shadows_gather_around,_their_hunger_a_palpable_thing.
ENDIF
IFVAR JABSTR = 4
  STRCPY 0 "Out_of_the_corner_of_your_eye,_you_catch_a_glimpse_of_something_horribly_misshapen.
ENDIF
IFVAR JABSTR = 5
  STRCPY 0 "A_flash_of_lightning_illuminates_strange_transparent_shapes_floating_in_the_air.
ENDIF
IFVAR JABSTR = 6
  STRCPY 0 "The_air_around_you_shimmers_and_shifts_briefly.
ENDIF
IFVAR JABSTR = 7
  STRCPY 0 "The_surrounding_shadows_take_on_more_substance_and_a_dark_voice_intones_"Beware!".
ENDIF
IFVAR JABSTR = 8
  STRCPY 0 "A_sudden_drop_in_temperature_chills_you_to_the_bone.
ENDIF
IFVAR JABSTR = 9
  STRCPY 0 "A_chorus_of_howls_echoes_and_hangs_eerily_in_the_air.
ENDIF
IFVAR JABSTR = 10
  STRCPY 0 "A_disembodied_claw_rips_through_the_air,_leaving_behind_a_tear_that_slowly_knits_back_together.      
ENDIF           
RANDOM DUMMY2 1 5 0
ADD LIGHTSHOW DUMMY2
IFVAR LIGHTSHOW > 60     
   RANDOM LIGHTS 1 10 0
   IFVAR LIGHTS = 1
     STRCPY 1 "indigo
   ENDIF
   IFVAR LIGHTS = 2
     STRCPY 1 "brilliant_yellow
   ENDIF
   IFVAR LIGHTS = 3
     STRCPY 1 "deep_scarlet
   ENDIF
   IFVAR LIGHTS = 4
     STRCPY 1 "emerald_green
   ENDIF
   IFVAR LIGHTS = 5
     STRCPY 1 "rich_cobalt_blue
   ENDIF
   IFVAR LIGHTS = 6
     STRCPY 1 "pale_rose
   ENDIF
   IFVAR LIGHTS = 7
     STRCPY 1 "pure_white
   ENDIF
   IFVAR LIGHTS = 8
     STRCPY 1 "iridescent_black
   ENDIF
   IFVAR LIGHTS = 9
     STRCPY 1 "shimmering_orange
   ENDIF
   IFVAR LIGHTS = 10
     STRCPY 1 "flickering_violet
   ENDIF
   AFFECT 3301
     ECHO ALL The silvery mist suddenly flares %1.
     EQUAL LIGHTSHOW 0
   AFFECT 3312
     ECHO ALL The dark mist suddenly flares %1.
     EQUAL LIGHTSHOW 0
   AFFECT 3323 
     ECHO ALL The brilliant mist suddenly flares %1.     
   EQUAL LIGHTSHOW 0
ENDIF   
;    
MACRO 19
;             
;checks player aura on prep, and sets flag for mana drain when player casts prepped spell.
;fyi, player can safely cast the prepared spell if they leave the room where 
;it was prepped before casting.
;
IFVAR SPELLNUM ! 0
  IFVAR FLAG1 = 0
    IFVAR ALIGN > 49
      EQUAL FLAG1 1
    ENDIF
    IFVAR ALIGN > 9
      IFVAR ALIGN < 50
        EQUAL FLAG1 4
      ENDIF
    ENDIF
    IFVAR ALIGN < 10
      IFVAR ALIGN > 5
         EQUAL FLAG1 2
      ENDIF
    ENDIF
    IFVAR ALIGN < 6
      IFVAR ALIGN > -1
        EQUAL FLAG1 3
       ENDIF
     ENDIF
   ENDIF
ENDIF
;drains mana on cast, based on aura -- lighter the aura, more the drain
VARIABLE JABMANA                                  
VARIABLE JABMANA1
VARIABLE JABMANA2
IFPREVERB CAST -1               
  IFVAR FLAG1 ! 0
    ECHO PLAYER You feel the shadows feeding hungrily on the mana you've released.
    IFVAR FLAG1 = 1
       RANDOM JABMANA2 20 50 0
       SUB MANAPOINTS JABMANA2
    ENDIF
    IFVAR FLAG1 = 2         
      RANDOM JABMANA1 10 30 0                       
      SUB MANAPOINTS JABMANA1
    ENDIF
    IFVAR FLAG1 = 3             
      RANDOM JABMANA 1 32000 0
      MOD JABMANA 10
      ADD JABMANA 5 
      STRCVT 1 JABMANA
      GMMSG JABMANA = %1 
      SUB MANAPOINTS JABMANA
    ENDIF                   
    IFVAR FLAG1 = 4
      RANDOM JABMANA 1 32000 0
      mod jabmana 10
      ADD JABMANA 10
      SUB MANAPOINTS JABMANA
    ENDIF
  ENDIF                      
  EQUAL FLAG1 0
ENDIF
