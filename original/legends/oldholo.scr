;
;SNOWY DECK (Holodeck Program)
NUMBER 3487
NAME Snowy Deck
REGION 1
INDOOR_FLOOR
FIXED_LIGHT
CAFE
MOVEMENT_ASTRAL
CHANNEL 777

CALL 49

RELOGIN 1920

ITEM 0 1125 ADJ1=510 ADJ2=407
ITEM 1 460 ADJ1=355 ADJ2=162
ITEM 2 198 ADJ1=162 ADJ2=42 VAL2=100
ITEM 3 451 
ITEM 4 86 ADJ1=63 ADJ2=1227
ITEM 5 821 ADJ1=317 UNLOCKED
PUT 5 1015 ADJ1=344 VAL5=9
ITEM 6 247 ADJ1=29
ITEM 7 247 ADJ1=347
ITEM 8 247 ADJ1=259

;FLAG1 = 1 (In Hot Tub)
;FLAG1 = 0 (Not In Hot Tub)

*DESCRIPTION_START
Clouds of steam rising up from a hot tub, its smooth rounded rim just slightly
above the surface of the snow covered wooden deck, envelopes the hot, bubbling
water in a veiled curtain of soothing warmth. Perched safely here on the crest
of a high mountaintop, the sturdy snow covered deck affords you a spectacular
view of the surrounding snow capped peaks and white blanketed valleys below.
Several lounge chairs, their soft cushions covered with thick wool blankets,
are tucked beneath a protective overhang beside a warming cabinet.
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 0
It's covered in snow.
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 1
The tub is immaculately clean, a soft magical light glowing dimly over its
polished redwood walls. Small openings, placed strategically along the smooth
inner surface of the tub, shoot massaging jets of bubbles in every angle. Amber
spotlights, highlighting the steamy water, are recessed in the molded seats in
each wall. Along one rim of the tub are three buttons; red, white and blue.
*DESCRIPTION_END

IFPREVERB GO 1
   CLEARVERB
   IFVAR FLAG1 = 1
      ECHO PLAYER You're already in the hot tub.
   ENDIF
   IFVAR FLAG1 = 0
      ECHO PLAYER You lower yourself into the steamy tub.
      ECHO OTHERS %N lowers %iself into the steamy tub.
      POSITION SIT
      EQUAL FLAG1 1
   ENDIF
ENDIF

IFPREVERB TOUCH 2
   IFVAR FLAG1 = 0
      CLEARVERB
      ECHO PLAYER You dip your fingers in %a, testing the temperature.
      ECHO OTHERS %N dips %h fingers in %a, testing the temperature.
   ENDIF
ENDIF

IFPREVERB WAVE 2
   CLEARVERB
   ECHO OTHERS %N splashes a little water at you.
   ECHO PLAYER You splash a little water around.
ENDIF

IFPREVERB SLAP 2
   CLEARVERB
   ECHO OTHERS %N splashes a lot of water at you!
   ECHO PLAYER You splash a lot of water around!
ENDIF

IFPREVERB PLAY 2
   CLEARVERB
   IFVAR FLAG1 = 0
      ECHO PLAYER You play your fingers across the surface of the water.
      ECHO OTHERS %N plays %h fingers across the surface of the water.
   ENDIF
   IFVAR FLAG1 = 1
      ECHO PLAYER You pretend to be a little submarine by submerging yourself completely and
      ECHO PLAYER blowing some friendly bubbles.
      ECHO OTHERS %N submerges %iself completely, blowing some friendly bubbles your way.
      POSITION LAY
   ENDIF
ENDIF

IFPREVERB GO 2
   CLEARVERB
   IFVAR FLAG1 = 1
      ECHO PLAYER You're already in the water.
   ENDIF
   IFVAR FLAG1 = 0
      ECHO PLAYER You lower yourself into the steamy tub.
      ECHO OTHERS %N lowers %iself into the steamy tub.
      POSITION SIT
      EQUAL FLAG1 1
   ENDIF
ENDIF

*DESCRIPTION_START ITEM EXAM 3
Delicate snowflakes melt instantly upon touching the warm mist hanging over
this cozy haven.
*DESCRIPTION_END

IFTOUCH 3
   CLEARVERB
   ECHO PLAYER You wave your hand through the mist.
   ECHO OTHERS %N waves %h hand through the mist.
ENDIF

IFPREVERB GAZE 3
   CLEARVERB
   ECHO PLAYER You gaze into the mist.
   ECHO OTHERS %N stares into the mist with a far away look on %h face.
   RANDOM DUMMY1 1 25 0
   IFVAR DUMMY1 = 20
      ECHO PLAYER You have a vision of another world in another time...
      SHOWROOM 206
   ENDIF
ENDIF

IFTOUCH 4
   IFVAR FLAG1 = 1
      CLEARVERB
      ECHO PLAYER You can't reach that from the hot tub.
   ENDIF
ENDIF

IFTOUCH 5
   IFVAR FLAG1 = 1
      CLEARVERB
      ECHO PLAYER You can't reach that from the hot tub.
   ENDIF
ENDIF

IFVERB PUSH 6
   ECHO ALL Bubbly hot water begins to jet from the sides of the tub.
ENDIF

IFVERB PUSH 7
   IFVAR ITEMVAL1 = 1
      ECHO ALL The music goes off.
      EQUAL FLAG2 0
   ENDIF
   IFVAR ITEMVAL1 = 0
      ECHO ALL The strains of Ravel's "Bolero" emanate from hidden speakers and fill the steamy air.
      EQUAL FLAG2 1
   ENDIF
   EQUAL ITEMVAL1 FLAG2
   EQUAL FLAG2 0
ENDIF

IFVERB PUSH 8
   ECHO ALL A wall panel slides open, exposing a cold bottle of ale.
   NEWITEM 9 158 ADJ1=152 VAL5=9
   NEWPUT 9 1546 VAL2=10
ENDIF

IFPREVERB LISTEN -1
   IFVAR ARCHNUM = -1
      CLEARVERB
      ECHO PLAYER You hear the hoot of a nearby owl.
      ECHO OTHERS %N listens to the night.
   ENDIF
ENDIF

IFPREVERB SNIFF -1
   CLEARVERB
   ECHO PLAYER You sniff and detect the chlorine in the hot tub.
   ECHO OTHERS %N sniffs.
ENDIF

IFPREVERB SPIT -1
   IFVAR FLAG1 = 1
      CLEARVERB
      ECHO PLAYER You take in a mouthful of water and shoot it out in an arching spout.
      ECHO OTHERS %N take in a mouthful of water and shoots it out in an arching spout.
   ENDIF
ENDIF

IFPREVERB SIT -1
   CLEARVERB
   IFVAR FLAG1 = 0
      IFVAR POSITION = 0
         ECHO PLAYER You sit down on the edge of the deck.
         ECHO OTHERS %N sits down on the edge of the deck.
      ENDIF
      IFVAR POSITION = 1
         ECHO PLAYER You are already sitting.
      ENDIF
      IFVAR POSITION = 2
         ECHO PLAYER You sit up.
         ECHO OTHERS %N sits up.
      ENDIF
      IFVAR POSITION = 3
         ECHO PLAYER You sit down on the edge of the deck.
         ECHO OTHERS %N sits down on the edge of the deck.
      ENDIF
   ENDIF
   IFVAR FLAG1 = 1
      IFVAR POSITION = 0
         ECHO PLAYER You slowly sit down, immersing yourself in the soothing suds.
         ECHO OTHERS %N slowly sits down, immersing %iself in the soothing suds.
      ENDIF
      IFVAR POSITION = 1
         ECHO PLAYER You're already sitting.
      ENDIF
      IFVAR POSITION = 2
         ECHO PLAYER You slowly sit up, leaning back against the walls of the tub.
         ECHO OTHERS %N slowly sits up, leaning back against the walls of the tub.
      ENDIF
      IFVAR POSITION = 3
         ECHO PLAYER You slowly sit down, immersing yourself in the soothing suds.
         ECHO OTHERS %N slowly sits down, immersing %iself in the soothing suds.
      ENDIF
   ENDIF
   POSITION SIT
ENDIF

IFPREVERB LAY -1
   CLEARVERB
   IFVAR FLAG1 = 0
      IFVAR POSITION ! 2
         ECHO PLAYER You lay down at the edge of the hot tub, dangling your hand in the bubbling
         ECHO PLAYER water.
         ECHO OTHERS %N lays down at the edge of the hot tub and dangles %h hand in the bubbling water.
      ENDIF
      IFVAR POSITION = 2
         ECHO PLAYER You're already laying down.
      ENDIF
   ENDIF
   IFVAR FLAG1 = 1
      IFVAR POSITION ! 2
         ECHO PLAYER You dive under the water.
         ECHO OTHERS %N dives under the water.
      ENDIF
      IFVAR POSITION = 2
         ECHO PLAYER You're already laying down.
      ENDIF
   ENDIF
   POSITION LAY
ENDIF

IFPREVERB STAND -1
