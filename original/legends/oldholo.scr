IFPREVERB SNIFF -1
   CLEARVERB
   ECHO PLAYER You sniff and detect the scent of honey on the breeze.
   ECHO OTHERS %N sniffs.
ENDIF

IFPREVERB SIT -1
   CLEARVERB
   IFVAR FLAG1 = 0
      IFVAR POSITION = 0
          ECHO PLAYER You sit on one of the smooth flat boulders surrounding the pond.
          ECHO OTHERS %N sits on one of the smooth flat boulders surrounding the pond.
      ENDIF
      IFVAR POSITION = 1
         ECHO PLAYER You're already sitting.
      ENDIF
      IFVAR POSITION = 2
