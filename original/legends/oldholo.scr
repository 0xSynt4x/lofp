      ENDIF
   ENDIF
   IFVAR FLAG1 = 1
      IFVAR POSITION = 0
         ECHO PLAYER You find a seat on a comfortable branch.
         ECHO OTHERS %N finds a seat on a comfortable branch.
      ENDIF
      IFVAR POSITION = 1
         ECHO PLAYER You're already sitting.
      ENDIF
      IFVAR POSITION = 2
         ECHO PLAYER You sit up.
         ECHO OTHERS %N sits up.
      ENDIF
      IFVAR POSITION = 3
         ECHO PLAYER You find a seat on a comfortable branch.
         ECHO OTHERS %N finds a seat on a comfortable branch.
      ENDIF
   ENDIF
   IFVAR FLAG1 = 2
      IFVAR POSITION = 0
         ECHO PLAYER You sit down, immersing yourself in the pond.
         ECHO OTHERS %N sits down, immersing %iself in the pond.
      ENDIF
      IFVAR POSITION = 1
         ECHO PLAYER You're already sitting.
      ENDIF
      IFVAR POSITION = 2
         ECHO PLAYER You stop floating.
         ECHO OTHERS %N stops floating.
      ENDIF
      IFVAR POSITION = 3
         ECHO PLAYER You sit down, immersing yourself in the pond.
         ECHO OTHERS %N sits down, immersing %iself in the pond.
      ENDIF
   ENDIF
   POSITION SIT
ENDIF

IFPREVERB LAY -1
   CLEARVERB
   IFVAR FLAG1 = 0
      IFVAR POSITION = 0
         ECHO PLAYER You stretch out on one of the smooth flat boulders, basking in the sun.
         ECHO OTHERS %N stretches out on one of the smooth flat boulders.
      ENDIF
      IFVAR POSITION = 1
         ECHO PLAYER You lie back.
         ECHO OTHERS %N lies back.
      ENDIF
      IFVAR POSITION = 2
         ECHO PLAYER You're already laying down.
      ENDIF
      IFVAR POSITION = 3
         ECHO PLAYER You stretch out on one of the smooth flat boulders, basking in the sun.
         ECHO OTHERS %N stretches out on one of the smooth flat boulders.
      ENDIF
   ENDIF
   IFVAR FLAG1 = 1
      ECHO PLAYER There's no place in this tree to lie down.
   ENDIF
   IFVAR FLAG1 = 2
      IFVAR POSITION ! 2
         ECHO PLAYER You lie back, floating on the water.
         ECHO OTHERS %N lies back, floating on the water.
      ENDIF
      IFVAR POSITION = 2
         ECHO PLAYER You're already floating on your back.
      ENDIF
   ENDIF
   POSITION LAY
ENDIF

IFPREVERB KNEEL -1
   IFVAR FLAG1 ! 0
      CLEARVERB
      ECHO PLAYER There's no place to kneel here.
   ENDIF
ENDIF

IFPREVERB STAND -1
   IFVAR FLAG1 = 2
      IFVAR POSITION = 2
         CLEARVERB
         ECHO PLAYER You stop floating.
         ECHO OTHERS %N stops floating.
         POSITION STAND
      ENDIF
   ENDIF
ENDIF

IFPREVERB JUMP -1
   CLEARVERB
   IFVAR ROUNDTIME ! 0
      STRCVT 0 ROUNDTIME
      ECHO PLAYER [Wait %0 seconds...]
   ENDIF
   IFVAR ROUNDTIME = 0
      IFVAR FLAG1 = 0
         ECHO PLAYER You take a running jump into the pond, splashing water everywhere!
         ECHO OTHERS %N takes a running jump into the pond, splashing you with water!
      ENDIF
      IFVAR FLAG1 = 1
         EQUAL FLAG2 0
         ECHO PLAYER You boldly swan dive off a high tree branch and into the pond...
