      ECHO PLAYER You turn a somersault on the sand.
      ECHO OTHERS %N turns a somersault on the sand.
      POSITION LAY
   ENDIF
ENDIF

IFPREVERB JUMP -1
   IFITEM 5
      CLEARVERB
      ECHO PLAYER You begin to jump up and down on the sand castle.
      ECHO OTHERS %N begins to jump up and down on the sand castle.
      IFVAR PLRSINROOM > 2
         ECHO PLAYER Suddenly everyone else starts jumping on the sand castle too!
         ECHO OTHERS You join %n jumping up and down on the sand castle!
      ENDIF
      ECHO ALL The sand castle is utterly destroyed.
