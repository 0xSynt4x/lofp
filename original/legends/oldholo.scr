   ECHO ALL Beau bangs out a series of arpeggios.
ENDIF

IFSAY WHISKEY
   ECHO ALL The bartkeep yells, "Buy it fer yerself."
ENDIF

IFSAY WHISKEY!
   ECHO ALL The bartkeep yells, "Buy it fer yerself."
ENDIF

IFSAY BEER
   ECHO ALL The barkeep yells, "Whadda I look like, a frigg'n char'ty?"
ENDIF

IFSAY BEER!
   ECHO ALL The barkeep yells, "Whadda I look like, a frigg'n char'ty?"
ENDIF

