NUMBER 1910
REGION 1
NAME Hotel Room 201
INDOOR_FLOOR
FIXED_LIGHT
CAFE
MOVEMENT_ASTRAL
CHANNEL 777

CALL 49

RELOGIN 1904

ITEM 0 199 ADJ1=241 ADJ2=216 VAL2=1904 UNLATCHED
ITEM 1 85 ADJ1=1145 ADJ2=1146 ADJ3=32
ITEM 2 91 ADJ1=216 ADJ2=642
ITEM 3 360 ADJ1=469 ADJ2=470
ITEM 4 1304 ADJ1=294 ADJ2=867 ADJ3=180
ITEM 5 192 ADJ1=291
ITEM 6 193 ADJ1=277

*DESCRIPTION_START
A haven for weary tourists, this room has been furnished in luxary. Against the
far wall rests a king-size four-poster brass bed, draped with silk sheets and
plump satin pillows, beside it a small oak night table. The only other visible
furnishings is a soft leather sofa and a bevel edged mirror on a nearby wall.
*DESCRIPTION_END

IFPREVERB GAZE 0
   IFVAR POSITION = 0
      CLEARVERB
      ECHO PLAYER You gaze out through the peep-hole in the door...
      ECHO OTHERS %N gazes out through the peep-hole in the door.
      SHOWROOM ITEMVAL2
   ENDIF
ENDIF

*DESCRIPTION_START ITEM EXAM 1
This large bed, draped in silk sheets, looks extremely comfortable, and the
perfect place to relax after a day of sight-seeing.
*DESCRIPTION_END

IFTOUCH 1
   IFVAR FLAG1 = 0
      IFVAR POSITION ! 0
         CLEARVERB
         ECHO PLAYER You can't reach the bed from here.
      ENDIF
   ENDIF
ENDIF

IFPREVERB GO 1
   CLEARVERB
   ECHO PLAYER You climb into bed.
   ECHO OTHERS %N climbs into bed.
   EQUAL FLAG1 1
   POSITION LAY
ENDIF

*DESCRIPTION_START ITEM EXAM 3
You admire your reflection in the mirror.
*DESCRIPTION_END

IFTOUCH 5
   IFVAR FLAG1 = 0
      IFVAR POSITION ! 0
         CLEARVERB
         ECHO PLAYER You can't reach that.
      ENDIF
   ENDIF
ENDIF

IFPREVERB PULL 5
   CLEARVERB
   IFVAR POSITION = 0
      ECHO PLAYER You pull back the silk sheets on the bed.
      ECHO OTHERS %N pulls back the silk sheets on the bed.
   ENDIF
   IFVAR FLAG1 = 1
      ECHO PLAYER You pull the sheets up around you.
      ECHO OTHERS %N pulls the sheets up around %i.
   ENDIF
ENDIF

IFTOUCH 6
   IFVAR FLAG1 = 0
      IFVAR POSITION ! 0
         CLEARVERB
         ECHO PLAYER You can't reach that.
      ENDIF
   ENDIF
ENDIF

IFPREVERB PUSH 6
   IFVAR FLAG1 = 1
      ECHO PLAYER You scrunch the pillow up and rest your head on it.
      ECHO OTHERS %N scrunches the pillow up and rests %h head on it.
      POSITION LAY
   ENDIF
ENDIF

IFPREVERB LAY -1
   CLEARVERB
   IFVAR POSITION = 0
      ECHO PLAYER You climb into bed.
      ECHO OTHERS %N climbs into bed.
      EQUAL FLAG1 1
   ENDIF
   IFVAR POSITION = 1
      IFVAR FLAG1 = 0
         ECHO PLAYER You lay back on the sofa.
         ECHO OTHERS %N lays back on the sofa.
      ENDIF
      IFVAR FLAG1 = 1
         ECHO PLAYER You lay back in bed.
         ECHO OTHERs %N lays back in bed.
      ENDIF
   ENDIF
   IFVAR POSITION = 2
      ECHO PLAYER You're already laying down.
   ENDIF
   IFVAR POSITION = 3
      ECHO PLAYER You climb into bed.
      ECHO OTHERS %N climbs into bed.
   ENDIF
   POSITION LAY
ENDIF

IFPREVERB SIT -1
   CLEARVERB
   IFVAR POSITION = 0
      ECHO PLAYER You take a seat and relax on the comfortable sofa.
      ECHO OTHERS %n takes a seat and relaxes on the comfortable sofa.
   ENDIF
   IFVAR POSITION = 1
      ECHO PLAYER You're already sitting.
   ENDIF
   IFVAR POSITION = 2
      ECHO PLAYER You sit up.
      ECHO OTHERS %N sits up.
   ENDIF
   IFVAR POSITION = 3
      ECHO PLAYER You take a seat and relax on the comfortable sofa.
      ECHO OTHERS %n takes a seat and relaxes on the comfortable sofa.
   ENDIF
   POSITION SIT
ENDIF

IFPREVERB KNEEL -1
   EQUAL FLAG1 0
ENDIF

IFPREVERB STAND -1
   EQUAL FLAG1 0
ENDIF
