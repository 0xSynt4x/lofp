   IFVAR FLAG4 ! 0
      STRCVT 0 FLAG4
      ECHO PLAYER The waitress comes by and quietly informs you that you owe $%0.00 on your tab.
   ENDIF
   IFVAR FLAG4 = 0
      ECHO PLAYER The waitress comes by whispers in your ear, "Honey, you're all paid up."
   ENDIF
   ECHO OTHERS The waitress comes by and whispers something to %N.
ENDIF

IFSAY BLUE_PLATE_SPECIAL
   ECHO PLAYER The waitress walks over carrying a tray with your blue plate special. She
   ECHO PLAYER indicates you should get the plate.
   ECHO OTHERS The waitress brings %n a blue plate special.
   NEWITEM 5 952 ADJ1=29 VAL5=9
   NEWPUT 5 408 VAL2=3 VAL5=9
   NEWPUT 5 407 VAL2=3 VAL5=9
   NEWPUT 5 762 VAL2=3 VAL5=9
   EQUAL FLAG1 666
   EQUAL ITEMVAL1 10
ENDIF

IFPREVERB SIT -1
   IFVAR POSITION ! 1
      CLEARVERB
      ECHO PLAYER You take a seat at the table.
      ECHO OTHERS %N takes a seat.
      POSITION SIT
   ENDIF
ENDIF

IFPREVERB LAY -1
   CLEARVERB
   ECHO PLAYER You think about laying on the floor, but change your mind when you realize
   ECHO PLAYER you'd probably just be thrown out.
ENDIF

IFPREVERB STAND -1
   IFVAR POSITION ! 0
      CLEARVERB
      POSITION STAND
      ECHO OTHERS %N excuses %hself from the table and stands up.
      ECHO PLAYER You excuse yourself from the table and stand up.
   ENDIF
ENDIF

IFPREVERB OUT -1
   IFVAR FLAG4 ! 0
      RANDOM DUMMY1 1 8 0
      IFVAR DUMMY1 ! 2
         CLEARVERB
         EQUAL ROUNDTIME 10
         ECHO PLAYER You try to dine and dash, but the glare from the waistress stops you cold.
         ECHO OTHERS You notice %n watching the door.
      ENDIF
      IFVAR DUMMY1 = 2
         ECHO PLAYER You take a chance and sneak out the door without paying.
      ENDIF
   ENDIF
ENDIF

IFVERB PAY -1
   CLEARVERB
   IFVAR FLAG4 = 0
      ECHO PLAYER The waitress informs you that you don't owe anything.
   ENDIF
   IFVAR FLAG4 ! 0
      STRCVT 0 FLAG4
      ECHO PLAYER You cough up the $%0 that's on your tab.
      ECHO OTHERS %N pays his tab.
      SUB WEALTH1 FLAG4
      EQUAL FLAG4 0
   ENDIF
ENDIF

IFPREVERB SMELL -1
   IFVAR ARCHNUM = -1
      CLEARVERB
      ECHO PLAYER Wafting through the air are a mixture of tantalizing, mouthwatering aromas.
      ECHO OTHERS %N seems to be enjoying the many aromas lingering in the air.
   ENDIF
ENDIF
;
;
;ROOMS 1941 - 1958 ARE IN THE SEASONAL SCRIPTS
;
;
;Sugar & Spice Bakery
NUMBER 1958
NAME Sugar & Spice Bakery
CAFE
MOVEMENT_ASTRAL
CHANNEL 777
REGION 1
INDOOR_FLOOR
FIXED_LIGHT

CALL 49

EXIT O 1949

ITEM 0 1677
PUT 0 475 ADJ1=902
PUT 0 81 ADJ1=32 ADJ2=306
PUT 0 803
PUT 0 661
ITEM 1 341
EXTEND 1 filled with cakes, cookies and pies
ITEM 2 720 ADJ1=347 ADJ2=187
PUT 2 973 ADJ1=292
ITEM 3 204 ADJ1=294
EXTEND 3 suspended from the ceiling on silver chains
ITEM 4 69
EXTEND 4 to the kitchen
ITEM 5 1595
EXTEND 5 of chococlate chip cookies
ITEM 6 1426 ADJ1=54 ADJ2=718
ITEM 7 91 ADJ1=294
ITEM 8 86 ADJ1=63 ADJ2=355

*DESCRIPTION_START
Two large shelves, filled with cakes, cookies and pies, line the cream colored
walls and flank the entrance to the kitchen behind a white marble counter that
presides over this comfortable room, a small sign hanging above it, suspended
from the ceiling on silver chains. A small table with a red and white checkered
tablecloth and a couple of comfortable wooden chairs sit in front of the large
bay window that looks out onto Liberty Lane. Several lush ferns are growing in
a shadowy corner of the bakery.
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 1
The glass shelves have been filled with a myriad of freshly baked cookies
and confections, rich cakes with thick luscious frosting, rows of freshly baked
breads and pies, pastries lightly dusted with powdered sugar and mouthwatering
chocolates.
*DESCRIPTION_END

*DESCRIPTION_START ITEM ON 1
The glass shelves have been filled with a myriad of freshly baked cookies
and confections, rich cakes with thick luscious frosting, rows of freshly baked
breads and pies, pastries lightly dusted with powdered sugar and mouthwatering
chocolates.
*DESCRIPTION_END

IFPREVERB LOOK 1
   ECHO OTHERS %N almost seems to droll as %s stares blankly at the shelves filled with baked goods, trying to decide which of the delicious treats %s will buy first.
ENDIF

*DESCRIPTION_START ITEM EXAM 2
The white marble counter has been worn smooth over the years, its faint black
veins standing out against the white background. While not too terribly dirty,
it has obviously not been used to the constant feather dusting of a certain
cockney florist, evident by small fingerprints and crumbs scattered about its
otherwise clean surface. A platter of chocolate chip cooks and a small silver
service bell rests on top of it.
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 3
The sign contains a price list for the various pastries being sold here.
*DESCRIPTION_END

*DESCRIPTION_START ITEM READ 3
You read the sign...

                     Welcome to the Sugar & Spice Bakery!

  Cakes (by the slice)......... $2.00   Pies (by the slice).......... $2.00
    Cheese, Chocolate, Coconut            Apple, Blueberry, Cherry,
    Coffee, Fruit                         Pumpkin

  Cookies...................... $1.00   Muffins...................... $1.00
    Chocolate, Oatmeal, Sugar             Banana, Blueberry, Bran,
                                          Strawberry

                                Miscellaneous
                      Strudel.................... $2.00
                      Danish..................... $1.00
                      Birthday Cake.............. $3.00
                      Toffee Bars................ $1.00
                      Honey bun.................. $1.00
                      Bagels..................... $1.00
                      Glass of Milk (chocolate).. $1.00
                      Coffee......................$1.00
                      Bread ..................... $2.00

                 Note: Some items may not yet be available.

*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 4
Through the entrance to the kitchen you can see someone busily preparing a
fresh batch of cookies.
*DESCRIPTION_END

IFTOUCH 4
   CLEARVERB
   ECHO PLAYER The entrance to the kitchen is on the other side of the counter.
ENDIF

*DESCRIPTION_START ITEM EXAM 5
The chocolate chip cookies on this platter look very delicious. Go ahead
and try one.
*DESCRIPTION_END

*DESCRIPTION_START ITEM ON 5
The chocolate chip cookies on this platter look very delicious. Go ahead
and try one.
*DESCRIPTION_END

*DESCRIPTION_START ITEM EXAM 6
The cookies are chock-full of chocolate chips. They are also free samples.
So go ahead and try one. Just don't make a pig of yourself.
*DESCRIPTION_END

IFPREVERB GET 6
   CLEARVERB
   ECHO PLAYER You remove a chocolate chip cookie from the platter.
   ECHO OTHERS %N removes a chocolate chip cookie from the platter.
   NEWITEM -1 790 ADJ1=54 ADJ2=718 VAL2=6
ENDIF

IFPREVERB EAT 6
   CLEARVERB
   ECHO PLAYER Don't be such an animal! At least remove the cookie from the platter before
   ECHO PLAYER you start trying to eat it.
ENDIF

*DESCRIPTION_START ITEM EXAM 7
The small table has been draped with a red and white checkered tablecloth.
Its location in front of the large bay window makes it a perfect place to sit
for a while, enjoying one of the bakery's many confections.
*DESCRIPTION_END

IFPREVERB GO 7
   CLEARVERB
   ECHO PLAYER You take a seat at the table in front of the bay window.
   ECHO OTHERS %N takes a seat at the table in front of the bay window.
   POSITION SIT
ENDIF

IFPREVERB LOOK -1
   IFVAR ARCHNUM = 475
      CLEARVERB
      ECHO PLAYER Crisp white gingham curtains are tied back with bows, providing a wonderful
      ECHO PLAYER view from the large bay window of the bakery.
   ENDIF
   IFVAR ARCHNUM = 81
      CLEARVERB
      ECHO PLAYER Within a recessed alcove, soft shadows and lush ferns barely conceal a brass
      ECHO PLAYER spiral staircase, the steps carved of pale white marble and worn soft from the
      ECHO PLAYER passage of both time and feet.
   ENDIF
   IFVAR ARCHNUM = 803
      CLEARVERB
      ECHO PLAYER The alcove is partially hidden by the ferns and totally cloaked in shadows.
   ENDIF
   IFVAR ARCHNUM = 661
      CLEARVERB
      ECHO PLAYER The ferns almost seem to try to hide a shadowy alcove.
   ENDIF
ENDIF

IFPREVERB GAZE -1
   IFVAR ARCHNUM = 475
      CLEARVERB
      ECHO PLAYER Off in the distance you can see a small pond surrounded by trees.
      ECHO OTHERS %N turns and gazes out the window.
   ENDIF
ENDIF

IFPREVERB LISTEN -1
   IFVAR ARCHNUM = -1
      CLEARVERB
      ECHO PLAYER You can barely make out the soft sound of someone singing from somewhere
      ECHO PLAYER in the back of the kitchen.
   ENDIF
ENDIF

IFPREVERB SEARCH -1
   CLEARVERB
   ECHO PLAYER You find an alcove partially hidden by shadows and the lush ferns.
ENDIF

IFPREVERB SNIFF -1
   CLEARVERB
   ECHO PLAYER The bakery is filled with mouthwatering scents of breads and cookies baking,
   ECHO PLAYER the pleasant smell of cinnamon and spices lingering in the air.
   ECHO OTHERS %N pauses for a moment, breathing in the delightful scents of the bakery.
ENDIF

IFPREVERB GO -1
   IFVAR ARCHNUM = 81
      CLEARVERB
      IFVAR INTNUM10 = 1959
         ECHO PLAYER As you make your way up the spiral stairway, you are greated with a welcoming
         ECHO PLAYER purr from within the shadows of the loft.
         ECHO OTHERS %P steps into the shadows and disappears.
         MOVEGROUP 1959
         AFFECT 1959
         ECHO OTHGROUP You hear the rustling of the ferns as %P steps out of the shadows of the alcove.
      ELSE
         ECHO PLAYER You hear a sudden low growl from above and decide you really don't want to
         ECHO PLAYER climb these stairs.
         ECHO OTHERS You hear a sudden low growl from above as %N steps away from the stairway.
      ENDIF
   ENDIF
   IFVAR ARCHNUM = 803
      CLEARVERB
      ECHO PLAYER You notice a brass spiral stairway recessed inside the alcove.
   ENDIF
ENDIF

IFPREVERB CLIMB -1
   IFVAR ARCHNUM = 81
      CLEARVERB
      IFVAR INTNUM10 = 1959
         ECHO PLAYER As you make your way up the spiral stairway, you are greated with a welcoming
         ECHO PLAYER purr from within the shadows of the loft.
         ECHO OTHERS %P steps into the shadows and disappears.
         MOVEGROUP 1959
         AFFECT 1959
         ECHO OTHGROUP You hear the rustling of the ferns as %P steps out of the shadows of the alcove.
      ELSE
         ECHO PLAYER You hear a sudden low growl from above and decide you really don't want to
         ECHO PLAYER climb these stairs.
         ECHO OTHERS You hear a sudden low growl from above as %N steps away from the stairway.
      ENDIF
   ENDIF
ENDIF

