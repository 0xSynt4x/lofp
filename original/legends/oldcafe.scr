IFPREVERB LOOK -1
   IFVAR ARCHNUM = 13
      CLEARVERB
      ECHO PLAYER It looks like your standard dart.
   ENDIF
ENDIF

IFPREVERB PLAY -1
   IFVAR ARCHNUM = 13
      CLEARVERB
      IFCARRY 13 -1
         EQUAL ROUNDTIME 3
         RANDOM DUMMY1 1 70 0
         IFVAR DUMMY1 < 41
            IFVAR DUMMY1 > 20
               SUB DUMMY1 20
            ENDIF
            STRCVT 0 DUMMY1
            ECHO PLAYER You throw the dart at the board... and it lands on %0!
            ECHO OTHERS %N throws the dart at the board... and it lands on %0!
            REMOVEITEM -1
         ENDIF
         IFVAR DUMMY1 > 40
            IFVAR DUMMY1 < 61
               SUB DUMMY1 40
               STRCVT 0 DUMMY1
               ECHO PLAYER You throw the dart at the board... and it lands on double %0!
               ECHO OTHERS %N throws the dart at the board... and it lands on double %0!
               REMOVEITEM -1
            ELSE
               IFVAR DUMMY1 < 66
                  ECHO PLAYER You throw the dart at the board... and it lands directly on the bull's-eye
                  ECHO PLAYER for 50 points!
                  ECHO OTHERS %N throws the dart at the board... and it lands directly on the bull's-eye for 50 points!
                  REMOVEITEM -1
               ELSE
                  IFVAR DUMMY1 > 66
                     ECHO PLAYER You throw the dart at the board... and miss entirely!
                     ECHO OTHERS %N throws the dart at the board... and misses entirely!
                     REMOVEITEM -1
                  ELSE
                     DAMAGEPLR SLASH 2 You throw the dart at the board, but hit yourelf instead!
                     ECHO OTHERS %N throws the dart at the board, but hits himself instead!%cGlancing blow. [2 Damage]
                  ENDIF
               ENDIF
            ENDIF
         ENDIF
      ELSE
         ECHO PLAYER You must be holding a dart to play it.
      ENDIF
   ENDIF
ENDIF

IFPREVERB GET -1
   IFVAR ARCHNUM = 13
      CLEARVERB
      IFCARRY 13 -1
         CLEARVERB
         ECHO PLAYER You already have a dart.
      ELSE
         NEWITEM -1 13 VAL5=9
         ECHO PLAYER You remove a dart from the board.
         ECHO OTHERS %N removes a dart from the board.
      ENDIF
   ENDIF
ENDIF

IFPREVERB GIVE -1
   IFVAR ARCHNUM = 13
      CLEARVERB
      ECHO PLAYER You can't do that. Just PLAY the dart.
   ENDIF
ENDIF

IFPREVERB OUT -1
   DISBAND
   IFCARRY 13 -1
      REMOVEITEM -1
      ECHO PLAYER As you get ready to leave, the dart you are carrying vanishes.
   ENDIF
ENDIF

IFVERB @LWHO -1
   ECHO PLAYER -- ------------------------------ ----- ------ ---------
ENDIF
