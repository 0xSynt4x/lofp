IFPREVERB WAVE -1
   IFVAR ARCHNUM = -1
      ECHO PLAYER A voice from nowhere intones, "Color and Material values have been reset."
      EQUAL FLAG1 -1
      EQUAL FLAG2 -1
      CLEARVERB
   ELSE
      EQUAL FLAG3 0
      IFVAR FLAG1 = 0
         EQUAL FLAG1 -1
      ENDIF
      IFVAR FLAG2 = 0
         EQUAL FLAG2 -1
      ENDIF
      IFVAR FLAG1 ! -1
         ADD FLAG3 5
      ENDIF
      IFVAR FLAG2 ! -1
         ADD FLAG3 5
      ENDIF
      IFVAR FLAG3 = 0
         CLEARVERB
         ECHO PLAYER A voice from nowhere intones, "You have selected no COLOR or MATERIAL."
      ELSE
         IFVAR WEALTH1 => 5
            EQUAL ITEMADJ1 FLAG1
            EQUAL ITEMADJ2 FLAG2
            EQUAL ITEMADJ3 -1
            EQUAL FLAG1 0
            EQUAL FLAG2 0
            SUB WEALTH1 5
         ELSE
            ECHO PLAYER You need at least $5 to use this service.
         ENDIF
      ENDIF
   ENDIF
ENDIF
