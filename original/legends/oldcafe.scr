;
;Holodeck Lobby
NUMBER 1920
NAME Holodeck Lobby
REGION 1
INDOOR_FLOOR
FIXED_LIGHT
CAFE
MOVEMENT_ASTRAL
CHANNEL 777

CALL 49

EXIT O 1919

ITEM 0 204
ITEM 1 65 VAL1=900 VAL2=1921 OPEN
EXTEND 1 leading to Holodeck 1
ITEM 2 65 VAL1=900 VAL2=1922 OPEN
EXTEND 2 leading to Holodeck 2
ITEM 3 65 VAL1=900 VAL2=1923 OPEN
EXTEND 3 leading to Holodeck 3

*DESCRIPTION_START
Pulsing pale blue light seeping from behind the translucent walls floods this
small lobby. The room is practically seamless, the walls and ceilings melding
together as if cast from a gigantic mold, save for the three doorways and the
exit which interrpts the perfect symmetry. A wide band of neon light replaces
the traditional doorframe, outlining each of the openings with a steady glow.
There is a small sign mounted on one wall.
*DESCRIPTION_END

*DESCRIPTION_START ITEM READ 0
Welcome to the Escapades Recreational Holodecks. Each Holodeck is programmed
with several theme rooms for you to choose from. To activate the holodecks, you
must enter them. To open the doors SAY "OPEN HOLODECK 1", "OPEN HOLODECK 2" or
"OPEN HOLODECK 3".
*DESCRIPTION_END

IFPREVERB OPEN 1
   CLEARVERB
   ECHO PLAYER As you try to open the door, a sign flashes briefly on the wall.
ENDIF

IFPREVERB OPEN 2
   CLEARVERB
   ECHO PLAYER As you try to open the door, a sign flashes briefly on the wall.
ENDIF

IFPREVERB OPEN 3
   CLEARVERB
   ECHO PLAYER As you try to open the door, a sign flashes briefly on the wall.
ENDIF

IFSAY RESET_HOLODECKS
   IFVAR INTNUM3 = 1
      IFVAR CHOSEN1 ! 0
         AFFECT CHOSEN1
         MOVEALL 1920
      ENDIF
      IFVAR CHOSEN1B ! 0
         AFFECT CHOSEN1B
         MOVEALL 1920
      ENDIF
      IFVAR CHOSEN2 ! 0
         AFFECT CHOSEN2
         MOVEALL 1920
      ENDIF
      IFVAR CHOSEN2B ! 0
         AFFECT CHOSEN2B
         MOVEALL 1920
      ENDIF
      IFVAR CHOSEN3 ! 0
         AFFECT CHOSEN3
         MOVEALL 1920
      ENDIF
      IFVAR CHOSEN3B ! 0
         AFFECT CHOSEN3B
         MOVEALL 1920
      ENDIF

      EQUAL INUSE1 0
      EQUAL INUSE2 0
      EQUAL INUSE3 0
      EQUAL CHOSEN1 0
      EQUAL CHOSEN1B 0
      EQUAL CHOSEN2 0
      EQUAL CHOSEN2B 0
      EQUAL CHOSEN3 0
      EQUAL CHOSEN3B 0

      ECHO ALL A soft voice from nowhere intones "All Holodecks have been reset by %N. Anyone participating inside a holodeck program has been transported to the Holodeck Lobby."
   ELSE
      ECHO ALL A soft voice from nowhere intones, "You do not have proper authorization for that command."
   ENDIF
ENDIF

IFSAY RESET_HOLODECK_1
   IFVAR INTNUM3 = 1
      IFVAR CHOSEN1 ! 0
         AFFECT CHOSEN1
         MOVEALL 1920
      ENDIF
      IFVAR CHOSEN1B ! 0
         AFFECT CHOSEN1B
         MOVEALL 1920
      ENDIF
      EQUAL INUSE1 0
      EQUAL CHOSEN1 0
      EQUAL CHOSEN1B 0
      ECHO ALL A soft voice from nowhere intones "Holodeck 1 has been reset by %N. Anyone participating inside a holodeck 1 program has been transported to the Holodeck Lobby."
   ELSE
      ECHO ALL A soft voice from nowhere intones, "You do not have proper authorization for that command."
   ENDIF
ENDIF

IFSAY RESET_HOLODECK_2
   IFVAR INTNUM3 = 1
      IFVAR CHOSEN2 ! 0
         AFFECT CHOSEN2
         MOVEALL 1920
      ENDIF
      IFVAR CHOSEN2B ! 0
         AFFECT CHOSEN2B
         MOVEALL 1920
      ENDIF
      EQUAL INUSE2 0
      EQUAL CHOSEN2 0
      EQUAL CHOSEN2B 0
      ECHO ALL A soft voice from nowhere intones "Holodeck 2 has been reset by %N. Anyone participating inside a holodeck 2 program has been transported to the Holodeck Lobby."
   ELSE
      ECHO ALL A soft voice from nowhere intones, "You do not have proper authorization for that command."
   ENDIF
ENDIF

IFSAY RESET_HOLODECK_3
   IFVAR INTNUM3 = 1
      IFVAR CHOSEN3 ! 0
         AFFECT CHOSEN3
         MOVEALL 1920
      ENDIF
      IFVAR CHOSEN3B ! 0
         AFFECT CHOSEN3B
         MOVEALL 1920
      ENDIF
      EQUAL INUSE3 0
      EQUAL CHOSEN3 0
      EQUAL CHOSEN3B 0
      ECHO ALL A soft voice from nowhere intones "Holodeck 3 has been reset by %N. Anyone participating inside a holodeck 3 program has been transported to the Holodeck Lobby."
   ELSE
      ECHO ALL A soft voice from nowhere intones, "You do not have proper authorization for that command."
   ENDIF
ENDIF

IFSAY OPEN_HOLODECK_1
   IFITEM 1 OPEN
      ECHO ALL A soft voice from nowhere responds, "Holodeck 1 is already open."
   ENDIF
   IFITEM 1 CLOSED
      IFVAR INUSE1 = 0
         ECHO ALL The door on the left side of the room opens.
         OPEN 1
         AFFECT 1921
         ECHO ALL The holodeck doors slide open.
         OPEN 2
      ENDIF
      IFVAR INUSE1 = 1
         ECHO ALL A soft voice from nowhere says, "Holodeck 1 is already in use."
         IFVAR INUSE2 = 0
            ECHO ALL Then adds, "Holodeck 2 is unused."
         ENDIF
         IFVAR INUSE3 = 0
            ECHO ALL Then adds, "Holodeck 3 is unused."
         ENDIF
         IFVAR INUSE2 = 1
            IFVAR INUSE3 = 1
               ECHO ALL  Then adds, "Holodecks 2 and 3 are also in use. Please try again later."
            ENDIF
         ENDIF
      ENDIF
   ENDIF
ENDIF

IFSAY OPEN_HOLODECK_2
   IFITEM 2 OPEN
      ECHO ALL A soft voice from nowhere responds, "Holodeck 2 is already open."
   ENDIF
   IFITEM 2 CLOSED
      IFVAR INUSE2 = 0
         ECHO ALL The door in the center of the room opens.
         UNLOCK 2
         OPEN 2
         AFFECT 1922
         ECHO ALL The holodeck doors slide open.
         OPEN 2
      ENDIF
      IFVAR INUSE2 = 1
         ECHO ALL A soft voice from nowhere says, "Holodeck 2 is already in use."
         IFVAR INUSE1 = 0
            ECHO ALL Then adds, "Holodeck 1 is unused."
         ENDIF
         IFVAR INUSE3 = 0
            ECHO ALL Then adds, "Holodeck 3 is unused."
         ENDIF
         IFVAR INUSE1 = 1
            IFVAR INUSE3 = 1
               ECHO ALL  Then adds, "Holodecks 1 and 3 are also in use. Please try again later."
            ENDIF
         ENDIF
      ENDIF
   ENDIF
ENDIF

IFSAY OPEN_HOLODECK_3
   IFITEM 3 OPEN
      ECHO ALL A soft voice from nowhere responds, "Holodeck 3 is already open."
   ENDIF
   IFITEM 3 CLOSED
      IFVAR INUSE3 = 0
         ECHO ALL The door on the right side of the room opens.
         OPEN 3
         AFFECT 1923
         ECHO ALL The holodeck doors slide open.
         OPEN 2
      ENDIF
      IFVAR INUSE3 = 1
         ECHO ALL A soft voice from nowhere says, "Holodeck 3 is already in use."
         IFVAR INUSE1 = 0
            ECHO ALL Then adds, "Holodeck 1 is unused."
         ENDIF
         IFVAR INUSE2 = 0
            ECHO ALL Then adds, "Holodeck 2 is unused."
         ENDIF
         IFVAR INUSE2 = 1
            IFVAR INUSE1 = 1
               ECHO ALL  Then adds, "Holodecks 1 and 2 are also in use. Please try again later."
            ENDIF
         ENDIF
      ENDIF
   ENDIF
ENDIF
