      ECHO OTHERS %N pulls the sheets up around %i.
   ENDIF
ENDIF

IFTOUCH 6
   IFVAR FLAG1 = 0
      IFVAR POSITION ! 0
         CLEARVERB
         ECHO PLAYER You can't reach that.
      ENDIF
   ENDIF
ENDIF

IFPREVERB PUSH 6
   IFVAR FLAG1 = 1
      ECHO PLAYER You scrunch the pillow up and rest your head on it.
      ECHO OTHERS %N scrunches the pillow up and rests %h head on it.
      POSITION LAY
   ENDIF
ENDIF

IFPREVERB LAY -1
   CLEARVERB
   IFVAR POSITION = 0
      ECHO PLAYER You climb into bed.
      ECHO OTHERS %N climbs into bed.
      EQUAL FLAG1 1
   ENDIF
   IFVAR POSITION = 1
      IFVAR FLAG1 = 0
         ECHO PLAYER You lay back on the sofa.
         ECHO OTHERS %N lays back on the sofa.
      ENDIF
      IFVAR FLAG1 = 1
         ECHO PLAYER You lay back in bed.
         ECHO OTHERs %N lays back in bed.
      ENDIF
   ENDIF
   IFVAR POSITION = 2
      ECHO PLAYER You're already laying down.
   ENDIF
   IFVAR POSITION = 3
      ECHO PLAYER You climb into bed.
      ECHO OTHERS %N climbs into bed.
   ENDIF
   POSITION LAY
ENDIF

IFPREVERB SIT -1
   CLEARVERB
   IFVAR POSITION = 0
      ECHO PLAYER You take a seat and relax on the comfortable sofa.
      ECHO OTHERS %n takes a seat and relaxes on the comfortable sofa.
   ENDIF
   IFVAR POSITION = 1
      ECHO PLAYER You're already sitting.
   ENDIF
   IFVAR POSITION = 2
      ECHO PLAYER You sit up.
      ECHO OTHERS %N sits up.
   ENDIF
   IFVAR POSITION = 3
      ECHO PLAYER You take a seat and relax on the comfortable sofa.
      ECHO OTHERS %n takes a seat and relaxes on the comfortable sofa.
   ENDIF
   POSITION SIT
ENDIF

IFPREVERB KNEEL -1
   EQUAL FLAG1 0
ENDIF

IFPREVERB STAND -1
   EQUAL FLAG1 0
ENDIF
